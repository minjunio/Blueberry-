        function calcSwap() {
            let from = document.getElementById('swap-asset-from').value; let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            if(from === to) { document.getElementById('swap-amt-to').value = amt; document.getElementById('swap-rate-text').innerText = `1 ${from} = 1 ${to}`; return; }
            let priceFromUsd = from === 'USDT' ? 1 : (livePrices[from+'USDT'] || 1); let priceToUsd = to === 'USDT' ? 1 : (livePrices[to+'USDT'] || 1);
            let toAmt = (amt * priceFromUsd) / priceToUsd;
            document.getElementById('swap-amt-to').value = toAmt.toFixed(6);
            document.getElementById('swap-rate-text').innerText = `1 ${from} ≈ ${(priceFromUsd/priceToUsd).toFixed(6)} ${to}`;
