<!DOCTYPE html>
<html lang="en">
<head>
    <title>Binance Pro Terminal - Gemini API Integration</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <link rel="icon" type="image/png" href="https://cryptologos.cc/logos/bnb-bnb-logo.png?v=029">
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <style>
        /* Fast, Bold, No-Glow Brutalist Theme */
        body { background: #0b0e11; color: #EAECEF; font-family: 'Inter', -apple-system, sans-serif; margin: 0; min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; }
        
        .panel { background: #181a20; border: 2px solid #2b3139; border-radius: 0px; }
        .overlay { background: #1e2329; border: 2px solid #2b3139; }
        
        .neo-input { background: #0b0e11; border: 2px solid #363c4e; color: white; outline: none; transition: border-color 0.1s; border-radius: 0px; }
        .neo-input:focus, .neo-input:hover { border-color: #F3BA2F; }
        
        .neo-btn { background: #2b3139; border: 2px solid #2b3139; color: #EAECEF; transition: all 0.1s; border-radius: 0px; text-transform: uppercase; font-weight: 900; }
        .neo-btn:hover { background: #F3BA2F; color: #000; border-color: #F3BA2F; transform: translate(-2px, -2px); box-shadow: 4px 4px 0px #0b0e11; }
        
        .icon-btn { display: flex; align-items: center; justify-content: center; background: transparent; border: 2px solid transparent; color: #848E9C; transition: 0.1s; }
        .icon-btn:hover { background: #EAECEF; color: #000; border-color: #EAECEF; }

        .text-muted { color: #848E9C; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; cursor: pointer; }
        input[type=range]:focus { outline: none; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 6px; background: #363c4e; }
        input[type=range]::-webkit-slider-thumb { height: 18px; width: 18px; background: #F3BA2F; -webkit-appearance: none; margin-top: -6px; border: 2px solid #000; }

        .modal-overlay { transition: opacity 0.1s; z-index: 9999; background: rgba(0,0,0,0.9); }
        .modal-content { transition: transform 0.1s; border: 4px solid #F3BA2F; box-shadow: 8px 8px 0px #000; }
        .modal-hidden { opacity: 0; pointer-events: none; }
        .modal-hidden .modal-content { transform: scale(0.98) translateY(5px); }
        .modal-active { opacity: 1; pointer-events: auto; }
        .modal-active .modal-content { transform: scale(1) translateY(0); }

        .tf-btn { padding: 4px 10px; border: 2px solid transparent; font-size: 10px; font-weight: 900; color: #848E9C; cursor: pointer; transition: 0.1s; }
        .tf-btn.active { background: #F3BA2F; color: #000; border-color: #F3BA2F; }
        .tf-btn:hover:not(.active) { color: #EAECEF; background: #2b3139; border-color: #EAECEF; }

        .dropdown-menu { transform-origin: top; transition: transform 0.1s, opacity 0.1s; z-index: 100; border: 2px solid #F3BA2F; }
        .dropdown-hidden { transform: scaleY(0); opacity: 0; pointer-events: none; }
        .dropdown-active { transform: scaleY(1); opacity: 1; pointer-events: auto; }

        .flash-up { animation: flashUp 0.2s; }
        .flash-down { animation: flashDown 0.2s; }
        @keyframes flashUp { 0% { background-color: #34d399; } 100% { background-color: transparent; } }
        @keyframes flashDown { 0% { background-color: #fb7185; } 100% { background-color: transparent; } }

        .spinner { border: 4px solid #2b3139; border-top-color: #F3BA2F; border-radius: 50%; animation: spin 0.6s linear infinite; }
        
        /* BOLD BRUTALIST BOXES */
        .bold-box { 
            background: #1e2329;
            border: 2px solid #363c4e;
            box-shadow: 4px 4px 0px #0b0e11;
            transition: all 0.1s ease-in-out;
            position: relative;
        }
        .bold-box:hover { 
            transform: translate(-4px, -4px); 
            border-color: #F3BA2F; 
            box-shadow: 8px 8px 0px #F3BA2F; 
            z-index: 10; 
        }
        .bold-box:active { transform: translate(0px, 0px); box-shadow: 0px 0px 0px #0b0e11; }

        .card-row { background: #0b0e11; border: 2px solid #2b3139; transition: all 0.1s; }
        .card-row:hover { border-color: #EAECEF; transform: translateX(4px); box-shadow: -4px 4px 0px #F3BA2F; }

        /* Fast, Sharp Mechanical Animations (No Glow) */
        .sol-flip { animation: coinFlip 2.5s infinite linear; transform-style: preserve-3d; }
        .dot-hard-pulse { animation: hardPulse 1s steps(2, end) infinite; }
        .eth-bounce { animation: mechanicalBounce 0.5s infinite alternate steps(4, end); }
        .btc-rock { animation: rockSide 2s infinite ease-in-out; }

        @keyframes spin { to { transform: rotate(360deg); } }
        @keyframes coinFlip { 0% { transform: perspective(400px) rotateY(0deg); } 100% { transform: perspective(400px) rotateY(360deg); } }
        @keyframes hardPulse { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.2); } }
        @keyframes mechanicalBounce { 0% { transform: translateY(0px); } 100% { transform: translateY(-6px); } }
        @keyframes rockSide { 0%, 100% { transform: rotate(-10deg); } 50% { transform: rotate(10deg); } }
    </style>
</head>
<body>

    <div class="w-full bg-[#0b0e11] border-b-2 border-[#2b3139] px-4 py-1.5 flex items-center gap-3 overflow-x-auto no-scrollbar shrink-0">
        <span class="text-[10px] uppercase font-black text-white tracking-widest flex-shrink-0 bg-[#2b3139] px-2 py-1">Wallets</span>
        <div id="wallet-tabs" class="flex gap-2 items-center flex-shrink-0"></div>
        <button onclick="addWallet()" class="text-[10px] uppercase font-black text-[#0b0e11] bg-[#F3BA2F] hover:bg-white transition flex-shrink-0 px-3 py-1 border-2 border-[#F3BA2F] hover:border-white">+ NEW</button>
    </div>

    <header class="flex flex-col shrink-0 z-50 sticky top-0 bg-[#181a20] border-b-2 border-[#2b3139]">
        <div class="flex justify-between items-center p-3 md:p-4 max-w-[1600px] w-full mx-auto">
            <div class="flex items-center gap-4 md:gap-6">
                <div class="flex items-center gap-2">
                    <img src="https://cryptologos.cc/logos/bnb-bnb-logo.svg?v=029" class="w-6 h-6">
                    <h2 class="text-lg font-black uppercase tracking-tight text-white hidden sm:block">BINANCE <span class="text-[#0b0e11] bg-[#F3BA2F] px-1">PRO</span></h2>
                </div>
                <div class="flex gap-1 bg-[#0b0e11] border-2 border-[#2b3139] p-0.5">
                    <button onclick="switchApp('terminal')" id="nav-terminal" class="px-4 py-1.5 text-[11px] font-black uppercase tracking-widest bg-[#F3BA2F] text-black">Terminal</button>
                    <button onclick="switchApp('wallet')" id="nav-wallet" class="px-4 py-1.5 text-[11px] font-black uppercase tracking-widest text-muted hover:text-white transition">Wallet</button>
                </div>
            </div>
            <div class="flex items-center gap-2 md:gap-3">
                <button onclick="toggleModal('history-modal')" class="neo-btn px-4 py-1.5 font-black text-[10px] uppercase tracking-widest hidden sm:flex">History</button>
                <button onclick="toggleModal('settings-modal')" class="icon-btn w-8 h-8" title="Settings">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                </button>
            </div>
        </div>
    </header>

    <div id="app-terminal" class="w-full">
        <main class="flex flex-col p-2 md:p-4 gap-4 w-full max-w-[1600px] mx-auto">
            
            <section class="panel p-4 md:p-6 flex flex-col relative overflow-hidden">
                <div class="flex items-center gap-2 mb-2 z-10">
                    <h1 class="text-[11px] font-black uppercase tracking-widest text-white bg-[#2b3139] px-2 py-1">Active Wallet Value</h1>
                </div>
                
                <div class="flex items-end gap-2 z-10 flex-wrap">
                    <span id="hero-currency-sym" class="text-3xl md:text-4xl lg:text-5xl font-black text-[#F3BA2F]">$</span>
                    <h2 id="hero-total-balance" class="text-4xl md:text-5xl lg:text-6xl font-black text-white font-mono tracking-tighter">0.00</h2>
                    <select id="currency-select" onchange="setCurrency(this.value)" class="bg-transparent text-[#F3BA2F] font-black text-sm md:text-base outline-none ml-2 cursor-pointer border-b-2 border-[#F3BA2F] pb-1 mb-2 uppercase hover:text-white transition"><option value="USD">USD</option><option value="AED">AED</option><option value="EUR">EUR</option><option value="GBP">GBP</option></select>

                    <div class="flex flex-col mb-1 md:mb-2 ml-4">
                        <span id="hero-daily-pnl" class="text-xs md:text-sm font-black text-green-400 tracking-wide bg-[#0b0e11] px-2 py-1 border-2 border-green-500">+ 0.00</span>
                    </div>
                </div>
                
                <div class="border-t-2 border-[#2b3139] pt-4 mt-4 z-10">
                    <div id="terminal-asset-list" class="flex flex-wrap gap-3"></div>
                </div>
            </section>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
                <div class="lg:col-span-9 flex flex-col gap-4">
                    
                    <div class="panel p-3 md:p-4 flex flex-col gap-3 border-l-8 border-l-[#F3BA2F]">
                        <div class="flex justify-between items-center border-b-2 border-[#2b3139] pb-2">
                            <div class="flex items-center gap-2">
                                <div class="w-3 h-3 bg-white animate-ping"></div>
                                <h3 class="text-[12px] font-black uppercase tracking-widest text-white">Gemini 1.5 Live API</h3>
                            </div>
                            <div class="flex gap-2">
                                <span id="api-status-text" class="text-[9px] font-black uppercase text-green-400 border-2 border-green-500 px-2 py-1">API CONNECTED</span>
                            </div>
                        </div>

                        <div class="grid grid-cols-3 md:grid-cols-6 gap-2 text-[10px] font-mono border-b-2 border-[#2b3139] pb-2">
                            <div class="flex flex-col"><span class="text-muted uppercase font-black">RSI (14)</span><span id="ai-rsi" class="text-white font-bold">--</span></div>
                            <div class="flex flex-col"><span class="text-muted uppercase font-black">SMA (20)</span><span id="ai-sma" class="text-white font-bold">--</span></div>
                            <div class="flex flex-col"><span class="text-muted uppercase font-black">Volatility</span><span id="ai-vol" class="text-white font-bold">--</span></div>
                            <div class="flex flex-col"><span class="text-muted uppercase font-black">Buy Vol 15m</span><span id="ai-b15" class="text-white font-bold">--</span></div>
                            <div class="flex flex-col"><span class="text-muted uppercase font-black">Buy Vol 1h</span><span id="ai-b1h" class="text-white font-bold">--</span></div>
                            <div class="flex flex-col"><span class="text-muted uppercase font-black">Whale Sent.</span><span id="ai-whale" class="text-white font-bold">--</span></div>
                        </div>

                        <div class="flex flex-col md:flex-row gap-3">
                            
                            <div class="flex-1 grid grid-cols-2 gap-3">
                                <div class="bold-box p-3 flex flex-col justify-between">
                                    <div class="flex justify-between items-center mb-2 border-b-2 border-[#363c4e] pb-1">
                                        <span class="text-[10px] text-white font-black uppercase tracking-widest">Short-Term AI</span>
                                        <span id="ai-short-conf" class="text-[9px] font-mono font-black text-[#F3BA2F] bg-[#0b0e11] px-1">0% CONF</span>
                                    </div>
                                    <div class="flex justify-between items-end mt-1">
                                        <div class="flex flex-col">
                                            <span id="ai-short-signal" class="text-sm font-black uppercase text-white">SYNCING...</span>
                                            <span id="ai-short-targets" class="text-[9px] text-[#848E9C] font-mono font-bold mt-1">SL: -- | TP: --</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="bold-box p-3 flex flex-col justify-between">
                                    <div class="flex justify-between items-center mb-2 border-b-2 border-[#363c4e] pb-1">
                                        <span class="text-[10px] text-white font-black uppercase tracking-widest">Macro Trend AI</span>
                                        <span id="ai-long-conf" class="text-[9px] font-mono font-black text-[#F3BA2F] bg-[#0b0e11] px-1">0% CONF</span>
                                    </div>
                                    <div class="flex justify-between items-end mt-1">
                                        <div class="flex flex-col">
                                            <span id="ai-long-signal" class="text-sm font-black uppercase text-white">SYNCING...</span>
                                            <span id="ai-long-targets" class="text-[9px] text-[#848E9C] font-mono font-bold mt-1">SL: -- | TP: --</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="w-full md:w-64 bold-box p-3 flex flex-col justify-center">
                                <span class="text-[10px] uppercase font-black text-black bg-[#F3BA2F] px-1 mb-2 border-2 border-transparent w-max">AI Paper Trading</span>
                                <div class="flex justify-between items-center font-mono text-sm font-black">
                                    <span id="ai-paper-pnl" class="text-white">$0.00</span>
                                    <span id="ai-paper-winrate" class="text-[#848E9C]">W: 0%</span>
                                </div>
                                <span id="ai-active-papers" class="text-[9px] text-white mt-1 font-mono font-bold">0 ACTIVE TRADES</span>
                            </div>

                        </div>
                    </div>

                    <div class="panel p-4 md:p-6 flex flex-col relative min-h-[55vh]" id="main-chart-wrapper">
                        <div class="flex justify-between items-start z-20 border-b-2 border-[#2b3139] pb-3 mb-2">
                            <div class="relative w-fit">
                                <button onclick="toggleDropdown('term-dropdown')" class="neo-input px-3 py-2 flex items-center gap-3 w-[150px] md:w-48 bg-[#0b0e11] border-2 border-[#F3BA2F]">
                                    <img id="term-logo" src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-6 h-6 bg-white border-2 border-black">
                                    <span id="term-text" class="font-black text-base uppercase text-white tracking-wide">BTC/USDT</span>
                                    <svg class="w-4 h-4 ml-auto text-[#F3BA2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                <div id="term-dropdown" class="absolute top-full left-0 mt-1 w-48 bg-[#1e2329] border-2 border-[#F3BA2F] py-1 dropdown-menu dropdown-hidden z-50 overflow-y-auto max-h-[300px] no-scrollbar"></div>
                            </div>

                            <div class="flex flex-wrap bg-[#0b0e11] p-1 border-2 border-[#2b3139] justify-end max-w-[50%] sm:max-w-full">
                                <div class="tf-btn" onclick="setTimeframe('live')" id="tf-live">LIVE</div>
                                <div class="tf-btn active" onclick="setTimeframe('5m')" id="tf-5m">5m</div>
                                <div class="tf-btn" onclick="setTimeframe('1h')" id="tf-1h">1H</div>
                                <div class="tf-btn" onclick="setTimeframe('7d')" id="tf-7d">7D</div>
                                <div class="tf-btn" onclick="setTimeframe('1y')" id="tf-1y">1Y</div>
                            </div>
                        </div>

                        <div class="flex flex-wrap justify-between gap-4 sm:gap-6 mt-2 z-10 items-end">
                            <div class="flex-grow flex justify-end items-end pointer-events-none min-w-0">
                                <h2 id="main-price" class="text-4xl sm:text-6xl md:text-7xl font-black text-white font-mono tracking-tighter leading-none truncate text-right max-w-full transition-colors duration-100">--</h2>
                            </div>
                        </div>

                        <div class="flex-grow mt-4 relative w-full h-full min-h-[300px] cursor-crosshair overflow-hidden border-2 border-[#2b3139] bg-[#0b0e11]" id="canvas-container">
                            <canvas id="custom-chart" class="absolute inset-0 w-full h-full"></canvas>
                        </div>
                    </div>

                    <div class="panel flex flex-col h-[260px]">
                        <div class="flex flex-col p-3 border-b-2 border-[#2b3139] shrink-0 bg-[#1e2329] gap-3">
                            <div class="flex justify-between items-center">
                                <div class="flex gap-4 items-center">
                                    <h3 class="text-[11px] font-black uppercase tracking-widest text-black bg-[#F3BA2F] px-2 py-1">Order Flow Logs</h3>
                                </div>
                            </div>
                            <div class="w-full flex items-center gap-2">
                                <span class="text-[11px] font-black text-green-400 w-8" id="ratio-buy-text">50%</span>
                                <div class="flex-grow h-4 bg-[#0b0e11] border-2 border-[#2b3139] flex overflow-hidden">
                                    <div id="ratio-buy-bar" class="h-full bg-green-500 transition-all duration-300" style="width: 50%"></div>
                                    <div id="ratio-sell-bar" class="h-full bg-pink-500 transition-all duration-300" style="width: 50%"></div>
                                </div>
                                <span class="text-[11px] font-black text-pink-400 w-8 text-right" id="ratio-sell-text">50%</span>
                            </div>
                        </div>
                        <div class="flex-grow overflow-y-auto no-scrollbar p-2 flex flex-col gap-1" id="below-chart-log">
                            <div class="text-[10px] font-bold text-muted text-center py-4 uppercase">Awaiting on-chain blocks...</div>
                        </div>
                    </div>

                    <div class="panel flex flex-col min-h-[30vh]">
                        <div class="flex justify-between items-center p-3 border-b-2 border-[#2b3139] shrink-0 bg-[#1e2329]">
                            <h3 class="text-[11px] font-black uppercase tracking-widest text-black bg-white px-2 py-1">Manual & AI Trades History</h3>
                        </div>
                        <div class="flex-grow overflow-y-auto no-scrollbar p-3 space-y-3 bg-[#0b0e11]" id="orders-body"></div>
                    </div>
                </div>

                <div class="lg:col-span-3 flex flex-col gap-4">
                    <div class="panel p-4 flex flex-col relative z-10">
                        <div class="flex justify-between items-center mb-4 border-b-2 border-[#2b3139] pb-2">
                            <h3 class="text-[12px] font-black uppercase tracking-widest text-white">Execution</h3>
                            <select id="trade-wallet-select" onchange="switchWallet(this.value)" class="bg-[#2b3139] text-white border-none rounded-none px-2 py-1 text-[10px] uppercase font-black outline-none cursor-pointer"></select>
                        </div>
                        
                        <div class="flex gap-2 mb-5">
                            <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 text-[11px] font-black uppercase tracking-widest bg-green-500 text-black border-2 border-black">LONG / BUY</button>
                            <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 text-[11px] font-black uppercase tracking-widest bg-[#1e2329] text-white border-2 border-[#2b3139]">SHORT / SELL</button>
                        </div>

                        <div class="space-y-5">
                            <div>
                                <div class="flex justify-between mb-1">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-white">Margin (USDT)</label>
                                    <span class="text-[10px] font-black text-black bg-[#F3BA2F] px-1 cursor-pointer border border-black" onclick="setMax()">MAX</span>
                                </div>
                                <input type="number" id="trade-margin" placeholder="0.00" class="w-full neo-input p-3 text-lg font-black font-mono text-center">
                            </div>

                            <div>
                                <div class="flex justify-between mb-2">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-white">Leverage</label>
                                    <span class="text-[10px] font-black text-white bg-[#2b3139] px-2 py-0.5 border-2 border-[#363c4e]"><span id="lev-val">10</span>x</span>
                                </div>
                                <input type="range" id="trade-lev" min="1" max="100" value="10" class="w-full">
                            </div>

                            <div class="p-3 bg-[#1e2329] border-2 border-[#363c4e] space-y-2">
                                <div class="flex justify-between text-[10px] font-black uppercase">
                                    <span class="text-white">Available</span>
                                    <span class="text-white font-mono" id="ui-avail">0.00</span>
                                </div>
                                <div class="flex justify-between text-[10px] font-black uppercase border-t-2 border-[#2b3139] pt-2">
                                    <span class="text-white">Position Size</span>
                                    <span class="text-[#F3BA2F] font-mono" id="ui-size">0.00</span>
                                </div>
                            </div>
                        </div>

                        <button onclick="executeOrder()" id="btn-execute" class="mt-4 w-full py-4 font-black uppercase tracking-[0.1em] text-[13px] bg-green-500 text-black border-2 border-black hover:bg-green-400 transition">
                            EXECUTE LONG
                        </button>
                    </div>

                    <div class="panel p-4 flex flex-col flex-grow relative z-10">
                        <div class="flex justify-between items-center mb-4 border-b-2 border-[#2b3139] pb-2">
                            <h3 class="text-[11px] font-black uppercase tracking-widest text-white">On-Chain Alpha</h3>
                            <select id="alpha-tf-select" onchange="setAlphaTimeframe(this.value)" class="bg-[#1e2329] text-white border-2 border-[#363c4e] px-2 py-1 text-[9px] uppercase font-black outline-none cursor-pointer">
                                <option value="86400000" selected>24 Hours</option>
                            </select>
                        </div>
                        
                        <div class="mb-4 bg-[#1e2329] p-2 border-2 border-[#2b3139]">
                            <h4 class="text-[10px] font-black uppercase tracking-widest text-green-400 mb-2 border-b-2 border-[#2b3139] pb-1">Top Purchases</h4>
                            <div id="ui-top-buys" class="space-y-1"></div>
                        </div>
                        
