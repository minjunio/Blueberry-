            let availCoins = ['USDT'];
            for(const c in state.manualAssets) { if(state.manualAssets[c] > 0) availCoins.push(c); }

            let allCoins = ['USDT'];
            ASSETS.forEach(a => { if(a.coin !== 'USDT') allCoins.push(a.coin); });

            const createItem = (coin, onClickStr) => {
                const icon = ASSETS.find(x => x.coin === coin)?.icon || (coin==='USDT'?'tether-usdt-logo.svg?v=029':`https://ui-avatars.com/api/?name=${coin}&background=181a20&color=F3BA2F&rounded=true`);
