        async function fetch24hStats() {
            try {
                let res = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbol=${ui.pair}`);
                let data = await res.json();
                document.getElementById('stat-high').innerText = parseFloat(data.highPrice).toLocaleString();
                document.getElementById('stat-low').innerText = parseFloat(data.lowPrice).toLocaleString();
            } catch(e){}
        }

        // Fast interval update for both Terminal Hero & Wallet Math
        function updateWalletSystem() {
            let totalUsdValue = state.usdtBalance;

            state.orders.forEach(o => {
                let livePrice = livePrices[o.pair] || o.entry;
                totalUsdValue += o.margin; 
                let pnl = o.side === 'buy' ? ((o.units * livePrice) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * livePrice));
                totalUsdValue += pnl;
            });

            for (const [coin, amt] of Object.entries(state.manualAssets)) {
                let valUsd = amt * (livePrices[coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
            }
            
            state.stakes.forEach(s => {
                let valUsd = s.amt * (livePrices[s.coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
            });

            let rate = FX_RATES[state.currency] || 1;
            let sym = FX_SYM[state.currency] || '$';
            let localTotal = totalUsdValue * rate;

            // Terminal Hero
            document.getElementById('hero-currency-sym').innerText = sym;
            document.getElementById('hero-total-balance').innerText = localTotal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            
            let dPnlUsd = totalUsdValue - state.startOfDayValue;
            let dPnlLocal = dPnlUsd * rate;
            let dRoi = (dPnlUsd / (state.startOfDayValue || 1)) * 100;
            const pnlEl = document.getElementById('hero-daily-pnl');
            const roiEl = document.getElementById('hero-daily-roi');
            
            pnlEl.innerText = `${dPnlLocal >= 0 ? '+' : ''}${sym}${dPnlLocal.toFixed(2)}`;
            pnlEl.className = `text-sm font-black tracking-wide drop-shadow ${dPnlLocal >= 0 ? 'up-color' : 'down-color'}`;
            roiEl.innerText = `${dPnlLocal >= 0 ? '+' : ''}${dRoi.toFixed(2)}% Today`;
            roiEl.className = `text-[10px] font-black px-2 py-0.5 rounded w-fit mt-1 ml-auto border shadow-sm ${dPnlLocal >= 0 ? 'up-color bg-[#0ecb81]/10 border-[#0ecb81]/20' : 'down-color bg-[#f6465d]/10 border-[#f6465d]/20'}`;
            
            state.lastRunTime = Date.now(); 

            // Update Wallet specific elements if active
            if(document.getElementById('app-wallet').style.display === 'block') {
                document.getElementById('wallet-currency-sym').innerText = sym;
                document.getElementById('wallet-total-bal').innerText = localTotal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
                updateWalletApp();
            }
        }

        // --- WALLET APP LOGIC ---
        function toggleWalletAssets() {
            walletAssetsExpanded = !walletAssetsExpanded;
            updateWalletApp();
        }

        function updateWalletApp() {
            let totalUsdValue = state.usdtBalance;
            let rows = [];
            let rate = FX_RATES[state.currency] || 1; let sym = FX_SYM[state.currency] || '$';

            const addRow = (coin, amt, isStake) => {
                let valUsd = coin === 'USDT' ? amt : amt * (livePrices[coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
                rows.push({ coin, amt, valUsd, isStake });
            };

            addRow('USDT', state.usdtBalance, false);
            for (const [coin, amt] of Object.entries(state.manualAssets)) addRow(coin, amt, false);
            state.stakes.forEach(s => addRow(s.coin, s.amt, true));

            rows.sort((a,b) => b.valUsd - a.valUsd);
            
            // Render Square Boxes
            const boxContainer = document.getElementById('wallet-boxes');
            let displayRows = walletAssetsExpanded ? rows : rows.slice(0, 4);
            
            boxContainer.innerHTML = displayRows.map(r => {
                let valLocal = r.valUsd * rate;
                const icon = ASSETS.find(x => x.coin === r.coin)?.icon || `https://ui-avatars.com/api/?name=${r.coin}&background=181a20&color=F3BA2F&rounded=true`;
                const imgSrc = icon.includes('ui-avatars') ? icon : `https://cryptologos.cc/logos/${icon}`;
                
                return `
                <div class="bg-[#181a20] border border-[#2b3139] hover:border-[#F3BA2F]/50 p-4 rounded-xl flex flex-col justify-between aspect-square transition shadow-lg relative overflow-hidden group">
                    <div class="absolute inset-0 bg-gradient-to-br from-[#F3BA2F]/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    ${r.isStake ? '<div class="absolute top-0 right-0 bg-[#0ecb81] text-[#0b0e11] text-[8px] font-black px-2 py-1 rounded-bl-lg shadow-sm">STAKED</div>' : ''}
                    <div class="flex justify-between items-start relative z-10">
                        <img src="${imgSrc}" class="w-10 h-10 rounded-full bg-[#0b0e11] p-1 border border-[#2b3139]">
                        <span class="text-white font-black text-lg">${r.coin}</span>
                    </div>
                    <div class="mt-4 relative z-10">
                        <p class="text-gray-400 text-[10px] uppercase font-bold mb-1">Balance</p>
                        <p class="text-white font-mono text-sm sm:text-base md:text-lg tracking-tight">${r.amt.toLocaleString(undefined, {maximumFractionDigits: 4})}</p>
                        <p class="text-[#F3BA2F] font-mono text-xs mt-1 font-bold">${sym}${valLocal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</p>
                    </div>
                </div>`;
            }).join('');

            const showMoreBtn = document.getElementById('wallet-show-more');
            if (rows.length > 4) {
                showMoreBtn.classList.remove('hidden');
                showMoreBtn.innerText = walletAssetsExpanded ? "Show Less" : `Show All (${rows.length})`;
            } else {
                showMoreBtn.classList.add('hidden');
            }

            // Update Stake Table
            let sBody = document.getElementById('active-stakes-body');
            if(state.stakes.length === 0) sBody.innerHTML = `<tr><td colspan="4" class="text-center text-muted italic text-[9px]">No active stakes.</td></tr>`;
            else {
                sBody.innerHTML = state.stakes.map(s => {
                    let d = (Date.now() - s.time) / 86400000; // days
                    let earned = s.amt * (s.apr / 100) * (d / 365);
                    const icon = ASSETS.find(x => x.coin === s.coin)?.icon || `https://ui-avatars.com/api/?name=${s.coin}&background=181a20&color=F3BA2F&rounded=true`;
                    const imgSrc = icon.includes('ui-avatars') ? icon : `https://cryptologos.cc/logos/${icon}`;

                    return `
                    <tr>
                        <td>
                            <div class="flex items-center gap-3">
                                <img src="${imgSrc}" class="w-6 h-6 rounded-full bg-[#0b0e11] p-1 border border-[#2b3139]">
                                <span class="text-white font-black">${s.coin}</span>
                            </div>
                        </td>
                        <td class="text-white font-mono">${s.amt.toFixed(4)}</td>
                        <td class="text-[#0ecb81] font-mono font-black">${s.apr}%</td>
                        <td class="text-right font-mono text-[#F3BA2F]">+${earned.toFixed(6)} <span class="text-muted text-[8px]">${s.coin}</span></td>
                    </tr>`;
                }).join('');
            }
        }

        function buildStakingGrid() {
            const grid = document.getElementById('staking-grid');
