                html += `<div class="bold-box p-3 flex justify-between items-center"><div class="flex items-center gap-2">${badge}${getIconImg(coin, 'w-5 h-5')}<span class="text-white font-black text-[10px] uppercase">${h.pair}</span></div><span class="font-black font-mono text-[11px] ${h.pnl>=0?'text-green-400':'text-pink-500'} bg-[#0b0e11] px-2 py-1 border border-[#363c4e]">${h.pnl>=0?'+':''}$${h.pnl.toFixed(2)}</span></div>`; 
            });
            container.innerHTML = html || `<div class="p-6 text-center text-white text-xs uppercase font-black border-4 border-[#2b3139] border-dashed">NO HISTORY</div>`;
        }

        // --- WALLET APP ---
        function updateWalletApp() {
            let totalUsdValue = w().usdtBalance; let rows = []; let rate = FX_RATES[appState.currency] || 1; let sym = FX_SYM[appState.currency] || '$';
            const addRow = (coin, amt) => { let valUsd = coin === 'USDT' ? amt : amt * (livePrices[coin + 'USDT'] || 0); totalUsdValue += valUsd; rows.push({ coin, amt, valUsd }); };
            addRow('USDT', w().usdtBalance); for (const [coin, amt] of Object.entries(w().manualAssets)) addRow(coin, amt); rows.sort((a,b) => b.valUsd - a.valUsd);
            
            let gridHtml = ''; 
            for(let i=0; i<rows.length; i++) {
                let r = rows[i]; let valLocal = r.valUsd * rate;
                gridHtml += `<div class="bold-box p-4 flex flex-col items-center justify-center text-center gap-2 bg-[#181a20]"><div class="w-12 h-12 mb-2">${getIconImg(r.coin, 'w-full h-full')}</div><span class="font-black text-white text-sm uppercase tracking-widest">${r.coin}</span><span class="font-mono text-[#848E9C] font-bold text-[11px]">${r.amt.toLocaleString(undefined, {maximumFractionDigits: 4})}</span><span class="font-mono text-black font-black mt-auto bg-[#F3BA2F] w-full py-2 border-2 border-black text-xs">${sym}${valLocal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span></div>`;
            }
            document.getElementById('wallet-square-grid').innerHTML = gridHtml;
        }

        function setUsdt() { const amt = parseFloat(document.getElementById('add-usdt-input').value); if(amt >= 0) { w().usdtBalance = amt; w().startOfDayValue = amt; document.getElementById('add-usdt-input').value = ''; saveState(); toggleModal('settings-modal'); updateWalletSystem(); } }
        function updateUI() { document.getElementById('ui-avail').innerText = w().usdtBalance.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT'; renderAIStats(); }
        function saveState() { localStorage.setItem('gemini_api_quant', JSON.stringify(appState)); updateUI(); }

        init();
    </script>
</body>
</html>
