            wallets: [{ id: 1, name: "Main API", usdtBalance: 25000.00, startOfDayValue: 25000.00, orders: [], history: [], manualAssets: { 'BTC': 0.25, 'SOL': 45.0, 'DOT': 300 }, stakes: [] }]
