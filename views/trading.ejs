        // --- 1. STATE & ROUTING ---
        function switchApp(appName) {
            document.getElementById('app-terminal').style.display = appName === 'terminal' ? 'block' : 'none';
            document.getElementById('app-wallet').style.display = appName === 'wallet' ? 'block' : 'none';
            
            document.getElementById('nav-terminal').className = appName === 'terminal' ? "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-[#F3BA2F] text-[#0b0e11] transition shadow-[0_0_10px_rgba(243,186,47,0.3)]" : "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-white transition";
            document.getElementById('nav-wallet').className = appName === 'wallet' ? "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-[#F3BA2F] text-[#0b0e11] transition shadow-[0_0_10px_rgba(243,186,47,0.3)]" : "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-white transition";
            
            if(appName === 'terminal') setupCanvas(); 
            if(appName === 'wallet') updateWalletApp();
