        function renderGlobalLogs() {
            const feed = document.getElementById('below-chart-log'); let filtered = state.globalTradeLogs.filter(l => l.pair === ui.pair);
            if(ui.logFilter === 'whales') filtered = filtered.filter(l => l.usdVal >= 25000);
