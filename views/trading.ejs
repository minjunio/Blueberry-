    <div id="history-modal" class="fixed inset-0 z-[100] modal-overlay modal-hidden flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="modal-content b-panel w-full max-w-lg p-0 relative max-h-[80vh] flex flex-col overflow-hidden">
            <div class="p-4 border-b border-[#2b3139] flex justify-between items-center bg-[#0b0e11]">
                <h2 class="text-sm font-bold text-white">Closed PnL History</h2>
                <button onclick="toggleModal('history-modal')" class="text-muted hover:text-white">✕</button>
            </div>
            <div class="flex-grow overflow-y-auto no-scrollbar p-2">
                <table class="w-full text-left">
                    <thead><tr><th>Symbol</th><th class="text-right">Realized PnL</th></tr></thead>
                    <tbody id="history-body" class="font-mono"></tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // --- 1. CORE STATE & ROUTING ---
        const ASSETS = [
            { id: 'BTCUSDT', name: 'BTC/USDT', icon: 'bitcoin-btc-logo.svg?v=029', coin: 'BTC' }, 
            { id: 'ETHUSDT', name: 'ETH/USDT', icon: 'ethereum-eth-logo.svg?v=029', coin: 'ETH' },
            { id: 'SOLUSDT', name: 'SOL/USDT', icon: 'solana-sol-logo.svg?v=029', coin: 'SOL' }, 
            { id: 'BNBUSDT', name: 'BNB/USDT', icon: 'bnb-bnb-logo.svg?v=029', coin: 'BNB' },
            { id: 'XRPUSDT', name: 'XRP/USDT', icon: 'xrp-xrp-logo.svg?v=029', coin: 'XRP' },
            { id: 'DOGEUSDT', name: 'DOGE/USDT', icon: 'dogecoin-doge-logo.svg?v=029', coin: 'DOGE' }, 
            { id: 'ADAUSDT', name: 'ADA/USDT', icon: 'cardano-ada-logo.svg?v=029', coin: 'ADA' },
            { id: 'DOTUSDT', name: 'DOT/USDT', icon: 'polkadot-new-dot-logo.svg?v=029', coin: 'DOT' }, 
            { id: 'MATICUSDT', name: 'MATIC/USDT', icon: 'polygon-matic-logo.svg?v=029', coin: 'MATIC' },
            { id: 'AVAXUSDT', name: 'AVAX/USDT', icon: 'avalanche-avax-logo.svg?v=029', coin: 'AVAX' }
        ];

        const STAKING_OPTS = [
            { id: 'ATOM', apr: 14.5, tag: 'High Yield' }, { id: 'DOT', apr: 11.8, tag: 'Hot' },
            { id: 'SOL', apr: 8.5, tag: 'Popular' }, { id: 'AVAX', apr: 6.5, tag: 'Stable' },
            { id: 'ETH', apr: 4.2, tag: 'Secure' }, { id: 'ADA', apr: 3.5, tag: 'Safe' }
        ];

        const FX_RATES = { USD: 1, AED: 3.67, EUR: 0.92, GBP: 0.79 };
        const FX_SYM = { USD: '$', AED: 'د.إ', EUR: '€', GBP: '£' };

        const defaultAI = `// --- AI Logic (Return BUY/SELL/NEUTRAL) ---\nlet score = 0;\nif (rsi > 70) score -= 2;\nif (rsi < 30) score += 2;\nif (score > 1) return "STRONG BUY";\nif (score < -1) return "STRONG SELL";\nreturn "NEUTRAL";`;

        let state = JSON.parse(localStorage.getItem('bpro_state_v2')) || {
            usdtBalance: 15000.00, startOfDayValue: 15000.00, orders: [], history: [], manualAssets: { 'BTC': 0.15, 'ETH': 3.0, 'DOT': 150 }, 
            stakes: [], aiLogic: defaultAI, currency: 'USD', globalTradeLogs: [], lastRunTime: Date.now()
        };
        
        let livePrices = {}; 
        let ui = { side: 'buy', pair: 'BTCUSDT', price: 0, lastPrice: 0, lev: 10, timeframe: '5m', chartData: [] };
        let wsTicker, chartCtx;
        let canvasHoverPos = null; 
        let isShowingAllAssets = false;

        function switchApp(appName) {
            document.getElementById('app-terminal').style.display = appName === 'terminal' ? 'block' : 'none';
            document.getElementById('app-wallet').style.display = appName === 'wallet' ? 'block' : 'none';
            
            document.getElementById('nav-terminal').className = appName === 'terminal' ? "px-3 py-1.5 rounded text-[11px] font-bold text-black bg-gold transition" : "px-3 py-1.5 rounded text-[11px] font-bold text-muted hover:text-white transition";
            document.getElementById('nav-wallet').className = appName === 'wallet' ? "px-3 py-1.5 rounded text-[11px] font-bold text-black bg-gold transition" : "px-3 py-1.5 rounded text-[11px] font-bold text-muted hover:text-white transition";
            
            if(appName === 'terminal') { setTimeout(setupCanvas, 50); drawChart(); }
            if(appName === 'wallet') updateWalletApp();
        }

        function init() {
            document.getElementById('wallet-currency').value = state.currency || 'USD';
            buildTerminalDropdown(); buildNativeSelects();
            document.getElementById('ai-logic-editor').value = state.aiLogic;
            setupCanvas();
            connectGlobalTickerStream(); // Fixes "prices don't show"
            triggerPairChange(); 
            updateUI(); renderOrders(); renderHistory(); buildStakingGrid();
            setInterval(updateWalletSystem, 1000);
            updateLev(document.getElementById('trade-lev')); // Set initial slider visual
        }

        // --- 2. WEBSOCKET (FIXED FOR ALL PRICES) ---
        function connectGlobalTickerStream() {
            // !ticker@arr sends all market prices, ensuring we never have missing data for custom/manual assets
            if(wsTicker) wsTicker.close();
            wsTicker = new WebSocket('wss://stream.binance.com:9443/ws/!ticker@arr');
            wsTicker.onmessage = (e) => {
                const data = JSON.parse(e.data);
                data.forEach(t => {
                    livePrices[t.s] = parseFloat(t.c);
                    if(t.s === ui.pair) processMainTick(parseFloat(t.c));
                });
            };
            wsTicker.onclose = () => setTimeout(connectGlobalTickerStream, 3000);
            wsTicker.onerror = () => wsTicker.close();
        }

        // --- 3. UI HELPERS ---
        function setCurrency(c) {
            state.currency = c; 
            document.getElementById('wallet-currency').value = c;
            saveState(); updateWalletSystem(); updateWalletApp();
        }

        function toggleDropdown(id) {
            const el = document.getElementById(id);
            if(el) { el.classList.toggle('dropdown-hidden'); el.classList.toggle('dropdown-active'); }
        }

        document.addEventListener('click', (e) => {
            const drop = document.getElementById('term-dropdown');
            if(drop && !e.target.closest('#term-dropdown') && !e.target.closest(`[onclick="toggleDropdown('term-dropdown')"]`)) {
                drop.classList.add('dropdown-hidden'); drop.classList.remove('dropdown-active');
            }
        });

        function toggleModal(id) {
            const el = document.getElementById(id);
            el.classList.toggle('modal-hidden'); el.classList.toggle('modal-active');
            if(id === 'swap-modal' && el.classList.contains('modal-active')) prepSwapModal();
            if(id === 'send-modal' && el.classList.contains('modal-active')) prepSendModal();
            if(id === 'settings-modal' && el.classList.contains('modal-active')) buildNativeSelects(); 
        }

        function buildTerminalDropdown() {
            const termDrop = document.getElementById('term-dropdown');
            termDrop.innerHTML = ASSETS.map(a => `
                <div onclick="selectPair('${a.id}', '${a.name}', '${a.icon}')" class="px-4 py-2 hover:bg-[#2b3139] cursor-pointer flex items-center gap-3 transition">
                    <img src="https://cryptologos.cc/logos/${a.icon}" class="w-5 h-5 rounded-full bg-[#1e2329] p-0.5">
                    <span class="text-xs font-bold text-white">${a.name}</span>
                </div>
            `).join('');
        }

        function selectPair(id, name, icon) {
            ui.pair = id; 
            document.getElementById('term-text').innerText = name; 
            document.getElementById('term-logo').src = `https://cryptologos.cc/logos/${icon}`; 
            toggleDropdown('term-dropdown'); 
            triggerPairChange();
        }

        function buildNativeSelects() {
            const sels = ['send-asset', 'swap-asset-from', 'swap-asset-to', 'new-asset-name'];
            
            let availOpts = `<option value="USDT">USDT</option>`;
            for(const c in state.manualAssets) { if(state.manualAssets[c] > 0) availOpts += `<option value="${c}">${c}</option>`; }
            
            let allOpts = `<option value="USDT">USDT</option>`;
            ASSETS.forEach(a => { if(a.coin !== 'USDT') allOpts += `<option value="${a.coin}">${a.coin}</option>`; });

            document.getElementById('send-asset').innerHTML = availOpts;
            document.getElementById('swap-asset-from').innerHTML = availOpts;
            document.getElementById('swap-asset-to').innerHTML = allOpts;
            document.getElementById('new-asset-name').innerHTML = allOpts;
        }

        function getIconImg(coin, cls) {
            const iconObj = ASSETS.find(x => x.coin === coin);
            const imgSrc = iconObj ? `https://cryptologos.cc/logos/${iconObj.icon}` : `https://ui-avatars.com/api/?name=${coin}&background=1e2329&color=F3BA2F&rounded=true`;
            let extraCls = coin === 'DOT' ? 'dot-spin' : (coin === 'ETH' ? 'eth-pulse' : '');
            return `<img src="${imgSrc}" class="${cls} ${extraCls} rounded-full bg-[#1e2329] p-0.5 shadow-md">`;
        }

        // --- 4. TERMINAL LOGIC & CHARTING ---
        function triggerPairChange() {
            ui.chartData = []; ui.price = livePrices[ui.pair] || 0;
            document.getElementById('main-price').innerText = "Syncing...";
            fetchChartData(); fetch24hStats(); generateFakeLog();
        }

        async function fetch24hStats() {
            try {
                let res = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbol=${ui.pair}`);
                let data = await res.json();
                document.getElementById('stat-high').innerText = parseFloat(data.highPrice).toLocaleString();
                document.getElementById('stat-low').innerText = parseFloat(data.lowPrice).toLocaleString();
            } catch(e){}
        }

        function setupCanvas() {
            const container = document.getElementById('canvas-container'); const canvas = document.getElementById('custom-chart'); chartCtx = canvas.getContext('2d');
            function resize() {
                const rect = container.getBoundingClientRect(); if(rect.width === 0) return; 
                const dpr = window.devicePixelRatio || 1; canvas.width = rect.width * dpr; canvas.height = rect.height * dpr; chartCtx.scale(dpr, dpr); drawChart();
            }
            window.addEventListener('resize', resize); setTimeout(resize, 100); 
            canvas.addEventListener('mousemove', (e) => { const rect = canvas.getBoundingClientRect(); canvasHoverPos = e.clientX - rect.left; drawChart(); });
            canvas.addEventListener('mouseleave', () => { canvasHoverPos = null; drawChart(); });
        }

        async function fetchChartData() {
            if(ui.timeframe === 'live') { ui.chartData = []; return; }
            let interval = ui.timeframe;
            try {
                let res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${ui.pair}&interval=${interval}&limit=80`);
                let json = await res.json();
                ui.chartData = json.map(d => ({ time: parseInt(d[0]), price: parseFloat(d[4]) }));
                drawChart(); calcAIEngine(); 
            } catch(e) {}
        }

        function setTimeframe(tf) {
            ui.timeframe = tf; 
            document.querySelectorAll('#tf-container .tf-btn').forEach(b => b.classList.remove('active')); 
            document.getElementById(`tf-${tf}`).classList.add('active'); 
            fetchChartData();
        }

        function drawChart() {
            if(!chartCtx || ui.chartData.length < 2) return;
            const canvas = document.getElementById('custom-chart'); if(canvas.width === 0) return;
            const w = canvas.width / (window.devicePixelRatio || 1); const h = canvas.height / (window.devicePixelRatio || 1); const data = ui.chartData;
            chartCtx.clearRect(0, 0, w, h);
            
            const padYBottom = 20, padXRight = 70; const gW = w - padXRight, gH = h - padYBottom;
            const prices = data.map(d => d.price); const minPrice = Math.min(...prices); const maxPrice = Math.max(...prices); const range = maxPrice - minPrice || 1; 
            
            // Grid
            chartCtx.strokeStyle = 'rgba(255,255,255,0.05)'; chartCtx.lineWidth = 1; chartCtx.fillStyle = '#848e9c'; chartCtx.font = '10px monospace'; chartCtx.textAlign = 'left'; chartCtx.textBaseline = 'middle';
            for(let i=0; i<=4; i++) {
                const yPos = (i / 4) * gH; chartCtx.beginPath(); chartCtx.moveTo(0, yPos); chartCtx.lineTo(gW, yPos); chartCtx.stroke();
                let gridPrice = maxPrice - (i / 4) * range; let gridText = gridPrice >= 1000 ? Math.round(gridPrice).toLocaleString() : gridPrice.toFixed(minPrice<1?4:2);
                chartCtx.fillText(gridText, gW + 6, yPos);
            }
            
            // Path
            chartCtx.beginPath(); let points = [];
            for(let i = 0; i < data.length; i++) {
                const x = (i / (data.length - 1)) * gW; let y = ((maxPrice - data[i].price) / range) * (gH * 0.8) + (gH * 0.1); y = Math.max(5, Math.min(gH - 5, y)); 
                points.push({x, y, p: data[i].price});
                if(i === 0) chartCtx.moveTo(x, y); else chartCtx.lineTo(x, y);
            }
            
            // Fill Gradient Underneath
            chartCtx.lineTo(points[points.length-1].x, gH); chartCtx.lineTo(points[0].x, gH); chartCtx.closePath();
            let gradient = chartCtx.createLinearGradient(0, 0, 0, gH);
            gradient.addColorStop(0, 'rgba(243, 186, 47, 0.3)'); gradient.addColorStop(1, 'rgba(243, 186, 47, 0.0)');
            chartCtx.fillStyle = gradient; chartCtx.fill();

            // Stroke Gold Line
            chartCtx.beginPath();
            for(let i = 0; i < points.length; i++) { if(i === 0) chartCtx.moveTo(points[i].x, points[i].y); else chartCtx.lineTo(points[i].x, points[i].y); }
            chartCtx.strokeStyle = '#F3BA2F'; chartCtx.lineWidth = 2; chartCtx.lineJoin = 'round'; chartCtx.stroke();
            
            // Orders Line
            state.orders.forEach(o => {
                if(o.pair === ui.pair) {
                    let y = ((maxPrice - o.entry) / range) * (gH * 0.8) + (gH * 0.1);
                    if(y > 0 && y < gH) {
                        chartCtx.beginPath(); chartCtx.moveTo(0, y); chartCtx.lineTo(gW, y);
                        chartCtx.strokeStyle = o.side === 'buy' ? '#0ECB81' : '#F6465D'; chartCtx.lineWidth = 1; chartCtx.setLineDash([4, 4]); chartCtx.stroke(); chartCtx.setLineDash([]);
                        chartCtx.fillStyle = o.side === 'buy' ? 'rgba(14,203,129,0.2)' : 'rgba(246,70,93,0.2)'; chartCtx.fillRect(gW - 60, y - 8, 60, 16);
                        chartCtx.fillStyle = o.side === 'buy' ? '#0ECB81' : '#F6465D'; chartCtx.font = 'bold 9px monospace';
                        chartCtx.fillText(`${o.lev}x ${o.side.toUpperCase()}`, gW - 55, y);
                    }
                }
            });

            // Hover / Price Tag
            function drawPriceTag(yPos, priceVal) {
                let tagY = Math.max(10, Math.min(gH - 10, yPos)); let priceText = priceVal >= 1000 ? Math.round(priceVal).toLocaleString() : priceVal.toFixed(minPrice<1?4:2);
                chartCtx.font = 'bold 11px monospace'; let boxWidth = chartCtx.measureText(priceText).width + 12; 
                chartCtx.fillStyle = '#F3BA2F'; chartCtx.fillRect(gW, tagY - 11, boxWidth, 22); chartCtx.fillStyle = '#0b0e11'; chartCtx.fillText(priceText, gW + 6, tagY);
            }

            if(canvasHoverPos !== null && canvasHoverPos <= gW) {
                let closest = points.reduce((prev, curr) => Math.abs(curr.x - canvasHoverPos) < Math.abs(prev.x - canvasHoverPos) ? curr : prev);
                chartCtx.strokeStyle = 'rgba(255,255,255,0.2)'; chartCtx.lineWidth = 1; chartCtx.setLineDash([4, 4]);
                chartCtx.beginPath(); chartCtx.moveTo(closest.x, 0); chartCtx.lineTo(closest.x, gH); chartCtx.stroke();
                chartCtx.beginPath(); chartCtx.moveTo(0, closest.y); chartCtx.lineTo(gW, closest.y); chartCtx.stroke(); chartCtx.setLineDash([]);
                chartCtx.beginPath(); chartCtx.arc(closest.x, closest.y, 4, 0, Math.PI*2); chartCtx.fillStyle = '#F3BA2F'; chartCtx.fill(); drawPriceTag(closest.y, closest.p);
            } else {
                const last = points[points.length-1]; chartCtx.beginPath(); chartCtx.arc(last.x, last.y, 4, 0, Math.PI*2); chartCtx.fillStyle = '#F3BA2F'; chartCtx.fill(); drawPriceTag(last.y, last.p);
            }
        }

        function processMainTick(newPrice) {
            const el = document.getElementById('main-price');
            if (ui.lastPrice !== 0 && newPrice !== ui.lastPrice) {
                const isUp = newPrice > ui.lastPrice;
                el.style.color = isUp ? 'var(--buy-green)' : 'var(--sell-red)';
                setTimeout(()=>el.style.color='white', 300);
            }
            ui.lastPrice = newPrice; ui.price = newPrice;
            
            if(ui.timeframe === 'live') {
                ui.chartData.push({time: Date.now(), price: newPrice});
                if(ui.chartData.length > 50) ui.chartData.shift();
            } else if (ui.chartData.length > 0) {
                ui.chartData[ui.chartData.length - 1].price = newPrice;
            }
            
            if(Math.random() < 0.1) calcAIEngine(); 
            if(!canvasHoverPos) drawChart(); 
            
            el.innerText = newPrice.toLocaleString(undefined, {minimumFractionDigits: newPrice<1?4:2, maximumFractionDigits: newPrice<1?4:2});
            renderOrders(); 
        }

        // --- 5. EXECUTION & LOGIC ---
        function updateLev(el) {
            ui.lev = parseInt(el.value); 
            document.getElementById('lev-val').innerText = ui.lev; 
            // Update slider visual fill
            const pct = (ui.lev - 1) / 99 * 100;
            el.style.background = `linear-gradient(to right, #F3BA2F ${pct}%, #2b3139 ${pct}%)`;
            calcSize(); 
        }

        function setSide(side) {
            ui.side = side;
            document.getElementById('btn-buy').className = side==='buy' ? "flex-1 py-2 rounded text-xs font-bold text-buy bg-[#0ECB81]/10 border border-[#0ECB81]/50" : "flex-1 py-2 rounded text-xs font-bold text-muted hover:text-buy transition border border-transparent";
            document.getElementById('btn-sell').className = side==='sell' ? "flex-1 py-2 rounded text-xs font-bold text-sell bg-[#F6465D]/10 border border-[#F6465D]/50" : "flex-1 py-2 rounded text-xs font-bold text-muted hover:text-sell transition border border-transparent";
            
            const exec = document.getElementById('btn-execute');
            exec.innerText = side==='buy' ? "Buy / Long" : "Sell / Short";
            exec.className = side==='buy' ? "mt-6 w-full py-3.5 rounded font-bold text-sm bg-buy text-white hover:opacity-90 transition" : "mt-6 w-full py-3.5 rounded font-bold text-sm bg-sell text-white hover:opacity-90 transition";
        }

        function calcSize() {
            const m = parseFloat(document.getElementById('trade-margin').value) || 0;
            document.getElementById('ui-cost').innerText = m.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT';
            document.getElementById('ui-size').innerText = (m * ui.lev).toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT';
        }

        function setMax() { document.getElementById('trade-margin').value = Math.floor(state.usdtBalance * 100) / 100; calcSize(); }

        function executeOrder() {
            const m = parseFloat(document.getElementById('trade-margin').value);
            if (isNaN(m) || m <= 0) return;
            if (m > state.usdtBalance) return alert("Insufficient USDT");

            state.usdtBalance -= m;
            state.orders.push({ id: Math.random().toString(36).substr(2, 9), pair: ui.pair, side: ui.side, margin: m, lev: ui.lev, entry: ui.price, units: (m * ui.lev) / ui.price, time: Date.now() });

            document.getElementById('trade-margin').value = ''; calcSize();
            saveState(); renderOrders(); drawChart();
        }

        function renderOrders() {
            const tbody = document.getElementById('orders-body');
            if (state.orders.length === 0) { tbody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-muted text-xs">No Open Positions</td></tr>`; return; }

            let html = '';
            state.orders.forEach(o => {
                let livePrice = livePrices[o.pair] || o.entry;
                let pnl = o.side === 'buy' ? ((o.units * livePrice) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * livePrice));
                let roi = (pnl / o.margin) * 100;
                const isProf = pnl >= 0;
                
                html += `
                    <tr>
                        <td class="text-white font-bold">${o.pair}</td>
                        <td><span class="${o.side==='buy'?'text-buy':'text-sell'} font-bold">${o.lev}x ${o.side.toUpperCase()}</span></td>
                        <td class="text-muted">${o.entry.toFixed(4)}</td>
                        <td class="text-white">${livePrice.toFixed(4)}</td>
                        <td class="text-white">${o.margin.toFixed(2)}</td>
                        <td class="text-right ${isProf?'text-buy':'text-sell'} font-bold">${isProf?'+':''}${roi.toFixed(2)}%<br/>${isProf?'+':''}${pnl.toFixed(2)}</td>
                        <td class="text-center"><button onclick="closeOrder('${o.id}')" class="b-btn px-3 py-1.5 text-xs">Close</button></td>
                    </tr>`;
            });
            tbody.innerHTML = html;
        }

        function closeOrder(id) {
            const idx = state.orders.findIndex(p => p.id === id);
            if(idx===-1) return;
            const o = state.orders[idx];
            let pnl = o.side === 'buy' ? ((o.units * (livePrices[o.pair]||o.entry)) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * (livePrices[o.pair]||o.entry)));
            
            state.usdtBalance += (o.margin + pnl);
            state.history.unshift({ pair: o.pair, pnl: pnl });
            if(state.history.length > 50) state.history.pop();
            
            state.orders.splice(idx, 1);
            saveState(); renderOrders(); renderHistory(); drawChart();
        }

        function renderHistory() {
            const tbody = document.getElementById('history-body');
            let html = '';
            state.history.forEach(h => {
                html += `<tr><td class="text-white">${h.pair}</td><td class="text-right font-bold ${h.pnl>=0?'text-buy':'text-sell'}">${h.pnl>=0?'+':''}$${h.pnl.toFixed(2)}</td></tr>`;
            });
            tbody.innerHTML = html || `<tr><td colspan="2" class="p-4 text-center text-muted text-xs">No History</td></tr>`;
        }

        function generateFakeLog() {
            const feed = document.getElementById('below-chart-log');
            let html = '';
            for(let i=0; i<10; i++) {
                let isBuy = Math.random() > 0.5;
                let val = Math.random() * 50000 + 1000;
                let qty = val / (ui.price || 50000);
                html += `<div class="flex justify-between items-center px-2 py-1.5 rounded ${isBuy?'bg-[#0ECB81]/10':'bg-[#F6465D]/10'}">
                    <span class="text-[10px] ${isBuy?'text-buy':'text-sell'} font-bold">${isBuy?'BUY':'SELL'}</span>
                    <span class="text-[10px] text-white font-mono">${qty.toFixed(4)}</span>
                    <span class="text-[10px] text-muted font-mono">$${val.toLocaleString(undefined, {maximumFractionDigits:0})}</span>
                </div>`;
            }
            feed.innerHTML = html;
        }

        function calcAIEngine() {
            if(ui.chartData.length < 21) return; 
            let gains = 0, losses = 0; const rsiData = ui.chartData.slice(-15);
            for(let i=1; i<rsiData.length; i++) { let diff = rsiData[i].price - rsiData[i-1].price; if(diff >= 0) gains += diff; else losses -= diff; }
            let rs = (gains/14) / ((losses/14) || 1); let rsi = 100 - (100 / (1 + rs));
            const smaData = ui.chartData.slice(-20); let sma = smaData.reduce((acc, val) => acc + val.price, 0) / 20;

            document.getElementById('ai-rsi').innerText = rsi.toFixed(1);
            document.getElementById('ai-sma').innerText = sma.toFixed(2);
            
            const predEl = document.getElementById('ai-signal');
            try {
                let fn = new Function('rsi', 'sma', state.aiLogic);
                let res = fn(rsi, sma);
                if(res.includes('SELL')) { predEl.innerText = res; predEl.className = "w-full text-center p-3 rounded font-black text-sm tracking-wide bg-[#F6465D]/20 text-sell border border-[#F6465D]/30"; }
                else if(res.includes('BUY')) { predEl.innerText = res; predEl.className = "w-full text-center p-3 rounded font-black text-sm tracking-wide bg-[#0ECB81]/20 text-buy border border-[#0ECB81]/30"; }
                else { predEl.innerText = "NEUTRAL"; predEl.className = "w-full text-center p-3 rounded font-black text-sm tracking-wide bg-[#2b3139] text-muted border border-[#2b3139]"; }
            } catch(e) { predEl.innerText = "SYNTAX ERROR"; }
        }

        function saveAILogic() {
            state.aiLogic = document.getElementById('ai-logic-editor').value;
            saveState(); toggleModal('ai-code-modal'); calcAIEngine();
        }

        // --- 6. WALLET LOGIC ---
        function updateWalletSystem() {
            let totalUsdValue = state.usdtBalance;
            state.orders.forEach(o => {
                let livePrice = livePrices[o.pair] || o.entry;
                totalUsdValue += o.margin; 
                totalUsdValue += (o.side === 'buy' ? ((o.units * livePrice) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * livePrice)));
            });
            for (const [coin, amt] of Object.entries(state.manualAssets)) { totalUsdValue += amt * (livePrices[coin + 'USDT'] || 0); }
            state.stakes.forEach(s => { totalUsdValue += s.amt * (livePrices[s.coin + 'USDT'] || 0); });

            let rate = FX_RATES[state.currency] || 1;
            let sym = FX_SYM[state.currency] || '$';
            let localTotal = totalUsdValue * rate;

            document.getElementById('wallet-currency-sym').innerText = sym;
            document.getElementById('wallet-total-value').innerText = localTotal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('ui-avail').innerText = state.usdtBalance.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT';
            state.lastRunTime = Date.now(); 
        }

        function toggleShowMoreAssets() {
            isShowingAllAssets = !isShowingAllAssets;
            updateWalletApp();
        }

        function updateWalletApp() {
            let totalUsdValue = state.usdtBalance;
            let rows = [];
            let rate = FX_RATES[state.currency] || 1; let sym = FX_SYM[state.currency] || '$';

            const addRow = (coin, amt, isStake) => {
                let valUsd = coin === 'USDT' ? amt : amt * (livePrices[coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
                rows.push({ coin, amt, valUsd, isStake });
            };

            addRow('USDT', state.usdtBalance, false);
            for (const [coin, amt] of Object.entries(state.manualAssets)) addRow(coin, amt, false);
            state.stakes.forEach(s => addRow(s.coin, s.amt, true));
            rows.sort((a,b) => b.valUsd - a.valUsd);
            
            // Generate Grid
            let gridHtml = '';
            let renderCount = isShowingAllAssets ? rows.length : Math.min(4, rows.length);
            for(let i=0; i<renderCount; i++) {
                let r = rows[i];
                let valLocal = r.valUsd * rate;
                gridHtml += `
                <div class="b-panel p-5 flex flex-col items-center justify-center text-center gap-2 aspect-square relative group hover:border-gold transition-colors duration-300 cursor-default">
                    ${r.isStake ? '<span class="absolute top-2 right-2 px-1.5 py-0.5 rounded bg-[#0ECB81]/20 text-buy text-[8px] font-bold">STAKED</span>' : ''}
                    ${getIconImg(r.coin, 'w-12 h-12 mb-1')}
                    <span class="font-black text-white text-base leading-none">${r.coin}</span>
                    <span class="font-mono text-muted text-xs">${r.amt.toLocaleString(undefined, {maximumFractionDigits: 4})}</span>
                    <span class="font-mono text-white font-bold mt-auto bg-[#0b0e11] w-full py-1.5 rounded text-sm">${sym}${valLocal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                </div>`;
            }
            document.getElementById('wallet-square-grid').innerHTML = gridHtml;
            
            const btn = document.getElementById('show-more-btn');
            if(rows.length > 4) {
                btn.classList.remove('hidden');
                btn.innerText = isShowingAllAssets ? "Show Less" : "Show More";
            } else { btn.classList.add('hidden'); }

            // Staking List
            let sBody = document.getElementById('active-stakes-body');
            if(state.stakes.length === 0) sBody.innerHTML = `<tr><td colspan="4" class="p-4 text-center text-muted italic text-xs">No active stakes.</td></tr>`;
            else {
                sBody.innerHTML = state.stakes.map(s => {
                    let d = (Date.now() - s.time) / 86400000; 
                    let earned = s.amt * (s.apr / 100) * (d / 365);
                    return `<tr>
                        <td><div class="flex items-center gap-2">${getIconImg(s.coin, 'w-5 h-5')}<span class="text-white font-bold">${s.coin}</span></div></td>
                        <td class="text-white">${s.amt.toFixed(4)}</td>
                        <td class="text-buy font-bold">${s.apr}%</td>
                        <td class="text-right text-gold">+${earned.toFixed(6)} <span class="text-muted text-[10px]">${s.coin}</span></td>
                    </tr>`;
                }).join('');
            }
        }

        // --- 7. WALLET ACTIONS (SWAP/SEND/STAKE) ---
        function buildStakingGrid() {
            document.getElementById('staking-grid').innerHTML = STAKING_OPTS.map(opt => `
                <div class="b-panel p-4 flex flex-col items-center cursor-pointer hover:border-gold transition hover:shadow-[0_0_15px_rgba(243,186,47,0.1)] group" onclick="openStakeModal('${opt.id}', ${opt.apr})">
                    <span class="text-[9px] bg-[#0ECB81]/10 text-buy px-2 py-0.5 rounded mb-3 font-bold border border-[#0ECB81]/20">${opt.tag}</span>
                    ${getIconImg(opt.id, 'w-10 h-10 mb-2 group-hover:scale-110 transition-transform')}
                    <h3 class="text-base font-bold text-white mb-1">${opt.id}</h3>
                    <span class="text-xl font-mono font-black text-buy">${opt.apr}%</span>
                </div>
            `).join('');
        }

        function openStakeModal(coin, apr) {
            document.getElementById('stake-modal-asset').innerText = coin;
            document.getElementById('stake-modal-apr').innerText = apr + '%';
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin] || 0);
            document.getElementById('stake-modal-avail').innerText = avail.toFixed(4);
            document.getElementById('stake-modal-avail').dataset.val = avail;
            document.getElementById('stake-amount').value = '';
            document.getElementById('stake-amount').dataset.coin = coin;
            document.getElementById('stake-amount').dataset.apr = apr;
            toggleModal('stake-modal');
        }

        function confirmStake() {
            const el = document.getElementById('stake-amount');
            const amt = parseFloat(el.value);
            const coin = el.dataset.coin;
            if(isNaN(amt) || amt <= 0 || amt > parseFloat(document.getElementById('stake-modal-avail').dataset.val)) return alert("Invalid amount.");
            if(coin === 'USDT') state.usdtBalance -= amt; else state.manualAssets[coin] -= amt;
            state.stakes.push({ coin, amt, apr: parseFloat(el.dataset.apr), time: Date.now() });
            saveState(); toggleModal('stake-modal'); updateWalletApp();
        }

        function prepSwapModal() {
            buildNativeSelects(); 
            document.getElementById('swap-asset-from').value = 'USDT'; document.getElementById('swap-asset-to').value = 'BTC';
            document.getElementById('swap-form-content').classList.remove('hidden');
            document.getElementById('swap-animation').classList.add('hidden');
            document.getElementById('swap-close-btn').classList.remove('hidden');
            updateSwapBals(); calcSwap();
        }

        function updateSwapBals() {
            let from = document.getElementById('swap-asset-from').value; let to = document.getElementById('swap-asset-to').value;
            document.getElementById('swap-bal-from').innerText = `Bal: ${(from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0)).toFixed(4)}`;
            document.getElementById('swap-bal-to').innerText = `Bal: ${(to === 'USDT' ? state.usdtBalance : (state.manualAssets[to]||0)).toFixed(4)}`;
        }

        function calcSwap() {
            let from = document.getElementById('swap-asset-from').value; let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            if(from === to) { document.getElementById('swap-amt-to').value = amt; document.getElementById('swap-rate-text').innerText = `1 ${from} = 1 ${to}`; return; }
            let priceFromUsd = from === 'USDT' ? 1 : (livePrices[from+'USDT'] || 1);
            let priceToUsd = to === 'USDT' ? 1 : (livePrices[to+'USDT'] || 1);
            let toAmt = (amt * priceFromUsd) / priceToUsd;
            document.getElementById('swap-amt-to').value = toAmt.toFixed(6);
            document.getElementById('swap-rate-text').innerText = `1 ${from} ≈ ${(priceFromUsd/priceToUsd).toFixed(6)} ${to}`;
        }

        function executeSwap() {
            let from = document.getElementById('swap-asset-from').value; let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            let toAmt = parseFloat(document.getElementById('swap-amt-to').value) || 0;
            if(amt <= 0) return;
            let avail = from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0);
            if(amt > avail) return alert("Insufficient balance.");

            document.getElementById('swap-form-content').classList.add('hidden'); document.getElementById('swap-close-btn').classList.add('hidden');
            const anim = document.getElementById('swap-animation');
            anim.classList.remove('hidden'); anim.classList.add('flex');
            anim.innerHTML = `<div class="spinner w-12 h-12 mb-4"></div><p class="text-gold font-bold text-sm animate-pulse">Swapping on-chain...</p>`;

            setTimeout(() => {
                anim.innerHTML = `<svg class="w-16 h-16 text-buy mb-4 drop-shadow-[0_0_10px_rgba(14,203,129,0.4)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg><p class="text-buy font-bold text-lg">Success!</p>`;
                if(from === 'USDT') state.usdtBalance -= amt; else state.manualAssets[from] -= amt;
                if(to === 'USDT') state.usdtBalance += toAmt; else { if(!state.manualAssets[to]) state.manualAssets[to] = 0; state.manualAssets[to] += toAmt; }
                saveState(); 
                setTimeout(() => { toggleModal('swap-modal'); updateWalletApp(); }, 1200);
            }, 1500);
        }

        function prepSendModal() {
            buildNativeSelects(); document.getElementById('send-asset').value = 'USDT'; updateSendMax();
            document.getElementById('send-form').classList.remove('hidden'); document.getElementById('send-processing').classList.add('hidden'); document.getElementById('send-close-btn').classList.remove('hidden');
        }

        function updateSendMax() {
            let coin = document.getElementById('send-asset').value;
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin]||0);
            document.getElementById('send-avail-txt').innerText = avail.toFixed(4);
        }

        function setMaxSend() { document.getElementById('send-amount').value = document.getElementById('send-avail-txt').innerText; }

        let sendInterval, sendTimeout;
        function initiateSend() {
            let asset = document.getElementById('send-asset').value; let addr = document.getElementById('send-address').value; let amt = parseFloat(document.getElementById('send-amount').value);
            if(!addr || addr.length < 10) return alert("Invalid destination.");
            if(isNaN(amt) || amt <= 0 || amt > parseFloat(document.getElementById('send-avail-txt').innerText)) return alert("Invalid amount.");

            document.getElementById('send-form').classList.add('hidden'); document.getElementById('send-processing').classList.remove('hidden'); document.getElementById('send-processing').classList.add('flex'); document.getElementById('send-close-btn').classList.add('hidden'); 
            const logBox = document.getElementById('send-log'); logBox.innerHTML = '';
            
            const addLog = (msg, delay) => new Promise(res => { sendTimeout = setTimeout(() => { logBox.innerHTML += `<div>${msg}</div>`; logBox.scrollTop = logBox.scrollHeight; res(); }, delay); });

            document.getElementById('send-status-title').innerText = "Initiating...";
            (async function runFakeTx() {
                await addLog(`[SYS] Initiating contract call for ${amt} ${asset}...`, 500);
                await addLog(`[NET] Establishing secure RPC...`, 800);
                document.getElementById('send-status-title').innerText = "Awaiting Inclusion";
                await addLog(`[MEM] TX accepted. Broadcasting...`, 1500);
                await addLog(`[VAL] Block discovered. Checking consensus...`, 2000);
                document.getElementById('send-status-title').innerText = "Verification Pending";
                document.getElementById('send-status-title').classList.replace('text-gold', 'text-sell');
                await addLog(`<span class="text-sell font-bold">[ERR] Validation stalled. Node mismatch.</span>`, 2000);
                document.getElementById('send-close-btn').classList.remove('hidden'); 
                sendInterval = setInterval(() => { logBox.innerHTML += `<div class="text-muted">[VAL] Retrying (Attempt ∞)...</div>`; logBox.scrollTop = logBox.scrollHeight; }, 3000);
            })();
        }
        function closeSendModal() { clearInterval(sendInterval); clearTimeout(sendTimeout); document.getElementById('send-status-title').classList.replace('text-sell', 'text-gold'); toggleModal('send-modal'); }

        function setUsdt() { const amt = parseFloat(document.getElementById('add-usdt-input').value); if(amt >= 0) { state.usdtBalance = amt; state.startOfDayValue = amt; document.getElementById('add-usdt-input').value = ''; saveState(); toggleModal('settings-modal'); } }
        function addManualAsset() {
            const n = document.getElementById('new-asset-name').value; const a = parseFloat(document.getElementById('new-asset-amt').value);
            if(n) { if (a <= 0 || isNaN(a)) { delete state.manualAssets[n]; } else { state.manualAssets[n] = a; } document.getElementById('new-asset-amt').value=''; saveState(); toggleModal('settings-modal'); }
        }

        function updateUI() { document.getElementById('ui-avail').innerText = state.usdtBalance.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT'; }
        function saveState() { localStorage.setItem('bpro_state_v2', JSON.stringify(state)); updateUI(); updateWalletApp(); }

        init();
    </script>
</body>
</html>
