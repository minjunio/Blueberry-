            let swapToDrop = document.getElementById('swap-to-drop');
            let setDrop = document.getElementById('settings-asset-drop');
            
            if(!sendDrop || !swapFromDrop || !swapToDrop || !setDrop) return;

            sendDrop.innerHTML = ''; swapFromDrop.innerHTML = ''; swapToDrop.innerHTML = ''; setDrop.innerHTML = '';

            // Generate available options based on state for Send & Swap From
            let availCoins = ['USDT'];
            for(const c in state.manualAssets) { if(state.manualAssets[c] > 0) availCoins.push(c); }

            // Generate ALL options for Swap To and Settings
            let allCoins = ['USDT'];
            ASSETS.forEach(a => { if(a.coin !== 'USDT') allCoins.push(a.coin); });

            const createItem = (coin, onClickStr) => {
                const icon = ASSETS.find(x => x.coin === coin)?.icon || (coin==='USDT'?'tether-usdt-logo.svg?v=029':`https://ui-avatars.com/api/?name=${coin}&background=0D0814&color=A78BFA&rounded=true`);
                const imgSrc = icon.includes('ui-avatars') ? icon : `https://cryptologos.cc/logos/${icon}`;
                return `<div onclick="${onClickStr}" class="px-3 py-2 hover:bg-purple-900/40 cursor-pointer flex items-center gap-2 border-b border-purple-900/30 last:border-0 transition text-xs font-black uppercase text-white"><img src="${imgSrc}" class="w-4 h-4 rounded-full bg-[#1e2026] p-0.5">${coin}</div>`;
            };

            availCoins.forEach(c => {
                sendDrop.innerHTML += createItem(c, `selectSendAsset('${c}')`);
                swapFromDrop.innerHTML += createItem(c, `selectSwapFrom('${c}')`);
            });

            allCoins.forEach(c => {
                swapToDrop.innerHTML += createItem(c, `selectSwapTo('${c}')`);
                setDrop.innerHTML += createItem(c, `selectSetAsset('${c}')`);
