            <h2 class="text-sm font-bold text-white mb-4 border-b border-[#2b3139] pb-2">Portfolio Override</h2>
            
            <div class="space-y-4">
                <div>
                    <label class="text-xs text-muted mb-1.5 block">Set Exact USDT Balance</label>
                    <div class="flex gap-2">
                        <input type="number" id="add-usdt-input" placeholder="0.00" class="flex-grow b-input p-2 text-sm font-mono">
                        <button onclick="setUsdt()" class="bg-[#2b3139] px-4 rounded text-xs font-bold text-white hover:bg-gold hover:text-black transition">Set</button>
                    </div>
                </div>

                <div class="pt-2">
                    <label class="text-xs text-muted mb-1.5 block">Override Asset Balance</label>
                    <div class="flex gap-2">
                        <select id="new-asset-name" class="w-1/2 native-sel"></select>
                        <input type="number" id="new-asset-amt" placeholder="Qty (0 to del)" class="w-1/2 b-input p-2 text-sm font-mono">
                    </div>
                    <button onclick="addManualAsset()" class="w-full mt-3 b-btn py-2 rounded text-xs font-bold">Apply Changes</button>
