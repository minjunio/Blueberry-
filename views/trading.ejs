        function generateBackgroundData(symbol, currentPrice, timeGap) {
            let numTrades = Math.min(Math.floor(timeGap / 60000) * 10, 300); 
            let now = Date.now();
            for(let i=0; i<numTrades; i++) {
                let isBuy = Math.random() > 0.5;
                let usdVal = Math.random() * 30000 + 1000; 
                if(Math.random() > 0.95) usdVal += Math.random() * 200000; 
                let qty = usdVal / currentPrice; let time = now - (Math.random() * timeGap);
                state.globalTradeLogs.push({ addr: '0x' + Math.random().toString(16).substring(2, 8).toUpperCase(), isBuy, qty, price: currentPrice, usdVal, pair: symbol, time });
            }
            state.globalTradeLogs.sort((a,b) => b.time - a.time);
            if(state.globalTradeLogs.length > 1500) state.globalTradeLogs = state.globalTradeLogs.slice(0, 1500);
            saveState(); renderGlobalLogs(); renderOnChainAlpha();
        }

        function saveAILogic() {
            state.aiLogic = document.getElementById('ai-logic-editor').value;
            saveState(); toggleModal('ai-code-modal'); calcAIEngine();
        }

        function calcAIEngine() {
            if(ui.chartData.length < 21) return; 
            let gains = 0, losses = 0; const rsiData = ui.chartData.slice(-15);
            for(let i=1; i<rsiData.length; i++) { let diff = rsiData[i].price - rsiData[i-1].price; if(diff >= 0) gains += diff; else losses -= diff; }
            let rs = (gains/14) / ((losses/14) || 1); let rsi = 100 - (100 / (1 + rs));
            const smaData = ui.chartData.slice(-20); let sma = smaData.reduce((acc, val) => acc + val.price, 0) / 20;
            const prices = smaData.map(d => d.price); let vol = Math.max(...prices) - Math.min(...prices);

            document.getElementById('ai-rsi').innerText = rsi.toFixed(1);
            document.getElementById('ai-sma').innerText = sma.toFixed(2);
            document.getElementById('ai-vol').innerText = vol.toFixed(2);
            
            const predEl = document.getElementById('ai-signal');
            try {
                let fn = new Function('rsi', 'sma', 'volatility', 'prices', state.aiLogic);
                let res = fn(rsi, sma, vol, prices);
                if(res.includes('SELL') || res.includes('BEAR')) { predEl.innerText = res; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-pink-900/30 text-pink-400 border border-pink-500/20"; }
                else if(res.includes('BUY') || res.includes('BULL')) { predEl.innerText = res; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-green-900/30 text-green-400 border border-green-500/20"; }
                else { predEl.innerText = res || "NEUTRAL"; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-purple-900/30 text-purple-400 border border-purple-500/20"; }
            } catch(e) { predEl.innerText = "SYNTAX ERR"; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-red-900/30 text-red-400"; }
        }

        // --- 5. EXECUTION LOGIC ---
        function setSide(side) {
            ui.side = side;
            document.getElementById('btn-buy').className = side==='buy' ? "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest bg-green-500/20 text-green-400 border border-green-500/50" : "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-green-400 transition";
            document.getElementById('btn-sell').className = side==='sell' ? "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest bg-pink-500/20 text-pink-400 border border-pink-500/50" : "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-pink-400 transition";
            
            const exec = document.getElementById('btn-execute');
            exec.innerText = side==='buy'?"Execute Long":"Execute Short";
            exec.className = side==='buy'?"mt-4 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-green-500 text-[#05020a] hover:bg-green-400 transition active:scale-95 shadow-[0_0_15px_rgba(52,211,153,0.3)]" : "mt-4 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-pink-500 text-[#05020a] hover:bg-pink-400 transition active:scale-95 shadow-[0_0_15px_rgba(251,113,133,0.3)]";
        }

        document.getElementById('trade-lev').addEventListener('input', (e) => { ui.lev = parseInt(e.target.value); document.getElementById('lev-val').innerText = ui.lev; calcSize(); });
        document.getElementById('trade-margin').addEventListener('input', calcSize);

        function calcSize() {
            const m = parseFloat(document.getElementById('trade-margin').value) || 0;
            document.getElementById('ui-size').innerText = (m * ui.lev).toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT';
        }

        function setMax() { document.getElementById('trade-margin').value = Math.floor(state.usdtBalance * 100) / 100; calcSize(); }

        function executeOrder() {
            const m = parseFloat(document.getElementById('trade-margin').value);
            if (isNaN(m) || m <= 0) return;
            if (m > state.usdtBalance) return alert("Insufficient USDT");

            state.usdtBalance -= m;
            state.orders.push({
                id: Math.random().toString(36).substr(2, 9), pair: ui.pair, side: ui.side,
                margin: m, lev: ui.lev, entry: ui.price, units: (m * ui.lev) / ui.price, time: Date.now()
            });

            document.getElementById('trade-margin').value = ''; calcSize();
            saveState(); renderOrders(); drawChart();
        }

        function renderOrders() {
            const tbody = document.getElementById('orders-body');
            if (state.orders.length === 0) { tbody.innerHTML = `<tr><td colspan="8" class="p-4 text-center text-muted font-black uppercase text-[9px]">No Open Trades</td></tr>`; return; }

            let html = '';
            state.orders.forEach(o => {
                let livePrice = livePrices[o.pair] || o.entry;
                let pnl = o.side === 'buy' ? ((o.units * livePrice) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * livePrice));
                let roi = (pnl / o.margin) * 100;
                const isProf = pnl >= 0;
                const coin = o.pair.replace('USDT', '');
                
                html += `
                    <tr class="border-b border-purple-900/20 hover:bg-purple-900/20">
                        <td class="p-3">
                            <div class="flex items-center gap-2">
                                ${getIconImg(coin, 'w-4 h-4')}
                                <span class="text-white">${o.pair}</span>
                            </div>
                        </td>
                        <td class="p-3"><span class="px-2 py-1 rounded ${o.side==='buy'?'bg-green-900/40 text-green-400 border border-green-500/20':'bg-pink-900/40 text-pink-400 border border-pink-500/20'} uppercase text-[9px] font-black">${o.lev}x ${o.side}</span></td>
                        <td class="p-3 text-purple-400 font-mono">$${o.entry.toFixed(4)}</td>
                        <td class="p-3 font-mono">$${livePrice.toFixed(4)}</td>
                        <td class="p-3 font-mono">$${o.margin.toFixed(2)}</td>
                        <td class="p-3 font-mono">$${(o.margin * o.lev).toFixed(2)}</td>
                        <td class="p-3 text-right ${isProf?'text-green-400':'text-pink-400'} font-black font-mono">${isProf?'+':''}${roi.toFixed(2)}% | ${isProf?'+':''}$${pnl.toFixed(2)}</td>
                        <td class="p-3 text-center"><button onclick="closeOrder('${o.id}')" class="px-3 py-1 bg-purple-900/50 hover:bg-pink-600 text-white rounded text-[9px] uppercase transition border border-purple-500/50 hover:border-pink-500">Close</button></td>
                    </tr>`;
            });
            tbody.innerHTML = html;
        }

        function closeOrder(id) {
            const idx = state.orders.findIndex(p => p.id === id);
            if(idx===-1) return;
            const o = state.orders[idx];
            let pnl = o.side === 'buy' ? ((o.units * (livePrices[o.pair]||o.entry)) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * (livePrices[o.pair]||o.entry)));
            
            state.usdtBalance += (o.margin + pnl);
            state.history.unshift({ pair: o.pair, pnl: pnl });
            if(state.history.length > 50) state.history.pop();
            
            state.orders.splice(idx, 1);
            saveState(); renderOrders(); renderHistory(); drawChart();
        }

        function renderHistory() {
            const tbody = document.getElementById('history-body');
            let html = '';
            state.history.forEach(h => {
                const coin = h.pair.replace('USDT', '');
                html += `<tr class="border-b border-purple-900/20">
                    <td class="p-3">
                        <div class="flex items-center gap-2">
                            ${getIconImg(coin, 'w-4 h-4')}
                            <span class="text-white">${h.pair}</span>
                        </div>
                    </td>
                    <td class="p-3 text-right font-black font-mono ${h.pnl>=0?'text-green-400':'text-pink-400'}">${h.pnl>=0?'+':''}$${h.pnl.toFixed(2)}</td>
                </tr>`;
            });
            tbody.innerHTML = html || `<tr><td colspan="2" class="p-4 text-center text-muted text-[9px] uppercase">No History</td></tr>`;
        }

        // --- 6. WALLET PROFESSIONAL REDESIGN LOGIC ---
        function toggleShowMoreAssets() {
            isShowingAllAssets = !isShowingAllAssets;
            updateWalletApp();
        }

        function updateWalletApp() {
            let totalUsdValue = state.usdtBalance;
            let rows = [];
            let rate = FX_RATES[state.currency] || 1; let sym = FX_SYM[state.currency] || '$';

            const addRow = (coin, amt, isStake) => {
                let valUsd = coin === 'USDT' ? amt : amt * (livePrices[coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
                rows.push({ coin, amt, valUsd, isStake });
            };

            addRow('USDT', state.usdtBalance, false);
            for (const [coin, amt] of Object.entries(state.manualAssets)) addRow(coin, amt, false);
            state.stakes.forEach(s => addRow(s.coin, s.amt, true));
            rows.sort((a,b) => b.valUsd - a.valUsd);
            
            let gridHtml = '';
            let renderCount = isShowingAllAssets ? rows.length : Math.min(4, rows.length);
            for(let i=0; i<renderCount; i++) {
                let r = rows[i]; let valLocal = r.valUsd * rate;
                gridHtml += `
                <div class="glass-panel p-5 flex flex-col items-center justify-center text-center gap-2 aspect-square relative group hover:border-purple-500 transition-colors duration-300">
                    ${r.isStake ? '<span class="absolute top-2 right-2 px-1.5 py-0.5 rounded bg-green-900/30 text-green-400 border border-green-500/30 text-[7px] uppercase font-black">Staked</span>' : ''}
                    ${getIconImg(r.coin, 'w-12 h-12 mb-1')}
                    <span class="font-black text-white text-base leading-none tracking-widest">${r.coin}</span>
                    <span class="font-mono text-purple-400 text-xs">${r.amt.toLocaleString(undefined, {maximumFractionDigits: 4})}</span>
                    <span class="font-mono text-white font-bold mt-auto bg-[#0a0510] w-full py-1.5 rounded border border-purple-900/50 text-sm shadow-inner">${sym}${valLocal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</span>
                </div>`;
            }
            document.getElementById('wallet-square-grid').innerHTML = gridHtml;
            
            const btn = document.getElementById('show-more-btn');
            if(rows.length > 4) { btn.classList.remove('hidden'); btn.innerText = isShowingAllAssets ? "Show Less" : "Show More"; } 
            else { btn.classList.add('hidden'); }

            let sBody = document.getElementById('active-stakes-body');
            if(state.stakes.length === 0) sBody.innerHTML = `<tr><td colspan="4" class="p-4 text-center text-muted italic text-[9px]">No active stakes.</td></tr>`;
            else {
                sBody.innerHTML = state.stakes.map(s => {
                    let d = (Date.now() - s.time) / 86400000; 
                    let earned = s.amt * (s.apr / 100) * (d / 365);
                    return `<tr class="border-b border-purple-900/20">
                        <td class="p-3"><div class="flex items-center gap-2">${getIconImg(s.coin, 'w-5 h-5')}<span class="text-white font-black">${s.coin}</span></div></td>
                        <td class="p-3 text-white">${s.amt.toFixed(4)}</td>
                        <td class="p-3 text-green-400 font-black">${s.apr}%</td>
                        <td class="p-3 text-right text-purple-400">+${earned.toFixed(6)} <span class="text-muted text-[8px]">${s.coin}</span></td>
                    </tr>`;
                }).join('');
            }
        }

        // --- 7. WALLET ACTIONS (STAKE/SWAP/SEND) ---
        function buildStakingGrid() {
            document.getElementById('staking-grid').innerHTML = STAKING_OPTS.map(opt => `
                <div class="glass-panel p-4 flex flex-col items-center cursor-pointer hover:border-green-500/50 transition hover:shadow-[0_0_15px_rgba(52,211,153,0.1)] group" onclick="openStakeModal('${opt.id}', ${opt.apr})">
                    <span class="text-[8px] bg-green-900/30 text-green-400 px-2 py-0.5 rounded mb-3 font-black uppercase tracking-widest border border-green-500/20">${opt.tag}</span>
                    ${getIconImg(opt.id, 'w-10 h-10 mb-2 group-hover:scale-110 transition-transform')}
                    <h3 class="text-base font-black text-white mb-1 tracking-widest">${opt.id}</h3>
                    <span class="text-xl font-mono font-black text-green-400">${opt.apr}%</span>
                </div>
            `).join('');
        }

        function openStakeModal(coin, apr) {
            document.getElementById('stake-modal-asset').innerText = coin; document.getElementById('stake-modal-apr').innerText = apr + '%';
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin] || 0);
            document.getElementById('stake-modal-avail').innerText = avail.toFixed(4); document.getElementById('stake-modal-avail').dataset.val = avail;
            document.getElementById('stake-amount').value = ''; document.getElementById('stake-amount').dataset.coin = coin; document.getElementById('stake-amount').dataset.apr = apr;
            toggleModal('stake-modal');
        }

        function confirmStake() {
            const el = document.getElementById('stake-amount'); const amt = parseFloat(el.value); const coin = el.dataset.coin;
            if(isNaN(amt) || amt <= 0 || amt > parseFloat(document.getElementById('stake-modal-avail').dataset.val)) return alert("Invalid amount.");
            if(coin === 'USDT') state.usdtBalance -= amt; else state.manualAssets[coin] -= amt;
            state.stakes.push({ coin, amt, apr: parseFloat(el.dataset.apr), time: Date.now() });
            saveState(); toggleModal('stake-modal'); updateWalletApp();
        }

        function prepSwapModal() {
            buildNativeSelects(); 
            document.getElementById('swap-asset-from').value = 'USDT'; document.getElementById('swap-asset-to').value = 'BTC';
            document.getElementById('swap-form-content').classList.remove('hidden'); document.getElementById('swap-animation').classList.add('hidden'); document.getElementById('swap-close-btn').classList.remove('hidden');
            updateSwapBals(); calcSwap();
        }

        function updateSwapBals() {
            let from = document.getElementById('swap-asset-from').value; let to = document.getElementById('swap-asset-to').value;
            document.getElementById('swap-bal-from').innerText = `Bal: ${(from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0)).toFixed(4)}`;
            document.getElementById('swap-bal-to').innerText = `Bal: ${(to === 'USDT' ? state.usdtBalance : (state.manualAssets[to]||0)).toFixed(4)}`;
        }

        function calcSwap() {
            let from = document.getElementById('swap-asset-from').value; let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            if(from === to) { document.getElementById('swap-amt-to').value = amt; document.getElementById('swap-rate-text').innerText = `1 ${from} = 1 ${to}`; return; }
            let priceFromUsd = from === 'USDT' ? 1 : (livePrices[from+'USDT'] || 1); let priceToUsd = to === 'USDT' ? 1 : (livePrices[to+'USDT'] || 1);
            let toAmt = (amt * priceFromUsd) / priceToUsd;
            document.getElementById('swap-amt-to').value = toAmt.toFixed(6);
            document.getElementById('swap-rate-text').innerText = `1 ${from} ≈ ${(priceFromUsd/priceToUsd).toFixed(6)} ${to}`;
        }

        function executeSwap() {
            let from = document.getElementById('swap-asset-from').value; let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0; let toAmt = parseFloat(document.getElementById('swap-amt-to').value) || 0;
            if(amt <= 0) return; let avail = from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0);
            if(amt > avail) return alert("Insufficient balance.");

            document.getElementById('swap-form-content').classList.add('hidden'); document.getElementById('swap-close-btn').classList.add('hidden');
            const anim = document.getElementById('swap-animation'); anim.classList.remove('hidden'); anim.classList.add('flex');
            anim.innerHTML = `<div class="spinner w-12 h-12 mb-4 border-[3px]"></div><p class="text-purple-400 font-black uppercase tracking-widest text-[10px] animate-pulse">Swapping on-chain...</p>`;

            setTimeout(() => {
                anim.innerHTML = `<svg class="w-16 h-16 text-green-500 mb-4 drop-shadow-[0_0_10px_rgba(34,197,94,0.4)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg><p class="text-green-500 font-black uppercase tracking-widest text-xs">Swap Successful</p>`;
                if(from === 'USDT') state.usdtBalance -= amt; else state.manualAssets[from] -= amt;
                if(to === 'USDT') state.usdtBalance += toAmt; else { if(!state.manualAssets[to]) state.manualAssets[to] = 0; state.manualAssets[to] += toAmt; }
                saveState(); setTimeout(() => { toggleModal('swap-modal'); updateWalletApp(); }, 1200);
            }, 1500);
        }

        function prepSendModal() {
            buildNativeSelects(); document.getElementById('send-asset').value = 'USDT'; updateSendMax();
            document.getElementById('send-form').classList.remove('hidden'); document.getElementById('send-processing').classList.add('hidden'); document.getElementById('send-close-btn').classList.remove('hidden');
        }

        function updateSendMax() {
            let coin = document.getElementById('send-asset').value; let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin]||0);
            document.getElementById('send-avail-txt').innerText = avail.toFixed(4);
        }

        function setMaxSend() { document.getElementById('send-amount').value = document.getElementById('send-avail-txt').innerText; }

        let sendInterval, sendTimeout;
        function initiateSend() {
            let asset = document.getElementById('send-asset').value; let addr = document.getElementById('send-address').value; let amt = parseFloat(document.getElementById('send-amount').value);
            if(!addr || addr.length < 10) return alert("Invalid destination address.");
            if(isNaN(amt) || amt <= 0 || amt > parseFloat(document.getElementById('send-avail-txt').innerText)) return alert("Invalid amount.");

            document.getElementById('send-form').classList.add('hidden'); document.getElementById('send-processing').classList.remove('hidden'); document.getElementById('send-processing').classList.add('flex'); document.getElementById('send-close-btn').classList.add('hidden'); 
            const logBox = document.getElementById('send-log'); logBox.innerHTML = '';
            
            const addLog = (msg, delay) => new Promise(res => { sendTimeout = setTimeout(() => { logBox.innerHTML += `<div>${msg}</div>`; logBox.scrollTop = logBox.scrollHeight; res(); }, delay); });

            document.getElementById('send-status-title').innerText = "Initiating...";
            (async function runFakeTx() {
                await addLog(`[SYS] Initiating contract call for ${amt} ${asset}...`, 500);
                await addLog(`[NET] Establishing secure RPC...`, 800);
                document.getElementById('send-status-title').innerText = "Awaiting Inclusion";
                await addLog(`[MEM] TX accepted. Broadcasting...`, 1500);
                await addLog(`[VAL] Block discovered. Checking consensus...`, 2000);
                document.getElementById('send-status-title').innerText = "Verification Pending";
                document.getElementById('send-status-title').classList.replace('text-purple-400', 'text-pink-400');
                await addLog(`<span class="text-pink-400 font-bold">[ERR] Validation stalled. Node mismatch.</span>`, 2000);
                document.getElementById('send-close-btn').classList.remove('hidden'); 
                sendInterval = setInterval(() => { logBox.innerHTML += `<div class="text-muted">[VAL] Retrying (Attempt ∞)...</div>`; logBox.scrollTop = logBox.scrollHeight; }, 3000);
            })();
        }
        function closeSendModal() { clearInterval(sendInterval); clearTimeout(sendTimeout); document.getElementById('send-status-title').classList.replace('text-pink-400', 'text-purple-400'); toggleModal('send-modal'); }

        function setUsdt() { const amt = parseFloat(document.getElementById('add-usdt-input').value); if(amt >= 0) { state.usdtBalance = amt; state.startOfDayValue = amt; document.getElementById('add-usdt-input').value = ''; saveState(); toggleModal('settings-modal'); } }
        function addManualAsset() {
            const n = document.getElementById('new-asset-name').value; const a = parseFloat(document.getElementById('new-asset-amt').value);
            if(n) { if (a <= 0 || isNaN(a)) { delete state.manualAssets[n]; } else { state.manualAssets[n] = a; } document.getElementById('new-asset-amt').value=''; saveState(); toggleModal('settings-modal'); }
        }

        function updateUI() { document.getElementById('ui-avail').innerText = state.usdtBalance.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT'; }
        function saveState() { localStorage.setItem('cloudquant_v3', JSON.stringify(state)); updateUI(); updateWalletApp(); }

        init();
    </script>
</body>
</html>
