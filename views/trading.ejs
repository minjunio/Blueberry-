        function toggleDropdown(id) {
            const el = document.getElementById(id);
            if(el) { el.classList.toggle('dropdown-hidden'); el.classList.toggle('dropdown-active'); }
        }

        // Close dropdowns when clicking outside
        document.addEventListener('click', (e) => {
            const dropdowns = ['term-dropdown', 'nav-currency-drop', 'alpha-tf-drop', 'send-asset-drop', 'swap-from-drop', 'swap-to-drop', 'settings-asset-drop'];
            dropdowns.forEach(id => {
                const drop = document.getElementById(id);
                if(drop && !e.target.closest(`#${id}`) && !e.target.closest(`[onclick="toggleDropdown('${id}')"]`)) {
                    drop.classList.add('dropdown-hidden'); drop.classList.remove('dropdown-active');
                }
            });
        });

        function buildTerminalDropdown() {
            const termDrop = document.getElementById('term-dropdown');
            termDrop.innerHTML = '';
            
