        document.getElementById('gemini-api-key').value = geminiApiKey;
        let lastAiUpdate = 0;
        let currentAISuggestion = null;

        function saveApiKey(val) {
            geminiApiKey = val;
            localStorage.setItem('gemini_api_key', val);
        }

        async function askGeminiForSignal(marketData) {
            if (!geminiApiKey) return;
            const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${geminiApiKey}`;

            const prompt = `
                You are a quantitative trading algorithm. Analyze this live market data for ${ui.pair}:
                Current Price: $${marketData.price.toFixed(4)}
                RSI (14): ${marketData.rsi.toFixed(1)}
                20 SMA: $${marketData.sma.toFixed(4)}
                Volatility (Price Range): $${marketData.vol.toFixed(2)}
                Buy Volume (15m Ratio): ${(marketData.flow15 * 100).toFixed(1)}%
                Whale Sentiment: ${(marketData.whaleSent * 100).toFixed(1)}%
                
                Rules for Short-Term (Scalp):
                - If RSI < 35 and Whale Sentiment > 50%, side = "buy", calculate TP (+2%) and SL (-1%).
                - If RSI > 65 and Whale Sentiment < 50%, side = "sell", calculate TP (-2%) and SL (+1%).
                - Otherwise side = "WAIT".
                
                Rules for Macro Trend (Swing):
                - If Price > SMA and Whale Sentiment > 60%, side = "buy", calculate TP (+10%) and SL (-4%).
                - If Price < SMA and Whale Sentiment < 40%, side = "sell", calculate TP (-10%) and SL (+4%).
                - Otherwise side = "WAIT".
                
                Output ONLY a valid JSON object in this exact format, with no markdown or text:
                {
                    "short": {"side": "buy|sell|WAIT", "conf": 0-100, "lev": 20, "tp": number, "sl": number},
                    "long": {"side": "buy|sell|WAIT", "conf": 0-100, "lev": 5, "tp": number, "sl": number}
                }
            `;

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        contents: [{ parts: [{ text: prompt }] }],
                        generationConfig: { responseMimeType: "application/json" }
                    })
                });

                const result = await response.json();
                if (result.candidates && result.candidates.length > 0) {
                    const aiText = result.candidates[0].content.parts[0].text;
                    const aiDecision = JSON.parse(aiText);
                    return aiDecision;
                }
            } catch (error) {
                console.error("Gemini API Error:", error);
            }
            return null;
        }

