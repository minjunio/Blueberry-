<!DOCTYPE html>
<html lang="en">
<head>
    <title>Binance Quant Terminal & Web3 Wallet</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <link rel="icon" type="image/png" href="https://cryptologos.cc/logos/bnb-bnb-logo.svg?v=029">
    
    <style>
        /* Binance Deep Dark Theme (Gold & Black) */
        body { background: #0b0e11; color: #EAECEF; font-family: 'Inter', system-ui, sans-serif; margin: 0; min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; }
        
        .glass-panel { background: #181a20; border: 1px solid #2b3139; border-radius: 0.5rem; box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
        .glass-overlay { background: #1e2329; border: 1px solid #2b3139; border-radius: 0.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.8); }
        
        .neo-input { background: #0b0e11; border: 1px solid #2b3139; color: white; outline: none; transition: 0.2s; cursor: pointer; border-radius: 0.5rem; }
        .neo-input:focus, .neo-input:hover { border-color: #F3BA2F; }
        
        .neo-btn { background: #2b3139; border: 1px solid #2b3139; color: #EAECEF; transition: 0.2s; cursor: pointer; border-radius: 0.5rem; }
        .neo-btn:hover { background: #323942; color: #F3BA2F; border-color: #F3BA2F; }
        .text-muted { color: #848E9C; }
        .text-accent { color: #F3BA2F; }
        .bg-accent { background: #F3BA2F; color: #0b0e11; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; cursor: pointer; }
        input[type=range]:focus { outline: none; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; background: #2b3139; border-radius: 2px; }
        input[type=range]::-webkit-slider-thumb { height: 16px; width: 16px; border-radius: 50%; background: #F3BA2F; -webkit-appearance: none; margin-top: -6px; transition: transform 0.1s; box-shadow: 0 0 5px rgba(243, 186, 47, 0.5); }
        input[type=range]::-webkit-slider-thumb:active { transform: scale(1.2); }

        .modal-overlay { transition: opacity 0.2s; }
        .modal-content { transition: transform 0.2s; }
        .modal-hidden { opacity: 0; pointer-events: none; }
        .modal-hidden .modal-content { transform: scale(0.98) translateY(5px); }
        .modal-active { opacity: 1; pointer-events: auto; }
        .modal-active .modal-content { transform: scale(1) translateY(0); }

        .tf-btn { padding: 4px 10px; border-radius: 4px; font-size: 10px; font-weight: 900; color: #848E9C; cursor: pointer; transition: 0.2s; }
        .tf-btn.active { background: rgba(243, 186, 47, 0.15); color: #F3BA2F; border: 1px solid #F3BA2F; }

        .dropdown-menu { transform-origin: top; transition: transform 0.2s ease, opacity 0.2s ease; z-index: 100; }
        .dropdown-hidden { transform: scaleY(0); opacity: 0; pointer-events: none; }
        .dropdown-active { transform: scaleY(1); opacity: 1; pointer-events: auto; }

        /* Dramatic Chart Pulses */
        @keyframes chartFlashUp { 0% { box-shadow: inset 0 0 80px rgba(14, 203, 129, 0.25); } 100% { box-shadow: inset 0 0 0px transparent; } }
        @keyframes chartFlashDown { 0% { box-shadow: inset 0 0 80px rgba(246, 70, 93, 0.25); } 100% { box-shadow: inset 0 0 0px transparent; } }
        .chart-up-pulse { animation: chartFlashUp 0.6s ease-out; border-color: rgba(14, 203, 129, 0.5) !important; }
        .chart-down-pulse { animation: chartFlashDown 0.6s ease-out; border-color: rgba(246, 70, 93, 0.5) !important; }

        @keyframes popupSlideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
        .bottom-popup { animation: popupSlideIn 0.2s ease-out forwards; transition: opacity 0.3s ease-out; }

        .code-area { font-family: 'Fira Code', monospace; line-height: 1.5; tab-size: 4; }
        .spinner { border: 3px solid rgba(243, 186, 47, 0.2); border-top-color: #F3BA2F; border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }

        .pro-table th { background: #0b0e11; border-bottom: 2px solid #2b3139; text-transform: uppercase; font-size: 9px; letter-spacing: 0.1em; color: #848E9C; padding: 10px 12px; }
        .pro-table td { border-bottom: 1px solid #2b3139; padding: 12px 12px; vertical-align: middle; }
        .pro-table tr:hover { background: rgba(243, 186, 47, 0.05); }

        /* Custom Checkmark Animation */
        .checkmark-circle { stroke-dasharray: 166; stroke-dashoffset: 166; stroke-width: 2; stroke-miterlimit: 10; stroke: #0ecb81; fill: none; animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards; }
        .checkmark { width: 56px; height: 56px; border-radius: 50%; display: block; stroke-width: 2; stroke: #0b0e11; stroke-miterlimit: 10; margin: 10% auto; box-shadow: inset 0px 0px 0px #0ecb81; animation: fill .4s ease-in-out .4s forwards, scale .3s ease-in-out .9s both; }
        .checkmark-check { transform-origin: 50% 50%; stroke-dasharray: 48; stroke-dashoffset: 48; stroke: #0b0e11; animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards; }
        @keyframes stroke { 100% { stroke-dashoffset: 0; } }
        @keyframes scale { 0%, 100% { transform: none; } 50% { transform: scale3d(1.1, 1.1, 1); } }
        @keyframes fill { 100% { box-shadow: inset 0px 0px 0px 30px #0ecb81; } }
        
        .up-color { color: #0ecb81; }
        .down-color { color: #f6465d; }
    </style>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <header class="flex flex-col shrink-0 z-50 sticky top-0 bg-[#0b0e11] border-b border-[#2b3139]">
        <div class="flex justify-between items-center p-3 md:p-4 max-w-[1600px] w-full mx-auto">
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <img src="https://cryptologos.cc/logos/bnb-bnb-logo.svg?v=029" class="w-8 h-8 p-1 bg-[#F3BA2F] rounded-full shadow-[0_0_10px_rgba(243,186,47,0.5)]">
                    <h2 class="text-xl font-black uppercase tracking-tighter text-white hidden sm:block">Binance <span class="text-[#F3BA2F]">Quant</span></h2>
                </div>
                <div class="flex gap-1 bg-[#181a20] border border-[#2b3139] p-1 rounded-md">
                    <button onclick="switchApp('terminal')" id="nav-terminal" class="px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-[#F3BA2F] text-[#0b0e11] transition shadow-[0_0_10px_rgba(243,186,47,0.3)]">Terminal</button>
                    <button onclick="switchApp('wallet')" id="nav-wallet" class="px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-white transition">Wallet</button>
                </div>
            </div>
            <div class="flex items-center gap-3">
                <button onclick="toggleModal('history-modal')" class="neo-btn px-4 py-2 rounded font-black text-[10px] uppercase tracking-widest flex items-center gap-2 text-[#F3BA2F] hover:bg-[#F3BA2F] hover:text-[#0b0e11]">History</button>
            </div>
        </div>
    </header>

    <div id="app-terminal" class="w-full">
        <main class="flex flex-col p-2 md:p-4 gap-4 w-full max-w-[1600px] mx-auto">
            
            <section class="glass-panel p-4 md:p-6 flex flex-col relative overflow-hidden bg-gradient-to-br from-[#181a20] to-[#0b0e11]">
                <div class="flex justify-between items-start z-10">
                    <div>
                        <div class="flex items-center gap-2 mb-2">
                            <svg class="w-4 h-4 text-[#F3BA2F]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                            <h1 class="text-xs font-bold uppercase tracking-widest text-gray-400">Total Account Net Value</h1>
                        </div>
                        <div class="flex items-end gap-2 flex-wrap">
                            <span id="hero-currency-sym" class="text-3xl md:text-4xl lg:text-5xl font-black text-[#F3BA2F] opacity-80">$</span>
                            <h2 id="hero-total-balance" class="text-4xl md:text-5xl lg:text-6xl font-black text-white font-mono tracking-tighter drop-shadow-lg">0.00</h2>
                            
                            <div class="relative ml-2 mb-2">
                                <div onclick="toggleDropdown('term-currency-drop')" class="flex items-center gap-1 cursor-pointer text-[#F3BA2F] hover:text-white transition font-black text-sm md:text-base uppercase border-b border-[#2b3139] pb-1">
                                    <span id="term-currency-text">USD</span>
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                                <div id="term-currency-drop" class="absolute top-full left-0 mt-1 w-24 glass-overlay py-1 dropdown-menu dropdown-hidden z-50">
                                    <div onclick="setCurrency('USD')" class="px-3 py-2 hover:bg-[#2b3139] cursor-pointer text-xs font-black uppercase text-white">🇺🇸 USD</div>
                                    <div onclick="setCurrency('AED')" class="px-3 py-2 hover:bg-[#2b3139] cursor-pointer text-xs font-black uppercase text-white">🇦🇪 AED</div>
                                    <div onclick="setCurrency('EUR')" class="px-3 py-2 hover:bg-[#2b3139] cursor-pointer text-xs font-black uppercase text-white">🇪🇺 EUR</div>
                                    <div onclick="setCurrency('GBP')" class="px-3 py-2 hover:bg-[#2b3139] cursor-pointer text-xs font-black uppercase text-white">🇬🇧 GBP</div>
                                    <div onclick="setCurrency('CAD')" class="px-3 py-2 hover:bg-[#2b3139] cursor-pointer text-xs font-black uppercase text-white">🇨🇦 CAD</div>
                                    <div onclick="setCurrency('AUD')" class="px-3 py-2 hover:bg-[#2b3139] cursor-pointer text-xs font-black uppercase text-white">🇦🇺 AUD</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="flex flex-col text-right">
                        <span id="hero-daily-pnl" class="text-sm font-black up-color tracking-wide drop-shadow">+ 0.00</span>
                        <span id="hero-daily-roi" class="text-[10px] font-black up-color bg-[#0ecb81]/10 px-2 py-0.5 rounded w-fit ml-auto mt-1 border border-[#0ecb81]/20">+0.00% Today</span>
                    </div>
                </div>
            </section>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
                <div class="lg:col-span-9 flex flex-col gap-4">
                    <div class="glass-panel p-3 md:p-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 border-l-4 border-l-[#F3BA2F]">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 rounded-full bg-[#F3BA2F] animate-pulse"></div>
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-[#F3BA2F]">AI Quant Logic Engine v5.0</h3>
                        </div>
                        <div class="flex flex-wrap items-center gap-3 md:gap-6 w-full md:w-auto">
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">RSI (14)</span><span id="ai-rsi" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">SMA (20)</span><span id="ai-sma" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">Trend Volatility</span><span id="ai-vol" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex items-center gap-2 ml-auto">
                                <span id="ai-signal" class="text-[10px] font-black uppercase px-2 py-1 rounded bg-[#F3BA2F]/20 text-[#F3BA2F] border border-[#F3BA2F]/30">ANALYZING</span>
                                <button onclick="toggleModal('ai-code-modal')" class="text-[9px] font-black uppercase tracking-widest text-white bg-[#2b3139] px-3 py-1.5 rounded hover:bg-[#F3BA2F] hover:text-[#0b0e11] transition">Edit Code</button>
                            </div>
                        </div>
                    </div>

                    <div class="glass-panel p-4 md:p-6 flex flex-col relative min-h-[55vh] transition-all duration-300 border border-transparent" id="main-chart-wrapper">
                        <div class="flex justify-between items-start z-20">
                            
                            <div class="relative w-fit">
                                <button onclick="toggleDropdown('term-dropdown')" class="neo-input px-3 py-2 rounded flex items-center gap-3 w-[160px] md:w-56 bg-[#0b0e11]">
                                    <img id="term-logo" src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-6 h-6 rounded-full bg-[#181a20] p-0.5">
                                    <span id="term-text" class="font-black text-sm uppercase">BTC/USDT</span>
                                    <svg class="w-4 h-4 ml-auto text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                <div id="term-dropdown" class="absolute top-full left-0 mt-1 w-full glass-overlay py-1 dropdown-menu dropdown-hidden z-50 max-h-[300px] overflow-y-auto no-scrollbar shadow-[0_15px_30px_rgba(0,0,0,0.8)] border-[#2b3139]"></div>
                            </div>

                            <div class="flex flex-wrap bg-[#0b0e11] p-1 rounded border border-[#2b3139] justify-end max-w-[50%] sm:max-w-full">
                                <div class="tf-btn" onclick="setTimeframe('live')" id="tf-live">LIVE</div>
                                <div class="tf-btn" onclick="setTimeframe('1m')" id="tf-1m">1m</div>
                                <div class="tf-btn active" onclick="setTimeframe('5m')" id="tf-5m">5m</div>
                                <div class="tf-btn" onclick="setTimeframe('1h')" id="tf-1h">1H</div>
                                <div class="tf-btn" onclick="setTimeframe('7d')" id="tf-7d">7D</div>
                                <div class="tf-btn" onclick="setTimeframe('1y')" id="tf-1y">1Y</div>
                                <div class="tf-btn" onclick="setTimeframe('max')" id="tf-max">MAX</div>
                            </div>
                        </div>

                        <div class="flex flex-wrap justify-between gap-4 sm:gap-6 mt-4 z-10 border-b border-[#2b3139] pb-3 items-end">
                            <div class="flex gap-4 sm:gap-6 shrink-0">
                                <div class="flex flex-col"><span class="text-[9px] text-muted uppercase tracking-widest">High</span><p class="text-xs font-mono up-color font-black" id="stat-high">--</p></div>
                                <div class="flex flex-col"><span class="text-[9px] text-muted uppercase tracking-widest">Low</span><p class="text-xs font-mono down-color font-black" id="stat-low">--</p></div>
                            </div>
                            <div class="flex-grow flex justify-end items-end pointer-events-none min-w-0">
                                <h2 id="main-price" class="text-4xl sm:text-5xl md:text-6xl font-black text-white font-mono tracking-tighter leading-none truncate text-right max-w-full drop-shadow-md transition-colors duration-200">--</h2>
                            </div>
                        </div>

                        <div class="flex-grow mt-2 relative w-full h-full min-h-[300px] cursor-crosshair overflow-hidden rounded" id="canvas-container">
                            <canvas id="custom-chart" class="absolute inset-0 w-full h-full"></canvas>
                            <div id="chart-popups-container" class="absolute bottom-2 left-2 flex flex-col-reverse gap-1.5 z-30 pointer-events-none overflow-hidden max-h-[250px]"></div>
                        </div>
                    </div>

                    <div class="glass-panel flex flex-col min-h-[25vh]">
                        <div class="flex justify-between items-center p-3 border-b border-[#2b3139] shrink-0 bg-[#181a20] rounded-t">
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-[#F3BA2F]">Active Positions</h3>
                        </div>
                        <div class="flex-grow overflow-x-auto no-scrollbar bg-[#0b0e11]/50 rounded-b">
                            <table class="w-full text-left border-collapse min-w-[700px] pro-table">
                                <thead class="sticky top-0 z-10">
                                    <tr>
                                        <th>Asset</th><th>Side/Lev</th><th>Entry Price</th><th>Mark Price</th><th>Margin</th><th>Size (USDT)</th><th class="text-right">ROI / PnL</th><th class="text-center">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="orders-body" class="text-[10px] font-bold text-white font-mono"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-3 flex flex-col gap-4">
                    <div class="glass-panel p-5 flex flex-col relative z-10">
                        <h3 class="text-[10px] font-black uppercase tracking-widest text-muted mb-4 border-b border-[#2b3139] pb-2">Manual Execution</h3>
                        
                        <div class="flex gap-2 bg-[#0b0e11] p-1 border border-[#2b3139] rounded mb-5">
                            <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest bg-[#0ecb81]/20 text-[#0ecb81] border border-[#0ecb81]/50 transition">Long</button>
                            <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-[#f6465d] transition">Short</button>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <div class="flex justify-between mb-1.5">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted">Margin (USDT)</label>
                                    <span class="text-[10px] font-black text-[#F3BA2F] cursor-pointer hover:text-white" onclick="setMax()">MAX</span>
                                </div>
                                <input type="number" id="trade-margin" placeholder="0.00" class="w-full neo-input p-3 rounded text-lg font-black font-mono text-center">
                            </div>

                            <div>
                                <div class="flex justify-between mb-3">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted">Leverage</label>
                                    <span class="text-[10px] font-black text-white bg-[#2b3139] px-2 py-0.5 rounded border border-[#2b3139]"><span id="lev-val">10</span>x</span>
                                </div>
                                <input type="range" id="trade-lev" min="1" max="100" value="10" class="w-full">
                                <div class="flex justify-between text-[8px] font-black text-muted mt-2 px-1">
                                    <span>1x</span><span>50x</span><span>100x</span>
                                </div>
                            </div>

                            <div class="p-3 bg-[#0b0e11] border border-[#2b3139] rounded space-y-2 mt-4">
                                <div class="flex justify-between text-[10px] font-black uppercase">
                                    <span class="text-muted">Available</span>
                                    <span class="text-white font-mono" id="ui-avail">0.00</span>
                                </div>
                                <div class="flex justify-between text-[10px] font-black uppercase border-t border-[#2b3139] pt-2">
                                    <span class="text-muted">Position Size</span>
                                    <span class="text-[#F3BA2F] font-mono" id="ui-size">0.00</span>
                                </div>
                            </div>
                        </div>

                        <button onclick="executeOrder()" id="btn-execute" class="mt-4 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-[#0ecb81] text-[#0b0e11] hover:opacity-90 transition active:scale-95 shadow-[0_0_15px_rgba(14,203,129,0.3)]">
                            Execute Long
                        </button>
                    </div>

                    <div class="glass-panel p-5 flex flex-col flex-grow relative z-10">
                        <div class="flex justify-between items-center mb-3 border-b border-[#2b3139] pb-2">
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-muted">On-Chain Alpha</h3>
                            <div class="relative w-20">
                                <div onclick="toggleDropdown('alpha-tf-drop')" class="neo-input px-2 py-1 rounded flex justify-between items-center text-[9px] font-black uppercase text-[#F3BA2F]">
                                    <span id="alpha-tf-text">24H</span>
                                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </div>
                                <div id="alpha-tf-drop" class="absolute top-full right-0 mt-1 w-full glass-overlay py-1 dropdown-menu dropdown-hidden z-50">
                                    <div onclick="setAlphaTimeframe('300000', '5M')" class="px-2 py-1 hover:bg-[#2b3139] cursor-pointer text-[9px] font-black uppercase text-white">5 Mins</div>
                                    <div onclick="setAlphaTimeframe('900000', '15M')" class="px-2 py-1 hover:bg-[#2b3139] cursor-pointer text-[9px] font-black uppercase text-white">15 Mins</div>
                                    <div onclick="setAlphaTimeframe('3600000', '1H')" class="px-2 py-1 hover:bg-[#2b3139] cursor-pointer text-[9px] font-black uppercase text-white">1 Hour</div>
                                    <div onclick="setAlphaTimeframe('18000000', '5H')" class="px-2 py-1 hover:bg-[#2b3139] cursor-pointer text-[9px] font-black uppercase text-white">5 Hours</div>
                                    <div onclick="setAlphaTimeframe('86400000', '24H')" class="px-2 py-1 hover:bg-[#2b3139] cursor-pointer text-[9px] font-black uppercase text-white">24 Hours</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <h4 class="text-[9px] font-bold uppercase tracking-widest up-color mb-2 border-b border-[#0ecb81]/20 pb-1 flex justify-between"><span>Top Purchases</span> <span id="lbl-buy-tf">24H</span></h4>
                            <div id="ui-top-buys" class="space-y-1.5"></div>
                        </div>
                        
                        <div class="mb-4">
                            <h4 class="text-[9px] font-bold uppercase tracking-widest down-color mb-2 border-b border-[#f6465d]/20 pb-1 flex justify-between"><span>Top Sells</span> <span id="lbl-sell-tf">24H</span></h4>
                            <div id="ui-top-sells" class="space-y-1.5"></div>
                        </div>

                        <div class="mt-auto">
                            <h4 class="text-[9px] font-bold uppercase tracking-widest text-[#F3BA2F] mb-2 border-b border-[#F3BA2F]/20 pb-1">Whale Tracker</h4>
                            <div id="ui-top-holders" class="flex flex-col gap-2"></div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="app-wallet" class="w-full hidden bg-[#0b0e11] min-h-screen">
        <main class="flex flex-col p-4 md:p-6 gap-8 w-full max-w-[1200px] mx-auto">
            
