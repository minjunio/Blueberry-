    <script>
        // --- 1. CORE STATE & ROUTING ---
        const ASSETS = [
            { id: 'BTCUSDT', name: 'BTC/USDT', icon: 'bitcoin-btc-logo.svg?v=029', coin: 'BTC' }, 
            { id: 'ETHUSDT', name: 'ETH/USDT', icon: 'ethereum-eth-logo.svg?v=029', coin: 'ETH' },
            { id: 'SOLUSDT', name: 'SOL/USDT', icon: 'solana-sol-logo.svg?v=029', coin: 'SOL' }, 
            { id: 'BNBUSDT', name: 'BNB/USDT', icon: 'bnb-bnb-logo.svg?v=029', coin: 'BNB' },
            { id: 'XRPUSDT', name: 'XRP/USDT', icon: 'xrp-xrp-logo.svg?v=029', coin: 'XRP' },
            { id: 'DOGEUSDT', name: 'DOGE/USDT', icon: 'dogecoin-doge-logo.svg?v=029', coin: 'DOGE' }, 
            { id: 'ADAUSDT', name: 'ADA/USDT', icon: 'cardano-ada-logo.svg?v=029', coin: 'ADA' },
            { id: 'DOTUSDT', name: 'DOT/USDT', icon: 'polkadot-new-dot-logo.svg?v=029', coin: 'DOT' }, 
            { id: 'MATICUSDT', name: 'MATIC/USDT', icon: 'polygon-matic-logo.svg?v=029', coin: 'MATIC' },
            { id: 'AVAXUSDT', name: 'AVAX/USDT', icon: 'avalanche-avax-logo.svg?v=029', coin: 'AVAX' }
        ];

        const STAKING_OPTS = [
            { id: 'ATOM', apr: 14.5, tag: 'High Yield' }, { id: 'DOT', apr: 11.8, tag: 'Hot' },
            { id: 'SOL', apr: 8.5, tag: 'Popular' }, { id: 'AVAX', apr: 6.5, tag: 'Stable' },
            { id: 'ETH', apr: 4.2, tag: 'Secure' }, { id: 'ADA', apr: 3.5, tag: 'Safe' }
        ];

        const FX_RATES = { USD: 1, AED: 3.67, EUR: 0.92, GBP: 0.79, CAD: 1.36, AUD: 1.52 };
        const FX_SYM = { USD: '$', AED: 'د.إ', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$' };

        const defaultAI = `// --- AI Logic (Return BUY/SELL/NEUTRAL) ---\nlet score = 0;\nif (rsi > 70) score -= 2;\nif (rsi < 30) score += 2;\nif (score > 1) return "STRONG BUY";\nif (score < -1) return "STRONG SELL";\nreturn "NEUTRAL";`;

        const defaultHolders = [
            {addr: "0x3f9A...8cA1", usd: 1450000, lastAction: "ACCUMULATING", amt: 0},
            {addr: "0x88bC...11C9", usd: 1120000, lastAction: "HOLDING", amt: 0},
            {addr: "0x1aF2...E4F2", usd: 890000, lastAction: "HOLDING", amt: 0},
            {addr: "0x7cE4...00B1", usd: 760000, lastAction: "HOLDING", amt: 0},
            {addr: "0x99D1...FA00", usd: 450000, lastAction: "DISTRIBUTING", amt: 0}
        ];

        let state = JSON.parse(localStorage.getItem('cloudquant_v3')) || {
            usdtBalance: 15000.00, startOfDayValue: 15000.00, orders: [], history: [], manualAssets: { 'BTC': 0.15, 'ETH': 3.0, 'DOT': 150 }, 
            stakes: [], aiLogic: defaultAI, currency: 'USD', globalTradeLogs: [], topHoldersSim: defaultHolders, lastRunTime: Date.now()
        };
        
        let livePrices = {}; 
        let ui = { side: 'buy', pair: 'BTCUSDT', price: 0, lastPrice: 0, lev: 10, timeframe: '5m', chartData: [], logFilter: 'all', alphaTfMs: 86400000 };
        let wsTicker, wsTrade, chartCtx;
        let flowData = { buy: 0, sell: 0 };
        let canvasHoverPos = null; 
        let isShowingAllAssets = false;

        function switchApp(appName) {
            document.getElementById('app-terminal').style.display = appName === 'terminal' ? 'block' : 'none';
            document.getElementById('app-wallet').style.display = appName === 'wallet' ? 'block' : 'none';
            
            document.getElementById('nav-terminal').className = appName === 'terminal' ? "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-purple-600 text-white transition shadow-lg" : "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-white transition";
            document.getElementById('nav-wallet').className = appName === 'wallet' ? "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-purple-600 text-white transition shadow-lg" : "px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-white transition";
            
            if(appName === 'terminal') { setTimeout(setupCanvas, 50); drawChart(); }
            if(appName === 'wallet') updateWalletApp();
        }

        function init() {
            document.getElementById('currency-select').value = state.currency || 'USD';
            document.getElementById('wallet-currency').value = state.currency || 'USD';
            buildTerminalDropdown(); buildNativeSelects();
            document.getElementById('ai-logic-editor').value = state.aiLogic;
            setupCanvas();
            connectGlobalTickerStream(); // !ticker@arr for all prices
            connectGlobalTradeStream();  // Trade flows and Whales
            triggerPairChange(); 
            updateUI(); renderOrders(); renderHistory(); buildStakingGrid();
            setInterval(updateWalletSystem, 1000);
            
            // Sim BG data
            const missedTime = Date.now() - state.lastRunTime;
            if(missedTime > 60000) setTimeout(() => { if(ui.price > 0) generateBackgroundData(ui.pair, ui.price, missedTime); }, 1500);
        }

        // --- 2. HELPERS & ICONS ---
        function getIconPath(coin) {
            if (coin === 'USDT') return 'https://cryptologos.cc/logos/tether-usdt-logo.svg?v=029';
            const a = ASSETS.find(x => x.id.replace('USDT','') === coin || x.coin === coin);
            if (a) return `https://cryptologos.cc/logos/${a.icon}`;
            return `https://ui-avatars.com/api/?name=${coin}&background=0D0814&color=A78BFA&rounded=true`;
        }

        function getIconImg(coin, cls) {
            let extraCls = coin === 'DOT' ? 'dot-spin' : (coin === 'ETH' ? 'eth-pulse' : '');
            return `<img src="${getIconPath(coin)}" class="${cls} ${extraCls} rounded-full bg-[#1e2329] p-0.5 shadow-md">`;
        }

        function setCurrency(c) {
            state.currency = c; 
            document.getElementById('currency-select').value = c;
            document.getElementById('wallet-currency').value = c;
            saveState(); updateWalletSystem(); updateWalletApp();
        }

        function toggleDropdown(id) {
            const el = document.getElementById(id);
            if(el) { el.classList.toggle('dropdown-hidden'); el.classList.toggle('dropdown-active'); }
        }

        document.addEventListener('click', (e) => {
            const drop = document.getElementById('term-dropdown');
            if(drop && !e.target.closest('#term-dropdown') && !e.target.closest(`[onclick="toggleDropdown('term-dropdown')"]`)) {
                drop.classList.add('dropdown-hidden'); drop.classList.remove('dropdown-active');
            }
        });

        function toggleModal(id) {
            const el = document.getElementById(id);
            el.classList.toggle('modal-hidden'); el.classList.toggle('modal-active');
            if(id === 'swap-modal' && el.classList.contains('modal-active')) prepSwapModal();
            if(id === 'send-modal' && el.classList.contains('modal-active')) prepSendModal();
            if(id === 'settings-modal' && el.classList.contains('modal-active')) buildNativeSelects(); 
        }

        function buildTerminalDropdown() {
            const termDrop = document.getElementById('term-dropdown');
            termDrop.innerHTML = ASSETS.map(a => `
                <div onclick="selectPair('${a.id}', '${a.name}', '${a.coin}')" class="px-4 py-2 hover:bg-purple-900/40 cursor-pointer flex items-center gap-3 transition">
                    <img src="${getIconPath(a.coin)}" class="w-5 h-5 rounded-full bg-[#1e2329] p-0.5">
                    <span class="text-xs font-black uppercase text-white">${a.name}</span>
                </div>
            `).join('');
        }

        function selectPair(id, name, coin) {
            ui.pair = id; 
            document.getElementById('term-text').innerText = name; 
            document.getElementById('term-logo').src = getIconPath(coin); 
            toggleDropdown('term-dropdown'); 
            triggerPairChange();
        }

        function buildNativeSelects() {
            const sels = ['send-asset', 'swap-asset-from', 'swap-asset-to', 'new-asset-name'];
            
            let availOpts = `<option value="USDT">USDT</option>`;
            for(const c in state.manualAssets) { if(state.manualAssets[c] > 0) availOpts += `<option value="${c}">${c}</option>`; }
            
            let allOpts = `<option value="USDT">USDT</option>`;
            ASSETS.forEach(a => { if(a.coin !== 'USDT') allOpts += `<option value="${a.coin}">${a.coin}</option>`; });

            document.getElementById('send-asset').innerHTML = availOpts;
            document.getElementById('swap-asset-from').innerHTML = availOpts;
            document.getElementById('swap-asset-to').innerHTML = allOpts;
            document.getElementById('new-asset-name').innerHTML = allOpts;
        }

        // --- 3. STREAMS & DATA ---
        function connectGlobalTickerStream() {
            if(wsTicker) wsTicker.close();
            wsTicker = new WebSocket('wss://stream.binance.com:9443/ws/!ticker@arr');
            wsTicker.onmessage = (e) => {
                const data = JSON.parse(e.data);
                data.forEach(t => {
                    livePrices[t.s] = parseFloat(t.c);
                    if(t.s === ui.pair) processMainTick(parseFloat(t.c));
                });
            };
            wsTicker.onclose = () => setTimeout(connectGlobalTickerStream, 3000);
        }

        function connectGlobalTradeStream() {
            let tradeStreams = ['btcusdt@aggTrade', 'ethusdt@aggTrade', 'solusdt@aggTrade', 'dogeusdt@aggTrade'];
            if(wsTrade) wsTrade.close();
            wsTrade = new WebSocket(`wss://stream.binance.com:9443/stream?streams=${tradeStreams.join('/')}`);
            
            wsTrade.onmessage = (e) => {
                const payload = JSON.parse(e.data);
                if(payload.data && payload.data.e === 'aggTrade') {
                    const data = payload.data;
                    const price = parseFloat(data.p), qty = parseFloat(data.q);
                    const isBuy = !data.m, usdVal = price * qty;
                    const pair = data.s;

                    if(usdVal < 1000) return; 

                    const logItem = { addr: '0x' + Math.random().toString(16).substring(2, 8).toUpperCase(), isBuy, qty, price, usdVal, pair, time: Date.now() };

                    state.globalTradeLogs.unshift(logItem);
                    if(state.globalTradeLogs.length > 1500) state.globalTradeLogs.pop(); 
                    
                    if(Math.random() < 0.05) saveState(); 

                    if(pair === ui.pair) {
                        if(isBuy) flowData.buy += usdVal; else flowData.sell += usdVal;
                        updateRatioBar(); renderOnChainAlpha(); renderGlobalLogs();

                        if(usdVal >= 25000) spawnBottomLeftPopup(isBuy, qty, price, usdVal);
                        
                        // Whale tracking logic
                        if(usdVal > 150000) {
                            let rndHolder = state.topHoldersSim[Math.floor(Math.random() * state.topHoldersSim.length)];
                            if(isBuy) { rndHolder.usd += usdVal; rndHolder.lastAction = "BUY"; } 
                            else { rndHolder.usd -= usdVal; rndHolder.lastAction = "SELL"; }
                            rndHolder.amt = Math.round(usdVal);
                            state.topHoldersSim.sort((a,b)=>b.usd - a.usd);
                            renderTopHolders();
                        }
                    }
                }
            };
            wsTrade.onclose = () => setTimeout(connectGlobalTradeStream, 3000); 
        }

