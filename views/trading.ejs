                    <span class="text-[8px] bg-[#0ecb81]/10 text-[#0ecb81] px-2 py-1 rounded-full mb-4 border border-[#0ecb81]/20 font-black uppercase tracking-widest relative z-10">${opt.tag}</span>
                    <img src="${imgSrc}" class="w-12 h-12 mb-3 bg-[#0b0e11] rounded-full p-1.5 shadow-md border border-[#2b3139] group-hover:scale-110 transition-transform relative z-10">
