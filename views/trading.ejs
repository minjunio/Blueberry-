<!DOCTYPE html>
<html lang="en">
<head>
    <title>BlueCrypto Pro Terminal</title>
    <%- include('partials/head') %>
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <style>
        .glass-card { background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px); border: 1px solid rgba(59, 130, 246, 0.1); }
        .trading-glow { box-shadow: 0 0 20px rgba(59, 130, 246, 0.15); }
        .neon-text-green { color: #00ff88; text-shadow: 0 0 5px rgba(0,255,136,0.5); }
    </style>
</head>
<body class="bg-[#f0f5ff] min-h-screen font-sans text-slate-800">

    <div class="max-w-[1600px] mx-auto p-4 md:p-6">
        <div class="flex flex-col lg:flex-row gap-6 mb-6">
            
            <div class="lg:w-1/3 glass-card rounded-[2rem] p-8 trading-glow bg-gradient-to-br from-blue-600 to-blue-800 text-white relative overflow-hidden">
                <div class="relative z-10">
                    <div class="flex justify-between items-start mb-8">
                        <div>
                            <p class="text-blue-100 font-bold uppercase tracking-wider text-xs">Total Balance</p>
                            <h1 class="text-4xl font-black mt-1">$88,000.00 <span class="text-lg font-medium opacity-80">USDT</span></h1>
                        </div>
                        <button onclick="toggleSettings()" class="bg-white/20 p-3 rounded-2xl hover:bg-white/30 transition">
                            ⚙️
                        </button>
                    </div>
                    
                    <div class="flex gap-4">
                        <div class="bg-white/10 p-4 rounded-2xl flex-1 border border-white/10">
                            <p class="text-[10px] uppercase font-bold opacity-70">Active Assets</p>
                            <p class="text-xl font-bold">12 Tokens</p>
                        </div>
                        <div class="bg-white/10 p-4 rounded-2xl flex-1 border border-white/10">
                            <p class="text-[10px] uppercase font-bold opacity-70">24h Profit</p>
                            <p class="text-xl font-bold text-green-300">+$2,410.20</p>
                        </div>
                    </div>
                </div>
                <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-white/10 rounded-full blur-3xl"></div>
            </div>

            <div class="lg:w-2/3 glass-card rounded-[2rem] p-6 flex flex-col justify-center">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4" id="ticker-container">
                    <div class="p-4 border-r border-gray-100">
                        <p class="text-xs font-bold text-gray-400">BTC/USDT</p>
                        <p id="btc-price" class="text-xl font-black text-blue-600">Loading...</p>
                    </div>
                    <div class="p-4 border-r border-gray-100">
                        <p class="text-xs font-bold text-gray-400">ETH/USDT</p>
                        <p id="eth-price" class="text-xl font-black text-blue-600">Loading...</p>
                    </div>
                    <div class="p-4 border-r border-gray-100">
                        <p class="text-xs font-bold text-gray-400">SOL/USDT</p>
                        <p id="sol-price" class="text-xl font-black text-blue-600">Loading...</p>
                    </div>
                    <div class="p-4">
                        <p class="text-xs font-bold text-gray-400">Market Status</p>
                        <p class="text-xl font-black text-green-500 flex items-center gap-2">
                            LIVE <span class="relative flex h-3 w-3"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span><span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span></span>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-4 gap-6">
            
            <div class="xl:col-span-3 space-y-6">
                <div class="glass-card rounded-[2rem] p-6 h-[500px] overflow-hidden">
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="font-black text-xl flex items-center gap-2">
                            <span class="p-2 bg-blue-100 rounded-lg">📊</span> Market Analysis
                        </h2>
                        <div class="flex gap-2">
                            <button class="px-4 py-1 bg-blue-600 text-white rounded-lg text-xs font-bold">1H</button>
                            <button class="px-4 py-1 bg-gray-100 rounded-lg text-xs font-bold">4H</button>
                            <button class="px-4 py-1 bg-gray-100 rounded-lg text-xs font-bold">1D</button>
                        </div>
                    </div>
                    <div id="chart-container" class="w-full h-[400px]"></div>
                </div>

                <div class="glass-card rounded-[2rem] p-8">
                    <h2 class="font-black text-xl mb-6">🤖 Smart DCA Algorithmic Bot</h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div>
                            <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Bot Algorithm</label>
                            <select class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500">
                                <option>Mean Reversion Pro</option>
                                <option>Aggressive Momentum</option>
                                <option>Conservative Growth</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-bold text-gray-400 mb-2 uppercase">Leverage</label>
                            <input type="range" min="1" max="100" value="10" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-600" id="levRange">
                            <p class="text-right font-black text-blue-600 mt-1" id="levValue">10x</p>
                        </div>
                        <div class="flex items-end">
                            <button class="w-full bg-black text-white py-3 rounded-xl font-black hover:bg-blue-700 transition">DEPLOY BOT</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="space-y-6">
                <div class="glass-card rounded-[2rem] p-6">
                    <div class="flex border-b border-gray-100 mb-6">
                        <button class="flex-1 pb-4 text-green-500 font-black border-b-2 border-green-500">BUY</button>
                        <button class="flex-1 pb-4 text-gray-400 font-black">SELL</button>
                    </div>
                    
                    <div class="space-y-4">
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase">Pair</label>
                            <div class="flex items-center justify-between bg-gray-50 p-3 rounded-xl border border-gray-100 mt-1">
                                <span class="font-black">BTC / USDT</span>
                                <span class="text-blue-600 font-bold text-xs">Switch</span>
                            </div>
                        </div>
                        <div>
                            <label class="text-[10px] font-black text-gray-400 uppercase">Amount (USDT)</label>
                            <input type="number" placeholder="0.00" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold mt-1">
                        </div>
                        <button class="w-full bg-green-500 text-white py-4 rounded-2xl font-black text-lg shadow-lg shadow-green-200 hover:scale-[1.02] transition">Execute Trade</button>
                    </div>
                </div>

                <div id="settings-panel" class="glass-card rounded-[2rem] p-6 hidden">
                    <h3 class="font-black text-lg mb-4">Manage Portfolio</h3>
                    <div class="space-y-3">
                        <div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl">
                            <span class="font-bold">Bitcoin</span>
                            <button class="text-red-500 font-black">Remove</button>
                        </div>
                        <div class="flex justify-between items-center p-3 bg-gray-50 rounded-xl">
                            <span class="font-bold">Ethereum</span>
                            <button class="text-red-500 font-black">Remove</button>
                        </div>
                        <button class="w-full py-2 border-2 border-dashed border-gray-200 rounded-xl font-bold text-gray-400 hover:border-blue-400 hover:text-blue-400 transition">+ Add Currency</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- REAL TIME PRICE FEED (Binance WebSocket) ---
        const btcPrice = document.getElementById('btc-price');
        const ethPrice = document.getElementById('eth-price');
        const solPrice = document.getElementById('sol-price');

        const ws = new WebSocket('wss://stream.binance.com:9443/ws/btcusdt@ticker/ethusdt@ticker/solusdt@ticker');

        ws.onmessage = (event) => {
            const data = JSON.parse(event.data);
            const price = parseFloat(data.c).toLocaleString(undefined, {minimumFractionDigits: 2});
            
            if(data.s === 'BTCUSDT') btcPrice.innerText = `$${price}`;
            if(data.s === 'ETHUSDT') ethPrice.innerText = `$${price}`;
            if(data.s === 'SOLUSDT') solPrice.innerText = `$${price}`;
        };

        // --- CUSTOM TRADING CHART ---
        const chart = LightweightCharts.createChart(document.getElementById('chart-container'), {
            layout: { backgroundColor: 'transparent', textColor: '#64748b' },
            grid: { vertLines: { color: '#f1f5f9' }, horzLines: { color: '#f1f5f9' } },
            crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
            rightPriceScale: { borderColor: '#f1f5f9' },
            timeScale: { borderColor: '#f1f5f9' },
        });
        const lineSeries = chart.addLineSeries({ color: '#2563eb', lineWidth: 3 });
        
        // Mock data for chart
        lineSeries.setData([
            { time: '2026-04-20', value: 62000 },
            { time: '2026-04-21', value: 64500 },
            { time: '2026-04-22', value: 63800 },
            { time: '2026-04-23', value: 66200 },
        ]);

        // Interface Logic
        function toggleSettings() {
            const panel = document.getElementById('settings-panel');
            panel.classList.toggle('hidden');
        }

        const levRange = document.getElementById('levRange');
        const levValue = document.getElementById('levValue');
        levRange.oninput = function() { levValue.innerText = this.value + 'x'; }
    </script>
</body>
</html>
