<!DOCTYPE html>
<html lang="en">
<head>
    <title>CloudCrypto Quant Terminal</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <link rel="icon" type="image/png" href="/favicon.png">
    
    <style>
        /* Flat Deep Quant Purple Theme (NO NEON) */
        body { background: #05020a; color: #f8fafc; font-family: 'Inter', system-ui, sans-serif; margin: 0; min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; }
        
        .glass-panel { background: rgba(13, 8, 20, 0.95); border: 1px solid rgba(139, 92, 246, 0.2); border-radius: 0.5rem; }
        .glass-overlay { background: #0a0510; border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 0.5rem; }
        
        .neo-input { background: rgba(5, 2, 10, 0.8); border: 1px solid rgba(139, 92, 246, 0.3); color: white; outline: none; transition: 0.2s; cursor: pointer; border-radius: 0.5rem; }
        .neo-input:focus, .neo-input:hover { border-color: #a78bfa; }
        
        .neo-btn { background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.3); color: #ddd; transition: 0.2s; cursor: pointer; border-radius: 0.5rem; }
        .neo-btn:hover { background: rgba(139, 92, 246, 0.3); color: white; border-color: #a78bfa; }
        .text-muted { color: #8b839e; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; cursor: pointer; }
        input[type=range]:focus { outline: none; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; background: rgba(139, 92, 246, 0.2); border-radius: 2px; }
        input[type=range]::-webkit-slider-thumb { height: 16px; width: 16px; border-radius: 50%; background: #a78bfa; -webkit-appearance: none; margin-top: -6px; transition: transform 0.1s; }
        input[type=range]::-webkit-slider-thumb:active { transform: scale(1.2); }

        .modal-overlay { transition: opacity 0.2s; }
        .modal-content { transition: transform 0.2s; }
        .modal-hidden { opacity: 0; pointer-events: none; }
        .modal-hidden .modal-content { transform: scale(0.98) translateY(5px); }
        .modal-active { opacity: 1; pointer-events: auto; }
        .modal-active .modal-content { transform: scale(1) translateY(0); }

        .tf-btn { padding: 4px 10px; border-radius: 4px; font-size: 10px; font-weight: 900; color: #8b839e; cursor: pointer; transition: 0.2s; }
        .tf-btn.active { background: rgba(167, 139, 250, 0.2); color: #a78bfa; border: 1px solid #a78bfa; }

        .dropdown-menu { transform-origin: top; transition: transform 0.2s ease, opacity 0.2s ease; z-index: 100; }
        .dropdown-hidden { transform: scaleY(0); opacity: 0; pointer-events: none; }
        .dropdown-active { transform: scaleY(1); opacity: 1; pointer-events: auto; }

        @keyframes megaPump { 0% { background-color: rgba(52, 211, 153, 0.15); } 100% { background-color: transparent; } }
        @keyframes megaDump { 0% { background-color: rgba(251, 113, 133, 0.15); } 100% { background-color: transparent; } }
        .flash-mega-pump { animation: megaPump 0.8s ease-out; border-color: #34d399 !important; }
        .flash-mega-dump { animation: megaDump 0.8s ease-out; border-color: #fb7185 !important; }

        @keyframes popupSlideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
        .bottom-popup { animation: popupSlideIn 0.2s ease-out forwards; transition: opacity 0.3s ease-out; }

        .code-area { font-family: 'Fira Code', monospace; line-height: 1.5; tab-size: 4; }
    </style>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <header class="flex flex-col shrink-0 z-50 sticky top-0 bg-[#05020a] border-b border-purple-900/40">
        <div class="flex justify-between items-center p-3 md:p-4 max-w-[1600px] w-full mx-auto">
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded bg-purple-600 flex items-center justify-center">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <h2 class="text-lg font-black uppercase tracking-tighter text-white hidden sm:block">Cloud<span class="text-purple-400">Quant</span></h2>
                </div>
                <div class="flex gap-1 bg-[#05020a] border border-purple-900/50 p-1 rounded-md">
                    <button onclick="switchApp('terminal')" id="nav-terminal" class="px-3 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-purple-600 text-white transition">Terminal</button>
                    <button onclick="switchApp('bot')" id="nav-bot" class="px-3 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-white transition">DCA Bots</button>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button onclick="toggleModal('history-modal')" class="neo-btn px-3 py-2 rounded font-black text-[10px] uppercase tracking-widest flex items-center gap-2">History</button>
            </div>
        </div>
    </header>

    <div id="app-terminal" class="w-full">
        <main class="flex flex-col p-2 md:p-4 gap-4 w-full max-w-[1600px] mx-auto">
            
            <section class="glass-panel p-4 md:p-6 flex flex-col relative overflow-hidden">
                <div class="flex items-center gap-2 mb-2 z-10">
                    <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    <h1 class="text-xs font-black uppercase tracking-widest text-purple-400">Portfolio Net Value</h1>
                </div>
                
                <div class="flex items-end gap-4 z-10 flex-wrap">
                    <h2 id="hero-total-balance" class="text-4xl md:text-5xl lg:text-6xl font-black text-white font-mono tracking-tighter">$0.00</h2>
                    <div class="flex flex-col mb-1 md:mb-2">
                        <span id="hero-daily-pnl" class="text-xs md:text-sm font-black text-green-400 tracking-wide">+ $0.00</span>
                        <span id="hero-daily-roi" class="text-[9px] md:text-[10px] font-black text-green-500 bg-green-500/10 px-1.5 py-0.5 rounded w-fit mt-0.5 border border-green-500/20">+0.00% Today</span>
                    </div>
                </div>
                
                <div class="border-t border-purple-900/40 pt-4 mt-4 z-10">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-[10px] font-black uppercase tracking-widest text-muted">Asset Holdings</h3>
                        <button onclick="toggleModal('settings-modal')" class="text-purple-400 hover:text-white transition p-1 bg-purple-900/20 rounded border border-purple-900/50">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        </button>
                    </div>
                    <div id="wallet-asset-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3"></div>
                </div>
            </section>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
                
                <div class="lg:col-span-9 flex flex-col gap-4">
                    
                    <div class="glass-panel p-3 md:p-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 border-l-4 border-l-purple-500">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 rounded-full bg-purple-500"></div>
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-purple-400">AI Logic Engine v4.0</h3>
                        </div>
                        <div class="flex flex-wrap items-center gap-3 md:gap-6 w-full md:w-auto">
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">RSI (14)</span><span id="ai-rsi" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">SMA (20)</span><span id="ai-sma" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">Trend Volatility</span><span id="ai-vol" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex items-center gap-2 ml-auto">
                                <span id="ai-signal" class="text-[10px] font-black uppercase px-2 py-1 rounded bg-purple-900/30 text-purple-400 border border-purple-500/20">ANALYZING</span>
                                <button onclick="toggleModal('ai-code-modal')" class="text-[9px] font-black uppercase tracking-widest text-purple-400 hover:text-white bg-purple-900/40 px-2 py-1 rounded border border-purple-900">Edit Code</button>
                            </div>
                        </div>
                    </div>

                    <div class="glass-panel p-4 md:p-6 flex flex-col relative min-h-[55vh] transition-colors duration-300" id="main-chart-wrapper">
                        <div class="flex justify-between items-start z-20">
                            
                            <div class="relative w-fit">
                                <button onclick="toggleDropdown('term-dropdown')" class="neo-input px-3 py-2 rounded flex items-center gap-3 w-[150px] md:w-48">
                                    <img id="term-logo" src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-5 h-5 rounded-full">
                                    <span id="term-text" class="font-black text-sm uppercase">BTC/USDT</span>
                                    <svg class="w-4 h-4 ml-auto text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                <div id="term-dropdown" class="absolute top-full left-0 mt-1 w-48 glass-overlay py-1 dropdown-menu dropdown-hidden"></div>
                            </div>

                            <div class="flex bg-[#05020a] p-1 rounded border border-purple-900/30">
                                <div class="tf-btn" onclick="setTimeframe('live')" id="tf-live">LIVE</div>
                                <div class="tf-btn active" onclick="setTimeframe('5m')" id="tf-5m">5m</div>
                                <div class="tf-btn" onclick="setTimeframe('15m')" id="tf-15m">15m</div>
                                <div class="tf-btn" onclick="setTimeframe('1h')" id="tf-1h">1H</div>
                            </div>
                        </div>

                        <div class="flex gap-6 mt-4 z-10 border-b border-purple-900/20 pb-3">
                            <div class="flex flex-col"><span class="text-[9px] text-muted uppercase tracking-widest">24h High</span><p class="text-xs font-mono text-green-400 font-black" id="stat-high">--</p></div>
                            <div class="flex flex-col"><span class="text-[9px] text-muted uppercase tracking-widest">24h Low</span><p class="text-xs font-mono text-pink-400 font-black" id="stat-low">--</p></div>
                            <div class="flex-grow flex justify-end items-end pointer-events-none">
                                <h2 id="main-price" class="text-4xl md:text-5xl font-black text-white font-mono tracking-tighter leading-none">--</h2>
                            </div>
                        </div>

                        <div class="flex-grow mt-2 relative w-full h-full min-h-[300px] cursor-crosshair overflow-hidden rounded" id="canvas-container">
                            <canvas id="custom-chart" class="absolute inset-0 w-full h-full"></canvas>
                            
                            <div id="chart-popups-container" class="absolute bottom-2 left-2 flex flex-col-reverse gap-1.5 z-30 pointer-events-none overflow-hidden max-h-[250px]">
                            </div>
                        </div>
                    </div>

                    <div class="glass-panel flex flex-col h-[180px]">
                        <div class="flex justify-between items-center p-3 border-b border-purple-900/30 shrink-0 bg-[#0a0510]/50 rounded-t">
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-purple-400">Live Block Order Log</h3>
                            <div class="flex items-center gap-2 w-48">
                                <span class="text-[8px] font-black text-green-400 w-6 text-right" id="ratio-buy-text">50%</span>
                                <div class="flex-grow h-1.5 bg-[#05020a] rounded overflow-hidden flex border border-purple-900/30">
                                    <div id="ratio-buy-bar" class="h-full bg-green-500" style="width: 50%"></div>
                                    <div id="ratio-sell-bar" class="h-full bg-pink-500" style="width: 50%"></div>
                                </div>
                                <span class="text-[8px] font-black text-pink-400 w-6" id="ratio-sell-text">50%</span>
                            </div>
                        </div>
                        <div class="flex-grow overflow-y-auto no-scrollbar p-2 flex flex-col gap-1" id="below-chart-log">
                            <div class="text-[9px] text-muted text-center py-4 italic">Awaiting on-chain / DEX block trades...</div>
                        </div>
                    </div>

                    <div class="glass-panel flex flex-col min-h-[20vh]">
                        <div class="flex justify-between items-center p-3 border-b border-purple-900/30 shrink-0">
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-purple-400">Open Manual Trades</h3>
                        </div>
                        <div class="flex-grow overflow-x-auto no-scrollbar">
                            <table class="w-full text-left border-collapse min-w-[500px]">
                                <thead class="bg-[#0a0510]/50 sticky top-0">
                                    <tr class="text-[9px] font-black uppercase tracking-widest text-muted border-b border-purple-900/30">
                                        <th class="p-3">Asset</th><th class="p-3">Side</th><th class="p-3">Margin</th><th class="p-3 text-right">ROI</th><th class="p-3 text-center">X</th>
                                    </tr>
                                </thead>
                                <tbody id="orders-body" class="text-[10px] font-bold text-slate-200 font-mono"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-3 flex flex-col">
                    <div class="glass-panel p-5 flex flex-col h-full relative z-10">
                        <h3 class="text-[10px] font-black uppercase tracking-widest text-muted mb-4 border-b border-purple-900/30 pb-2">Manual Execution</h3>
                        
                        <div class="flex gap-2 bg-[#05020a] p-1 border border-purple-900/50 rounded mb-5">
                            <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest bg-green-500/20 text-green-400 border border-green-500/50 transition">Long</button>
                            <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-pink-400 transition">Short</button>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <div class="flex justify-between mb-1.5">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted">Margin (USDT)</label>
                                    <span class="text-[10px] font-black text-purple-400 cursor-pointer hover:text-purple-300" onclick="setMax()">MAX</span>
                                </div>
                                <input type="number" id="trade-margin" placeholder="0.00" class="w-full neo-input p-3 rounded text-lg font-black font-mono text-center">
                            </div>

                            <div>
                                <div class="flex justify-between mb-3">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted">Leverage</label>
                                    <span class="text-[10px] font-black text-white bg-purple-900/50 px-2 py-0.5 rounded border border-purple-700/50"><span id="lev-val">10</span>x</span>
                                </div>
                                <input type="range" id="trade-lev" min="1" max="100" value="10" class="w-full">
                                <div class="flex justify-between text-[8px] font-black text-muted mt-2 px-1">
                                    <span>1x</span><span>50x</span><span>100x</span>
                                </div>
                            </div>

                            <div class="p-3 bg-[#05020a] border border-purple-900/30 rounded space-y-2 mt-4">
                                <div class="flex justify-between text-[10px] font-black uppercase">
                                    <span class="text-muted">Available</span>
                                    <span class="text-white font-mono" id="ui-avail">0.00</span>
                                </div>
                                <div class="flex justify-between text-[10px] font-black uppercase border-t border-purple-900/30 pt-2">
                                    <span class="text-muted">Position Size</span>
                                    <span class="text-purple-400 font-mono" id="ui-size">0.00</span>
                                </div>
                            </div>
                        </div>

                        <button onclick="executeOrder()" id="btn-execute" class="mt-auto w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-green-500 text-[#05020a] hover:bg-green-400 transition active:scale-95">
                            Execute Long
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="app-bot" class="w-full hidden">
        <main class="flex flex-col p-2 md:p-4 gap-6 w-full max-w-[1600px] mx-auto">
            <div class="glass-panel p-6">
                <div class="flex justify-between items-center mb-6 border-b border-purple-900/30 pb-4">
                    <div>
                        <h1 class="text-xl font-black uppercase text-white tracking-tighter">Bot Factory</h1>
                        <p class="text-xs text-muted mt-1">Configure & deploy algorithmic execution engines.</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-4">
                        <div class="bg-[#05020a] p-5 rounded border border-purple-900/40 space-y-5">
                            <div>
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Bot Strategy Mode</label>
                                <div class="relative w-full">
                                    <div onclick="toggleDropdown('bot-mode-dropdown')" class="neo-input p-3 rounded text-xs font-black uppercase flex justify-between">
                                        <span id="bot-mode-text">Standard DCA</span>
                                        <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                    </div>
                                    <div id="bot-mode-dropdown" class="absolute top-full left-0 mt-1 w-full glass-overlay py-1 dropdown-menu dropdown-hidden">
                                        <div onclick="setBotMode('standard', 'Standard DCA')" class="px-4 py-2 hover:bg-purple-900/40 cursor-pointer text-xs font-black uppercase text-white">Standard DCA</div>
                                        <div onclick="setBotMode('sniper', 'Sniper Pump Scalp')" class="px-4 py-2 hover:bg-purple-900/40 cursor-pointer text-xs font-black uppercase text-white">Sniper Pump Scalp</div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Target Asset</label>
                                    <div class="relative w-full">
                                        <div onclick="toggleDropdown('bot-asset-dropdown')" class="neo-input p-3 rounded text-xs font-black uppercase flex items-center gap-2 justify-between">
                                            <div class="flex items-center gap-2"><img id="bot-asset-logo" src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-4 h-4 rounded-full"><span id="bot-asset-text">BTCUSDT</span></div>
                                            <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                        </div>
                                        <div id="bot-asset-dropdown" class="absolute top-full left-0 mt-1 w-full glass-overlay py-1 dropdown-menu dropdown-hidden max-h-40 overflow-y-auto no-scrollbar"></div>
                                    </div>
                                </div>
                                <div>
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Base Order (USDT)</label>
                                    <input type="number" id="bot-size" value="100" class="w-full neo-input p-3 rounded text-xs font-mono">
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Max Active TXs</label>
                                    <input type="number" id="bot-max-tx" value="3" class="w-full neo-input p-3 rounded text-xs font-mono">
                                </div>
                                <div>
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Max Capital (USDT)</label>
                                    <input type="number" id="bot-max-cap" value="1000" class="w-full neo-input p-3 rounded text-xs font-mono">
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-4">
                                <div>
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Trigger Threshold (%)</label>
                                    <input type="number" id="bot-drop" value="2.5" class="w-full neo-input p-3 rounded text-xs font-mono">
                                </div>
                                <div>
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Execution Leverage</label>
                                    <input type="number" id="bot-lev" value="1" class="w-full neo-input p-3 rounded text-xs font-mono">
                                </div>
                            </div>
                            
                            <div>
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted block mb-2">Bot Identification Name</label>
                                <input type="text" id="bot-name" value="Alpha-01" class="w-full neo-input p-3 rounded text-xs font-black uppercase">
                            </div>
                        </div>
                        <button onclick="deployBot()" class="w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-purple-600 text-white hover:bg-purple-500 transition active:scale-95">
                            Deploy Bot Instance
                        </button>
                    </div>

                    <div class="flex flex-col h-full min-h-[400px]">
                        <div class="bg-[#1e1e1e] rounded-t border border-gray-800 p-2 flex justify-between items-center">
                            <span class="text-[10px] font-mono text-gray-400 ml-2">bot_core.js</span>
                            <div class="flex gap-1.5 mr-2">
                                <div class="w-3 h-3 rounded-full bg-gray-600"></div><div class="w-3 h-3 rounded-full bg-gray-600"></div><div class="w-3 h-3 rounded-full bg-gray-600"></div>
                            </div>
                        </div>
                        <textarea id="code-editor" class="code-area w-full flex-grow bg-[#1e1e1e] text-[#d4d4d4] p-4 text-[10px] outline-none border border-t-0 border-gray-800 rounded-b resize-none" spellcheck="false">
// --- ADVANCED BOT LOGIC ENGINE ---
// ENVIRONMENT VARIABLES:
// * price (Number) - Current live asset price
// * rsi (Number) - Current Relative Strength Index (14)
// * volume (Number) - Current tick volume
// * volatility (Number) - Current price variance
// * bot (Object) - Context: { mode, size, lev, dropPercent, maxTx, maxCap, activeTxs[] }
// 
// AVAILABLE ADVANCED FUNCTIONS:
// * executeMarket({ side: 'buy'|'sell', size: USDT, lev: Integer })
// * closeAllPositions() - Closes all active trades for this instance
// * closePosition(id) - Closes a specific transaction by ID
// * setTrailingStop(percent) - Activates trailing stop loss dynamically
// * setTakeProfit(percent) - Sets a hard TP for open orders
// * setStopLoss(percent) - Sets a hard SL for open orders
// * getAverageEntry() - Returns volume-weighted avg entry price
// * getOpenExposure() - Returns total active capital deployed
// * getOpenPnL() - Returns total unrealized profit/loss
// * log(msg) - Prints string output to bot debug console
//
// NOTE: Evaluated tick-by-tick. Handle execution gates properly.

function onTick(price, rsi, volume) {
    // 1. Safety Check: Respect Max Capital & Max TX Limits
    if (bot.activeTxs.length >= bot.maxTx || getOpenExposure() >= bot.maxCap) {
        if(getOpenPnL() > (bot.maxCap * 0.1)) { // Take profit at 10%
            closeAllPositions();
        }
        return;
    }

    // 2. Strategy Execution
    if (bot.mode === 'sniper') {
        if (rsi > 80 && volume > 1000000) {
            executeMarket({ side: 'sell', size: bot.size, lev: bot.lev });
            setStopLoss(2.0); // 2% Stop Loss
        }
    } else {
        // Standard DCA Mode logic
        const dropFromATH = ((ATH - price) / ATH) * 100;
        if (dropFromATH >= bot.dropPercent) {
            executeMarket({ side: 'buy', size: bot.size, lev: 1 });
            setTrailingStop(1.5); // 1.5% Trailing Stop
        }
    }
}
</textarea>
                    </div>
