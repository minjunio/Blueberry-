        const FX_SYM = { USD: '$', AED: 'د.إ', EUR: '€', GBP: '£' };

        const defaultHolders = [
            {addr: "0x3f9A...8cA1", usd: 1450000, lastAction: "ACCUMULATING", amt: 0}, {addr: "0x88bC...11C9", usd: 1120000, lastAction: "HOLDING", amt: 0},
            {addr: "0x1aF2...E4F2", usd: 890000, lastAction: "HOLDING", amt: 0}, {addr: "0x7cE4...00B1", usd: 760000, lastAction: "HOLDING", amt: 0}
