        }

        async function fetch24hStats() {
            try {
                let res = await fetch(`https://api.binance.com/api/v3/ticker/24hr?symbol=${ui.pair}`);
                let data = await res.json();
                document.getElementById('stat-high').innerText = parseFloat(data.highPrice).toLocaleString();
                document.getElementById('stat-low').innerText = parseFloat(data.lowPrice).toLocaleString();
            } catch(e){}
        }

        function updateWalletSystem() {
            let totalUsdValue = state.usdtBalance;
            let gridHtml = createWalletCard('USDT', state.usdtBalance, state.usdtBalance);

            state.orders.forEach(o => {
                let livePrice = livePrices[o.pair] || o.entry;
                totalUsdValue += o.margin; 
                let pnl = o.side === 'buy' ? ((o.units * livePrice) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * livePrice));
                totalUsdValue += pnl;
            });

            for (const [coin, amt] of Object.entries(state.manualAssets)) {
                let valUsd = amt * (livePrices[coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
                gridHtml += createWalletCard(coin, amt, valUsd);
            }
            
            state.stakes.forEach(s => {
                let valUsd = s.amt * (livePrices[s.coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
            });

            document.getElementById('wallet-asset-grid').innerHTML = gridHtml;
            
            let rate = FX_RATES[state.currency] || 1;
            let sym = FX_SYM[state.currency] || '$';
            let localTotal = totalUsdValue * rate;

            document.getElementById('hero-currency-sym').innerText = sym;
            document.getElementById('hero-total-balance').innerText = localTotal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            
            let dPnlUsd = totalUsdValue - state.startOfDayValue;
            let dPnlLocal = dPnlUsd * rate;
            let dRoi = (dPnlUsd / (state.startOfDayValue || 1)) * 100;
            const pnlEl = document.getElementById('hero-daily-pnl');
            const roiEl = document.getElementById('hero-daily-roi');
            
            pnlEl.innerText = `${dPnlLocal >= 0 ? '+' : ''}${sym}${dPnlLocal.toFixed(2)}`;
            pnlEl.className = `text-xs md:text-sm font-black tracking-wide drop-shadow ${dPnlLocal >= 0 ? 'text-green-400' : 'text-pink-400'}`;
            roiEl.innerText = `${dPnlLocal >= 0 ? '+' : ''}${dRoi.toFixed(2)}% Today`;
            roiEl.className = `text-[9px] md:text-[10px] font-black px-1.5 py-0.5 rounded w-fit mt-0.5 border shadow-sm ${dPnlLocal >= 0 ? 'text-green-400 bg-green-500/10 border-green-500/20' : 'text-pink-400 bg-pink-500/10 border-pink-500/20'}`;
            state.lastRunTime = Date.now(); 
        }

        function createWalletCard(coin, amount, valueUsd) {
            let rate = FX_RATES[state.currency] || 1; let sym = FX_SYM[state.currency] || '$'; let valLocal = valueUsd * rate;
            const valStr = valueUsd >= 0 ? `${sym}${valLocal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}` : 'Syncing...';
            const icon = ASSETS.find(x => x.coin === coin)?.icon || (coin==='USDT'?'tether-usdt-logo.svg?v=029':`https://ui-avatars.com/api/?name=${coin}&background=0D0814&color=A78BFA&rounded=true`);
            const imgSrc = icon.includes('ui-avatars') ? icon : `https://cryptologos.cc/logos/${icon}`;
            return `
            <div class="bg-[#05020a]/80 border border-purple-900/30 p-2 lg:p-3 rounded-lg flex items-center gap-3 transition hover:border-purple-500/50 hover:bg-[#0a0510]">
                <img src="${imgSrc}" class="w-6 h-6 lg:w-8 lg:h-8 rounded-full shrink-0 bg-[#1e2026] p-1 shadow-md">
                <div class="flex flex-col min-w-0">
                    <span class="text-[10px] font-black text-white uppercase truncate">${coin}</span>
                    <span class="text-[9px] lg:text-[10px] font-mono text-purple-400 truncate">${amount.toLocaleString(undefined, {maximumFractionDigits: 4})}</span>
                    <span class="text-[8px] font-bold text-muted truncate">≈ ${valStr}</span>
                </div>
            </div>`;
        }

        // --- WALLET APP LOGIC (SEND, SWAP, STAKE) ---
        function updateWalletApp() {
            let totalUsdValue = state.usdtBalance;
            let rows = [];
            let rate = FX_RATES[state.currency] || 1; let sym = FX_SYM[state.currency] || '$';

            const addRow = (coin, amt, isStake) => {
                let valUsd = coin === 'USDT' ? amt : amt * (livePrices[coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
                rows.push({ coin, amt, valUsd, isStake });
            };

            addRow('USDT', state.usdtBalance, false);
            for (const [coin, amt] of Object.entries(state.manualAssets)) addRow(coin, amt, false);
            state.stakes.forEach(s => addRow(s.coin, s.amt, true));

            rows.sort((a,b) => b.valUsd - a.valUsd);
            
            let tbody = document.getElementById('wallet-detailed-body');
            tbody.innerHTML = rows.map(r => {
                let alloc = totalUsdValue > 0 ? ((r.valUsd / totalUsdValue) * 100).toFixed(1) : 0;
                let valLocal = r.valUsd * rate;
                
                const icon = ASSETS.find(x => x.coin === r.coin)?.icon || (r.coin==='USDT'?'tether-usdt-logo.svg?v=029':`https://ui-avatars.com/api/?name=${r.coin}&background=0D0814&color=A78BFA&rounded=true`);
                const imgSrc = icon.includes('ui-avatars') ? icon : `https://cryptologos.cc/logos/${icon}`;

                return `
                <tr>
                    <td>
                        <div class="flex items-center gap-3">
                            <img src="${imgSrc}" class="w-6 h-6 rounded-full bg-[#1e2026] p-0.5">
                            <span class="text-white font-black">${r.coin}</span>
                            ${r.isStake ? '<span class="px-1.5 py-0.5 rounded bg-green-900/30 text-green-400 border border-green-500/30 text-[8px] uppercase font-bold">Staked</span>' : ''}
                        </div>
                    </td>
                    <td class="text-right text-purple-400 font-mono">${r.amt.toLocaleString(undefined, {maximumFractionDigits: 4})}</td>
                    <td class="text-right font-mono">${sym}${valLocal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}</td>
                    <td class="text-right text-muted font-mono">${alloc}%</td>
                </tr>`;
            }).join('');

            // Update Stake Table
            let sBody = document.getElementById('active-stakes-body');
            if(state.stakes.length === 0) sBody.innerHTML = `<tr><td colspan="4" class="text-center text-muted italic text-[9px]">No active stakes.</td></tr>`;
            else {
                sBody.innerHTML = state.stakes.map(s => {
                    let d = (Date.now() - s.time) / 86400000; // days
                    let earned = s.amt * (s.apr / 100) * (d / 365);
                    const icon = ASSETS.find(x => x.coin === s.coin)?.icon || `https://ui-avatars.com/api/?name=${s.coin}&background=0D0814&color=A78BFA&rounded=true`;
                    const imgSrc = icon.includes('ui-avatars') ? icon : `https://cryptologos.cc/logos/${icon}`;

                    return `
                    <tr>
                        <td>
                            <div class="flex items-center gap-2">
                                <img src="${imgSrc}" class="w-5 h-5 rounded-full bg-[#1e2026] p-0.5">
                                <span class="text-white font-black">${s.coin}</span>
                            </div>
                        </td>
                        <td class="text-purple-400 font-mono">${s.amt.toFixed(4)}</td>
                        <td class="text-green-400 font-mono font-black">${s.apr}%</td>
                        <td class="text-right font-mono">+${earned.toFixed(6)} <span class="text-muted text-[8px]">${s.coin}</span></td>
                    </tr>`;
                }).join('');
            }
        }

        function buildStakingGrid() {
            const grid = document.getElementById('staking-grid');
            grid.innerHTML = STAKING_OPTS.map(opt => {
                const icon = ASSETS.find(x => x.coin === opt.id)?.icon || `https://ui-avatars.com/api/?name=${opt.id}&background=0D0814&color=A78BFA&rounded=true`;
                const imgSrc = icon.includes('ui-avatars') ? icon : `https://cryptologos.cc/logos/${icon}`;
                return `
                <div class="bg-[#05020a] p-4 rounded border border-purple-900/30 hover:border-green-500/50 hover:shadow-[0_0_15px_rgba(52,211,153,0.1)] transition flex flex-col items-center cursor-pointer group" onclick="openStakeModal('${opt.id}', ${opt.apr})">
                    <span class="text-[8px] bg-green-900/30 text-green-400 px-2 py-0.5 rounded mb-3 border border-green-500/20 font-black uppercase tracking-widest">${opt.tag}</span>
                    <img src="${imgSrc}" class="w-10 h-10 mb-2 bg-[#1e2026] rounded-full p-1 shadow-md group-hover:scale-110 transition-transform">
                    <h3 class="text-lg font-black text-white mb-1">${opt.id}</h3>
                    <p class="text-[9px] text-muted mb-2 uppercase tracking-widest font-bold">Est. APR</p>
                    <span class="text-xl font-mono font-black text-green-400">${opt.apr}%</span>
                    <button class="mt-4 w-full py-2 bg-purple-900/40 text-purple-400 text-[9px] font-black uppercase tracking-widest rounded group-hover:bg-green-500 group-hover:text-[#05020a] transition">Stake</button>
                </div>
            `}).join('');
        }

        function openStakeModal(coin, apr) {
            document.getElementById('stake-modal-asset').innerText = coin;
            document.getElementById('stake-modal-apr').innerText = apr + '%';
            
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin] || 0);
            let aEl = document.getElementById('stake-modal-avail');
            aEl.innerText = avail.toFixed(4);
            aEl.dataset.val = avail;
            document.getElementById('stake-amount').value = '';
            
            document.getElementById('stake-amount').dataset.coin = coin;
            document.getElementById('stake-amount').dataset.apr = apr;

            toggleModal('stake-modal');
        }

        function confirmStake() {
            const el = document.getElementById('stake-amount');
            const amt = parseFloat(el.value);
            const coin = el.dataset.coin;
            const apr = parseFloat(el.dataset.apr);
            
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin] || 0);
            if(isNaN(amt) || amt <= 0 || amt > avail) return alert("Invalid amount.");

            if(coin === 'USDT') state.usdtBalance -= amt;
            else state.manualAssets[coin] -= amt;

            state.stakes.push({ coin, amt, apr, time: Date.now() });
            saveState(); toggleModal('stake-modal'); updateWalletApp();
        }

        function prepSwapModal() {
            buildDynamicDropdowns(); // refresh dropdown options
            document.getElementById('swap-asset-from').value = 'USDT';
            document.getElementById('swap-from-selected').innerText = 'USDT';
            document.getElementById('swap-asset-to').value = 'BTC';
            document.getElementById('swap-to-selected').innerText = 'BTC';
            updateSwapBals(); calcSwap();
        }

        function updateSwapBals() {
            let from = document.getElementById('swap-asset-from').value;
            let to = document.getElementById('swap-asset-to').value;
            document.getElementById('swap-bal-from').innerText = `Bal: ${(from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0)).toFixed(4)}`;
            document.getElementById('swap-bal-to').innerText = `Bal: ${(to === 'USDT' ? state.usdtBalance : (state.manualAssets[to]||0)).toFixed(4)}`;
        }

        function calcSwap() {
            let from = document.getElementById('swap-asset-from').value;
            let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            
            if(from === to) { document.getElementById('swap-amt-to').value = amt; document.getElementById('swap-rate-text').innerText = `1 ${from} = 1 ${to}`; return; }
            
            let priceFromUsd = from === 'USDT' ? 1 : (livePrices[from+'USDT'] || 1);
            let priceToUsd = to === 'USDT' ? 1 : (livePrices[to+'USDT'] || 1);
            
            let toAmt = (amt * priceFromUsd) / priceToUsd;
            document.getElementById('swap-amt-to').value = toAmt.toFixed(6);
            document.getElementById('swap-rate-text').innerText = `1 ${from} ≈ ${(priceFromUsd/priceToUsd).toFixed(6)} ${to}`;
        }

        function executeSwap() {
            let from = document.getElementById('swap-asset-from').value;
            let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            let toAmt = parseFloat(document.getElementById('swap-amt-to').value) || 0;

            if(amt <= 0) return;
            let avail = from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0);
            if(amt > avail) return alert("Insufficient balance.");

            if(from === 'USDT') state.usdtBalance -= amt; else state.manualAssets[from] -= amt;
            if(to === 'USDT') state.usdtBalance += toAmt; else {
                if(!state.manualAssets[to]) state.manualAssets[to] = 0;
                state.manualAssets[to] += toAmt;
            }

            saveState(); toggleModal('swap-modal'); updateWalletApp();
        }

