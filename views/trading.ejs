        function toggleModal(id) {
            const el = document.getElementById(id);
            el.classList.toggle('modal-hidden'); el.classList.toggle('modal-active');
            
            if(id === 'swap-modal' && el.classList.contains('modal-active')) prepSwapModal();
            if(id === 'send-modal' && el.classList.contains('modal-active')) prepSendModal();
