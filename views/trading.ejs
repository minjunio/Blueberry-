        };
        
        let livePrices = {}; 
        let ui = { side: 'buy', pair: 'BTCUSDT', price: 0, lastPrice: 0, lev: 10, timeframe: '5m', chartData: [], logFilter: 'all' };
        let wsTicker, wsTrade;
        let chartCtx;
        let flowData = { buy: 0, sell: 0 };
        let canvasHoverPos = null; 
        let activeBotViewId = null;

        let topBuysArray = [];
        let topSellsArray = [];
        let topHoldersSim = [
            {addr: "0x3f9A...8cA1", usd: 1450000}, {addr: "0x88bC...11C9", usd: 1120000},
            {addr: "0x1aF2...E4F2", usd: 890000}, {addr: "0x7cE4...00B1", usd: 760000}, {addr: "0x99D1...FA00", usd: 450000}
