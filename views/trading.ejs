<!DOCTYPE html>
<html lang="en">
<head>
    <title>CloudCrypto Professional Quant Terminal</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <style>
        /* Flat Quant Theme (No Neon, No Glow) */
        body { background: #05020a; color: #f8fafc; font-family: 'Inter', system-ui, sans-serif; margin: 0; min-height: 100vh; overflow: hidden; display: flex; flex-direction: column; }
        .glass-panel { background: #0a0510; border: 1px solid #2d1b4e; border-radius: 0.3rem; }
        .neo-input { background: #05020a; border: 1px solid #4c1d95; color: white; border-radius: 0.2rem; padding: 0.5rem; }
        .neo-btn { background: #1f1235; border: 1px solid #4c1d95; color: #e5e7eb; cursor: pointer; padding: 0.5rem 1rem; border-radius: 0.2rem; }
        .neo-btn:hover { background: #311858; }

        /* Prevent Text Overflow */
        .price-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
        
        /* Trade Popups */
        .popup { position: absolute; bottom: 20px; left: 20px; z-index: 50; padding: 8px 12px; border: 1px solid; font-size: 10px; font-family: monospace; animation: fade 3s forwards; }
        @keyframes fade { 0% { opacity: 0; transform: translateY(20px); } 20% { opacity: 1; transform: translateY(0); } 80% { opacity: 1; } 100% { opacity: 0; } }
        
        #code-editor { font-family: 'Courier New', monospace; font-size: 12px; }
    </style>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <header class="flex justify-between items-center p-3 border-b border-purple-900 bg-[#0a0510]">
        <div class="flex gap-4 items-center">
            <h1 class="text-lg font-black text-white">CLOUD QUANT</h1>
            <div class="flex gap-2">
                <button onclick="switchApp('terminal')" class="neo-btn text-[10px]">TERMINAL</button>
                <button onclick="switchApp('bot')" class="neo-btn text-[10px]">DCA BOT FACTORY</button>
            </div>
        </div>
    </header>

    <div id="app-terminal" class="flex-grow flex flex-col p-4 gap-4 overflow-y-auto">
        <div class="grid grid-cols-12 gap-4">
            <div class="col-span-9 glass-panel p-4 h-[60vh] relative">
                <div class="flex justify-between mb-4">
                    <div id="ai-status" class="text-[10px] uppercase font-bold text-purple-400">AI SIGNAL: NEUTRAL</div>
                    <div id="main-price" class="price-text text-3xl font-black font-mono">--</div>
                </div>
                <canvas id="chart-canvas" class="w-full h-full"></canvas>
            </div>
            
            <div class="col-span-3 glass-panel p-4">
                <h3 class="text-[10px] font-black uppercase text-muted">Execution</h3>
                <input type="number" id="trade-margin" placeholder="Margin (USDT)" class="w-full neo-input mt-2">
                <input type="range" id="trade-lev" min="1" max="100" class="w-full mt-4">
                <button onclick="executeOrder()" class="w-full neo-btn mt-4">EXECUTE</button>
            </div>
        </div>
        <div id="trade-log" class="glass-panel p-4 h-[20vh] overflow-y-auto font-mono text-[10px]"></div>
    </div>

    <div id="app-bot" class="hidden flex-grow p-4">
        <div class="grid grid-cols-2 gap-4">
            <div class="glass-panel p-4">
                <h3 class="text-sm font-black text-white">BOT CONFIG</h3>
                <input id="bot-name" placeholder="Bot Name" class="w-full neo-input mt-2">
                <input id="bot-usdt" placeholder="Total USDT Allowance" class="w-full neo-input mt-2">
                <input id="bot-txs" placeholder="Max Transactions" class="w-full neo-input mt-2">
                <button onclick="deployBot()" class="neo-btn w-full mt-4">DEPLOY BOT</button>
            </div>
            <div class="glass-panel p-4">
                <textarea id="code-editor" class="w-full h-64 bg-black text-green-500 p-2 border border-purple-900">
// Available Syntax/Variables:
// price, rsi, sma, volatility, volume

function onTick(price, rsi, sma, volatility) {
    if (rsi < 30) return "BUY";
    if (rsi > 70) return "SELL";
    return "HOLD";
}
                </textarea>
            </div>
        </div>
        <div id="bot-list" class="mt-4 grid grid-cols-3 gap-2"></div>
    </div>

    <script>
        // --- Core Engine ---
        let state = { balance: 10000, bots: [] };
        
        function switchApp(app) {
            document.getElementById('app-terminal').classList.toggle('hidden', app !== 'terminal');
            document.getElementById('app-bot').classList.toggle('hidden', app !== 'bot');
        }

        function deployBot() {
            const bot = {
                id: Math.random().toString(36).substr(2, 9),
                name: document.getElementById('bot-name').value,
                usdt: parseFloat(document.getElementById('bot-usdt').value),
                maxTxs: parseInt(document.getElementById('bot-txs').value),
                activeTxs: [], pnl: 0
            };
            state.bots.push(bot);
            renderBots();
        }

        function renderBots() {
            const container = document.getElementById('bot-list');
            container.innerHTML = state.bots.map(b => `
                <div class="glass-panel p-2 text-[10px]">
                    <div class="font-black">${b.name}</div>
                    <div>PnL: $${b.pnl}</div>
                    <div class="text-green-400">${b.activeTxs.length}/${b.maxTxs} Active</div>
                </div>
            `).join('');
        }

        // --- Mocking Live Data for Price/Chart ---
        function updateUI() {
            document.getElementById('main-price').innerText = "$64,230.12"; // Fixed display
        }
        setInterval(updateUI, 1000);
    </script>
</body>
</html>
