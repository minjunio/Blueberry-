<!DOCTYPE html>
<html lang="en">
<head>
    <title>Binance Pro Terminal</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <link rel="icon" type="image/png" href="/favicon.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Exact Binance Pro Palette */
        :root {
            --bg-base: #0b0e11;
            --bg-panel: #1e2329;
            --bg-panel-hover: #2b3139;
            --border-color: #2b3139;
            --text-primary: #eaecef;
            --text-secondary: #848e9c;
            --binance-gold: #F3BA2F;
            --binance-gold-hover: #FCD535;
            --buy-green: #0ECB81;
            --sell-red: #F6465D;
        }

        body { background: var(--bg-base); color: var(--text-primary); font-family: 'Inter', -apple-system, sans-serif; margin: 0; min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; }
        
        .b-panel { background: var(--bg-panel); border: 1px solid var(--border-color); border-radius: 8px; }
        .b-input { background: var(--bg-base); border: 1px solid var(--border-color); color: var(--text-primary); outline: none; transition: border-color 0.2s; border-radius: 6px; }
        .b-input:focus, .b-input:hover { border-color: var(--binance-gold); }
        .b-btn { background: var(--bg-panel-hover); color: var(--text-primary); transition: 0.2s; cursor: pointer; border-radius: 6px; border: 1px solid transparent; }
        .b-btn:hover { background: var(--binance-gold); color: var(--bg-base); }
        
        .text-muted { color: var(--text-secondary); }
        .text-gold { color: var(--binance-gold); }
        .bg-gold { background: var(--binance-gold); }
        .text-buy { color: var(--buy-green); }
        .text-sell { color: var(--sell-red); }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        /* Dynamic Leverage Slider */
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; cursor: pointer; border-radius: 4px; height: 6px; outline: none; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 6px; background: transparent; border-radius: 4px; border: 1px solid var(--border-color); }
        input[type=range]::-webkit-slider-thumb { height: 18px; width: 18px; border-radius: 50%; background: var(--binance-gold); -webkit-appearance: none; margin-top: -6px; box-shadow: 0 0 10px rgba(243,186,47,0.4); transition: transform 0.1s; border: 2px solid var(--bg-base); }
        input[type=range]::-webkit-slider-thumb:active { transform: scale(1.15); }

        .modal-overlay { transition: opacity 0.2s; }
        .modal-content { transition: transform 0.2s; }
        .modal-hidden { opacity: 0; pointer-events: none; }
        .modal-hidden .modal-content { transform: scale(0.95) translateY(10px); }
        .modal-active { opacity: 1; pointer-events: auto; }
        .modal-active .modal-content { transform: scale(1) translateY(0); }

        .tf-btn { padding: 4px 12px; border-radius: 4px; font-size: 11px; font-weight: bold; color: var(--text-secondary); cursor: pointer; transition: 0.2s; }
        .tf-btn.active { color: var(--binance-gold); background: rgba(243, 186, 47, 0.1); }
        .tf-btn:hover:not(.active) { color: var(--text-primary); }

        .dropdown-menu { transform-origin: top; transition: transform 0.2s ease, opacity 0.2s ease; z-index: 100; background: var(--bg-panel); border: 1px solid var(--border-color); box-shadow: 0 10px 30px rgba(0,0,0,0.8); border-radius: 6px; }
        .dropdown-hidden { transform: scaleY(0); opacity: 0; pointer-events: none; }
        .dropdown-active { transform: scaleY(1); opacity: 1; pointer-events: auto; }

        @keyframes popupSlideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
        .bottom-popup { animation: popupSlideIn 0.2s ease-out forwards; transition: opacity 0.3s ease-out; }

        .spinner { border: 3px solid rgba(243, 186, 47, 0.2); border-top-color: var(--binance-gold); border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        
        .dot-spin { animation: spin 5s linear infinite; }
        .eth-pulse { animation: subtlePulse 2.5s ease-in-out infinite; }
        @keyframes subtlePulse { 0%, 100% { transform: scale(1); filter: drop-shadow(0 0 2px rgba(98,126,234,0)); } 50% { transform: scale(1.05); filter: drop-shadow(0 0 8px rgba(98,126,234,0.6)); } }

        table th { border-bottom: 1px solid var(--border-color); text-transform: uppercase; font-size: 10px; color: var(--text-secondary); padding: 12px; font-weight: normal; }
        table td { border-bottom: 1px solid var(--border-color); padding: 12px; vertical-align: middle; font-size: 12px; }
        table tr:hover td { background: rgba(255,255,255,0.02); }
        
        select.native-sel { background: var(--bg-base); color: var(--text-primary); border: 1px solid var(--border-color); border-radius: 6px; padding: 8px 12px; cursor: pointer; outline: none; appearance: none; font-weight: bold; }
        select.native-sel option { background: var(--bg-panel); color: var(--text-primary); }
    </style>
</head>
<body>

    <header class="flex flex-col shrink-0 z-50 sticky top-0 bg-[#0b0e11] border-b border-[#2b3139]">
        <div class="flex justify-between items-center p-3 md:p-4 max-w-[1600px] w-full mx-auto">
            <div class="flex items-center gap-6">
                <div class="flex items-center gap-2">
                    <img src="https://cryptologos.cc/logos/bnb-bnb-logo.svg?v=029" class="w-7 h-7">
                    <h2 class="text-lg font-black tracking-tight text-white hidden sm:block">Binance</h2>
                </div>
                <div class="flex gap-2">
                    <button onclick="switchApp('terminal')" id="nav-terminal" class="px-3 py-1.5 rounded text-[11px] font-bold text-black bg-gold transition">Terminal</button>
                    <button onclick="switchApp('wallet')" id="nav-wallet" class="px-3 py-1.5 rounded text-[11px] font-bold text-muted hover:text-white transition">Wallet</button>
                </div>
            </div>
            <div class="flex items-center gap-4">
                <span class="text-xs font-bold text-[#EAECEF] hidden sm:block bg-[#1e2329] px-3 py-1.5 rounded border border-[#2b3139]">K. Al Dhaheri</span>
                <button onclick="toggleModal('history-modal')" class="b-btn px-4 py-1.5 text-xs font-bold">Orders</button>
            </div>
        </div>
    </header>

    <div id="app-terminal" class="w-full">
        <main class="flex flex-col p-2 md:p-4 gap-4 w-full max-w-[1600px] mx-auto">
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
                
                <div class="lg:col-span-9 flex flex-col gap-4">
                    
                    <div class="b-panel p-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                        <div class="relative w-fit">
                            <button onclick="toggleDropdown('term-dropdown')" class="flex items-center gap-3 w-48 hover:bg-[#2b3139] p-2 rounded transition border border-transparent hover:border-[#2b3139]">
                                <img id="term-logo" src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-6 h-6 rounded-full">
                                <div class="flex flex-col items-start">
                                    <span id="term-text" class="font-black text-lg leading-none">BTCUSDT</span>
                                    <span class="text-[10px] text-muted underline decoration-dashed mt-0.5 cursor-pointer">Change Pair</span>
                                </div>
                            </button>
                            <div id="term-dropdown" class="absolute top-full left-0 mt-1 w-full dropdown-menu dropdown-hidden max-h-[300px] overflow-y-auto no-scrollbar py-2"></div>
                        </div>

                        <div class="flex flex-wrap gap-6 items-center">
                            <div class="flex flex-col text-right">
                                <span class="text-[10px] text-muted">Price</span>
                                <span id="main-price" class="text-xl font-black font-mono text-white transition-colors duration-200">--</span>
                            </div>
                            <div class="flex flex-col text-right hidden sm:flex">
                                <span class="text-[10px] text-muted">24h High</span>
                                <span id="stat-high" class="text-sm font-mono text-white">--</span>
                            </div>
                            <div class="flex flex-col text-right hidden sm:flex">
                                <span class="text-[10px] text-muted">24h Low</span>
                                <span id="stat-low" class="text-sm font-mono text-white">--</span>
                            </div>
                        </div>
                    </div>

                    <div class="b-panel p-0 flex flex-col relative min-h-[55vh] overflow-hidden" id="main-chart-wrapper">
                        <div class="flex justify-between items-center p-2 border-b border-[#2b3139] bg-[#0b0e11]">
                            <div class="flex gap-1" id="tf-container">
                                <div class="tf-btn" onclick="setTimeframe('live')" id="tf-live">LIVE</div>
                                <div class="tf-btn" onclick="setTimeframe('1m')" id="tf-1m">1m</div>
                                <div class="tf-btn active" onclick="setTimeframe('5m')" id="tf-5m">5m</div>
                                <div class="tf-btn" onclick="setTimeframe('15m')" id="tf-15m">15m</div>
                                <div class="tf-btn" onclick="setTimeframe('1h')" id="tf-1h">1H</div>
                                <div class="tf-btn" onclick="setTimeframe('4h')" id="tf-4h">4H</div>
                                <div class="tf-btn" onclick="setTimeframe('1d')" id="tf-1d">1D</div>
                            </div>
                        </div>
                        <div class="flex-grow relative w-full h-full min-h-[300px] cursor-crosshair bg-[#0b0e11]" id="canvas-container">
                            <canvas id="custom-chart" class="absolute inset-0 w-full h-full"></canvas>
                            <div id="chart-popups-container" class="absolute bottom-2 left-2 flex flex-col-reverse gap-1.5 z-30 pointer-events-none overflow-hidden max-h-[250px]"></div>
                        </div>
                    </div>

                    <div class="b-panel flex flex-col min-h-[25vh]">
                        <div class="p-3 border-b border-[#2b3139]">
                            <h3 class="text-xs font-bold text-white">Positions</h3>
                        </div>
                        <div class="flex-grow overflow-x-auto no-scrollbar">
                            <table class="w-full text-left min-w-[700px]">
                                <thead><tr><th>Symbol</th><th>Size/Side</th><th>Entry Price</th><th>Mark Price</th><th>Margin</th><th class="text-right">PnL (ROI%)</th><th class="text-center">Action</th></tr></thead>
                                <tbody id="orders-body" class="font-mono"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-3 flex flex-col gap-4">
                    
                    <div class="b-panel p-5 flex flex-col">
                        <div class="flex gap-2 bg-[#0b0e11] p-1 rounded-md border border-[#2b3139] mb-6">
                            <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-2 rounded text-xs font-bold text-buy bg-[#0ECB81]/10 border border-[#0ECB81]/50">Buy / Long</button>
                            <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-2 rounded text-xs font-bold text-muted hover:text-sell transition border border-transparent">Sell / Short</button>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <div class="flex justify-between mb-2 text-xs">
                                    <label class="text-muted">Avail</label>
                                    <span class="text-white font-mono" id="ui-avail">0.00 USDT</span>
                                </div>
                                <div class="relative">
                                    <input type="number" id="trade-margin" placeholder="Order Margin" class="w-full b-input p-3 pr-16 text-sm font-mono" oninput="calcSize()">
                                    <button onclick="setMax()" class="absolute right-2 top-2 px-2 py-1 text-[10px] font-bold text-gold bg-[#2b3139] rounded">MAX</button>
                                </div>
                            </div>

                            <div>
                                <div class="flex justify-between mb-3 text-xs">
                                    <label class="text-muted">Leverage</label>
                                    <span class="text-white font-mono bg-[#2b3139] px-2 py-0.5 rounded"><span id="lev-val">10</span>x</span>
                                </div>
                                <input type="range" id="trade-lev" min="1" max="100" value="10" step="1" oninput="updateLev(this)" style="background: linear-gradient(to right, #F3BA2F 10%, #2b3139 10%);">
                                <div class="flex justify-between text-[10px] text-muted mt-2">
                                    <span>1x</span><span>50x</span><span>100x</span>
                                </div>
                            </div>

                            <div class="pt-4 border-t border-[#2b3139]">
                                <div class="flex justify-between text-xs mb-1">
                                    <span class="text-muted">Cost</span><span class="text-white font-mono" id="ui-cost">0.00 USDT</span>
                                </div>
                                <div class="flex justify-between text-xs">
                                    <span class="text-muted">Position Size</span><span class="text-white font-mono" id="ui-size">0.00 USDT</span>
                                </div>
                            </div>
                        </div>

                        <button onclick="executeOrder()" id="btn-execute" class="mt-6 w-full py-3.5 rounded font-bold text-sm bg-buy text-white hover:opacity-90 transition">
                            Buy / Long
                        </button>
                    </div>

                    <div class="b-panel p-4 flex flex-col">
                        <div class="flex justify-between items-center mb-4 border-b border-[#2b3139] pb-2">
                            <h3 class="text-xs font-bold text-gold flex items-center gap-2"><div class="w-2 h-2 bg-gold rounded-full animate-pulse"></div> AI Predictor</h3>
                            <button onclick="toggleModal('ai-code-modal')" class="text-[10px] text-muted hover:text-white underline">Edit Logic</button>
                        </div>
                        <div class="grid grid-cols-2 gap-3 text-xs mb-4">
                            <div class="flex flex-col bg-[#0b0e11] p-2 rounded border border-[#2b3139]"><span class="text-muted text-[10px]">RSI (14)</span><span id="ai-rsi" class="font-mono text-white">--</span></div>
                            <div class="flex flex-col bg-[#0b0e11] p-2 rounded border border-[#2b3139]"><span class="text-muted text-[10px]">SMA (20)</span><span id="ai-sma" class="font-mono text-white">--</span></div>
                        </div>
                        <div class="w-full text-center p-3 rounded border border-[#2b3139] font-black text-sm tracking-wide bg-[#0b0e11]" id="ai-signal">ANALYZING...</div>
                    </div>

                    <div class="b-panel flex flex-col flex-grow min-h-[200px]">
                        <div class="p-3 border-b border-[#2b3139] flex justify-between items-center bg-[#0b0e11] rounded-t-lg">
                            <h3 class="text-[10px] font-bold text-white uppercase">Market Trades</h3>
                            <button onclick="toggleModal('settings-modal')" class="text-[10px] text-gold hover:underline">Portfolio Setup</button>
                        </div>
                        <div class="flex-grow overflow-y-auto no-scrollbar p-2 space-y-1" id="below-chart-log">
                            <div class="text-xs text-muted text-center py-4">Awaiting network...</div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="app-wallet" class="w-full hidden">
        <main class="flex flex-col p-2 md:p-6 gap-8 w-full max-w-[1200px] mx-auto">
            
            <div class="b-panel p-6 md:p-8 flex flex-col md:flex-row justify-between items-center md:items-start gap-6 border-t-4 border-t-[#F3BA2F] relative overflow-hidden">
                <div class="z-10 flex flex-col items-center md:items-start w-full">
                    <div class="flex items-center gap-3 w-full justify-center md:justify-start">
                        <span class="text-muted text-sm font-bold">Estimated Balance</span>
                        <select id="wallet-currency" onchange="setCurrency(this.value)" class="native-sel text-xs py-1 px-2 border-none bg-transparent hover:bg-[#2b3139]">
                            <option value="USD">🇺🇸 USD</option>
                            <option value="AED">🇦🇪 AED</option>
                            <option value="EUR">🇪🇺 EUR</option>
                            <option value="GBP">🇬🇧 GBP</option>
                        </select>
                    </div>
                    <div class="flex items-baseline gap-2 mt-1">
                        <span id="wallet-currency-sym" class="text-3xl font-bold text-muted">$</span>
                        <h2 id="wallet-total-value" class="text-4xl md:text-5xl font-black text-white font-mono tracking-tighter">0.00</h2>
                    </div>
                    <div class="flex gap-3 mt-6 w-full md:w-auto">
                        <button onclick="toggleModal('send-modal')" class="flex-1 md:flex-none px-8 py-2.5 rounded text-sm font-bold bg-gold text-black hover:opacity-90 transition">Send</button>
                        <button onclick="toggleModal('swap-modal')" class="flex-1 md:flex-none px-8 py-2.5 rounded text-sm font-bold bg-[#2b3139] text-white hover:bg-[#3b4149] transition">Swap</button>
                    </div>
                </div>
                <svg class="absolute right-0 bottom-0 opacity-10 w-64 h-64 pointer-events-none transform translate-x-1/4 translate-y-1/4" viewBox="0 0 100 100"><path fill="#F3BA2F" d="M0,50 L50,0 L100,50 L50,100 Z"/></svg>
            </div>

            <div>
                <div class="flex justify-between items-end mb-4">
                    <h3 class="text-sm font-bold text-white border-l-4 border-gold pl-3">My Assets</h3>
                </div>
                <div id="wallet-square-grid" class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    </div>
                <button id="show-more-btn" onclick="toggleShowMoreAssets()" class="w-full mt-4 py-3 b-btn font-bold text-xs uppercase tracking-wider hidden">Show More</button>
            </div>

            <div class="b-panel p-6">
                <div class="flex items-center gap-3 mb-6 pb-4 border-b border-[#2b3139]">
                    <svg class="w-6 h-6 text-gold" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
                    <h2 class="text-lg font-bold text-white">Binance Earn</h2>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4" id="staking-grid">
                    </div>

                <div class="mt-8">
                    <h3 class="text-xs font-bold text-muted mb-3">Active Stakes</h3>
                    <div class="overflow-x-auto border border-[#2b3139] rounded-lg bg-[#0b0e11]">
                        <table class="w-full text-left min-w-[500px]">
                            <thead><tr><th>Asset</th><th>Staked</th><th>APR</th><th class="text-right">Earned</th></tr></thead>
                            <tbody id="active-stakes-body" class="font-mono"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="ai-code-modal" class="fixed inset-0 z-[100] modal-overlay modal-hidden flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="modal-content b-panel w-full max-w-xl p-6 relative flex flex-col">
            <button onclick="toggleModal('ai-code-modal')" class="absolute top-4 right-4 text-muted hover:text-white">✕</button>
            <h2 class="text-sm font-bold text-white mb-4">AI Predictor Logic (JS)</h2>
            <textarea id="ai-logic-editor" class="w-full h-[300px] bg-[#0b0e11] text-[#EAECEF] p-4 text-xs font-mono outline-none border border-[#2b3139] rounded resize-none mb-4" spellcheck="false"></textarea>
            <button onclick="saveAILogic()" class="w-full py-3 rounded text-sm font-bold bg-gold text-black hover:opacity-90 transition">Compile & Save</button>
        </div>
    </div>

    <div id="send-modal" class="fixed inset-0 z-[100] modal-overlay modal-hidden flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="modal-content b-panel w-full max-w-sm p-6 relative flex flex-col border-t-4 border-t-gold">
            <button onclick="closeSendModal()" class="absolute top-4 right-4 text-muted hover:text-white" id="send-close-btn">✕</button>
            <h2 class="text-lg font-bold text-white mb-6">Send Crypto</h2>
            
            <div id="send-form" class="space-y-4">
                <div>
                    <label class="text-xs text-muted block mb-1.5">Asset</label>
                    <select id="send-asset" class="w-full native-sel" onchange="updateSendMax()"></select>
                </div>
                <div>
                    <label class="text-xs text-muted block mb-1.5">Address</label>
                    <input type="text" id="send-address" placeholder="0x..." class="w-full b-input p-3 text-sm font-mono">
                </div>
                <div>
                    <div class="flex justify-between text-xs mb-1.5">
                        <label class="text-muted">Amount</label>
                        <span class="text-gold cursor-pointer" onclick="setMaxSend()">MAX (<span id="send-avail-txt">0.00</span>)</span>
                    </div>
                    <input type="number" id="send-amount" placeholder="0.00" class="w-full b-input p-3 text-sm font-mono">
                </div>
                <button onclick="initiateSend()" class="mt-4 w-full py-3 rounded text-sm font-bold bg-gold text-black hover:opacity-90 transition">Withdraw</button>
            </div>

            <div id="send-processing" class="hidden flex-col items-center justify-center py-6">
                <div class="spinner w-10 h-10 mb-4"></div>
                <h3 class="text-sm font-bold text-gold mb-3" id="send-status-title">Broadcasting...</h3>
                <div class="w-full bg-[#0b0e11] p-3 rounded border border-[#2b3139] text-[10px] font-mono text-muted h-32 overflow-y-auto no-scrollbar" id="send-log"></div>
            </div>
        </div>
    </div>

    <div id="swap-modal" class="fixed inset-0 z-[100] modal-overlay modal-hidden flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="modal-content b-panel w-full max-w-sm p-6 relative flex flex-col">
            <button onclick="toggleModal('swap-modal')" class="absolute top-4 right-4 text-muted hover:text-white" id="swap-close-btn">✕</button>
            <h2 class="text-lg font-bold text-white mb-6">Swap Assets</h2>
            
            <div id="swap-form-content" class="space-y-4">
                <div class="bg-[#0b0e11] p-3 rounded border border-[#2b3139]">
                    <div class="flex justify-between text-xs text-muted mb-2"><span>From</span><span id="swap-bal-from">Bal: 0.00</span></div>
                    <div class="flex gap-2">
                        <input type="number" id="swap-amt-from" placeholder="0.00" class="flex-grow bg-transparent text-white text-lg font-mono outline-none w-full" oninput="calcSwap()">
                        <select id="swap-asset-from" class="w-24 native-sel" onchange="updateSwapBals(); calcSwap()"></select>
                    </div>
                </div>
                
                <div class="flex justify-center -my-3 relative z-10">
                    <div class="bg-[#2b3139] p-1.5 rounded-full border-2 border-[#1e2329] text-white">↓</div>
                </div>

                <div class="bg-[#0b0e11] p-3 rounded border border-[#2b3139]">
                    <div class="flex justify-between text-xs text-muted mb-2"><span>To (Est.)</span><span id="swap-bal-to">Bal: 0.00</span></div>
                    <div class="flex gap-2">
                        <input type="text" id="swap-amt-to" placeholder="0.00" class="flex-grow bg-transparent text-muted text-lg font-mono outline-none w-full" readonly>
                        <select id="swap-asset-to" class="w-24 native-sel" onchange="updateSwapBals(); calcSwap()"></select>
                    </div>
                </div>
                
                <div class="text-[10px] text-muted text-center" id="swap-rate-text">1 -- = -- --</div>
