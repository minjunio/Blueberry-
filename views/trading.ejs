<!DOCTYPE html>
<html lang="en">
<head>
    <title>Pro Terminal - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <style>
        /* Exact Rainbet/Admin Casino Theme */
        body { background: #06090e; color: #f8fafc; font-family: 'Inter', sans-serif; transition: background-color 0.3s; }
        .casino-panel { background: #0d131f; border: 1px solid #1f2937; box-shadow: 0 15px 35px rgba(0,0,0,0.6); border-radius: 1rem; }
        .casino-input { background: #06090e; border: 1px solid #1f2937; color: white; outline: none; transition: 0.2s; }
        .casino-input:focus { border-color: #00ffaa; }
        .casino-btn { background: #1f2937; border: 1px solid #374151; color: white; transition: 0.2s; }
        .casino-btn:hover { background: #374151; }
        .text-muted { color: #6b7280; }
        
        /* Dramatic Market Effects */
        @keyframes flashGreen {
            0% { box-shadow: inset 0 0 60px rgba(0, 255, 170, 0.15), 0 0 20px rgba(0, 255, 170, 0.2); border-color: rgba(0, 255, 170, 0.5); }
            100% { box-shadow: inset 0 0 0 transparent; border-color: #1f2937; }
        }
        @keyframes flashRed {
            0% { box-shadow: inset 0 0 60px rgba(239, 68, 68, 0.15), 0 0 20px rgba(239, 68, 68, 0.2); border-color: rgba(239, 68, 68, 0.5); }
            100% { box-shadow: inset 0 0 0 transparent; border-color: #1f2937; }
        }
        .anim-pump { animation: flashGreen 0.6s ease-out; }
        .anim-dump { animation: flashRed 0.6s ease-out; }

        .text-pump { color: #00ffaa !important; text-shadow: 0 0 15px rgba(0,255,170,0.5); }
        .text-dump { color: #ef4444 !important; text-shadow: 0 0 15px rgba(239,68,68,0.5); }

        /* Custom UI */
        .tab-active { background: #00ffaa !important; color: #06090e !important; border-color: #00ffaa !important; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        /* Range Slider */
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 16px; width: 16px; border-radius: 50%; background: #00ffaa; cursor: pointer; margin-top: -6px; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; background: #374151; border-radius: 2px; }
    </style>
</head>
<body class="p-3 md:p-6 h-screen flex flex-col">

    <div class="max-w-[1600px] mx-auto w-full flex-grow flex flex-col relative z-10">
        
        <div class="flex justify-between items-center mb-4 shrink-0 bg-[#0d131f] border border-[#1f2937] p-3 md:p-4 rounded-2xl shadow-lg">
            <div class="flex items-center gap-3">
                <svg viewBox="0 0 24 24" width="28" height="28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 5 12 2 12 2C12 2 2 5 2 12C2 17.5228 6.47715 22 12 22Z" fill="#00ffaa"/><path d="M12 16C13.6569 16 15 14.6569 15 13C15 11.3431 12 8 12 8C12 8 9 11.3431 9 13C9 14.6569 10.3431 16 12 16Z" fill="#06090e"/></svg>
                <h2 class="text-xl md:text-2xl font-black uppercase tracking-tighter text-white">Pro Terminal</h2>
            </div>
            
            <div class="flex gap-2 bg-[#06090e] p-1 rounded-xl border border-[#1f2937]">
                <button onclick="switchTab('wallet')" id="btn-wallet" class="px-5 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest casino-btn">Portfolio</button>
                <button onclick="switchTab('trading')" id="btn-trading" class="px-5 py-2 rounded-lg text-[10px] font-black uppercase tracking-widest casino-btn tab-active">Trading</button>
            </div>

            <a href="/admin" class="casino-btn px-4 py-2 rounded-lg font-black text-[10px] uppercase tracking-widest transition hover:text-[#00ffaa]">Exit Node</a>
        </div>

        <div class="flex-grow relative overflow-hidden">
            
            <div id="tab-wallet" class="absolute inset-0 hidden overflow-y-auto no-scrollbar">
                <div class="casino-panel p-8 md:p-12 mb-6 relative overflow-hidden">
                    <div class="absolute -right-10 -bottom-10 w-64 h-64 bg-[#00ffaa]/10 rounded-full blur-[80px]"></div>
                    <p class="text-[10px] font-black text-[#00ffaa] uppercase tracking-widest mb-2">Total Node Equity</p>
                    <h2 class="text-5xl md:text-6xl font-black tracking-tight text-white mb-2" id="wallet-total">$88,000.00</h2>
                    <p class="text-xs font-bold text-muted">Available Liquidity: <span class="text-white" id="wallet-avail">88000.00</span> USDT</p>
                </div>

                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="casino-panel p-5 flex flex-col justify-between hover:border-[#00ffaa]/50 transition">
                        <div class="flex justify-between items-start mb-4">
                            <img src="https://cryptologos.cc/logos/tether-usdt-logo.svg?v=029" class="w-8 h-8 rounded-full shadow-lg">
                            <span class="text-[10px] font-black uppercase text-muted">Tether</span>
                        </div>
                        <h4 class="text-xl font-black text-white" id="wallet-usdt-display">88,000.00</h4>
                    </div>
                    <div class="casino-panel p-5 flex flex-col justify-between opacity-50">
                        <div class="flex justify-between items-start mb-4">
                            <img src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-8 h-8 rounded-full shadow-lg filter grayscale">
                            <span class="text-[10px] font-black uppercase text-muted">Bitcoin</span>
                        </div>
                        <h4 class="text-xl font-black text-white">0.000</h4>
                    </div>
                </div>
            </div>

            <div id="tab-trading" class="absolute inset-0 flex flex-col lg:flex-row gap-4 h-full overflow-y-auto lg:overflow-hidden pb-4">
                
                <div class="flex-grow flex flex-col gap-4 lg:w-2/3 h-full">
                    
                    <div id="chart-wrap" class="casino-panel flex-grow relative flex flex-col min-h-[40vh] transition-all duration-300 overflow-hidden">
                        
                        <div class="absolute top-4 left-4 z-10 flex flex-col pointer-events-none">
                            <div class="flex items-center gap-2 pointer-events-auto">
                                <select id="symbol-select" onchange="initFeeds()" class="casino-input px-3 py-1.5 rounded-lg text-lg font-black uppercase cursor-pointer appearance-none">
                                    <option value="BTCUSDT">BTC/USDT</option>
                                    <option value="ETHUSDT">ETH/USDT</option>
                                    <option value="SOLUSDT">SOL/USDT</option>
                                    <option value="DOGEUSDT">DOGE/USDT</option>
                                </select>
                            </div>
                            <h2 id="live-price" class="text-4xl font-black text-white mt-1 transition-colors duration-200">Loading...</h2>
                        </div>

                        <div id="tvchart" class="w-full h-full mt-20"></div>
                    </div>

                    <div class="casino-panel h-[35vh] flex flex-col shrink-0">
                        <div class="flex justify-between items-center p-4 border-b border-[#1f2937] bg-[#06090e]/50">
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-[#00ffaa]">Active Contracts</h3>
                            <span class="text-[10px] font-bold text-muted">Live ROI Updates via WebSocket</span>
                        </div>
                        <div class="flex-grow overflow-auto no-scrollbar p-0">
                            <table class="w-full text-left border-collapse min-w-[600px]">
                                <thead class="sticky top-0 bg-[#0d131f] shadow-sm">
                                    <tr class="text-[9px] font-black uppercase tracking-widest text-muted border-b border-[#1f2937]">
                                        <th class="p-3">Asset</th>
                                        <th class="p-3">Side</th>
                                        <th class="p-3">Lev</th>
                                        <th class="p-3">Margin</th>
                                        <th class="p-3">Entry</th>
                                        <th class="p-3 text-right">Live ROI</th>
                                        <th class="p-3 text-center">Execute</th>
                                    </tr>
                                </thead>
                                <tbody id="orders-body" class="text-xs font-bold text-slate-300">
                                    </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="casino-panel lg:w-[340px] shrink-0 p-5 flex flex-col h-full">
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-muted mb-4 border-b border-[#1f2937] pb-2">Order Execution</h3>
                    
                    <div class="flex gap-2 bg-[#06090e] p-1 border border-[#1f2937] rounded-xl mb-6 shrink-0">
                        <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest bg-[#00ffaa] text-[#06090e] shadow-[0_0_10px_rgba(0,255,170,0.3)] transition">Long</button>
                        <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-red-500 transition">Short</button>
                    </div>

                    <div class="space-y-6 flex-grow overflow-y-auto no-scrollbar">
                        
                        <div>
                            <div class="flex justify-between mb-2">
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted">Margin (USDT)</label>
                                <span class="text-[10px] font-black text-[#00ffaa] cursor-pointer hover:underline" onclick="setMax()">MAX</span>
                            </div>
                            <input type="number" id="trade-margin" placeholder="0.00" class="w-full casino-input p-4 rounded-xl text-xl font-black">
                        </div>

                        <div>
                            <div class="flex justify-between mb-3">
                                <label class="text-[10px] font-black uppercase tracking-widest text-muted">Leverage</label>
                                <span class="text-[10px] font-black text-white"><span id="lev-val">10</span>x</span>
                            </div>
                            <input type="range" id="trade-lev" min="1" max="100" value="10" class="w-full">
                            <div class="flex justify-between text-[9px] font-black text-muted mt-2">
                                <span>1x</span><span>50x</span><span>100x</span>
                            </div>
                        </div>

                        <div class="p-4 bg-[#06090e] border border-[#1f2937] rounded-xl space-y-2">
                            <div class="flex justify-between text-[10px] font-black uppercase tracking-widest">
                                <span class="text-muted">Available</span>
                                <span class="text-white"><span id="ui-avail">88000.00</span> USDT</span>
                            </div>
                            <div class="flex justify-between text-[10px] font-black uppercase tracking-widest">
                                <span class="text-muted">Total Size</span>
                                <span class="text-blue-400"><span id="ui-size">0.00</span> USDT</span>
                            </div>
                        </div>
                    </div>

                    <button onclick="executeOrder()" id="btn-execute" class="mt-4 w-full py-5 rounded-xl font-black uppercase tracking-[0.2em] text-xs bg-[#00ffaa] text-[#06090e] hover:bg-[#00d68f] shadow-[0_0_20px_rgba(0,255,170,0.3)] transition active:scale-95 shrink-0">
                        Open Long
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- 1. CORE DATA & PERSISTENCE ---
        let state = JSON.parse(localStorage.getItem('terminal_state')) || {
            balance: 88000.00,
            orders: []
        };
        let ui = { side: 'buy', symbol: 'BTCUSDT', price: 0, lastPrice: 0, lev: 10 };

        function saveState() {
            localStorage.setItem('terminal_state', JSON.stringify(state));
            updateWalletUI();
        }

        // --- 2. TAB CONTROLS ---
        function switchTab(tab) {
            document.getElementById('btn-trading').classList.replace('tab-active', 'casino-btn');
            document.getElementById('btn-wallet').classList.replace('tab-active', 'casino-btn');
            document.getElementById(`btn-${tab}`).classList.add('tab-active');
            
            document.getElementById('tab-trading').style.display = tab === 'trading' ? 'flex' : 'none';
            document.getElementById('tab-wallet').style.display = tab === 'wallet' ? 'block' : 'none';
            
            if(tab === 'trading') setTimeout(() => chart.timeScale().fitContent(), 50);
            updateWalletUI();
        }

        // --- 3. CHARTING (Lightweight Charts - Exact Theme Colors) ---
        const chartElement = document.getElementById('tvchart');
        const chart = LightweightCharts.createChart(chartElement, {
            layout: { background: { type: 'solid', color: 'transparent' }, textColor: '#6b7280' },
            grid: { vertLines: { color: 'rgba(31, 41, 55, 0.5)' }, horzLines: { color: 'rgba(31, 41, 55, 0.5)' } },
            crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
            rightPriceScale: { borderColor: '#1f2937' },
            timeScale: { borderColor: '#1f2937', timeVisible: true }
        });

        const candleSeries = chart.addCandlestickSeries({
            upColor: '#00ffaa', downColor: '#ef4444', borderVisible: false,
            wickUpColor: '#00ffaa', wickDownColor: '#ef4444'
        });

        new ResizeObserver(entries => {
            if (entries.length === 0 || entries[0].target !== chartElement) return;
            chart.applyOptions({ width: entries[0].contentRect.width, height: entries[0].contentRect.height });
        }).observe(chartElement);

        // --- 4. GUARANTEED DATA FEEDS (Binance REST + WebSockets) ---
        let ws;
        async function initFeeds() {
            ui.symbol = document.getElementById('symbol-select').value;
            const priceEl = document.getElementById('live-price');
            const wrapEl = document.getElementById('chart-wrap');
            
            priceEl.innerText = "Syncing...";
            if(ws) ws.close();

            try {
                // 1. Fetch historical data so chart is never empty
                const res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${ui.symbol}&interval=1m&limit=100`);
                if (!res.ok) throw new Error("REST API Failed");
                const data = await res.json();
                
                const history = data.map(d => ({
                    time: d[0] / 1000,
                    open: parseFloat(d[1]), high: parseFloat(d[2]), low: parseFloat(d[3]), close: parseFloat(d[4])
                }));
                candleSeries.setData(history);
                ui.price = history[history.length - 1].close;
                priceEl.innerText = `$${ui.price.toFixed(2)}`;

            } catch (err) {
                console.error("API Error, injecting simulated history.", err);
                // Guaranteed Fallback: If network blocks Binance, generate a fake graph so UI works
                let fakeHistory = [];
                let p = 60000;
                for(let i=100; i>0; i--) {
                    let move = (Math.random()-0.5)*100;
                    fakeHistory.push({ time: (Date.now()/1000) - (i*60), open: p, high: p+50, low: p-50, close: p+move });
                    p += move;
                }
                candleSeries.setData(fakeHistory);
                ui.price = p;
            }

            // 2. Connect Binance WebSocket for live data
            ws = new WebSocket(`wss://stream.binance.com:9443/ws/${ui.symbol.toLowerCase()}@kline_1m`);
            ws.onmessage = (e) => {
                const k = JSON.parse(e.data).k;
                const newPrice = parseFloat(k.c);
                
                // Dramatic UI Flashes
                if (ui.lastPrice !== 0 && newPrice !== ui.lastPrice) {
                    wrapEl.classList.remove('anim-pump', 'anim-dump');
                    priceEl.classList.remove('text-pump', 'text-dump');
                    void wrapEl.offsetWidth; // Reflow
                    
                    const isUp = newPrice > ui.lastPrice;
                    wrapEl.classList.add(isUp ? 'anim-pump' : 'anim-dump');
                    priceEl.classList.add(isUp ? 'text-pump' : 'text-dump');
                }
                
                ui.lastPrice = newPrice;
                ui.price = newPrice;
                const dec = newPrice < 10 ? 4 : 2;
                priceEl.innerText = `$${newPrice.toLocaleString(undefined, {minimumFractionDigits: dec})}`;

                candleSeries.update({
                    time: k.t / 1000, open: parseFloat(k.o), high: parseFloat(k.h), low: parseFloat(k.l), close: parseFloat(k.c)
                });

                renderOrders(); // Update ROI
            };
        }

        // --- 5. EXECUTION PANEL ---
        function setSide(side) {
            ui.side = side;
            const bBuy = document.getElementById('btn-buy');
            const bSell = document.getElementById('btn-sell');
            const bExec = document.getElementById('btn-execute');

            if(side === 'buy') {
                bBuy.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest bg-[#00ffaa] text-[#06090e] shadow-[0_0_10px_rgba(0,255,170,0.3)] transition";
                bSell.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-red-500 transition";
                bExec.className = "mt-4 w-full py-5 rounded-xl font-black uppercase tracking-[0.2em] text-xs bg-[#00ffaa] text-[#06090e] hover:bg-[#00d68f] shadow-[0_0_20px_rgba(0,255,170,0.3)] transition active:scale-95 shrink-0";
                bExec.innerText = "Open Long";
            } else {
                bSell.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest bg-red-500 text-white shadow-[0_0_10px_rgba(239,68,68,0.3)] transition";
                bBuy.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-[#00ffaa] transition";
                bExec.className = "mt-4 w-full py-5 rounded-xl font-black uppercase tracking-[0.2em] text-xs bg-red-500 text-white hover:bg-red-400 shadow-[0_0_20px_rgba(239,68,68,0.3)] transition active:scale-95 shrink-0";
                bExec.innerText = "Open Short";
            }
        }

        document.getElementById('trade-lev').addEventListener('input', (e) => {
            ui.lev = parseInt(e.target.value);
            document.getElementById('lev-val').innerText = ui.lev;
            calcSize();
        });

        const marginInput = document.getElementById('trade-margin');
        marginInput.addEventListener('input', calcSize);

        function calcSize() {
            const margin = parseFloat(marginInput.value) || 0;
            document.getElementById('ui-size').innerText = (margin * ui.lev).toLocaleString(undefined, {minimumFractionDigits: 2});
        }

        function setMax() {
            marginInput.value = state.balance.toFixed(2);
            calcSize();
        }

        function executeOrder() {
            const margin = parseFloat(marginInput.value);
            if (isNaN(margin) || margin <= 0) return alert("Enter valid margin.");
            if (margin > state.balance) return alert("Insufficient USDT.");

            state.balance -= margin;
            
            const totalSize = margin * ui.lev;
            state.orders.push({
                id: Math.random().toString(36).substr(2, 9),
                symbol: ui.symbol,
                side: ui.side,
                margin: margin,
                lev: ui.lev,
                entry: ui.price,
                units: totalSize / ui.price
            });

            marginInput.value = '';
            calcSize();
            saveState();
            renderOrders();
        }

        // --- 6. ROI & ORDER RENDERING ---
        function renderOrders() {
            const tbody = document.getElementById('orders-body');
            
            if (state.orders.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="p-6 text-center text-muted font-black uppercase tracking-widest text-xs">No Active Positions</td></tr>`;
                return;
            }

            let html = '';
            state.orders.forEach(order => {
                let pnl = 0;
                // Live PNL updates automatically if symbol matches the active websocket
                if (order.symbol === ui.symbol) {
                    const currentVal = order.units * ui.price;
                    const initialVal = order.margin * order.lev;
                    pnl = order.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
                }

                const roiPct = (pnl / order.margin) * 100;
                const isProf = pnl >= 0;
                const cColor = isProf ? 'text-[#00ffaa]' : 'text-red-500';
                const sColor = order.side === 'buy' ? 'text-[#00ffaa] bg-[#00ffaa]/10' : 'text-red-500 bg-red-500/10';
                
                html += `
                    <tr class="border-b border-[#1f2937]/50 hover:bg-[#1f2937]/30 transition group">
                        <td class="p-3 font-black text-white">${order.symbol}</td>
                        <td class="p-3"><span class="px-2 py-1 rounded text-[9px] font-black uppercase tracking-widest ${sColor}">${order.side}</span></td>
                        <td class="p-3">${order.lev}x</td>
                        <td class="p-3">$${order.margin.toFixed(2)}</td>
                        <td class="p-3">$${order.entry.toFixed(4)}</td>
                        <td class="p-3 text-right ${cColor} font-black">${isProf?'+':''}$${pnl.toFixed(2)} (${isProf?'+':''}${roiPct.toFixed(2)}%)</td>
                        <td class="p-3 text-center">
                            <button onclick="closeOrder('${order.id}')" class="px-3 py-2 bg-[#1f2937] hover:bg-white hover:text-black text-white rounded text-[9px] uppercase font-black transition">Close</button>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function closeOrder(id) {
            const idx = state.orders.findIndex(p => p.id === id);
            if (idx === -1) return;
            
            const o = state.orders[idx];
            let pnl = 0;
            if (o.symbol === ui.symbol) {
                const currentVal = o.units * ui.price;
                const initialVal = o.margin * o.lev;
                pnl = o.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
            }
            
            state.balance += (o.margin + pnl);
            state.orders.splice(idx, 1);
            
            saveState();
            renderOrders();
        }

        function updateWalletUI() {
            const bal = state.balance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('ui-avail').innerText = bal;
            document.getElementById('wallet-total').innerText = `$${bal}`;
            document.getElementById('wallet-usdt-display').innerText = bal;
            document.getElementById('wallet-avail').innerText = bal;
        }

        // --- Initialization ---
        switchTab('trading');
        initFeeds();
        updateWalletUI();
        renderOrders();
    </script>
</body>
</html>
