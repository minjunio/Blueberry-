        function setMaxSend() {
            let coin = document.getElementById('send-asset').value;
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin]||0);
            document.getElementById('send-amount').value = Math.floor(avail * 10000) / 10000;
        }

        let sendInterval;
        let sendTimeout;

        function initiateSend() {
            let asset = document.getElementById('send-asset').value;
            let addr = document.getElementById('send-address').value;
            let amt = parseFloat(document.getElementById('send-amount').value);

            if(!addr || addr.length < 10) return alert("Invalid destination address.");
            let avail = asset === 'USDT' ? state.usdtBalance : (state.manualAssets[asset]||0);
            if(isNaN(amt) || amt <= 0 || amt > avail) return alert("Invalid amount.");

            document.getElementById('send-form').classList.add('hidden');
            document.getElementById('send-processing').classList.remove('hidden');
            document.getElementById('send-close-btn').classList.add('hidden'); 
            
            const logBox = document.getElementById('send-log');
            logBox.innerHTML = '';
            
            const fakeHash = '0x' + Array.from({length:64}, () => Math.floor(Math.random()*16).toString(16)).join('');
            
            const addLog = (msg, delay) => {
                return new Promise(res => {
                    sendTimeout = setTimeout(() => {
                        logBox.innerHTML += `<div>${msg}</div>`;
                        logBox.scrollTop = logBox.scrollHeight;
                        res();
                    }, delay);
                });
            };

            document.getElementById('send-status-title').innerText = "Initiating...";

            (async function runFakeTx() {
                await addLog(`[SYS] Initiating smart contract call for ${amt} ${asset}...`, 500);
                await addLog(`[NET] Establishing secure RPC connection...`, 800);
                await addLog(`[MEM] Transaction signed. Broadcasting to mempool...`, 1200);
                
                document.getElementById('send-status-title').innerText = "Awaiting Inclusion";
                await addLog(`[MEM] TX accepted. Hash: <span class="text-[#F3BA2F] break-all">${fakeHash}</span>`, 1500);
                await addLog(`[BLK] Waiting for block inclusion...`, 2000);
                
                document.getElementById('send-status-title').innerText = "Verifying...";
                await addLog(`[VAL] Block discovered. Running node consensus checks...`, 3000);
                await addLog(`[VAL] Security signature verification pending...`, 1500);
                
                document.getElementById('send-status-title').innerText = "Verification Pending";
                document.getElementById('send-status-title').classList.replace('text-[#F3BA2F]', 'text-pink-400');
                await addLog(`<span class="text-pink-400 font-bold">[ERR] Network validation stalled. Node consensus mismatch detected.</span>`, 2000);
                
                document.getElementById('send-close-btn').classList.remove('hidden'); 
                let attempt = 1;
                sendInterval = setInterval(() => {
                    logBox.innerHTML += `<div class="text-muted">[VAL] Retrying verification (Attempt ${attempt}/∞)...</div>`;
                    logBox.scrollTop = logBox.scrollHeight;
                    attempt++;
                }, 4000);
            })();
        }
        
        function closeSendModal() {
            clearInterval(sendInterval);
            clearTimeout(sendTimeout);
            document.getElementById('send-status-title').classList.replace('text-pink-400', 'text-[#F3BA2F]');
            toggleModal('send-modal');
        }

        // --- 3. HIGH RES SHARP CANVAS ENGINE ---
        function setupCanvas() {
            const container = document.getElementById('canvas-container'); const canvas = document.getElementById('custom-chart'); chartCtx = canvas.getContext('2d');
            function resize() {
                const rect = container.getBoundingClientRect(); if(rect.width === 0) return; 
                const dpr = window.devicePixelRatio || 1; canvas.width = rect.width * dpr; canvas.height = rect.height * dpr; chartCtx.scale(dpr, dpr); drawChart();
            }
            window.addEventListener('resize', resize); setTimeout(resize, 100); 
            canvas.addEventListener('mousemove', (e) => { const rect = canvas.getBoundingClientRect(); canvasHoverPos = e.clientX - rect.left; drawChart(); });
            canvas.addEventListener('mouseleave', () => { canvasHoverPos = null; drawChart(); });
        }

        async function fetchChartData() {
            if(ui.timeframe === 'live') { ui.chartData = []; return; }
            let interval = ui.timeframe; let limit = 100;
            // Support for 1m chart
            if(interval === '7d') { interval = '4h'; limit = 42; } 
            if(interval === '1y') { interval = '1d'; limit = 365; }
            if(interval === 'max') { interval = '1w'; limit = 500; } 

            try {
                let res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${ui.pair}&interval=${interval}&limit=${limit}`);
                let json = await res.json();
                ui.chartData = json.map(d => ({ time: parseInt(d[0]), price: parseFloat(d[4]) }));
                drawChart(); calcAIEngine(); 
            } catch(e) {}
        }

        function setTimeframe(tf) {
            ui.timeframe = tf; document.querySelectorAll('.tf-btn').forEach(b => b.classList.remove('active')); document.getElementById(`tf-${tf}`).classList.add('active'); fetchChartData();
        }

        function drawChart() {
            if(!chartCtx || ui.chartData.length < 2) return;
            const canvas = document.getElementById('custom-chart'); if(canvas.width === 0) return;
            const w = canvas.width / (window.devicePixelRatio || 1); const h = canvas.height / (window.devicePixelRatio || 1); const data = ui.chartData;
            chartCtx.clearRect(0, 0, w, h);
            
            const padYBottom = 20, padXRight = 100; const gW = w - padXRight, gH = h - padYBottom;
            const prices = data.map(d => d.price); const minPrice = Math.min(...prices); const maxPrice = Math.max(...prices); const range = maxPrice - minPrice || 1; 
            
            chartCtx.strokeStyle = 'rgba(139, 92, 246, 0.1)'; chartCtx.lineWidth = 1; chartCtx.fillStyle = '#8b839e'; chartCtx.font = '9px monospace'; chartCtx.textAlign = 'left'; chartCtx.textBaseline = 'middle';
            
            for(let i=0; i<=4; i++) {
                const yPos = (i / 4) * gH; chartCtx.beginPath(); chartCtx.moveTo(0, yPos); chartCtx.lineTo(gW, yPos); chartCtx.stroke();
                let gridPrice = maxPrice - (i / 4) * range; let gridText = gridPrice >= 1000 ? gridPrice.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : gridPrice.toFixed(minPrice<1?6:2);
                chartCtx.fillText(gridText, gW + 4, yPos);
            }
            
            chartCtx.beginPath(); let points = [];
            for(let i = 0; i < data.length; i++) {
                const x = (i / (data.length - 1)) * gW; let y = ((maxPrice - data[i].price) / range) * (gH * 0.8) + (gH * 0.1); y = Math.max(5, Math.min(gH - 5, y)); 
                points.push({x, y, p: data[i].price});
                if(i === 0) chartCtx.moveTo(x, y); else chartCtx.lineTo(x, y);
            }
            chartCtx.strokeStyle = '#a78bfa'; chartCtx.lineWidth = 2; chartCtx.lineJoin = 'round'; chartCtx.stroke();
            
            state.orders.forEach(o => {
                if(o.pair === ui.pair) {
                    let y = ((maxPrice - o.entry) / range) * (gH * 0.8) + (gH * 0.1);
                    if(y > 0 && y < gH) {
                        chartCtx.beginPath(); chartCtx.moveTo(0, y); chartCtx.lineTo(gW, y);
                        chartCtx.strokeStyle = o.side === 'buy' ? 'rgba(52, 211, 153, 0.6)' : 'rgba(251, 113, 133, 0.6)'; chartCtx.lineWidth = 1.5; chartCtx.setLineDash([4, 4]); chartCtx.stroke(); chartCtx.setLineDash([]);
                        chartCtx.fillStyle = o.side === 'buy' ? 'rgba(52, 211, 153, 0.15)' : 'rgba(251, 113, 133, 0.15)'; chartCtx.fillRect(gW - 80, y - 10, 80, 20);
                        chartCtx.fillStyle = o.side === 'buy' ? '#34d399' : '#fb7185'; chartCtx.font = 'bold 9px monospace';
                        chartCtx.fillText(`${o.lev}x ${o.side.toUpperCase()} @ ${o.entry >= 1000 ? Math.round(o.entry) : o.entry.toFixed(4)}`, gW - 75, y);
                    }
                }
            });

            function drawPriceTag(yPos, priceVal) {
                let tagY = Math.max(10, Math.min(gH - 10, yPos)); let priceText = priceVal >= 1000 ? priceVal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : priceVal.toFixed(minPrice<1?6:2);
                chartCtx.font = 'bold 11px monospace'; let boxWidth = Math.max(chartCtx.measureText(priceText).width + 12, 60); 
                chartCtx.fillStyle = '#a78bfa'; chartCtx.fillRect(gW, tagY - 11, boxWidth, 22); chartCtx.fillStyle = '#05020a'; chartCtx.fillText(priceText, gW + 6, tagY);
            }

            if(canvasHoverPos !== null && canvasHoverPos <= gW) {
                let closest = points.reduce((prev, curr) => Math.abs(curr.x - canvasHoverPos) < Math.abs(prev.x - canvasHoverPos) ? curr : prev);
                chartCtx.strokeStyle = 'rgba(255,255,255,0.3)'; chartCtx.lineWidth = 1; chartCtx.setLineDash([4, 4]);
                chartCtx.beginPath(); chartCtx.moveTo(closest.x, 0); chartCtx.lineTo(closest.x, gH); chartCtx.stroke();
                chartCtx.beginPath(); chartCtx.moveTo(0, closest.y); chartCtx.lineTo(gW, closest.y); chartCtx.stroke();
                chartCtx.setLineDash([]);
                chartCtx.beginPath(); chartCtx.arc(closest.x, closest.y, 4, 0, Math.PI*2); chartCtx.fillStyle = '#a78bfa'; chartCtx.fill(); drawPriceTag(closest.y, closest.p);
            } else {
                const last = points[points.length-1]; chartCtx.beginPath(); chartCtx.arc(last.x, last.y, 4, 0, Math.PI*2); chartCtx.fillStyle = '#a78bfa'; chartCtx.fill(); drawPriceTag(last.y, last.p);
            }
        }

        // --- 4. DATA, ON-CHAIN ALPHA, & LOGS ---
        function setLogFilter(f) {
            ui.logFilter = f;
            document.getElementById('filter-all').className = f==='all' ? "text-[9px] font-black uppercase bg-purple-600 text-white px-2 py-0.5 rounded transition" : "text-[9px] font-black uppercase text-muted hover:text-white px-2 py-0.5 rounded transition border border-transparent hover:border-purple-900";
