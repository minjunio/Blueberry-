<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bluebook Terminal - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');
        
        /* Bluebook Aesthetic */
        body { background-color: #020617; color: #f8fafc; font-family: 'Inter', sans-serif; height: 100vh; overflow: hidden; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        
        /* Glass/Blueprint Panels */
        .blue-panel { background: rgba(15, 23, 42, 0.6); backdrop-filter: blur(10px); border: 1px solid #1e3a8a; border-radius: 12px; }
        .input-blue { background: #020617; border: 1px solid #1e3a8a; color: #38bdf8; outline: none; transition: all 0.2s; }
        .input-blue:focus { border-color: #0ea5e9; box-shadow: 0 0 15px rgba(14, 165, 233, 0.3); }
        
        /* Dramatic Price Effects */
        @keyframes pumpGlow {
            0% { text-shadow: 0 0 40px #0ea5e9, 0 0 20px #0ea5e9; color: #38bdf8; transform: scale(1.02); }
            100% { text-shadow: 0 0 0 transparent; color: #f8fafc; transform: scale(1); }
        }
        @keyframes dumpGlow {
            0% { text-shadow: 0 0 40px #f43f5e, 0 0 20px #f43f5e; color: #fb7185; transform: scale(0.98); }
            100% { text-shadow: 0 0 0 transparent; color: #f8fafc; transform: scale(1); }
        }
        .effect-pump { animation: pumpGlow 0.5s ease-out; }
        .effect-dump { animation: dumpGlow 0.5s ease-out; }

        @keyframes bgPulsePump { 0% { background: rgba(14, 165, 233, 0.1); } 100% { background: transparent; } }
        @keyframes bgPulseDump { 0% { background: rgba(244, 63, 94, 0.1); } 100% { background: transparent; } }
        .bg-pump { animation: bgPulsePump 0.5s ease-out; }
        .bg-dump { animation: bgPulseDump 0.5s ease-out; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #1e3a8a; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #3b82f6; }
        
        /* Range Slider */
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 20px; width: 20px; border-radius: 50%; background: #0ea5e9; cursor: pointer; box-shadow: 0 0 10px #0ea5e9; margin-top: -8px; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; cursor: pointer; background: #1e3a8a; border-radius: 2px; }
        input[type=number]::-webkit-inner-spin-button, input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; margin: 0; }
    </style>
</head>
<body class="flex flex-col">

    <header class="h-16 border-b border-[#1e3a8a] bg-[#020617] shrink-0 px-4 flex items-center justify-between z-50 shadow-[0_4px_30px_rgba(30,58,138,0.2)]">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded border border-[#38bdf8] flex items-center justify-center bg-[#0ea5e9]/20 shadow-[0_0_10px_#0ea5e9]">
                <svg class="w-5 h-5 text-[#38bdf8]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <h1 class="text-lg font-black uppercase tracking-widest text-[#f8fafc] hidden sm:block">Bluebook <span class="text-[#38bdf8]">Pro</span></h1>
        </div>
        
        <div class="flex gap-1 bg-[#0f172a] p-1 rounded-lg border border-[#1e3a8a]">
            <button onclick="switchTab('trading')" id="tabBtn-trading" class="px-4 md:px-8 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-[#1e3a8a] text-white shadow">Terminal</button>
            <button onclick="switchTab('wallet')" id="tabBtn-wallet" class="px-4 md:px-8 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-white transition">Portfolio</button>
        </div>

        <a href="/admin" class="text-[10px] font-black uppercase tracking-widest text-[#38bdf8] border border-[#1e3a8a] hover:bg-[#1e3a8a] px-4 py-2 rounded transition">Exit System</a>
    </header>

    <main class="flex-1 flex overflow-hidden relative">
        
        <div id="view-trading" class="absolute inset-0 flex flex-col lg:flex-row w-full h-full overflow-y-auto lg:overflow-hidden p-2 gap-2 bg-[#020617]">
            
            <div class="flex-1 flex flex-col gap-2 min-h-[70vh] lg:min-h-0 relative">
                
                <div id="chart-wrap" class="blue-panel flex-1 flex flex-col relative min-h-[40vh] transition-colors duration-300">
                    <div class="absolute top-4 left-4 z-10 flex flex-col gap-1 pointer-events-none">
                        <select id="symbol-select" onchange="initBybitAPI()" class="appearance-none bg-[#020617]/80 border border-[#1e3a8a] text-[#38bdf8] font-black text-lg px-3 py-1 rounded shadow-lg pointer-events-auto cursor-pointer outline-none max-w-fit">
                            <option value="BTCUSDT">BTC / USDT</option>
                            <option value="ETHUSDT">ETH / USDT</option>
                            <option value="SOLUSDT">SOL / USDT</option>
                            <option value="XRPUSDT">XRP / USDT</option>
                        </select>
                        <h2 id="price-display" class="text-4xl md:text-5xl font-black font-mono tracking-tight text-white transition-all duration-75">---</h2>
                    </div>
                    <div id="tvchart" class="flex-1 w-full h-full mt-20"></div>
                </div>

                <div class="blue-panel h-64 shrink-0 flex flex-col">
                    <div class="p-3 border-b border-[#1e3a8a] flex justify-between items-center bg-[#020617]/50 shrink-0">
                        <h3 class="text-[10px] font-black uppercase tracking-widest text-[#38bdf8]">Active Positions Database</h3>
                        <span class="text-[10px] font-bold text-slate-500 font-mono" id="live-pnl-total">ROI: $0.00</span>
                    </div>
                    <div class="flex-1 overflow-auto">
                        <table class="w-full text-left min-w-[600px] border-collapse">
                            <thead class="sticky top-0 bg-[#0f172a] shadow">
                                <tr class="text-[9px] font-black uppercase tracking-widest text-slate-400 border-b border-[#1e3a8a]">
                                    <th class="p-3">Symbol</th>
                                    <th class="p-3">Type</th>
                                    <th class="p-3">Margin</th>
                                    <th class="p-3">Leverage</th>
                                    <th class="p-3">Entry</th>
                                    <th class="p-3 text-right">Live PNL</th>
                                    <th class="p-3 text-center">Action</th>
                                </tr>
                            </thead>
                            <tbody id="positions-body" class="text-xs font-mono text-slate-200">
                                </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="blue-panel w-full lg:w-80 xl:w-96 p-4 flex flex-col shrink-0">
                <h3 class="text-[10px] font-black uppercase tracking-widest text-[#38bdf8] mb-4">Execution Panel</h3>
                
                <div class="flex gap-2 mb-6">
                    <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 rounded text-xs font-black uppercase tracking-widest bg-[#0ea5e9] text-[#020617] shadow-[0_0_15px_rgba(14,165,233,0.4)] transition">Long</button>
                    <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 rounded text-xs font-black uppercase tracking-widest bg-[#020617] border border-[#1e3a8a] text-slate-500 hover:text-[#f43f5e] transition">Short</button>
                </div>

                <div class="space-y-6 flex-1">
                    <div>
                        <div class="flex justify-between mb-2">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Margin (USDT)</label>
                            <span class="text-[10px] font-bold text-[#38bdf8] cursor-pointer hover:underline" onclick="setMax()">Max</span>
                        </div>
                        <input type="number" id="trade-margin" placeholder="0.00" class="input-blue w-full p-4 rounded font-mono text-xl font-black">
                    </div>

                    <div>
                        <div class="flex justify-between mb-2">
                            <label class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Leverage</label>
                            <span class="text-[10px] font-black text-[#0ea5e9] font-mono"><span id="lev-val">10</span>x</span>
                        </div>
                        <input type="range" id="trade-leverage" min="1" max="100" value="10" class="w-full">
                        <div class="flex justify-between text-[8px] font-black text-slate-500 mt-1">
                            <span>1x</span><span>25x</span><span>50x</span><span>75x</span><span>100x</span>
                        </div>
                    </div>

                    <div class="p-3 bg-[#020617] border border-[#1e3a8a] rounded space-y-2">
                        <div class="flex justify-between text-[10px] font-black uppercase tracking-widest">
                            <span class="text-slate-500">Available</span>
                            <span class="text-[#f8fafc] font-mono"><span id="ui-avail">88000.00</span> USDT</span>
                        </div>
                        <div class="flex justify-between text-[10px] font-black uppercase tracking-widest">
                            <span class="text-slate-500">Position Size</span>
                            <span class="text-[#38bdf8] font-mono" id="ui-size">0.00 USDT</span>
                        </div>
                    </div>
                </div>

                <button onclick="executeTrade()" id="btn-execute" class="mt-6 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-sm bg-[#0ea5e9] text-[#020617] shadow-[0_0_20px_rgba(14,165,233,0.4)] hover:bg-[#38bdf8] transition active:scale-95 shrink-0">
                    Open Long
                </button>
            </div>
        </div>

        <div id="view-wallet" class="absolute inset-0 w-full h-full overflow-y-auto bg-[#020617] hidden p-4 md:p-8">
            <div class="max-w-5xl mx-auto">
                <div class="blue-panel p-8 md:p-12 mb-8 relative overflow-hidden">
                    <div class="absolute -right-20 -bottom-20 w-80 h-80 bg-[#0ea5e9]/20 rounded-full blur-[100px]"></div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-[#38bdf8] mb-2">Total Net Equity</p>
                    <h2 class="text-5xl md:text-7xl font-black font-mono text-white tracking-tighter" id="wallet-total">$88,000.00</h2>
                    <p class="text-xs font-bold text-slate-400 mt-2 font-mono" id="wallet-pnl">Unrealized PNL: $0.00</p>
                </div>

                <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-500 mb-4 px-2">Spot Assets</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    <div class="blue-panel p-5 hover:border-[#38bdf8] transition">
                        <div class="flex items-center gap-3 mb-4">
                            <img src="https://cryptologos.cc/logos/tether-usdt-logo.svg?v=029" class="w-8 h-8 rounded-full shadow-[0_0_10px_rgba(0,0,0,0.5)]">
                            <span class="text-[10px] font-black uppercase tracking-widest bg-[#020617] px-2 py-1 rounded border border-[#1e3a8a] text-slate-300">Tether</span>
                        </div>
                        <h4 class="text-2xl font-black font-mono" id="wallet-usdt">88,000.00</h4>
                    </div>
                </div>
            </div>
        </div>

    </main>

    <script>
        // --- 1. CORE DATA & STORAGE ---
        let state = JSON.parse(localStorage.getItem('bluebook_state')) || {
            balance: 88000.00,
            positions: []
        };
        let ui = { side: 'buy', symbol: 'BTCUSDT', price: 0, lastPrice: 0, leverage: 10 };

        function saveState() {
            localStorage.setItem('bluebook_state', JSON.stringify(state));
            updateWalletUI();
        }

        // --- 2. TAB MANAGEMENT ---
        function switchTab(tab) {
            document.getElementById('tabBtn-trading').className = "px-4 md:px-8 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-white transition";
            document.getElementById('tabBtn-wallet').className = "px-4 md:px-8 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-slate-500 hover:text-white transition";
            
            document.getElementById(`tabBtn-${tab}`).classList.add('bg-[#1e3a8a]', 'text-white', 'shadow');
            document.getElementById(`tabBtn-${tab}`).classList.remove('text-slate-500');

            document.getElementById('view-trading').style.display = tab === 'trading' ? 'flex' : 'none';
            document.getElementById('view-wallet').style.display = tab === 'wallet' ? 'block' : 'none';
            
            if(tab === 'trading') setTimeout(() => chart.timeScale().fitContent(), 10);
            updateWalletUI();
        }

        // --- 3. CHARTING (Lightweight Charts - Bluebook Theme) ---
        const chartElement = document.getElementById('tvchart');
        const chart = LightweightCharts.createChart(chartElement, {
            layout: { background: { type: 'solid', color: 'transparent' }, textColor: '#64748b' },
            grid: { vertLines: { color: 'rgba(30, 58, 138, 0.3)' }, horzLines: { color: 'rgba(30, 58, 138, 0.3)' } },
            crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
            rightPriceScale: { borderColor: '#1e3a8a' },
            timeScale: { borderColor: '#1e3a8a', timeVisible: true }
        });

        const areaSeries = chart.addAreaSeries({
            lineColor: '#0ea5e9', topColor: 'rgba(14, 165, 233, 0.4)', bottomColor: 'rgba(14, 165, 233, 0.0)',
            lineWidth: 2, crosshairMarkerBorderColor: '#020617', crosshairMarkerBackgroundColor: '#38bdf8'
        });

        // Resize observer
        new ResizeObserver(entries => {
            if (entries.length === 0 || entries[0].target !== chartElement) return;
            chart.applyOptions({ width: entries[0].contentRect.width, height: entries[0].contentRect.height });
        }).observe(chartElement);

        // --- 4. BYBIT API INTEGRATION (Historical + Live) ---
        let ws;
        async function initBybitAPI() {
            ui.symbol = document.getElementById('symbol-select').value;
            const priceText = document.getElementById('price-display');
            priceText.innerText = "Syncing...";
            if(ws) ws.close();

            try {
                // 1. Fetch REST History to populate graph instantly
                const res = await fetch(`https://api.bybit.com/v5/market/kline?category=spot&symbol=${ui.symbol}&interval=1&limit=100`);
                const json = await res.json();
                
                // Bybit returns newest first, LightweightCharts needs oldest first
                const history = json.result.list.reverse().map(d => ({
                    time: parseInt(d[0]) / 1000,
                    value: parseFloat(d[4]) // Close price for Area chart
                }));
                areaSeries.setData(history);
                ui.price = history[history.length - 1].value;
                priceText.innerText = `$${ui.price}`;
                
                // 2. Connect WebSocket for live ticks
                ws = new WebSocket('wss://stream.bybit.com/v5/public/spot');
                ws.onopen = () => {
                    ws.send(JSON.stringify({ "op": "subscribe", "args": [`kline.1.${ui.symbol}`] }));
                };
                ws.onmessage = (e) => {
                    const data = JSON.parse(e.data);
                    if (data.topic && data.data && data.data.length > 0) {
                        const tick = data.data[0];
                        const newPrice = parseFloat(tick.c);
                        
                        // Update Chart
                        areaSeries.update({ time: parseInt(tick.t) / 1000, value: newPrice });
                        
                        // Dramatic Effects if price changed
                        if(ui.lastPrice !== 0 && newPrice !== ui.lastPrice) {
                            priceText.classList.remove('effect-pump', 'effect-dump');
                            document.getElementById('chart-wrap').classList.remove('bg-pump', 'bg-dump');
                            void priceText.offsetWidth; // Reflow
                            
                            const isUp = newPrice > ui.lastPrice;
                            priceText.classList.add(isUp ? 'effect-pump' : 'effect-dump');
                            document.getElementById('chart-wrap').classList.add(isUp ? 'bg-pump' : 'bg-dump');
                            
                            // Adjust line color based on direction
                            areaSeries.applyOptions({ lineColor: isUp ? '#0ea5e9' : '#f43f5e' });
                        }
                        
                        ui.lastPrice = newPrice;
                        ui.price = newPrice;
                        const dec = newPrice < 10 ? 4 : 2;
                        priceText.innerText = `$${newPrice.toLocaleString(undefined, {minimumFractionDigits: dec})}`;
                        
                        renderPositions(); // Update live PNL
                    }
                };
            } catch (err) {
                console.error("API Error", err);
                priceText.innerText = "API Error";
            }
        }

        // --- 5. EXECUTION & LOGIC ---
        function setSide(side) {
            ui.side = side;
            const bBuy = document.getElementById('btn-buy');
            const bSell = document.getElementById('btn-sell');
            const bExec = document.getElementById('btn-execute');

            if(side === 'buy') {
                bBuy.className = "flex-1 py-3 rounded text-xs font-black uppercase tracking-widest bg-[#0ea5e9] text-[#020617] shadow-[0_0_15px_rgba(14,165,233,0.4)] transition";
                bSell.className = "flex-1 py-3 rounded text-xs font-black uppercase tracking-widest bg-[#020617] border border-[#1e3a8a] text-slate-500 hover:text-[#f43f5e] transition";
                bExec.className = "mt-6 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-sm bg-[#0ea5e9] text-[#020617] shadow-[0_0_20px_rgba(14,165,233,0.4)] hover:bg-[#38bdf8] transition active:scale-95 shrink-0";
                bExec.innerText = "Open Long Position";
            } else {
                bSell.className = "flex-1 py-3 rounded text-xs font-black uppercase tracking-widest bg-[#f43f5e] text-white shadow-[0_0_15px_rgba(244,63,94,0.4)] transition";
                bBuy.className = "flex-1 py-3 rounded text-xs font-black uppercase tracking-widest bg-[#020617] border border-[#1e3a8a] text-slate-500 hover:text-[#0ea5e9] transition";
                bExec.className = "mt-6 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-sm bg-[#f43f5e] text-white shadow-[0_0_20px_rgba(244,63,94,0.4)] hover:bg-[#fb7185] transition active:scale-95 shrink-0";
                bExec.innerText = "Open Short Position";
            }
        }

        document.getElementById('trade-leverage').addEventListener('input', (e) => {
            ui.leverage = parseInt(e.target.value);
            document.getElementById('lev-val').innerText = ui.leverage;
            calcSize();
        });

        const marginInput = document.getElementById('trade-margin');
        marginInput.addEventListener('input', calcSize);

        function calcSize() {
            const margin = parseFloat(marginInput.value) || 0;
            const size = margin * ui.leverage;
            document.getElementById('ui-size').innerText = size.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT';
        }

        function setMax() {
            marginInput.value = Math.floor(state.balance * 100) / 100;
            calcSize();
        }

        function executeTrade() {
            const margin = parseFloat(marginInput.value);
            if (isNaN(margin) || margin <= 0) return alert("Invalid margin.");
            if (margin > state.balance) return alert("Insufficient funds.");

            // Deduct
            state.balance -= margin;
            
            // Leveraged units
            const positionSizeUsdt = margin * ui.leverage;
            const units = positionSizeUsdt / ui.price;

            state.positions.push({
                id: Math.random().toString(36).substr(2, 9),
                symbol: ui.symbol,
                side: ui.side,
                margin: margin,
                leverage: ui.leverage,
                entryPrice: ui.price,
                units: units
            });

            marginInput.value = '';
            calcSize();
            saveState();
            renderPositions();
        }

        function renderPositions() {
            const tbody = document.getElementById('positions-body');
            let totalPnl = 0;

            if (state.positions.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="p-6 text-center text-[#1e3a8a] font-black uppercase tracking-widest text-xs">Database Empty</td></tr>`;
                document.getElementById('live-pnl-total').innerText = "ROI: $0.00";
                return;
            }

            let html = '';
            state.positions.forEach(pos => {
                let pnl = 0;
                // Calculate live PNL if symbol matches current graph
                if (pos.symbol === ui.symbol) {
                    const currentVal = pos.units * ui.price;
                    const initialVal = pos.margin * pos.leverage;
                    pnl = pos.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
                }
                totalPnl += pnl;

                const roiPct = (pnl / pos.margin) * 100;
                const isProf = pnl >= 0;
                const cColor = isProf ? 'text-[#38bdf8]' : 'text-[#f43f5e]';
                const sColor = pos.side === 'buy' ? 'text-[#0ea5e9] bg-[#0ea5e9]/10' : 'text-[#f43f5e] bg-[#f43f5e]/10';
                
                html += `
                    <tr class="border-b border-[#1e3a8a]/50 hover:bg-[#1e3a8a]/20 transition">
                        <td class="p-3 font-bold text-white">${pos.symbol}</td>
                        <td class="p-3"><span class="px-2 py-1 rounded text-[9px] font-black uppercase tracking-widest ${sColor}">${pos.side}</span></td>
                        <td class="p-3">$${pos.margin.toFixed(2)}</td>
                        <td class="p-3">${pos.leverage}x</td>
                        <td class="p-3">$${pos.entryPrice.toFixed(4)}</td>
                        <td class="p-3 text-right ${cColor} font-black">${isProf?'+':''}$${pnl.toFixed(2)} (${isProf?'+':''}${roiPct.toFixed(2)}%)</td>
                        <td class="p-3 text-center">
                            <button onclick="closeTrade('${pos.id}')" class="px-3 py-1 bg-[#1e3a8a] hover:bg-[#0ea5e9] hover:text-[#020617] text-white rounded text-[9px] uppercase font-black transition shadow">Close</button>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
            
            const pnlColor = totalPnl >= 0 ? 'text-[#38bdf8]' : 'text-[#f43f5e]';
            document.getElementById('live-pnl-total').className = `text-[10px] font-black font-mono ${pnlColor}`;
            document.getElementById('live-pnl-total').innerText = `LIVE PNL: ${totalPnl >= 0 ? '+' : ''}$${totalPnl.toFixed(2)}`;
            
            // Update wallet unrealized
            document.getElementById('wallet-pnl').innerText = `Unrealized PNL: ${totalPnl >= 0 ? '+' : ''}$${totalPnl.toFixed(2)}`;
            document.getElementById('wallet-pnl').className = `text-xs font-bold mt-2 font-mono ${pnlColor}`;
        }

        function closeTrade(id) {
            const idx = state.positions.findIndex(p => p.id === id);
            if (idx === -1) return;
            
            const pos = state.positions[idx];
            let pnl = 0;
            if (pos.symbol === ui.symbol) {
                const currentVal = pos.units * ui.price;
                const initialVal = pos.margin * pos.leverage;
                pnl = pos.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
            }
            
            state.balance += (pos.margin + pnl);
            state.positions.splice(idx, 1);
            
            saveState();
            renderPositions();
        }

        function updateWalletUI() {
            const bal = state.balance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('ui-avail').innerText = bal;
            document.getElementById('wallet-total').innerText = `$${bal}`;
            document.getElementById('wallet-usdt').innerText = bal;
        }

        // Init
        switchTab('trading');
        initBybitAPI();
        updateWalletUI();
