<!DOCTYPE html>
<html lang="en">
<head>
    <title>CloudCrypto Terminal</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <link rel="icon" type="image/png" href="/favicon.png">
    
    <style>
        /* Purple Black Cloudy Theme */
        body { 
            background: #05020a; 
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(76, 29, 149, 0.15), transparent 50%),
                radial-gradient(circle at 85% 30%, rgba(139, 92, 246, 0.1), transparent 50%);
            color: #f8fafc; 
            font-family: 'Inter', system-ui, sans-serif; 
            margin: 0; 
            min-height: 100vh; 
            display: flex; 
            flex-direction: column; 
            overflow-x: hidden;
        }
        
        .glass-panel { 
            background: rgba(13, 8, 20, 0.7); 
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(139, 92, 246, 0.2); 
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5), inset 0 0 20px rgba(139, 92, 246, 0.05);
            border-radius: 1rem; 
        }
        
        .neo-input { background: rgba(5, 2, 10, 0.8); border: 1px solid rgba(139, 92, 246, 0.3); color: white; outline: none; transition: 0.3s; }
        .neo-input:focus { border-color: #a78bfa; box-shadow: 0 0 15px rgba(139, 92, 246, 0.4); }
        
        .neo-btn { background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.3); color: #ddd; transition: 0.2s; cursor: pointer; }
        .neo-btn:hover { background: rgba(139, 92, 246, 0.2); color: white; border-color: #a78bfa; }
        
        .text-muted { color: #8b839e; }
        .text-pump { color: #34d399; text-shadow: 0 0 20px rgba(52, 211, 153, 0.6); }
        .text-dump { color: #fb7185; text-shadow: 0 0 20px rgba(251, 113, 133, 0.6); }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 18px; width: 18px; border-radius: 50%; background: #a78bfa; cursor: pointer; box-shadow: 0 0 15px #a78bfa; margin-top: -7px; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; background: rgba(139, 92, 246, 0.2); border-radius: 2px; }

        .dropdown-menu { transform-origin: top; transition: transform 0.2s ease, opacity 0.2s ease; }
        .dropdown-hidden { transform: scaleY(0); opacity: 0; pointer-events: none; }
        .dropdown-active { transform: scaleY(1); opacity: 1; pointer-events: auto; }

        .modal-overlay { transition: opacity 0.3s; }
        .modal-content { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
        .modal-hidden { opacity: 0; pointer-events: none; }
        .modal-hidden .modal-content { transform: scale(0.95) translateY(10px); }
        .modal-active { opacity: 1; pointer-events: auto; }
        .modal-active .modal-content { transform: scale(1) translateY(0); }

        .tf-btn { padding: 4px 10px; border-radius: 6px; font-size: 10px; font-weight: 900; color: #8b839e; cursor: pointer; transition: 0.2s; }
        .tf-btn.active { background: #a78bfa; color: #05020a; box-shadow: 0 0 10px rgba(167, 139, 250, 0.5); }
    </style>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <header class="flex flex-col shrink-0 z-50 sticky top-0 bg-[#05020a]/90 backdrop-blur-md border-b border-purple-900/40">
        <div class="flex justify-between items-center p-3 md:p-4">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-purple-600 flex items-center justify-center shadow-[0_0_15px_rgba(147,51,234,0.5)]">
                    <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <h2 class="text-lg font-black uppercase tracking-tighter text-white">Cloud<span class="text-purple-400">Trade</span></h2>
            </div>
            
            <div class="flex items-center gap-3">
                <div class="text-right hidden sm:block">
                    <p class="text-[9px] font-black uppercase tracking-widest text-purple-400">Total Net Worth</p>
                    <p class="text-lg font-black text-white font-mono leading-none" id="top-net-worth">$0.00</p>
                </div>
                
                <button onclick="toggleModal('history-modal')" class="neo-btn p-2 rounded-lg transition flex items-center justify-center">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </button>
                <button onclick="toggleModal('settings-modal')" class="neo-btn px-3 py-2 rounded-lg font-black text-[10px] uppercase tracking-widest flex items-center gap-2">
                    <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    Portfolio
                </button>
            </div>
        </div>
        
        <div class="sm:hidden border-t border-purple-900/30 bg-purple-900/10 py-2 px-4 flex justify-between items-center">
            <span class="text-[10px] font-black uppercase tracking-widest text-purple-400">Net Worth</span>
            <span class="text-sm font-black text-white font-mono" id="mobile-net-worth">$0.00</span>
        </div>
    </header>

    <main class="flex-grow flex flex-col lg:flex-row p-2 md:p-4 gap-3 lg:gap-4 overflow-x-hidden">
        
        <div class="flex-grow flex flex-col gap-3 lg:gap-4">
            
            <div class="glass-panel p-3 md:p-5 flex flex-col relative min-h-[40vh] lg:min-h-[50vh]">
                
                <div class="flex justify-between items-start z-20">
                    <div class="relative w-fit">
                        <button onclick="togglePairDropdown()" class="neo-input px-3 py-2 rounded-xl flex items-center gap-2 md:gap-3 w-[140px] md:w-40 hover:bg-purple-900/30">
                            <img id="active-coin-logo" src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-5 h-5 md:w-6 md:h-6 rounded-full">
                            <span id="active-coin-text" class="font-black text-xs md:text-sm uppercase">BTC/USDT</span>
                            <svg class="w-4 h-4 ml-auto text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div id="pair-dropdown" class="absolute top-full left-0 mt-2 w-48 glass-panel py-2 dropdown-menu dropdown-hidden">
                            </div>
                    </div>

                    <div class="flex bg-[#05020a] p-1 rounded-lg border border-purple-900/30">
                        <div class="tf-btn" onclick="setTimeframe('live')" id="tf-live">LIVE</div>
                        <div class="tf-btn" onclick="setTimeframe('1m')" id="tf-1m">1m</div>
                        <div class="tf-btn active" onclick="setTimeframe('5m')" id="tf-5m">5m</div>
                        <div class="tf-btn" onclick="setTimeframe('15m')" id="tf-15m">15m</div>
                        <div class="tf-btn" onclick="setTimeframe('1h')" id="tf-1h">1H</div>
                    </div>
                </div>

                <div class="mt-2 z-10 flex flex-col">
                    <h2 id="main-price" class="text-3xl md:text-5xl font-black text-white font-mono tracking-tighter">--</h2>
                </div>

                <div class="flex-grow mt-2 relative w-full h-full min-h-[250px]" id="canvas-container">
                    <canvas id="custom-chart" class="absolute inset-0 w-full h-full"></canvas>
                </div>
            </div>

            <div class="glass-panel flex flex-col flex-grow min-h-[25vh]">
                <div class="flex justify-between items-center p-3 md:p-4 border-b border-purple-900/30 shrink-0">
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-purple-400">Open Trades</h3>
                </div>
                <div class="flex-grow overflow-x-auto no-scrollbar">
                    <table class="w-full text-left border-collapse min-w-[550px]">
                        <thead class="bg-[#0a0510]/50 sticky top-0">
                            <tr class="text-[9px] font-black uppercase tracking-widest text-muted border-b border-purple-900/30">
                                <th class="p-3">Asset</th>
                                <th class="p-3">Side</th>
                                <th class="p-3">Margin</th>
                                <th class="p-3">Entry</th>
                                <th class="p-3 text-right">Live ROI</th>
                                <th class="p-3 text-center">Action</th>
                            </tr>
                        </thead>
                        <tbody id="orders-body" class="text-[11px] font-bold text-slate-200 font-mono">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="glass-panel lg:w-[320px] shrink-0 p-4 md:p-5 flex flex-col h-fit relative z-10">
            <h3 class="text-[10px] font-black uppercase tracking-widest text-muted mb-4 border-b border-purple-900/30 pb-2">Execution</h3>
            
            <div class="flex gap-2 bg-[#05020a] p-1 border border-purple-900/50 rounded-xl mb-5">
                <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-2.5 rounded-lg text-[10px] font-black uppercase tracking-widest bg-purple-500 text-white shadow-[0_0_15px_rgba(168,85,247,0.4)] transition">Long</button>
                <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-2.5 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-pink-500 transition">Short</button>
            </div>

            <div class="space-y-5">
                <div>
                    <div class="flex justify-between mb-1.5">
                        <label class="text-[9px] font-black uppercase tracking-widest text-muted">Margin (USDT)</label>
                        <span class="text-[9px] font-black text-purple-400 cursor-pointer hover:underline" onclick="setMax()">MAX</span>
                    </div>
                    <input type="number" id="trade-margin" placeholder="0.00" class="w-full neo-input p-3 rounded-xl text-lg font-black font-mono">
                </div>

                <div>
                    <div class="flex justify-between mb-2">
                        <label class="text-[9px] font-black uppercase tracking-widest text-muted">Leverage</label>
                        <span class="text-[10px] font-black text-white bg-purple-900/50 px-2 py-0.5 rounded border border-purple-700/50"><span id="lev-val">10</span>x</span>
                    </div>
                    <input type="range" id="trade-lev" min="1" max="100" value="10" class="w-full">
                </div>

                <div class="p-3 bg-[#05020a] border border-purple-900/30 rounded-xl space-y-2 mt-4">
                    <div class="flex justify-between text-[9px] font-black uppercase tracking-widest">
                        <span class="text-muted">Available USDT</span>
                        <span class="text-white font-mono" id="ui-avail">0.00</span>
                    </div>
                    <div class="flex justify-between text-[9px] font-black uppercase tracking-widest border-t border-purple-900/30 pt-2">
                        <span class="text-muted">Position Size</span>
                        <span class="text-purple-400 font-mono" id="ui-size">0.00</span>
                    </div>
                </div>
            </div>

            <button onclick="executeOrder()" id="btn-execute" class="mt-5 w-full py-4 rounded-xl font-black uppercase tracking-[0.2em] text-[11px] bg-purple-600 text-white hover:bg-purple-500 shadow-[0_0_20px_rgba(147,51,234,0.4)] transition active:scale-95">
                Execute Long
            </button>
        </div>
    </main>

    <div id="settings-modal" class="fixed inset-0 z-[100] modal-overlay modal-hidden flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="modal-content glass-panel w-full max-w-sm p-6 relative">
            <button onclick="toggleModal('settings-modal')" class="absolute top-4 right-4 text-muted hover:text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <h2 class="text-sm font-black uppercase tracking-widest text-white mb-6 border-b border-purple-900/50 pb-2">Portfolio Management</h2>
            
            <div class="space-y-4">
                <div>
                    <label class="text-[9px] font-black uppercase tracking-widest text-purple-400 mb-1 block">Add/Update USDT</label>
                    <div class="flex gap-2">
                        <input type="number" id="add-usdt-input" placeholder="Set Amount" class="flex-grow neo-input p-2.5 rounded-lg text-sm font-mono">
                        <button onclick="setUsdt()" class="bg-purple-600 px-4 rounded-lg text-[10px] font-black uppercase text-white hover:bg-purple-500 transition">Set</button>
                    </div>
                </div>
                
                <div class="pt-4 border-t border-purple-900/30">
                    <label class="text-[9px] font-black uppercase tracking-widest text-muted mb-2 block">Custom Holdings</label>
                    <div id="manual-assets-list" class="space-y-2 max-h-[150px] overflow-y-auto no-scrollbar"></div>
                    
                    <div class="flex gap-2 mt-3">
                        <input type="text" id="new-asset-name" placeholder="Coin (e.g. BTC)" class="w-1/2 neo-input p-2 rounded-lg text-xs font-black uppercase">
                        <input type="number" id="new-asset-amt" placeholder="Amount" class="w-1/2 neo-input p-2 rounded-lg text-xs font-mono">
                    </div>
                    <button onclick="addManualAsset()" class="w-full mt-2 neo-btn py-2.5 rounded-lg text-[10px] font-black uppercase tracking-widest">Add Holding</button>
                </div>
            </div>
        </div>
    </div>

    <div id="history-modal" class="fixed inset-0 z-[100] modal-overlay modal-hidden flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
        <div class="modal-content glass-panel w-full max-w-lg p-6 relative max-h-[80vh] flex flex-col">
            <button onclick="toggleModal('history-modal')" class="absolute top-4 right-4 text-muted hover:text-white">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
            <h2 class="text-sm font-black uppercase tracking-widest text-white mb-4 border-b border-purple-900/50 pb-2">Trade History</h2>
            
            <div class="flex-grow overflow-y-auto no-scrollbar">
                <table class="w-full text-left border-collapse">
                    <thead class="bg-[#0a0510]/80 sticky top-0">
                        <tr class="text-[9px] font-black uppercase tracking-widest text-muted border-b border-purple-900/30">
                            <th class="p-2">Asset</th>
                            <th class="p-2">Side</th>
                            <th class="p-2 text-right">Result PnL</th>
                        </tr>
                    </thead>
                    <tbody id="history-body" class="text-xs font-bold text-slate-200 font-mono">
                        </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // --- 1. STATE & GLOBALS ---
        const ASSETS = [
            { id: 'BTCUSDT', name: 'BTC/USDT', icon: 'bitcoin-btc-logo.svg?v=029' },
            { id: 'ETHUSDT', name: 'ETH/USDT', icon: 'ethereum-eth-logo.svg?v=029' },
            { id: 'SOLUSDT', name: 'SOL/USDT', icon: 'solana-sol-logo.svg?v=029' },
            { id: 'XRPUSDT', name: 'XRP/USDT', icon: 'xrp-xrp-logo.svg?v=029' },
            { id: 'DOGEUSDT', name: 'DOGE/USDT', icon: 'dogecoin-doge-logo.svg?v=029' }
        ];

        let state = JSON.parse(localStorage.getItem('cloud_state_v2')) || {
            usdtBalance: 10000.00,
            orders: [],
            history: [],
            manualAssets: { 'BTC': 0.1, 'ETH': 1.0 }
        };
        
        let livePrices = {}; 
        let ui = { 
            side: 'buy', pair: 'BTCUSDT', price: 0, lastPrice: 0, lev: 10,
            timeframe: '5m', // live, 1m, 5m, 15m, 1h
            chartData: [] // Array of {time, price}
        };
        let ws;
        let chartCtx;
        
        // --- 2. INITIALIZATION ---
        function init() {
            buildDropdown();
            setupCanvas();
            connectMultiStream();
            fetchChartData(); // initial fetch
            updateUI();
            renderOrders();
            renderHistory();
            renderManualAssets();
            
            // Loop to calculate net worth frequently
            setInterval(calculateNetWorth, 1000);
        }

        function toggleModal(id) {
            const el = document.getElementById(id);
            el.classList.toggle('modal-hidden');
            el.classList.toggle('modal-active');
        }

        // --- 3. UI COMPONENTS & DROPDOWN ---
        function buildDropdown() {
            const menu = document.getElementById('pair-dropdown');
            menu.innerHTML = '';
            ASSETS.forEach(a => {
                const el = document.createElement('div');
                el.className = "px-4 py-2 hover:bg-purple-900/40 cursor-pointer flex items-center gap-3 transition";
                el.innerHTML = `<img src="https://cryptologos.cc/logos/${a.icon}" class="w-5 h-5 rounded-full"><span class="text-xs font-black uppercase text-white">${a.name}</span>`;
                el.onclick = () => selectPair(a);
                menu.appendChild(el);
            });
        }

        function togglePairDropdown() {
            const el = document.getElementById('pair-dropdown');
            el.classList.toggle('dropdown-hidden');
            el.classList.toggle('dropdown-active');
        }

        function selectPair(asset) {
            ui.pair = asset.id;
            document.getElementById('active-coin-text').innerText = asset.name;
            document.getElementById('active-coin-logo').src = `https://cryptologos.cc/logos/${asset.icon}`;
            togglePairDropdown();
            
            ui.chartData = [];
            ui.price = livePrices[ui.pair] || 0;
            document.getElementById('main-price').innerText = "Syncing...";
            fetchChartData();
        }

        // --- 4. HIGH RES CUSTOM CANVAS ENGINE ---
        function setupCanvas() {
            const container = document.getElementById('canvas-container');
            const canvas = document.getElementById('custom-chart');
            chartCtx = canvas.getContext('2d');
            
            function resize() {
                const rect = container.getBoundingClientRect();
                const dpr = window.devicePixelRatio || 1;
                
                canvas.width = rect.width * dpr;
                canvas.height = rect.height * dpr;
                
                chartCtx.scale(dpr, dpr);
                canvas.style.width = `${rect.width}px`;
                canvas.style.height = `${rect.height}px`;
                drawChart();
            }
            
            window.addEventListener('resize', resize);
            resize();
        }

        async function fetchChartData() {
            if(ui.timeframe === 'live') {
                ui.chartData = [];
                return;
            }
            try {
                // Fetch Historical Klines from Binance
                let res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${ui.pair}&interval=${ui.timeframe}&limit=50`);
                let json = await res.json();
                ui.chartData = json.map(d => ({
                    time: parseInt(d[0]),
                    price: parseFloat(d[4])
                }));
                drawChart();
            } catch(e) { console.error("Klines fetch error", e); }
        }

        function setTimeframe(tf) {
            ui.timeframe = tf;
            document.querySelectorAll('.tf-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById(`tf-${tf}`).classList.add('active');
            fetchChartData();
        }

        function drawChart() {
            if(!chartCtx || ui.chartData.length < 2) return;
            
            // Get CSS display size (not internal canvas resolution)
            const canvas = document.getElementById('custom-chart');
            const w = canvas.clientWidth;
            const h = canvas.clientHeight;
            const data = ui.chartData;
            
            chartCtx.clearRect(0, 0, w, h);
            
            // Dimensions & Padding
            const padYBottom = 20; // X axis text
            const padXRight = 60; // Y axis text
            const gW = w - padXRight;
            const gH = h - padYBottom;
            
            const prices = data.map(d => d.price);
            const minPrice = Math.min(...prices);
            const maxPrice = Math.max(...prices);
            const range = maxPrice - minPrice || 1; 
            
            const isUp = data[data.length-1].price >= data[0].price;
            const strokeColor = isUp ? '#34d399' : '#fb7185';
            const gradientTop = isUp ? 'rgba(52, 211, 153, 0.4)' : 'rgba(251, 113, 133, 0.4)';
            
            // Draw Grid & Axes
            chartCtx.strokeStyle = 'rgba(139, 92, 246, 0.1)';
            chartCtx.lineWidth = 1;
            chartCtx.fillStyle = '#8b839e';
            chartCtx.font = '10px "Inter", monospace';
            chartCtx.textAlign = 'left';
            chartCtx.textBaseline = 'middle';
            
            // Y-Axis Lines & Labels
            const levels = 4;
            for(let i=0; i<=levels; i++) {
                const yPos = (i / levels) * gH;
                const priceLvl = maxPrice - (i / levels) * range;
                chartCtx.beginPath();
                chartCtx.moveTo(0, yPos);
                chartCtx.lineTo(gW, yPos);
                chartCtx.stroke();
                
                const dec = priceLvl < 1 ? 4 : 2;
                chartCtx.fillText(priceLvl.toFixed(dec), gW + 5, yPos);
            }
            
            // Draw Line
            chartCtx.beginPath();
            let lastX = 0, lastY = 0;
            
            for(let i = 0; i < data.length; i++) {
                const x = (i / (data.length - 1)) * gW;
                // Add tiny vertical padding inside graph bounds so it doesn't clip top/bottom
                const y = ((maxPrice - data[i].price) / range) * (gH * 0.8) + (gH * 0.1); 
                
                if(i === 0) chartCtx.moveTo(x, y);
                else chartCtx.lineTo(x, y);
                
                if(i === data.length - 1) { lastX = x; lastY = y; }
            }
            
            chartCtx.strokeStyle = strokeColor;
            chartCtx.lineWidth = 2.5;
            chartCtx.lineJoin = 'round';
            chartCtx.shadowColor = strokeColor;
            chartCtx.shadowBlur = 8;
            chartCtx.stroke();
            
            // Fill Gradient
            chartCtx.lineTo(lastX, gH);
            chartCtx.lineTo(0, gH);
            chartCtx.closePath();
            const gradient = chartCtx.createLinearGradient(0, 0, 0, gH);
            gradient.addColorStop(0, gradientTop);
            gradient.addColorStop(1, 'rgba(0,0,0,0)');
            chartCtx.fillStyle = gradient;
            chartCtx.shadowBlur = 0; 
            chartCtx.fill();
            
            // Current Price Dot (Tip of line)
            chartCtx.beginPath();
            chartCtx.arc(lastX, lastY, 4, 0, 2 * Math.PI);
            chartCtx.fillStyle = strokeColor;
            chartCtx.shadowColor = strokeColor;
            chartCtx.shadowBlur = 10;
            chartCtx.fill();
            
            // Current Price Tag on Y Axis
            chartCtx.shadowBlur = 0;
            chartCtx.fillStyle = strokeColor;
            chartCtx.fillRect(gW, lastY - 10, padXRight, 20);
            chartCtx.fillStyle = '#05020a'; // Text color inside tag
            chartCtx.font = 'bold 10px monospace';
            const currPrice = data[data.length-1].price;
            const dec2 = currPrice < 1 ? 4 : 2;
            chartCtx.fillText(currPrice.toFixed(dec2), gW + 4, lastY);
            
            // X-Axis Time (Start & End)
            chartCtx.fillStyle = '#8b839e';
            const tStart = new Date(data[0].time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            const tEnd = new Date(data[data.length-1].time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
            chartCtx.textAlign = 'left';
            chartCtx.fillText(tStart, 0, gH + 10);
            chartCtx.textAlign = 'right';
            chartCtx.fillText(tEnd, gW, gH + 10);
        }

        // --- 5. LIVE WEBSOCKET ---
        function connectMultiStream() {
            const streams = ASSETS.map(a => a.id.toLowerCase() + '@ticker').join('/');
            ws = new WebSocket(`wss://stream.binance.com:9443/stream?streams=${streams}`);
            
            ws.onmessage = (e) => {
                const payload = JSON.parse(e.data);
                if(payload.data && payload.data.c) {
                    const symbol = payload.data.s; 
                    const price = parseFloat(payload.data.c);
                    livePrices[symbol] = price;

                    if(symbol === ui.pair) {
                        processMainTick(price);
                    }
                }
            };
            ws.onclose = () => setTimeout(connectMultiStream, 3000); 
        }

        function processMainTick(newPrice) {
            const el = document.getElementById('main-price');
            
            if (ui.lastPrice !== 0 && newPrice !== ui.lastPrice) {
                el.classList.remove('text-pump', 'text-dump');
                void el.offsetWidth; 
                el.classList.add(newPrice > ui.lastPrice ? 'text-pump' : 'text-dump');
            }
            
            ui.lastPrice = newPrice;
            ui.price = newPrice;
            
            // Update chart data
            if(ui.timeframe === 'live') {
                ui.chartData.push({time: Date.now(), price: newPrice});
                if(ui.chartData.length > 50) ui.chartData.shift();
            } else if (ui.chartData.length > 0) {
                // If historical, just update the very last candle's price
                ui.chartData[ui.chartData.length - 1].price = newPrice;
            }
            
            drawChart();
            
            const dec = newPrice < 1 ? 4 : 2;
            el.innerText = `$${newPrice.toLocaleString(undefined, {minimumFractionDigits: dec, maximumFractionDigits: dec})}`;
            
            renderOrders(); 
        }

        // --- 6. NET WORTH CALCULATOR ---
        function calculateNetWorth() {
            let total = state.usdtBalance;
            
            // Add Open Positions PnL & Margin
            state.orders.forEach(o => {
                total += o.margin; // Initial margin locked
                let currentPrice = livePrices[o.pair] || o.entry;
                const currentVal = o.units * currentPrice;
                const initialVal = o.margin * o.lev;
                let pnl = o.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
                total += pnl;
            });
            
            // Add Manual Assets Value
            for (const [coin, amt] of Object.entries(state.manualAssets)) {
                // Find matching pair price (e.g. BTC -> BTCUSDT)
                const price = livePrices[coin + 'USDT'];
                if(price) total += (amt * price);
            }
            
            const str = `$${total.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}`;
            document.getElementById('top-net-worth').innerText = str;
            document.getElementById('mobile-net-worth').innerText = str;
        }

        // --- 7. EXECUTION ---
        function setSide(side) {
            ui.side = side;
            const bBuy = document.getElementById('btn-buy');
            const bSell = document.getElementById('btn-sell');
            const bExec = document.getElementById('btn-execute');

            if(side === 'buy') {
                bBuy.className = "flex-1 py-2.5 rounded-lg text-[10px] font-black uppercase tracking-widest bg-purple-500 text-white shadow-[0_0_15px_rgba(168,85,247,0.4)] transition";
                bSell.className = "flex-1 py-2.5 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-pink-500 transition";
                bExec.className = "mt-5 w-full py-4 rounded-xl font-black uppercase tracking-[0.2em] text-[11px] bg-purple-600 text-white hover:bg-purple-500 shadow-[0_0_20px_rgba(147,51,234,0.4)] transition active:scale-95";
                bExec.innerText = "Execute Long";
            } else {
                bSell.className = "flex-1 py-2.5 rounded-lg text-[10px] font-black uppercase tracking-widest bg-pink-500 text-white shadow-[0_0_15px_rgba(236,72,153,0.4)] transition";
                bBuy.className = "flex-1 py-2.5 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-purple-400 transition";
                bExec.className = "mt-5 w-full py-4 rounded-xl font-black uppercase tracking-[0.2em] text-[11px] bg-pink-600 text-white hover:bg-pink-500 shadow-[0_0_20px_rgba(236,72,153,0.4)] transition active:scale-95";
                bExec.innerText = "Execute Short";
            }
        }

        document.getElementById('trade-lev').addEventListener('input', (e) => {
            ui.lev = parseInt(e.target.value);
            document.getElementById('lev-val').innerText = ui.lev;
            calcSize();
        });

        const marginInput = document.getElementById('trade-margin');
        marginInput.addEventListener('input', calcSize);

        function calcSize() {
            const margin = parseFloat(marginInput.value) || 0;
            document.getElementById('ui-size').innerText = (margin * ui.lev).toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT';
        }

        function setMax() {
            marginInput.value = Math.floor(state.usdtBalance * 100) / 100;
            calcSize();
        }

        function executeOrder() {
            if (ui.price === 0) return alert("Waiting for price...");
            const margin = parseFloat(marginInput.value);
            if (isNaN(margin) || margin <= 0) return;
            if (margin > state.usdtBalance) return alert("Insufficient USDT.");

            state.usdtBalance -= margin;
            const aName = ASSETS.find(x => x.id === ui.pair).name;

            state.orders.push({
                id: Math.random().toString(36).substr(2, 9),
                pair: ui.pair, 
                display: aName,
                side: ui.side,
                margin: margin,
                lev: ui.lev,
                entry: ui.price,
                units: (margin * ui.lev) / ui.price,
                time: new Date().getTime()
            });

            marginInput.value = '';
            calcSize();
            saveState();
            renderOrders();
        }

        // --- 8. ORDERS & HISTORY ---
        function renderOrders() {
            const tbody = document.getElementById('orders-body');
            
            if (state.orders.length === 0) {
                tbody.innerHTML = `<tr><td colspan="6" class="p-5 text-center text-muted font-black uppercase tracking-widest text-[10px]">No Open Trades</td></tr>`;
                return;
            }

            let html = '';
            state.orders.forEach(o => {
                let currentPrice = livePrices[o.pair] || o.entry;
                const currentVal = o.units * currentPrice;
                const initialVal = o.margin * o.lev;
                let pnl = o.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
                
                const isProf = pnl >= 0;
                const cColor = isProf ? 'text-green-400' : 'text-pink-400';
                const sColor = o.side === 'buy' ? 'text-purple-300 bg-purple-900/40' : 'text-pink-300 bg-pink-900/40';
                
                html += `
                    <tr class="border-b border-purple-900/20 hover:bg-purple-900/20 transition">
                        <td class="p-3 text-white whitespace-nowrap">${o.display}</td>
                        <td class="p-3"><span class="px-2 py-0.5 rounded ${sColor} uppercase text-[9px]">${o.lev}x ${o.side}</span></td>
                        <td class="p-3">$${o.margin.toFixed(2)}</td>
                        <td class="p-3">$${o.entry.toFixed(4)}</td>
                        <td class="p-3 text-right ${cColor} font-black">${isProf?'+':''}$${pnl.toFixed(2)}</td>
                        <td class="p-3 text-center">
                            <button onclick="closeOrder('${o.id}')" class="px-3 py-1.5 bg-purple-900/50 hover:bg-pink-600 hover:text-white text-muted rounded uppercase text-[9px] font-black transition shadow">Close</button>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function closeOrder(id) {
            const idx = state.orders.findIndex(p => p.id === id);
            if (idx === -1) return;
            const o = state.orders[idx];
            
            let currentPrice = livePrices[o.pair] || o.entry;
            const currentVal = o.units * currentPrice;
            const initialVal = o.margin * o.lev;
            let pnl = o.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
            
            state.usdtBalance += (o.margin + pnl);
            
            // Add to history
            state.history.unshift({
                display: o.display,
                side: o.side,
                pnl: pnl,
                time: new Date().getTime()
            });
            if(state.history.length > 50) state.history.pop(); // Keep last 50
            
            state.orders.splice(idx, 1);
            
            saveState();
            renderOrders();
            renderHistory();
        }

        function renderHistory() {
            const tbody = document.getElementById('history-body');
            if (state.history.length === 0) {
                tbody.innerHTML = `<tr><td colspan="3" class="p-5 text-center text-muted font-black uppercase tracking-widest text-[10px]">No Trade History</td></tr>`;
                return;
            }

            let html = '';
            state.history.forEach(h => {
                const isProf = h.pnl >= 0;
                const cColor = isProf ? 'text-green-400' : 'text-pink-400';
                
                html += `
                    <tr class="border-b border-purple-900/20 hover:bg-purple-900/20 transition">
                        <td class="p-2 text-white">${h.display}</td>
                        <td class="p-2 text-[10px] text-muted uppercase">${h.side}</td>
                        <td class="p-2 text-right ${cColor} font-black">${isProf?'+':''}$${h.pnl.toFixed(2)}</td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        // --- 9. PORTFOLIO MANAGER ---
        function setUsdt() {
            const amt = parseFloat(document.getElementById('add-usdt-input').value);
            if(amt !== isNaN) {
                state.usdtBalance = amt;
                document.getElementById('add-usdt-input').value = '';
                saveState();
            }
        }

        function addManualAsset() {
            const name = document.getElementById('new-asset-name').value.toUpperCase();
            const amt = parseFloat(document.getElementById('new-asset-amt').value);
            if(name && amt) {
                state.manualAssets[name] = amt;
                document.getElementById('new-asset-name').value = '';
                document.getElementById('new-asset-amt').value = '';
                saveState();
                renderManualAssets();
            }
        }
        
        function removeManualAsset(name) {
            delete state.manualAssets[name];
            saveState();
            renderManualAssets();
        }

        function renderManualAssets() {
            const container = document.getElementById('manual-assets-list');
            let html = '';
            for (const [coin, amt] of Object.entries(state.manualAssets)) {
                html += `
                    <div class="flex justify-between items-center bg-purple-900/20 p-2 rounded border border-purple-900/30">
                        <span class="text-xs font-black text-white">${amt} <span class="text-purple-400">${coin}</span></span>
                        <button onclick="removeManualAsset('${coin}')" class="text-muted hover:text-pink-500 text-xs font-bold">DEL</button>
                    </div>
                `;
            }
            container.innerHTML = html || '<p class="text-[9px] text-muted text-center py-2">No custom assets added.</p>';
        }

        function updateUI() {
            document.getElementById('ui-avail').innerText = state.usdtBalance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            calculateNetWorth();
        }

        function saveState() {
            localStorage.setItem('cloud_state_v2', JSON.stringify(state));
            updateUI();
        }

        init();
    </script>
</body>
</html>
