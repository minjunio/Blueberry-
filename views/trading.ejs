        let sendInterval;
        let sendTimeout;

        function initiateSend() {
            let asset = document.getElementById('send-asset').value;
            let addr = document.getElementById('send-address').value;
            let amt = parseFloat(document.getElementById('send-amount').value);

            if(!addr || addr.length < 10) return alert("Invalid destination address.");
            let avail = asset === 'USDT' ? state.usdtBalance : (state.manualAssets[asset]||0);
            if(isNaN(amt) || amt <= 0 || amt > avail) return alert("Invalid amount.");

            document.getElementById('send-form').classList.add('hidden');
            document.getElementById('send-processing').classList.remove('hidden');
            document.getElementById('send-close-btn').classList.add('hidden'); 
            
            const logBox = document.getElementById('send-log');
            logBox.innerHTML = '';
            
            const fakeHash = '0x' + Array.from({length:64}, () => Math.floor(Math.random()*16).toString(16)).join('');
            
            const addLog = (msg, delay) => {
                return new Promise(res => {
                    sendTimeout = setTimeout(() => {
                        logBox.innerHTML += `<div>${msg}</div>`;
                        logBox.scrollTop = logBox.scrollHeight;
                        res();
                    }, delay);
                });
            };

            document.getElementById('send-status-title').innerText = "Initiating...";

            (async function runFakeTx() {
                await addLog(`[SYS] Initiating smart contract call for ${amt} ${asset}...`, 500);
                await addLog(`[NET] Establishing secure RPC connection...`, 800);
                await addLog(`[MEM] Transaction signed. Broadcasting to mempool...`, 1200);
                
                document.getElementById('send-status-title').innerText = "Awaiting Inclusion";
                await addLog(`[MEM] TX accepted. Hash: <span class="text-[#F3BA2F] break-all">${fakeHash}</span>`, 1500);
                await addLog(`[BLK] Waiting for block inclusion...`, 2000);
                
                document.getElementById('send-status-title').innerText = "Verifying...";
                await addLog(`[VAL] Block discovered. Running node consensus checks...`, 3000);
                await addLog(`[VAL] Security signature verification pending...`, 1500);
                
                document.getElementById('send-status-title').innerText = "Verification Pending";
                document.getElementById('send-status-title').classList.replace('text-[#F3BA2F]', 'text-[#f6465d]');
                await addLog(`<span class="text-[#f6465d] font-bold">[ERR] Network validation stalled. Node consensus mismatch detected.</span>`, 2000);
                
                document.getElementById('send-close-btn').classList.remove('hidden'); 
                let attempt = 1;
                sendInterval = setInterval(() => {
                    logBox.innerHTML += `<div class="text-muted">[VAL] Retrying verification (Attempt ${attempt}/∞)...</div>`;
                    logBox.scrollTop = logBox.scrollHeight;
                    attempt++;
                }, 4000);
            })();
        }
        
        function closeSendModal() {
            clearInterval(sendInterval);
            clearTimeout(sendTimeout);
            document.getElementById('send-status-title').classList.replace('text-[#f6465d]', 'text-[#F3BA2F]');
