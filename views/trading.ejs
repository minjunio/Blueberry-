        }

        function updateWalletSystem() {
            let totalUsdValue = state.usdtBalance;
            let gridHtml = createWalletCard('USDT', state.usdtBalance, state.usdtBalance);

            state.orders.forEach(o => {
                totalUsdValue += o.margin; 
                let pnl = o.side === 'buy' ? ((o.units * (livePrices[o.pair]||o.entry)) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * (livePrices[o.pair]||o.entry)));
                totalUsdValue += pnl;
            });
            state.bots.forEach(b => {
                b.activeTxs.forEach(t => {
                    let livePrice = livePrices[b.asset] || t.entry;
                    let pnl = t.side === 'buy' ? ((t.size/t.entry * livePrice) - t.size) : (t.size - (t.size/t.entry * livePrice));
                    totalUsdValue += pnl; 
                });
            });

            for (const [coin, amt] of Object.entries(state.manualAssets)) {
                let valUsd = amt * (livePrices[coin + 'USDT'] || 0);
                totalUsdValue += valUsd;
                gridHtml += createWalletCard(coin, amt, valUsd);
            }

            document.getElementById('wallet-asset-grid').innerHTML = gridHtml;
            
            let rate = FX_RATES[state.currency] || 1;
            let sym = FX_SYM[state.currency] || '$';
            let localTotal = totalUsdValue * rate;

            document.getElementById('hero-currency-sym').innerText = sym;
            document.getElementById('hero-total-balance').innerText = localTotal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            
            let dPnlUsd = totalUsdValue - state.startOfDayValue;
            let dPnlLocal = dPnlUsd * rate;
            let dRoi = (dPnlUsd / (state.startOfDayValue || 1)) * 100;
            const pnlEl = document.getElementById('hero-daily-pnl');
            const roiEl = document.getElementById('hero-daily-roi');
            
            pnlEl.innerText = `${dPnlLocal >= 0 ? '+' : ''}${sym}${dPnlLocal.toFixed(2)}`;
            pnlEl.className = `text-xs md:text-sm font-black tracking-wide ${dPnlLocal >= 0 ? 'text-green-400' : 'text-pink-400'}`;
            roiEl.innerText = `${dPnlLocal >= 0 ? '+' : ''}${dRoi.toFixed(2)}% Today`;
            roiEl.className = `text-[9px] md:text-[10px] font-black px-1.5 py-0.5 rounded w-fit mt-0.5 border ${dPnlLocal >= 0 ? 'text-green-400 bg-green-500/10 border-green-500/20' : 'text-pink-400 bg-pink-500/10 border-pink-500/20'}`;
        }

        function createWalletCard(coin, amount, valueUsd) {
            let rate = FX_RATES[state.currency] || 1;
            let sym = FX_SYM[state.currency] || '$';
            let valLocal = valueUsd * rate;

            const valStr = valueUsd >= 0 ? `${sym}${valLocal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2})}` : 'Syncing...';
            const aInfo = ASSETS.find(x => x.id.replace('USDT','') === coin);
            const icon = aInfo ? `https://cryptologos.cc/logos/${aInfo.icon}` : (coin==='USDT'?'https://cryptologos.cc/logos/tether-usdt-logo.svg?v=029':`https://ui-avatars.com/api/?name=${coin}&background=0D0814&color=A78BFA&rounded=true`);
            
            return `
            <div class="bg-[#05020a]/80 border border-purple-900/30 p-2 lg:p-3 rounded-lg flex items-center gap-3">
                <img src="${icon}" class="w-6 h-6 lg:w-8 lg:h-8 rounded-full shrink-0">
                <div class="flex flex-col min-w-0">
                    <span class="text-[10px] font-black text-white uppercase truncate">${coin}</span>
                    <span class="text-[9px] lg:text-[10px] font-mono text-purple-400 truncate">${amount.toLocaleString(undefined, {maximumFractionDigits: 4})}</span>
                    <span class="text-[8px] font-bold text-muted truncate">≈ ${valStr}</span>
                </div>
            </div>`;
        }

        // --- 3. HIGH RES SHARP CANVAS ENGINE ---
        function setupCanvas() {
            const container = document.getElementById('canvas-container');
            const canvas = document.getElementById('custom-chart');
            chartCtx = canvas.getContext('2d');
            
            function resize() {
                const rect = container.getBoundingClientRect();
                if(rect.width === 0) return; 
                const dpr = window.devicePixelRatio || 1;
                canvas.width = rect.width * dpr;
                canvas.height = rect.height * dpr;
                chartCtx.scale(dpr, dpr);
                drawChart();
            }
            window.addEventListener('resize', resize); setTimeout(resize, 100); 

            canvas.addEventListener('mousemove', (e) => {
                const rect = canvas.getBoundingClientRect(); canvasHoverPos = e.clientX - rect.left; drawChart();
            });
            canvas.addEventListener('mouseleave', () => { canvasHoverPos = null; drawChart(); });
        }

        async function fetchChartData() {
            if(ui.timeframe === 'live') { ui.chartData = []; return; }
            let interval = ui.timeframe;
            let limit = 100;
            // Map special timeframes
            if(interval === '7d') { interval = '4h'; limit = 42; } // 42 * 4h = 168h (7 days)
            if(interval === '1y') { interval = '1d'; limit = 365; }
            if(interval === 'max') { interval = '1w'; limit = 500; } // 500 weeks ~ 10 years

            try {
                let res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${ui.pair}&interval=${interval}&limit=${limit}`);
                let json = await res.json();
                ui.chartData = json.map(d => ({ time: parseInt(d[0]), price: parseFloat(d[4]) }));
                drawChart(); calcAIEngine(); 
            } catch(e) {}
        }

        function setTimeframe(tf) {
            ui.timeframe = tf;
            document.querySelectorAll('.tf-btn').forEach(b => b.classList.remove('active'));
            document.getElementById(`tf-${tf}`).classList.add('active');
            fetchChartData();
        }

        function drawChart() {
            if(!chartCtx || ui.chartData.length < 2) return;
            const canvas = document.getElementById('custom-chart');
            if(canvas.width === 0) return;
            const w = canvas.width / (window.devicePixelRatio || 1);
            const h = canvas.height / (window.devicePixelRatio || 1);
            const data = ui.chartData;
            chartCtx.clearRect(0, 0, w, h);
            
            const padYBottom = 20, padXRight = 100; 
            const gW = w - padXRight, gH = h - padYBottom;
            const prices = data.map(d => d.price);
            const minPrice = Math.min(...prices); const maxPrice = Math.max(...prices);
            const range = maxPrice - minPrice || 1; 
            
            chartCtx.strokeStyle = 'rgba(139, 92, 246, 0.1)'; chartCtx.lineWidth = 1;
            chartCtx.fillStyle = '#8b839e'; chartCtx.font = '9px monospace';
            chartCtx.textAlign = 'left'; chartCtx.textBaseline = 'middle';
            
            for(let i=0; i<=4; i++) {
                const yPos = (i / 4) * gH;
                chartCtx.beginPath(); chartCtx.moveTo(0, yPos); chartCtx.lineTo(gW, yPos); chartCtx.stroke();
                let gridPrice = maxPrice - (i / 4) * range;
                let gridText = gridPrice >= 1000 ? gridPrice.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : gridPrice.toFixed(minPrice<1?6:2);
                chartCtx.fillText(gridText, gW + 4, yPos);
            }
            
            chartCtx.beginPath();
            let points = [];
            for(let i = 0; i < data.length; i++) {
                const x = (i / (data.length - 1)) * gW;
                let y = ((maxPrice - data[i].price) / range) * (gH * 0.8) + (gH * 0.1); 
                y = Math.max(5, Math.min(gH - 5, y)); 
                points.push({x, y, p: data[i].price});
                if(i === 0) chartCtx.moveTo(x, y); else chartCtx.lineTo(x, y);
            }
            chartCtx.strokeStyle = '#a78bfa'; chartCtx.lineWidth = 2; chartCtx.lineJoin = 'round'; chartCtx.stroke();
            
            // Draw manual trade markers on the chart
            state.orders.forEach(o => {
                if(o.pair === ui.pair) {
                    let y = ((maxPrice - o.entry) / range) * (gH * 0.8) + (gH * 0.1);
                    if(y > 0 && y < gH) {
                        chartCtx.beginPath(); chartCtx.moveTo(0, y); chartCtx.lineTo(gW, y);
                        chartCtx.strokeStyle = o.side === 'buy' ? 'rgba(52, 211, 153, 0.6)' : 'rgba(251, 113, 133, 0.6)';
                        chartCtx.lineWidth = 1.5; chartCtx.setLineDash([4, 4]); chartCtx.stroke(); chartCtx.setLineDash([]);
                        
                        chartCtx.fillStyle = o.side === 'buy' ? 'rgba(52, 211, 153, 0.15)' : 'rgba(251, 113, 133, 0.15)';
                        chartCtx.fillRect(gW - 80, y - 10, 80, 20);
                        chartCtx.fillStyle = o.side === 'buy' ? '#34d399' : '#fb7185';
                        chartCtx.font = 'bold 9px monospace';
                        chartCtx.fillText(`${o.lev}x ${o.side.toUpperCase()} @ ${o.entry >= 1000 ? Math.round(o.entry) : o.entry.toFixed(4)}`, gW - 75, y);
                    }
                }
            });

            function drawPriceTag(yPos, priceVal) {
                let tagY = Math.max(10, Math.min(gH - 10, yPos));
                let priceText = priceVal >= 1000 ? priceVal.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2}) : priceVal.toFixed(minPrice<1?6:2);
                chartCtx.font = 'bold 11px monospace';
                let boxWidth = Math.max(chartCtx.measureText(priceText).width + 12, 60); 
                chartCtx.fillStyle = '#a78bfa'; chartCtx.fillRect(gW, tagY - 11, boxWidth, 22);
                chartCtx.fillStyle = '#05020a'; chartCtx.fillText(priceText, gW + 6, tagY);
            }

            if(canvasHoverPos !== null && canvasHoverPos <= gW) {
                let closest = points.reduce((prev, curr) => Math.abs(curr.x - canvasHoverPos) < Math.abs(prev.x - canvasHoverPos) ? curr : prev);
                chartCtx.strokeStyle = 'rgba(255,255,255,0.3)'; chartCtx.lineWidth = 1; chartCtx.setLineDash([4, 4]);
                chartCtx.beginPath(); chartCtx.moveTo(closest.x, 0); chartCtx.lineTo(closest.x, gH); chartCtx.stroke();
                chartCtx.beginPath(); chartCtx.moveTo(0, closest.y); chartCtx.lineTo(gW, closest.y); chartCtx.stroke();
                chartCtx.setLineDash([]);
                chartCtx.beginPath(); chartCtx.arc(closest.x, closest.y, 4, 0, Math.PI*2);
                chartCtx.fillStyle = '#a78bfa'; chartCtx.fill();
                drawPriceTag(closest.y, closest.p);
            } else {
                const last = points[points.length-1];
                chartCtx.beginPath(); chartCtx.arc(last.x, last.y, 4, 0, Math.PI*2);
                chartCtx.fillStyle = '#a78bfa'; chartCtx.fill();
                drawPriceTag(last.y, last.p);
            }
        }

        // --- 4. DATA, ON-CHAIN ALPHA, & LOGS ---
        function setLogFilter(f) {
            ui.logFilter = f;
            document.getElementById('filter-all').className = f==='all' ? "text-[9px] font-black uppercase bg-purple-600 text-white px-2 py-0.5 rounded transition" : "text-[9px] font-black uppercase text-muted hover:text-white px-2 py-0.5 rounded transition border border-transparent hover:border-purple-900";
            document.getElementById('filter-whales').className = f==='whales' ? "text-[9px] font-black uppercase bg-purple-600 text-white px-2 py-0.5 rounded transition" : "text-[9px] font-black uppercase text-muted hover:text-white px-2 py-0.5 rounded transition border border-transparent hover:border-purple-900";
            renderGlobalLogs();
        }

        function renderGlobalLogs() {
            const feed = document.getElementById('below-chart-log');
            if(!state.globalTradeLogs || state.globalTradeLogs.length === 0) { feed.innerHTML = '<div class="text-[9px] text-muted text-center py-4 italic">Awaiting multi-chain DEX/CEX block trades...</div>'; return; }
            
            let filtered = state.globalTradeLogs;
            if(ui.logFilter === 'whales') filtered = filtered.filter(l => l.usdVal >= 25000);

            feed.innerHTML = filtered.map(l => {
                const cStr = l.isBuy ? 'text-green-400' : 'text-pink-400';
                const bStr = l.isBuy ? 'bg-green-500/10 border-green-500/20' : 'bg-pink-500/10 border-pink-500/20';
                return `
                <div class="flex justify-between items-center px-3 py-1.5 rounded border ${bStr}">
                    <span class="text-[9px] font-mono text-muted w-16">${l.addr}</span>
                    <span class="text-[10px] font-black ${cStr} uppercase">${l.pair.replace('USDT','')} ${l.isBuy?'BUY':'SELL'} ${l.qty.toFixed(l.price<1?0:4)}</span>
                    <span class="text-[10px] font-mono text-white">$${l.usdVal.toLocaleString(undefined, {maximumFractionDigits:0})}</span>
                </div>`;
            }).join('');
        }

        function renderOnChainAlpha() {
            const buysContainer = document.getElementById('ui-top-buys');
            const sellsContainer = document.getElementById('ui-top-sells');

            if (topBuysArray.length === 0) buysContainer.innerHTML = `<div class="text-[9px] text-muted text-center italic py-2">Syncing chain...</div>`;
            else buysContainer.innerHTML = topBuysArray.map(t => `<div class="flex justify-between items-center text-[10px] font-mono"><span class="text-white">${t.qty.toFixed(ui.price<1?0:4)} <span class="text-[8px] text-muted">${ui.pair.replace('USDT','')}</span></span><span class="text-green-400 font-black">$${t.usdVal.toLocaleString(undefined,{maximumFractionDigits:0})}</span></div>`).join('');

            if (topSellsArray.length === 0) sellsContainer.innerHTML = `<div class="text-[9px] text-muted text-center italic py-2">Syncing chain...</div>`;
            else sellsContainer.innerHTML = topSellsArray.map(t => `<div class="flex justify-between items-center text-[10px] font-mono"><span class="text-white">${t.qty.toFixed(ui.price<1?0:4)} <span class="text-[8px] text-muted">${ui.pair.replace('USDT','')}</span></span><span class="text-pink-400 font-black">$${t.usdVal.toLocaleString(undefined,{maximumFractionDigits:0})}</span></div>`).join('');
        }

        function renderTopHolders() {
            document.getElementById('ui-top-holders').innerHTML = topHoldersSim.map(h => `<div class="flex justify-between items-center text-[10px] font-mono py-0.5"><span class="text-muted hover:text-purple-400 cursor-pointer transition">${h.addr}</span><span class="text-white font-black">$${(h.usd).toLocaleString()}</span></div>`).join('');
        }

        function connectMultiStream() {
            let streamSet = new Set(['btcusdt@ticker', 'ethusdt@ticker', 'solusdt@ticker', 'xrpusdt@ticker', 'dogeusdt@ticker', 'adausdt@ticker']);
            for(const coin of Object.keys(state.manualAssets)) streamSet.add((coin+'USDT').toLowerCase() + '@ticker');
            
            wsTicker = new WebSocket(`wss://stream.binance.com:9443/stream?streams=${Array.from(streamSet).join('/')}`);
            wsTicker.onmessage = (e) => {
                const payload = JSON.parse(e.data);
                if(payload.data && payload.data.c) {
                    livePrices[payload.data.s] = parseFloat(payload.data.c);
                    if(payload.data.s === ui.pair) processMainTick(parseFloat(payload.data.c));
                    tickBots(payload.data.s, parseFloat(payload.data.c));
                }
            };
            wsTicker.onclose = () => setTimeout(connectMultiStream, 3000); 
        }

        function connectGlobalTradeStream() {
            // Connect to multiple aggTrade streams to persist log continuously
            let tradeStreams = ['btcusdt@aggTrade', 'ethusdt@aggTrade', 'solusdt@aggTrade'];
            if(wsTrade) wsTrade.close();
            wsTrade = new WebSocket(`wss://stream.binance.com:9443/stream?streams=${tradeStreams.join('/')}`);
            flowData = { buy: 0, sell: 0 };
            
            wsTrade.onmessage = (e) => {
                const payload = JSON.parse(e.data);
                if(payload.data && payload.data.e === 'aggTrade') {
                    const data = payload.data;
                    const price = parseFloat(data.p), qty = parseFloat(data.q);
                    const isBuy = !data.m, usdVal = price * qty;
                    const pair = data.s;

                    if(usdVal < 1000) return; // Filter out dust from global stream to save memory

                    const logItem = {
                        addr: '0x' + Math.random().toString(16).substring(2, 8).toUpperCase(),
                        isBuy, qty, price, usdVal, pair
                    };

                    state.globalTradeLogs.unshift(logItem);
                    if(state.globalTradeLogs.length > 200) state.globalTradeLogs.pop(); // limit size
                    
                    if(Math.random() < 0.1) saveState(); // throttle localstorage saving

                    // Update local UI elements if pair matches current view
                    if(pair === ui.pair) {
                        if(isBuy) {
                            flowData.buy += usdVal;
                            topBuysArray.push({qty, price, usdVal}); topBuysArray.sort((a,b) => b.usdVal - a.usdVal);
                            if(topBuysArray.length > 5) topBuysArray.pop();
                        } else {
                            flowData.sell += usdVal;
                            topSellsArray.push({qty, price, usdVal}); topSellsArray.sort((a,b) => b.usdVal - a.usdVal);
                            if(topSellsArray.length > 5) topSellsArray.pop();
                        }
                        updateRatioBar();
                        renderOnChainAlpha(); 

                        if(usdVal >= 25000) spawnBottomLeftPopup(isBuy, qty, price, usdVal);
                        if(usdVal >= 100000) triggerDramaticEffect(isBuy);

                        // Whale tracking logic
                        if(usdVal > 150000) {
                            let rndHolder = topHoldersSim[Math.floor(Math.random() * topHoldersSim.length)];
                            if(isBuy) rndHolder.usd += usdVal; else rndHolder.usd -= usdVal;
                            topHoldersSim.sort((a,b)=>b.usd - a.usd);
                            renderTopHolders();
                        }
                    }
                    renderGlobalLogs(); // Re-render log UI
                }
            };
            wsTrade.onclose = () => setTimeout(connectGlobalTradeStream, 3000); 
        }

        function triggerDramaticEffect(isBuy) {
            const wrap = document.getElementById('main-chart-wrapper');
            wrap.classList.remove('flash-mega-pump', 'flash-mega-dump'); void wrap.offsetWidth; 
            wrap.classList.add(isBuy ? 'flash-mega-pump' : 'flash-mega-dump');
        }

        function spawnBottomLeftPopup(isBuy, qty, price, usdVal) {
            const container = document.getElementById('chart-popups-container');
            const el = document.createElement('div');
            const addr = '0x' + Math.random().toString(16).substring(2, 6).toUpperCase();
            let duration = 2000;
            let bgStyle = isBuy ? 'bg-[#05020a]/90 text-green-400 border border-green-500/30' : 'bg-[#05020a]/90 text-pink-400 border border-pink-500/30';
            
            if (usdVal >= 100000) { duration = 6000; bgStyle = isBuy ? 'bg-green-500 text-[#05020a] font-black border-2 border-white' : 'bg-pink-500 text-[#05020a] font-black border-2 border-white'; }
            else if (usdVal >= 25000) { duration = 4000; bgStyle = isBuy ? 'bg-green-800 text-white font-bold border border-green-400' : 'bg-pink-800 text-white font-bold border border-pink-400'; }
            
            el.className = `bottom-popup flex flex-col px-2 py-1 rounded ${bgStyle} backdrop-blur w-fit min-w-[120px]`;
            el.innerHTML = `<div class="flex justify-between items-center gap-3"><span class="text-[8px] font-mono opacity-80">${addr}</span><span class="text-[10px] uppercase">${isBuy?'WHALE BUY':'WHALE SELL'}</span></div><div class="text-[11px] font-mono mt-0.5">${qty.toFixed(4)} @ $${price.toLocaleString()}</div>`;
            container.prepend(el);
            if(container.children.length > 8) container.removeChild(container.lastChild);
            setTimeout(() => { el.style.opacity = '0'; setTimeout(() => { if(el.parentNode) el.remove(); }, 300); }, duration);
        }

        function updateRatioBar() {
            const t = flowData.buy + flowData.sell;
            let bPct = 50, sPct = 50;
            if(t > 0) { bPct = (flowData.buy/t)*100; sPct = (flowData.sell/t)*100; }
            document.querySelectorAll('#ratio-buy-bar').forEach(el => el.style.width = `${bPct}%`);
            document.querySelectorAll('#ratio-sell-bar').forEach(el => el.style.width = `${sPct}%`);
            document.querySelectorAll('#ratio-buy-text').forEach(el => el.innerText = `${bPct.toFixed(0)}%`);
            document.querySelectorAll('#ratio-sell-text').forEach(el => el.innerText = `${sPct.toFixed(0)}%`);
        }

        function saveAILogic() {
            state.aiLogic = document.getElementById('ai-logic-editor').value;
            saveState(); toggleModal('ai-code-modal'); calcAIEngine();
        }

        function calcAIEngine() {
            if(ui.chartData.length < 21) return; 
            let gains = 0, losses = 0; const rsiData = ui.chartData.slice(-15);
            for(let i=1; i<rsiData.length; i++) { let diff = rsiData[i].price - rsiData[i-1].price; if(diff >= 0) gains += diff; else losses -= diff; }
            let rs = (gains/14) / ((losses/14) || 1); let rsi = 100 - (100 / (1 + rs));
            const smaData = ui.chartData.slice(-20); let sma = smaData.reduce((acc, val) => acc + val.price, 0) / 20;
            const prices = smaData.map(d => d.price); let vol = Math.max(...prices) - Math.min(...prices);

            document.getElementById('ai-rsi').innerText = rsi.toFixed(1);
            document.getElementById('ai-sma').innerText = sma.toFixed(2);
            document.getElementById('ai-vol').innerText = vol.toFixed(2);
            
            const predEl = document.getElementById('ai-signal');
            try {
                let fn = new Function('rsi', 'sma', 'volatility', 'prices', state.aiLogic);
                let res = fn(rsi, sma, vol, prices);
                if(res.includes('SELL') || res.includes('BEAR')) { predEl.innerText = res; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-pink-900/30 text-pink-400 border border-pink-500/20"; }
                else if(res.includes('BUY') || res.includes('BULL')) { predEl.innerText = res; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-green-900/30 text-green-400 border border-green-500/20"; }
                else { predEl.innerText = res || "NEUTRAL"; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-purple-900/30 text-purple-400 border border-purple-500/20"; }
            } catch(e) { predEl.innerText = "SYNTAX ERR"; predEl.className = "text-[10px] font-black uppercase px-2 py-1 rounded bg-red-900/30 text-red-400"; }
        }

        function processMainTick(newPrice) {
            const el = document.getElementById('main-price');
            if (ui.lastPrice !== 0 && newPrice !== ui.lastPrice) {
                el.style.color = newPrice > ui.lastPrice ? '#34d399' : '#fb7185';
                setTimeout(()=>el.style.color='white', 200);
            }
            ui.lastPrice = newPrice; ui.price = newPrice;
            
            if(ui.timeframe === 'live') {
                ui.chartData.push({time: Date.now(), price: newPrice});
                if(ui.chartData.length > 50) ui.chartData.shift();
            } else if (ui.chartData.length > 0) {
                ui.chartData[ui.chartData.length - 1].price = newPrice;
            }
            
            if(Math.random() < 0.1) calcAIEngine(); 
            if(!canvasHoverPos) drawChart(); 
            
            el.innerText = newPrice.toLocaleString(undefined, {minimumFractionDigits: newPrice<1?4:2, maximumFractionDigits: newPrice<1?4:2});
            renderOrders(); 
        }

        // --- 5. MANUAL EXECUTION ---
        function setSide(side) {
            ui.side = side;
            document.getElementById('btn-buy').className = side==='buy' ? "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest bg-green-500/20 text-green-400 border border-green-500/50" : "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-green-400 transition";
            document.getElementById('btn-sell').className = side==='sell' ? "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest bg-pink-500/20 text-pink-400 border border-pink-500/50" : "flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-pink-400 transition";
            
            const exec = document.getElementById('btn-execute');
            exec.innerText = side==='buy'?"Execute Long":"Execute Short";
            exec.className = side==='buy'?"mt-4 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-green-500 text-[#05020a] hover:bg-green-400 transition active:scale-95" : "mt-4 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-pink-500 text-[#05020a] hover:bg-pink-400 transition active:scale-95";
        }

        document.getElementById('trade-lev').addEventListener('input', (e) => { ui.lev = parseInt(e.target.value); document.getElementById('lev-val').innerText = ui.lev; calcSize(); });
        document.getElementById('trade-margin').addEventListener('input', calcSize);

        function calcSize() {
            const m = parseFloat(document.getElementById('trade-margin').value) || 0;
            document.getElementById('ui-size').innerText = (m * ui.lev).toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT';
        }

        function setMax() { document.getElementById('trade-margin').value = Math.floor(state.usdtBalance * 100) / 100; calcSize(); }

        function executeOrder() {
            const m = parseFloat(document.getElementById('trade-margin').value);
            if (isNaN(m) || m <= 0) return;
            if (m > state.usdtBalance) return alert("Insufficient USDT");

            state.usdtBalance -= m;
            state.orders.push({
                id: Math.random().toString(36).substr(2, 9), pair: ui.pair, side: ui.side,
                margin: m, lev: ui.lev, entry: ui.price, units: (m * ui.lev) / ui.price, time: Date.now()
            });

            document.getElementById('trade-margin').value = ''; calcSize();
            saveState(); renderOrders(); drawChart();
        }

        function renderOrders() {
            const tbody = document.getElementById('orders-body');
            if (state.orders.length === 0) { tbody.innerHTML = `<tr><td colspan="8" class="p-4 text-center text-muted font-black uppercase text-[9px]">No Open Trades</td></tr>`; return; }

            let html = '';
            state.orders.forEach(o => {
                let livePrice = livePrices[o.pair] || o.entry;
                let pnl = o.side === 'buy' ? ((o.units * livePrice) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * livePrice));
                let roi = (pnl / o.margin) * 100;
                const isProf = pnl >= 0;
                html += `
                    <tr class="border-b border-purple-900/20 hover:bg-purple-900/20">
                        <td class="p-3 text-white">${o.pair}</td>
                        <td class="p-3"><span class="px-2 py-1 rounded ${o.side==='buy'?'bg-green-900/40 text-green-400 border border-green-500/20':'bg-pink-900/40 text-pink-400 border border-pink-500/20'} uppercase text-[9px]">${o.lev}x ${o.side}</span></td>
                        <td class="p-3 text-purple-400">$${o.entry.toFixed(4)}</td>
                        <td class="p-3">$${livePrice.toFixed(4)}</td>
                        <td class="p-3">$${o.margin.toFixed(2)}</td>
                        <td class="p-3">$${(o.margin * o.lev).toFixed(2)}</td>
                        <td class="p-3 text-right ${isProf?'text-green-400':'text-pink-400'} font-black">${isProf?'+':''}${roi.toFixed(2)}% | ${isProf?'+':''}$${pnl.toFixed(2)}</td>
                        <td class="p-3 text-center"><button onclick="closeOrder('${o.id}')" class="px-3 py-1 bg-purple-900/50 hover:bg-pink-600 text-white rounded text-[9px] uppercase transition">Close</button></td>
                    </tr>`;
            });
            tbody.innerHTML = html;
        }

        function closeOrder(id) {
            const idx = state.orders.findIndex(p => p.id === id);
            if(idx===-1) return;
            const o = state.orders[idx];
            let pnl = o.side === 'buy' ? ((o.units * (livePrices[o.pair]||o.entry)) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * (livePrices[o.pair]||o.entry)));
            
            state.usdtBalance += (o.margin + pnl);
            state.history.unshift({ pair: o.pair, pnl: pnl });
            if(state.history.length > 50) state.history.pop();
            
            state.orders.splice(idx, 1);
            saveState(); renderOrders(); renderHistory(); drawChart();
        }

        function renderHistory() {
            const tbody = document.getElementById('history-body');
            let html = '';
            state.history.forEach(h => {
                html += `<tr class="border-b border-purple-900/20"><td class="p-3 text-white">${h.pair}</td><td class="p-3 text-right font-black ${h.pnl>=0?'text-green-400':'text-pink-400'}">${h.pnl>=0?'+':''}$${h.pnl.toFixed(2)}</td></tr>`;
            });
            tbody.innerHTML = html || `<tr><td colspan="2" class="p-4 text-center text-muted text-[9px] uppercase">No History</td></tr>`;
        }

        function setUsdt() {
            const amt = parseFloat(document.getElementById('add-usdt-input').value);
            if(amt >= 0) { state.usdtBalance = amt; state.startOfDayValue = amt; document.getElementById('add-usdt-input').value = ''; saveState(); }
        }
        function addManualAsset() {
            const n = document.getElementById('new-asset-name').value.toUpperCase(), a = parseFloat(document.getElementById('new-asset-amt').value);
            if(n && a) { state.manualAssets[n] = a; document.getElementById('new-asset-name').value=''; document.getElementById('new-asset-amt').value=''; saveState(); }
        }
        function updateUI() { document.getElementById('ui-avail').innerText = state.usdtBalance.toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT'; }
        function saveState() { localStorage.setItem('cloud_state_v15', JSON.stringify(state)); updateUI(); updateWalletSystem(); }

        // --- 7. REAL-TIME DCA & SNIPER ENGINE ---
        function checkSyntax(code) {
            try {
                new Function('price', 'rsi', 'volume', 'bot', 'executeMarket', 'closeAllPositions', 'getOpenExposure', 'getOpenPnL', 'getAverageEntry', 'setTrailingStop', 'setStopLoss', 'setTakeProfit', 'log', 'ATH', code);
                return true;
            } catch(e) {
                alert("Syntax Error in Engine Logic:\n" + e.message);
                return false;
            }
        }

        function deployBot() {
            const code = document.getElementById('code-editor').value;
            if(!checkSyntax(code)) return;

            const dropVal = parseFloat(document.getElementById('bot-drop').value) || 2.5;
            const bot = {
                id: Math.random().toString(36).substr(2, 9),
                name: document.getElementById('bot-name').value || "Unnamed Bot",
                mode: botModeConfig, asset: botAssetConfig,
                size: parseFloat(document.getElementById('bot-size').value) || 0,
                lev: parseFloat(document.getElementById('bot-lev').value) || 1,
                maxTx: parseInt(document.getElementById('bot-max-tx').value) || 1,
                maxCap: parseFloat(document.getElementById('bot-max-cap').value) || 0,
                dropPercent: dropVal, 
                code: code,
                activeTxs: [], closedTxs: [], realizedPnl: 0,
                state: null,
                lastStatusMsg: "Status: Initialized & Waiting"
            };
            if(bot.size <= 0) return alert("Invalid size");
            state.bots.push(bot);
            saveState(); renderBots();
            document.getElementById('bot-name').value = '';
        }

        function renderBots() {
            const list = document.getElementById('active-bots-list');
            let html = '';
            state.bots.forEach(b => {
                let livePnl = b.realizedPnl;
                b.activeTxs.forEach(t => {
                    let livePrice = livePrices[b.asset] || t.entry;
                    livePnl += t.side === 'buy' ? ((t.size/t.entry * livePrice) - t.size) : (t.size - (t.size/t.entry * livePrice));
                });
                const isProf = livePnl >= 0; let cColor = isProf ? 'text-green-400' : 'text-pink-400';
                
                html += `
                <div class="bg-[#05020a]/80 p-4 rounded border border-purple-900/40 cursor-pointer hover:border-purple-500 transition" onclick="openBotDetails('${b.id}')">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-xs font-black text-white uppercase">${b.name}</span>
                        <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
                    </div>
                    <div class="flex justify-between items-end">
                        <div class="flex flex-col">
                            <span class="text-[9px] text-muted uppercase">${b.asset} | ${b.mode}</span>
                            <span class="text-[10px] font-mono text-white mt-1">Order: $${b.size} | ${b.lev}x</span>
                            <span class="text-[8px] text-purple-400 mt-1 truncate max-w-[120px]">${b.lastStatusMsg}</span>
                        </div>
                        <div class="flex flex-col text-right">
                            <span class="text-[9px] text-muted uppercase">Net PnL</span>
                            <span class="text-sm font-black font-mono ${cColor}">${isProf?'+':''}$${livePnl.toFixed(2)}</span>
                        </div>
                    </div>
                </div>`;
            });
            list.innerHTML = html || `<p class="text-xs text-muted">No bots running.</p>`;
        }

        function openBotDetails(id) {
            const b = state.bots.find(x => x.id === id);
            if(!b) return;
            activeBotViewId = id;
            document.getElementById('bot-detail-title').innerText = b.name;
            document.getElementById('bot-modal-code').value = b.code;
            updateBotModalUI(b);
            toggleModal('bot-details-modal');
        }

        function saveBotModalCode() {
            if(!activeBotViewId) return;
            const b = state.bots.find(x => x.id === activeBotViewId);
            if(b) {
                const newCode = document.getElementById('bot-modal-code').value;
                if(!checkSyntax(newCode)) return;
                b.code = newCode;
                b.state = null; 
                saveState(); alert("Live logic validated and updated successfully.");
            }
        }

        function updateBotModalUI(b) {
            if(!b) return;
            let livePnl = b.realizedPnl; let activeHtml = '';
            
            b.activeTxs.forEach(t => {
                let livePrice = livePrices[b.asset] || t.entry;
                let tPnl = t.side === 'buy' ? ((t.size/t.entry * livePrice) - t.size) : (t.size - (t.size/t.entry * livePrice));
                livePnl += tPnl; let isProf = tPnl >= 0;
                activeHtml += `<tr class="border-b border-purple-900/20"><td class="p-2">${b.asset}</td><td class="p-2">${t.side}</td><td class="p-2">$${t.entry.toFixed(4)}</td><td class="p-2 text-right ${isProf?'text-green-400':'text-pink-400'}">${isProf?'+':''}$${tPnl.toFixed(2)}</td></tr>`;
            });
            document.getElementById('bot-active-tx').innerHTML = activeHtml || `<tr><td colspan="4" class="p-4 text-center text-[9px] text-muted">No live executions.</td></tr>`;
            
            let closedHtml = '';
            b.closedTxs.forEach(tx => {
                let isProf = tx.result >= 0;
                closedHtml += `<tr class="border-b border-purple-900/20"><td class="p-2">Close</td><td class="p-2">${tx.side}</td><td class="p-2">$${tx.size}</td><td class="p-2 text-right ${isProf?'text-green-400':'text-pink-400'}">${isProf?'+':''}$${tx.result.toFixed(2)}</td></tr>`;
            });
            document.getElementById('bot-closed-tx').innerHTML = closedHtml || `<tr><td colspan="4" class="p-4 text-center text-[9px] text-muted">No closed history.</td></tr>`;

            const isNetProf = livePnl >= 0;
            document.getElementById('bot-detail-pnl').innerText = `${isNetProf?'+':''}$${livePnl.toFixed(2)}`;
            document.getElementById('bot-detail-pnl').className = `text-lg font-mono font-black ${isNetProf ? 'text-green-400' : 'text-pink-400'}`;
            
            document.getElementById('bot-detail-status-text').innerText = b.lastStatusMsg;
            document.getElementById('bot-detail-status-dot').className = b.lastStatusMsg.includes("HALTED") ? "w-3 h-3 rounded-full bg-red-500" : "w-3 h-3 rounded-full bg-green-500 animate-pulse";
        }

        function killBot() {
            if(!activeBotViewId) return;
            state.bots = state.bots.filter(b => b.id !== activeBotViewId);
            saveState(); renderBots(); toggleModal('bot-details-modal');
        }

