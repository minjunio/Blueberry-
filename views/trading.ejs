                const img = `<img src="https://cryptologos.cc/logos/${a.icon}" class="w-5 h-5 rounded-full bg-[#1e2026] p-0.5">`;
                const elT = document.createElement('div');
                elT.className = "px-4 py-3 hover:bg-purple-900/40 cursor-pointer flex items-center gap-3 transition border-b border-purple-900/30 last:border-0";
                elT.innerHTML = `${img}<span class="text-xs font-black uppercase text-white">${a.name}</span>`;
                elT.onclick = () => { ui.pair = a.id; document.getElementById('term-text').innerText = a.name; document.getElementById('term-logo').src = `https://cryptologos.cc/logos/${a.icon}`; toggleDropdown('term-dropdown'); triggerPairChange(); };
