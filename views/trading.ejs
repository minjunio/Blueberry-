<!DOCTYPE html>
<html lang="en">
<head>
    <title>CloudCrypto Quant Terminal</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <link rel="icon" type="image/png" href="/favicon.png">
    
    <style>
        /* Flat Deep Quant Purple Theme */
        body { background: #05020a; color: #f8fafc; font-family: 'Inter', system-ui, sans-serif; margin: 0; min-height: 100vh; display: flex; flex-direction: column; overflow-x: hidden; }
        
        .glass-panel { background: rgba(13, 8, 20, 0.95); border: 1px solid rgba(139, 92, 246, 0.2); border-radius: 0.5rem; }
        .glass-overlay { background: #0a0510; border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 0.5rem; }
        
        .neo-input { background: rgba(5, 2, 10, 0.8); border: 1px solid rgba(139, 92, 246, 0.3); color: white; outline: none; transition: 0.2s; cursor: pointer; border-radius: 0.5rem; }
        .neo-input:focus, .neo-input:hover { border-color: #a78bfa; }
        
        .neo-btn { background: rgba(139, 92, 246, 0.1); border: 1px solid rgba(139, 92, 246, 0.3); color: #ddd; transition: 0.2s; cursor: pointer; border-radius: 0.5rem; }
        .neo-btn:hover { background: rgba(139, 92, 246, 0.3); color: white; border-color: #a78bfa; }
        .text-muted { color: #8b839e; }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; cursor: pointer; }
        input[type=range]:focus { outline: none; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; background: rgba(139, 92, 246, 0.2); border-radius: 2px; }
        input[type=range]::-webkit-slider-thumb { height: 16px; width: 16px; border-radius: 50%; background: #a78bfa; -webkit-appearance: none; margin-top: -6px; transition: transform 0.1s; }
        input[type=range]::-webkit-slider-thumb:active { transform: scale(1.2); }

        .modal-overlay { transition: opacity 0.2s; z-index: 9999; }
        .modal-content { transition: transform 0.2s; }
        .modal-hidden { opacity: 0; pointer-events: none; }
        .modal-hidden .modal-content { transform: scale(0.98) translateY(5px); }
        .modal-active { opacity: 1; pointer-events: auto; }
        .modal-active .modal-content { transform: scale(1) translateY(0); }

        .tf-btn { padding: 4px 10px; border-radius: 4px; font-size: 10px; font-weight: 900; color: #8b839e; cursor: pointer; transition: 0.2s; }
        .tf-btn.active { background: rgba(167, 139, 250, 0.2); color: #a78bfa; border: 1px solid #a78bfa; }

        .dropdown-menu { transform-origin: top; transition: transform 0.2s ease, opacity 0.2s ease; z-index: 100; }
        .dropdown-hidden { transform: scaleY(0); opacity: 0; pointer-events: none; }
        .dropdown-active { transform: scaleY(1); opacity: 1; pointer-events: auto; }

        @keyframes megaPump { 0% { box-shadow: inset 0 0 80px rgba(52, 211, 153, 0.3); border-color: #34d399; } 100% { box-shadow: inset 0 0 0 transparent; border-color: rgba(139, 92, 246, 0.2); } }
        @keyframes megaDump { 0% { box-shadow: inset 0 0 80px rgba(251, 113, 133, 0.3); border-color: #fb7185; } 100% { box-shadow: inset 0 0 0 transparent; border-color: rgba(139, 92, 246, 0.2); } }
        .flash-mega-pump { animation: megaPump 0.8s ease-out; }
        .flash-mega-dump { animation: megaDump 0.8s ease-out; }

        @keyframes popupSlideIn { from { opacity: 0; transform: translateX(-10px); } to { opacity: 1; transform: translateX(0); } }
        .bottom-popup { animation: popupSlideIn 0.2s ease-out forwards; transition: opacity 0.3s ease-out; }

        .code-area { font-family: 'Fira Code', monospace; line-height: 1.5; tab-size: 4; }
        select option { background: #05020a; color: white; }
        
        .spinner { border: 3px solid rgba(139, 92, 246, 0.2); border-top-color: #a78bfa; border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }

        .dot-spin { animation: spin 5s linear infinite; }
        .eth-pulse { animation: subtlePulse 2.5s ease-in-out infinite; }
        @keyframes subtlePulse { 0%, 100% { transform: scale(1); filter: drop-shadow(0 0 2px rgba(98,126,234,0)); } 50% { transform: scale(1.05); filter: drop-shadow(0 0 8px rgba(98,126,234,0.6)); } }

        table th { padding: 12px; font-size: 9px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: #8b839e; border-bottom: 1px solid rgba(139, 92, 246, 0.3); }
        table td { padding: 12px; border-bottom: 1px solid rgba(139, 92, 246, 0.15); }
    </style>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <header class="flex flex-col shrink-0 z-50 sticky top-0 bg-[#05020a] border-b border-purple-900/40">
        <div class="flex justify-between items-center p-3 md:p-4 max-w-[1600px] w-full mx-auto">
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-8 h-8 rounded bg-purple-600 flex items-center justify-center shadow-[0_0_15px_rgba(147,51,234,0.5)]">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    </div>
                    <h2 class="text-lg font-black uppercase tracking-tighter text-white hidden sm:block">Cloud<span class="text-purple-400">Quant</span></h2>
                </div>
                <div class="flex gap-1 bg-[#05020a] border border-purple-900/50 p-1 rounded-md">
                    <button onclick="switchApp('terminal')" id="nav-terminal" class="px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest bg-purple-600 text-white transition shadow-lg">Terminal</button>
                    <button onclick="switchApp('wallet')" id="nav-wallet" class="px-4 py-1.5 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-white transition">Wallet</button>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button onclick="toggleModal('history-modal')" class="neo-btn px-4 py-2 rounded font-black text-[10px] uppercase tracking-widest flex items-center gap-2">History</button>
            </div>
        </div>
    </header>

    <div id="app-terminal" class="w-full">
        <main class="flex flex-col p-2 md:p-4 gap-4 w-full max-w-[1600px] mx-auto">
            
            <section class="glass-panel p-4 md:p-6 flex flex-col relative overflow-hidden">
                <div class="flex items-center gap-2 mb-2 z-10">
                    <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                    <h1 class="text-xs font-black uppercase tracking-widest text-purple-400">Portfolio Net Value</h1>
                </div>
                
                <div class="flex items-end gap-2 z-10 flex-wrap">
                    <span id="hero-currency-sym" class="text-3xl md:text-4xl lg:text-5xl font-black text-purple-400">$</span>
                    <h2 id="hero-total-balance" class="text-4xl md:text-5xl lg:text-6xl font-black text-white font-mono tracking-tighter drop-shadow-md">0.00</h2>
                    
                    <select id="currency-select" onchange="setCurrency(this.value)" class="bg-transparent text-purple-400 font-black text-sm md:text-base outline-none ml-2 cursor-pointer border-b border-purple-900/50 pb-1 mb-2 uppercase hover:text-white transition">
                        <option value="USD">🇺🇸 USD</option>
                        <option value="AED">🇦🇪 AED</option>
                        <option value="EUR">🇪🇺 EUR</option>
                        <option value="GBP">🇬🇧 GBP</option>
                    </select>

                    <div class="flex flex-col mb-1 md:mb-2 ml-4">
                        <span id="hero-daily-pnl" class="text-xs md:text-sm font-black text-green-400 tracking-wide">+ 0.00</span>
                        <span id="hero-daily-roi" class="text-[9px] md:text-[10px] font-black text-green-500 bg-green-500/10 px-1.5 py-0.5 rounded w-fit mt-0.5 border border-green-500/20">+0.00% Today</span>
                    </div>
                </div>
                
                <div class="border-t border-purple-900/40 pt-4 mt-4 z-10">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-[10px] font-black uppercase tracking-widest text-muted">Quick Asset View</h3>
                    </div>
                    <div id="terminal-asset-list" class="flex flex-wrap gap-2"></div>
                </div>
            </section>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
                <div class="lg:col-span-9 flex flex-col gap-4">
                    
                    <div class="glass-panel p-3 md:p-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 border-l-4 border-l-purple-500">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 rounded-full bg-purple-500 animate-pulse"></div>
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-purple-400">AI Logic Engine v4.0</h3>
                        </div>
                        <div class="flex flex-wrap items-center gap-3 md:gap-6 w-full md:w-auto">
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">RSI (14)</span><span id="ai-rsi" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">SMA (20)</span><span id="ai-sma" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex flex-col"><span class="text-[8px] uppercase text-muted">Trend Volatility</span><span id="ai-vol" class="text-xs font-mono font-black text-white">--</span></div>
                            <div class="flex items-center gap-2 ml-auto">
                                <span id="ai-signal" class="text-[10px] font-black uppercase px-2 py-1 rounded bg-purple-900/30 text-purple-400 border border-purple-500/20">ANALYZING</span>
                                <button onclick="toggleModal('ai-code-modal')" class="text-[9px] font-black uppercase tracking-widest text-purple-400 hover:text-white bg-purple-900/40 px-2 py-1 rounded border border-purple-900 transition">Edit Code</button>
                            </div>
                        </div>
                    </div>

                    <div class="glass-panel p-4 md:p-6 flex flex-col relative min-h-[55vh] transition-colors duration-300 border border-transparent" id="main-chart-wrapper">
                        <div class="flex justify-between items-start z-20">
                            
                            <div class="relative w-fit">
                                <button onclick="toggleDropdown('term-dropdown')" class="neo-input px-3 py-2 rounded flex items-center gap-3 w-[150px] md:w-48 bg-[#05020a]">
                                    <img id="term-logo" src="https://cryptologos.cc/logos/bitcoin-btc-logo.svg?v=029" class="w-5 h-5 rounded-full bg-[#1e2329] p-0.5">
                                    <span id="term-text" class="font-black text-sm uppercase">BTC/USDT</span>
                                    <svg class="w-4 h-4 ml-auto text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                <div id="term-dropdown" class="absolute top-full left-0 mt-1 w-48 glass-overlay py-1 dropdown-menu dropdown-hidden z-50"></div>
                            </div>

                            <div class="flex flex-wrap bg-[#05020a] p-1 rounded border border-purple-900/30 justify-end max-w-[50%] sm:max-w-full">
                                <div class="tf-btn" onclick="setTimeframe('live')" id="tf-live">LIVE</div>
                                <div class="tf-btn active" onclick="setTimeframe('5m')" id="tf-5m">5m</div>
                                <div class="tf-btn" onclick="setTimeframe('1h')" id="tf-1h">1H</div>
                                <div class="tf-btn" onclick="setTimeframe('7d')" id="tf-7d">7D</div>
                                <div class="tf-btn" onclick="setTimeframe('1y')" id="tf-1y">1Y</div>
                                <div class="tf-btn" onclick="setTimeframe('max')" id="tf-max">MAX</div>
                            </div>
                        </div>

                        <div class="flex flex-wrap justify-between gap-4 sm:gap-6 mt-4 z-10 border-b border-purple-900/20 pb-3 items-end">
                            <div class="flex gap-4 sm:gap-6 shrink-0">
                                <div class="flex flex-col"><span class="text-[9px] text-muted uppercase tracking-widest">High</span><p class="text-xs font-mono text-green-400 font-black" id="stat-high">--</p></div>
                                <div class="flex flex-col"><span class="text-[9px] text-muted uppercase tracking-widest">Low</span><p class="text-xs font-mono text-pink-400 font-black" id="stat-low">--</p></div>
                            </div>
                            <div class="flex-grow flex justify-end items-end pointer-events-none min-w-0">
                                <h2 id="main-price" class="text-4xl sm:text-5xl md:text-6xl font-black text-white font-mono tracking-tighter leading-none truncate text-right max-w-full transition-colors duration-200">--</h2>
                            </div>
                        </div>

                        <div class="flex-grow mt-2 relative w-full h-full min-h-[300px] cursor-crosshair overflow-hidden rounded" id="canvas-container">
                            <canvas id="custom-chart" class="absolute inset-0 w-full h-full"></canvas>
                            <div id="chart-popups-container" class="absolute bottom-2 left-2 flex flex-col-reverse gap-1.5 z-30 pointer-events-none overflow-hidden max-h-[250px]"></div>
                        </div>
                    </div>

                    <div class="glass-panel flex flex-col h-[220px]">
                        <div class="flex justify-between items-center p-3 border-b border-purple-900/30 shrink-0 bg-[#0a0510]/50 rounded-t">
                            <div class="flex gap-4 items-center">
                                <h3 class="text-[10px] font-black uppercase tracking-widest text-purple-400 hidden sm:block">Asset Block Logs</h3>
                                <div class="flex gap-2">
                                    <button onclick="setLogFilter('all')" id="filter-all" class="text-[9px] font-black uppercase bg-purple-600 text-white px-2 py-0.5 rounded transition">All Txs</button>
                                    <button onclick="setLogFilter('whales')" id="filter-whales" class="text-[9px] font-black uppercase text-muted hover:text-white px-2 py-0.5 rounded transition border border-transparent hover:border-purple-900">Whales (>$25k)</button>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 w-32 sm:w-48">
                                <span class="text-[8px] font-black text-green-400 w-6 text-right" id="ratio-buy-text">50%</span>
                                <div class="flex-grow h-1.5 bg-[#05020a] rounded overflow-hidden flex border border-purple-900/30">
                                    <div id="ratio-buy-bar" class="h-full bg-green-500 transition-all duration-300" style="width: 50%"></div>
                                    <div id="ratio-sell-bar" class="h-full bg-pink-500 transition-all duration-300" style="width: 50%"></div>
                                </div>
                                <span class="text-[8px] font-black text-pink-400 w-6" id="ratio-sell-text">50%</span>
                            </div>
                        </div>
                        <div class="flex-grow overflow-y-auto no-scrollbar p-2 flex flex-col gap-1" id="below-chart-log">
                            <div class="text-[9px] text-muted text-center py-4 italic">Awaiting on-chain / DEX block trades...</div>
                        </div>
                    </div>

                    <div class="glass-panel flex flex-col min-h-[25vh]">
                        <div class="flex justify-between items-center p-3 border-b border-purple-900/30 shrink-0">
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-purple-400">Detailed Open Trades</h3>
                        </div>
                        <div class="flex-grow overflow-x-auto no-scrollbar">
                            <table class="w-full text-left border-collapse min-w-[700px]">
                                <thead class="bg-[#0a0510]/50 sticky top-0">
                                    <tr><th class="p-3">Asset</th><th class="p-3">Side/Lev</th><th class="p-3">Entry Price</th><th class="p-3">Mark Price</th><th class="p-3">Margin</th><th class="p-3">Size (USDT)</th><th class="p-3 text-right">ROI / PnL</th><th class="p-3 text-center">Close</th></tr>
                                </thead>
                                <tbody id="orders-body" class="text-[10px] font-bold text-slate-200 font-mono"></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-3 flex flex-col gap-4">
                    <div class="glass-panel p-5 flex flex-col relative z-10">
                        <h3 class="text-[10px] font-black uppercase tracking-widest text-muted mb-4 border-b border-purple-900/30 pb-2">Manual Execution</h3>
                        
                        <div class="flex gap-2 bg-[#05020a] p-1 border border-purple-900/50 rounded mb-5">
                            <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest bg-green-500/20 text-green-400 border border-green-500/50 transition">Long</button>
                            <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 rounded text-[10px] font-black uppercase tracking-widest text-muted hover:text-pink-400 transition">Short</button>
                        </div>

                        <div class="space-y-6">
                            <div>
                                <div class="flex justify-between mb-1.5">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted">Margin (USDT)</label>
                                    <span class="text-[10px] font-black text-purple-400 cursor-pointer hover:text-white transition" onclick="setMax()">MAX</span>
                                </div>
                                <input type="number" id="trade-margin" placeholder="0.00" class="w-full neo-input p-3 rounded text-lg font-black font-mono text-center">
                            </div>

                            <div>
                                <div class="flex justify-between mb-3">
                                    <label class="text-[10px] font-black uppercase tracking-widest text-muted">Leverage</label>
                                    <span class="text-[10px] font-black text-white bg-purple-900/50 px-2 py-0.5 rounded border border-purple-700/50"><span id="lev-val">10</span>x</span>
                                </div>
                                <input type="range" id="trade-lev" min="1" max="100" value="10" class="w-full">
                                <div class="flex justify-between text-[8px] font-black text-muted mt-2 px-1">
                                    <span>1x</span><span>50x</span><span>100x</span>
                                </div>
                            </div>

                            <div class="p-3 bg-[#05020a] border border-purple-900/30 rounded space-y-2 mt-4">
                                <div class="flex justify-between text-[10px] font-black uppercase">
                                    <span class="text-muted">Available</span>
                                    <span class="text-white font-mono" id="ui-avail">0.00</span>
                                </div>
                                <div class="flex justify-between text-[10px] font-black uppercase border-t border-purple-900/30 pt-2">
                                    <span class="text-muted">Position Size</span>
                                    <span class="text-purple-400 font-mono" id="ui-size">0.00</span>
                                </div>
                            </div>
                        </div>

                        <button onclick="executeOrder()" id="btn-execute" class="mt-4 w-full py-4 rounded font-black uppercase tracking-[0.2em] text-[11px] bg-green-500 text-[#05020a] hover:bg-green-400 transition active:scale-95 shadow-[0_0_15px_rgba(52,211,153,0.3)]">
                            Execute Long
                        </button>
                    </div>

                    <div class="glass-panel p-5 flex flex-col flex-grow relative z-10">
                        <div class="flex justify-between items-center mb-3 border-b border-purple-900/30 pb-2">
                            <h3 class="text-[10px] font-black uppercase tracking-widest text-muted">On-Chain Alpha</h3>
                            <select id="alpha-tf-select" onchange="setAlphaTimeframe(this.value)" class="bg-[#05020a] text-purple-400 border border-purple-900/50 rounded px-1.5 py-1 text-[9px] uppercase font-black outline-none cursor-pointer">
                                <option value="300000">5 Mins</option>
                                <option value="900000">15 Mins</option>
                                <option value="3600000">1 Hour</option>
                                <option value="18000000">5 Hours</option>
                                <option value="86400000" selected>24 Hours</option>
                                <option value="604800000">1 Week</option>
                            </select>
                        </div>
                        
                        <div class="mb-4">
                            <h4 class="text-[9px] font-bold uppercase tracking-widest text-green-400 mb-2 border-b border-green-500/20 pb-1 flex justify-between"><span>Top Purchases</span> <span id="lbl-buy-tf">24H</span></h4>
                            <div id="ui-top-buys" class="space-y-1.5">
                                <div class="text-[9px] text-muted text-center italic py-2">Syncing chain...</div>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <h4 class="text-[9px] font-bold uppercase tracking-widest text-pink-400 mb-2 border-b border-pink-500/20 pb-1 flex justify-between"><span>Top Sells</span> <span id="lbl-sell-tf">24H</span></h4>
                            <div id="ui-top-sells" class="space-y-1.5">
                                <div class="text-[9px] text-muted text-center italic py-2">Syncing chain...</div>
                            </div>
                        </div>

                        <div class="mt-auto">
                            <h4 class="text-[9px] font-bold uppercase tracking-widest text-purple-400 mb-2 border-b border-purple-500/20 pb-1">Whale Tracker</h4>
                            <div id="ui-top-holders" class="flex flex-col gap-2"></div>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <div id="app-wallet" class="w-full hidden">
        <main class="flex flex-col p-2 md:p-6 gap-8 w-full max-w-[1200px] mx-auto">
            
            <div class="glass-panel p-6 md:p-8 flex flex-col md:flex-row justify-between items-center md:items-start gap-6 relative overflow-hidden">
                <div class="z-10 flex flex-col items-center md:items-start w-full">
                    <span class="text-purple-400 text-xs font-black uppercase tracking-widest mb-1 border-b border-purple-500/30 pb-1">Total Estimated Balance</span>
                    
                    <div class="flex items-baseline gap-2 mt-2">
                        <span id="wallet-currency-sym" class="text-3xl font-black text-purple-400 opacity-80">$</span>
                        <h2 id="wallet-total-value" class="text-4xl md:text-5xl font-black text-white font-mono tracking-tighter drop-shadow-lg">0.00</h2>
                        
                        <select id="wallet-currency" onchange="setCurrency(this.value)" class="ml-2 bg-[#05020a] border border-purple-900/50 text-white font-black text-sm rounded px-2 py-1 outline-none cursor-pointer">
                            <option value="USD">🇺🇸 USD</option>
                            <option value="AED">🇦🇪 AED</option>
                            <option value="EUR">🇪🇺 EUR</option>
                            <option value="GBP">🇬🇧 GBP</option>
                        </select>
                    </div>

                    <div class="flex gap-3 mt-6 w-full md:w-auto">
                        <button onclick="toggleModal('send-modal')" class="flex-1 md:flex-none px-8 py-3 rounded text-[11px] font-black uppercase tracking-widest bg-purple-600 text-white hover:bg-purple-500 transition shadow-[0_0_15px_rgba(139,92,246,0.4)]">Send / Withdraw</button>
