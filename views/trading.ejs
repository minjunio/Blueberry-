<!DOCTYPE html>
<html lang="en">
<head>
    <title>Pro Terminal - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <style>
        /* Exact Casino Dark Theme */
        body { background: #06090e; color: #f8fafc; font-family: 'Inter', sans-serif; overflow: hidden; height: 100vh; display: flex; flex-direction: column; }
        .casino-panel { background: #0d131f; border: 1px solid #1f2937; box-shadow: 0 10px 30px rgba(0,0,0,0.5); border-radius: 1rem; }
        .casino-input { background: #06090e; border: 1px solid #1f2937; color: white; outline: none; transition: 0.2s; }
        .casino-input:focus { border-color: #00ffaa; box-shadow: 0 0 10px rgba(0,255,170,0.2); }
        .casino-btn { background: #1f2937; border: 1px solid #374151; color: white; transition: 0.2s; cursor: pointer; }
        .casino-btn:hover { background: #374151; }
        .text-muted { color: #6b7280; }
        
        /* Dramatic Market Effects */
        @keyframes flashGreen {
            0% { box-shadow: inset 0 0 80px rgba(0, 255, 170, 0.15), 0 0 20px rgba(0, 255, 170, 0.2); border-color: rgba(0, 255, 170, 0.5); }
            100% { box-shadow: inset 0 0 0 transparent; border-color: #1f2937; }
        }
        @keyframes flashRed {
            0% { box-shadow: inset 0 0 80px rgba(239, 68, 68, 0.15), 0 0 20px rgba(239, 68, 68, 0.2); border-color: rgba(239, 68, 68, 0.5); }
            100% { box-shadow: inset 0 0 0 transparent; border-color: #1f2937; }
        }
        .anim-pump { animation: flashGreen 0.6s ease-out; }
        .anim-dump { animation: flashRed 0.6s ease-out; }

        .text-pump { color: #00ffaa !important; text-shadow: 0 0 20px rgba(0,255,170,0.6); }
        .text-dump { color: #ef4444 !important; text-shadow: 0 0 20px rgba(239,68,68,0.6); }

        /* Custom UI Tools */
        .no-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
        .no-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .no-scrollbar::-webkit-scrollbar-thumb { background: #1f2937; border-radius: 4px; }
        input[type=number]::-webkit-inner-spin-button { -webkit-appearance: none; }
        
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 18px; width: 18px; border-radius: 50%; background: #00ffaa; cursor: pointer; box-shadow: 0 0 10px #00ffaa; margin-top: -7px; transition: background 0.2s; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 4px; background: #374151; border-radius: 2px; }

        /* Off-Canvas Portfolio Drawer */
        #portfolio-modal { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s; }
        .modal-hidden { transform: translateX(100%); opacity: 0; pointer-events: none; }
        .modal-active { transform: translateX(0); opacity: 1; pointer-events: auto; }
    </style>
</head>
<body>

    <header class="flex justify-between items-center p-3 md:p-4 bg-[#0d131f] border-b border-[#1f2937] shrink-0 z-50">
        <div class="flex items-center gap-3">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 22C17.5228 22 22 17.5228 22 12C22 5 12 2 12 2C12 2 2 5 2 12C2 17.5228 6.47715 22 12 22Z" fill="#00ffaa"/><path d="M12 16C13.6569 16 15 14.6569 15 13C15 11.3431 12 8 12 8C12 8 9 11.3431 9 13C9 14.6569 10.3431 16 12 16Z" fill="#06090e"/></svg>
            <h2 class="text-lg md:text-xl font-black uppercase tracking-tighter text-white">Pro Terminal</h2>
        </div>
        
        <div class="flex items-center gap-2">
            <a href="/admin" class="casino-btn px-3 md:px-4 py-2 rounded-lg font-black text-[10px] uppercase tracking-widest transition hover:text-[#00ffaa] hidden sm:block">Exit Node</a>
            <button onclick="togglePortfolio()" class="bg-[#1f2937] border border-[#374151] hover:border-[#00ffaa] text-white px-4 py-2 rounded-lg font-black text-[10px] uppercase tracking-widest transition flex items-center gap-2">
                <svg class="w-4 h-4 text-[#00ffaa]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                Portfolio
            </button>
        </div>
    </header>

    <main class="flex-grow flex flex-col lg:flex-row p-2 md:p-4 gap-4 overflow-hidden relative">
        
        <div class="flex-grow flex flex-col gap-4 overflow-hidden">
            
            <div id="chart-wrap" class="casino-panel flex-grow relative flex flex-col min-h-[40vh] transition-all duration-300 overflow-hidden">
                <div class="absolute top-4 left-4 z-10 flex flex-col pointer-events-none">
                    <select id="symbol-select" onchange="initFeeds()" class="casino-input px-3 py-1.5 rounded-lg text-lg font-black uppercase cursor-pointer appearance-none pointer-events-auto w-fit shadow-lg bg-[#0d131f]/90 border border-[#1f2937]">
                        <option value="BTCUSDT">BTC / USDT</option>
                        <option value="ETHUSDT">ETH / USDT</option>
                        <option value="SOLUSDT">SOL / USDT</option>
                        <option value="DOGEUSDT">DOGE / USDT</option>
                        <option value="XRPUSDT">XRP / USDT</option>
                    </select>
                    <h2 id="live-price" class="text-4xl md:text-5xl font-black text-white mt-1 transition-colors duration-200 tracking-tight font-mono">Initializing...</h2>
                </div>
                <div id="tvchart" class="w-full h-full mt-24"></div>
            </div>

            <div class="casino-panel h-[35vh] flex flex-col shrink-0">
                <div class="flex justify-between items-center p-3 md:p-4 border-b border-[#1f2937] bg-[#06090e]/50 shrink-0">
                    <h3 class="text-[10px] font-black uppercase tracking-widest text-[#00ffaa]">Active Positions</h3>
                    <span id="feed-status" class="text-[10px] font-bold text-[#00ffaa] bg-[#1f2937] px-2 py-1 rounded">Engine Online</span>
                </div>
                <div class="flex-grow overflow-auto no-scrollbar">
                    <table class="w-full text-left border-collapse min-w-[650px]">
                        <thead class="sticky top-0 bg-[#0d131f] shadow-sm z-10">
                            <tr class="text-[9px] font-black uppercase tracking-widest text-muted border-b border-[#1f2937]">
                                <th class="p-3">Asset</th>
                                <th class="p-3">Side</th>
                                <th class="p-3">Lev</th>
                                <th class="p-3">Margin</th>
                                <th class="p-3">Entry</th>
                                <th class="p-3 text-right">Live ROI</th>
                                <th class="p-3 text-center">Execute</th>
                            </tr>
                        </thead>
                        <tbody id="orders-body" class="text-xs font-bold text-slate-300 font-mono">
                            </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="casino-panel lg:w-[320px] xl:w-[360px] shrink-0 p-4 md:p-6 flex flex-col overflow-y-auto no-scrollbar">
            <h3 class="text-[10px] font-black uppercase tracking-widest text-muted mb-4 border-b border-[#1f2937] pb-2">Order Setup</h3>
            
            <div class="flex gap-2 bg-[#06090e] p-1 border border-[#1f2937] rounded-xl mb-6 shrink-0">
                <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest bg-[#00ffaa] text-[#06090e] shadow-[0_0_10px_rgba(0,255,170,0.3)] transition">Long</button>
                <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-red-500 transition">Short</button>
            </div>

            <div class="space-y-6 flex-grow">
                <div>
                    <div class="flex justify-between mb-2">
                        <label class="text-[10px] font-black uppercase tracking-widest text-muted">Margin (USDT)</label>
                        <span class="text-[10px] font-black text-[#00ffaa] cursor-pointer hover:underline" onclick="setMax()">MAX</span>
                    </div>
                    <input type="number" id="trade-margin" placeholder="0.00" class="w-full casino-input p-4 rounded-xl text-xl font-black font-mono">
                </div>

                <div>
                    <div class="flex justify-between mb-3">
                        <label class="text-[10px] font-black uppercase tracking-widest text-muted">Leverage</label>
                        <span class="text-[10px] font-black text-white bg-[#1f2937] px-2 py-0.5 rounded"><span id="lev-val">10</span>x</span>
                    </div>
                    <input type="range" id="trade-lev" min="1" max="100" value="10" class="w-full">
                    <div class="flex justify-between text-[9px] font-black text-muted mt-2">
                        <span>1x</span><span>50x</span><span>100x</span>
                    </div>
                </div>

                <div class="p-4 bg-[#06090e] border border-[#1f2937] rounded-xl space-y-3">
                    <div class="flex justify-between text-[10px] font-black uppercase tracking-widest">
                        <span class="text-muted">Available</span>
                        <span class="text-white font-mono">$<span id="ui-avail">88000.00</span></span>
                    </div>
                    <div class="flex justify-between text-[10px] font-black uppercase tracking-widest border-t border-[#1f2937] pt-2">
                        <span class="text-muted">Est. Size</span>
                        <span class="text-[#00ffaa] font-mono">$<span id="ui-size">0.00</span></span>
                    </div>
                </div>
            </div>

            <button onclick="executeOrder()" id="btn-execute" class="mt-6 w-full py-5 rounded-xl font-black uppercase tracking-[0.2em] text-xs bg-[#00ffaa] text-[#06090e] hover:bg-[#00d68f] shadow-[0_0_20px_rgba(0,255,170,0.3)] transition active:scale-95 shrink-0">
                Execute Long
            </button>
        </div>
    </main>

    <div id="portfolio-modal" class="fixed inset-y-0 right-0 w-full md:w-[450px] bg-[#0d131f] border-l border-[#1f2937] shadow-[-20px_0_50px_rgba(0,0,0,0.8)] z-[100] modal-hidden flex flex-col">
        <div class="flex justify-between items-center p-6 border-b border-[#1f2937] bg-[#06090e]">
            <h2 class="text-xl font-black uppercase tracking-widest text-white flex items-center gap-2">
                <svg class="w-5 h-5 text-[#00ffaa]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                My Portfolio
            </h2>
            <button onclick="togglePortfolio()" class="text-muted hover:text-[#00ffaa] transition">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        
        <div class="p-6 flex-grow overflow-y-auto no-scrollbar">
            <div class="bg-[#06090e] border border-[#1f2937] p-6 rounded-2xl mb-8 relative overflow-hidden">
                <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-[#00ffaa]/10 rounded-full blur-[50px]"></div>
                <p class="text-[10px] font-black text-[#00ffaa] uppercase tracking-widest mb-1">Total Net Equity</p>
                <h2 class="text-4xl font-black tracking-tight text-white mb-2 font-mono" id="wallet-total">$88,000.00</h2>
                <p class="text-xs font-bold text-muted font-mono" id="wallet-pnl">Live ROI: $0.00</p>
            </div>

            <h3 class="text-[10px] font-black uppercase tracking-widest text-muted mb-4 border-b border-[#1f2937] pb-2">Spot Assets</h3>
            
            <div class="space-y-3">
                <div class="bg-[#06090e] border border-[#1f2937] p-4 rounded-xl flex justify-between items-center hover:border-[#00ffaa]/50 transition cursor-pointer">
                    <div class="flex items-center gap-3">
                        <img src="https://cryptologos.cc/logos/tether-usdt-logo.svg?v=029" class="w-8 h-8 rounded-full">
                        <div>
                            <p class="text-[10px] font-black uppercase tracking-widest text-white">Tether (USD)</p>
                            <p class="text-[10px] font-bold text-[#00ffaa]">Available Margin</p>
                        </div>
                    </div>
                    <h4 class="text-lg font-black text-white font-mono" id="wallet-usdt-display">88,000.00</h4>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- 1. STATE & GLOBAL PRICING ---
        let state = JSON.parse(localStorage.getItem('terminal_state_v3')) || {
            balance: 88000.00,
            orders: []
        };
        
        // Base starting prices for the simulation fallback
        const basePrices = { 'BTCUSDT': 65000, 'ETHUSDT': 3400, 'SOLUSDT': 150, 'DOGEUSDT': 0.15, 'XRPUSDT': 0.60 };
        window.livePrices = { ...basePrices }; // Track all prices globally
        
        let ui = { side: 'buy', symbol: 'BTCUSDT', price: 65000, lastPrice: 0, lev: 10 };
        let simLoop = null; // Variable to hold the fallback loop

        function saveState() {
            localStorage.setItem('terminal_state_v3', JSON.stringify(state));
            updateWalletUI();
        }

        function togglePortfolio() {
            const modal = document.getElementById('portfolio-modal');
            if (modal.classList.contains('modal-hidden')) {
                modal.classList.replace('modal-hidden', 'modal-active');
            } else {
                modal.classList.replace('modal-active', 'modal-hidden');
            }
        }

        // --- 2. BULLETPROOF CHARTING SETUP ---
        const chartElement = document.getElementById('tvchart');
        const chart = LightweightCharts.createChart(chartElement, {
            layout: { background: { type: 'solid', color: 'transparent' }, textColor: '#6b7280' },
            grid: { vertLines: { color: 'rgba(31, 41, 55, 0.4)' }, horzLines: { color: 'rgba(31, 41, 55, 0.4)' } },
            crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
            rightPriceScale: { borderColor: '#1f2937' },
            timeScale: { borderColor: '#1f2937', timeVisible: true }
        });

        const areaSeries = chart.addAreaSeries({
            lineColor: '#00ffaa', topColor: 'rgba(0, 255, 170, 0.3)', bottomColor: 'rgba(0, 255, 170, 0.0)',
            lineWidth: 2, crosshairMarkerBorderColor: '#06090e', crosshairMarkerBackgroundColor: '#00ffaa'
        });

        new ResizeObserver(entries => {
            if (entries.length === 0 || entries[0].target !== chartElement) return;
            chart.applyOptions({ width: entries[0].contentRect.width, height: entries[0].contentRect.height });
        }).observe(chartElement);

        // --- 3. THE INDESTRUCTIBLE FEED ENGINE ---
        let ws;
        async function initFeeds() {
            ui.symbol = document.getElementById('symbol-select').value;
            ui.price = window.livePrices[ui.symbol] || basePrices[ui.symbol];
            
            const priceEl = document.getElementById('live-price');
            priceEl.innerText = `$${ui.price.toFixed(2)}`;
            
            // 1. Instantly Generate Fake History (Guarantees chart is never empty)
            let history = [];
            let currentTime = Math.floor(Date.now() / 1000);
            let p = ui.price * 0.98; // Start history slightly lower
            for(let i=100; i>=0; i--) {
                p += (Math.random() - 0.45) * (ui.price * 0.002); // Random walk
                history.push({ time: currentTime - (i*60), value: p });
            }
            areaSeries.setData(history);
            ui.price = p; 
            ui.lastPrice = p;

            // 2. Try Fetching Real Price (Graceful Failure)
            try {
                let res = await fetch(`https://api.binance.com/api/v3/ticker/price?symbol=${ui.symbol}`);
                let data = await res.json();
                ui.price = parseFloat(data.price);
                window.livePrices[ui.symbol] = ui.price;
                processTick(ui.price); // Align UI to reality
            } catch(e) {
                console.log("REST Blocked. Falling back to simulation start.");
            }

            // 3. Connect WebSockets
            if(ws) ws.close();
            if(simLoop) clearInterval(simLoop);

            try {
                ws = new WebSocket(`wss://stream.binance.com:9443/ws/${ui.symbol.toLowerCase()}@ticker`);
                
                ws.onopen = () => {
                    document.getElementById('feed-status').innerText = "Live WS Engine";
                    document.getElementById('feed-status').className = "text-[10px] font-bold text-[#00ffaa] bg-[#1f2937] px-2 py-1 rounded";
                };

                ws.onmessage = (e) => {
                    let data = JSON.parse(e.data);
                    processTick(parseFloat(data.c));
                };

                ws.onerror = () => startSimulation();
                ws.onclose = () => startSimulation();
            } catch (err) {
                startSimulation();
            }
        }

        // 4. Fallback Simulation (If Firewalls block WS)
        function startSimulation() {
            if(simLoop) return; // Already running
            document.getElementById('feed-status').innerText = "Local Simulation";
            document.getElementById('feed-status').className = "text-[10px] font-bold text-yellow-500 bg-[#1f2937] px-2 py-1 rounded";
            
            simLoop = setInterval(() => {
                // Fluctuate price by a tiny random percentage
                let change = (Math.random() - 0.5) * (ui.price * 0.001); 
                processTick(ui.price + change);
                
                // Simulate other assets in background for portfolio ROIs
                for (let sym in window.livePrices) {
                    if(sym !== ui.symbol) {
                        let c = (Math.random() - 0.5) * (window.livePrices[sym] * 0.001);
                        window.livePrices[sym] += c;
                    }
                }
            }, 1500); // Tick every 1.5s
        }

        // Central Tick Processor (Handles UI flashes, chart updates, and ROI)
        function processTick(newPrice) {
            const priceEl = document.getElementById('live-price');
            const wrapEl = document.getElementById('chart-wrap');
            
            window.livePrices[ui.symbol] = newPrice; // Update global state
            
            if (ui.lastPrice !== 0 && newPrice !== ui.lastPrice) {
                wrapEl.classList.remove('anim-pump', 'anim-dump');
                priceEl.classList.remove('text-pump', 'text-dump');
                void wrapEl.offsetWidth; // Force Reflow
                
                const isUp = newPrice > ui.lastPrice;
                wrapEl.classList.add(isUp ? 'anim-pump' : 'anim-dump');
                priceEl.classList.add(isUp ? 'text-pump' : 'text-dump');
                
                areaSeries.applyOptions({ 
                    lineColor: isUp ? '#00ffaa' : '#ef4444',
                    topColor: isUp ? 'rgba(0, 255, 170, 0.3)' : 'rgba(239, 68, 68, 0.3)'
                });
            }
            
            ui.lastPrice = newPrice;
            ui.price = newPrice;
            
            const dec = newPrice < 1 ? 4 : 2;
            priceEl.innerText = `$${newPrice.toLocaleString(undefined, {minimumFractionDigits: dec})}`;
            
            areaSeries.update({ time: Math.floor(Date.now() / 1000), value: newPrice });
            
            renderOrders(); // Re-calculate ROIs
        }

        // --- 5. EXECUTION PANEL LOGIC ---
        function setSide(side) {
            ui.side = side;
            const bBuy = document.getElementById('btn-buy');
            const bSell = document.getElementById('btn-sell');
            const bExec = document.getElementById('btn-execute');

            if(side === 'buy') {
                bBuy.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest bg-[#00ffaa] text-[#06090e] shadow-[0_0_10px_rgba(0,255,170,0.3)] transition";
                bSell.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-red-500 transition";
                bExec.className = "mt-6 w-full py-5 rounded-xl font-black uppercase tracking-[0.2em] text-xs bg-[#00ffaa] text-[#06090e] hover:bg-[#00d68f] shadow-[0_0_20px_rgba(0,255,170,0.3)] transition active:scale-95 shrink-0";
                bExec.innerText = "Execute Long";
            } else {
                bSell.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest bg-red-500 text-white shadow-[0_0_10px_rgba(239,68,68,0.3)] transition";
                bBuy.className = "flex-1 py-3 rounded-lg text-[10px] font-black uppercase tracking-widest text-muted hover:text-[#00ffaa] transition";
                bExec.className = "mt-6 w-full py-5 rounded-xl font-black uppercase tracking-[0.2em] text-xs bg-red-500 text-white hover:bg-red-400 shadow-[0_0_20px_rgba(239,68,68,0.3)] transition active:scale-95 shrink-0";
                bExec.innerText = "Execute Short";
            }
        }

        document.getElementById('trade-lev').addEventListener('input', (e) => {
            ui.lev = parseInt(e.target.value);
            document.getElementById('lev-val').innerText = ui.lev;
            calcSize();
        });

        const marginInput = document.getElementById('trade-margin');
        marginInput.addEventListener('input', calcSize);

        function calcSize() {
            const margin = parseFloat(marginInput.value) || 0;
            document.getElementById('ui-size').innerText = (margin * ui.lev).toLocaleString(undefined, {minimumFractionDigits: 2});
        }

        function setMax() {
            marginInput.value = Math.floor(state.balance * 100) / 100;
            calcSize();
        }

        function executeOrder() {
            const margin = parseFloat(marginInput.value);
            if (isNaN(margin) || margin <= 0) return alert("Enter valid margin.");
            if (margin > state.balance) return alert("Insufficient USDT.");

            state.balance -= margin;
            const totalSize = margin * ui.lev;
            
            state.orders.push({
                id: Math.random().toString(36).substr(2, 9),
                symbol: ui.symbol,
                side: ui.side,
                margin: margin,
                lev: ui.lev,
                entry: ui.price,
                units: totalSize / ui.price
            });

            marginInput.value = '';
            calcSize();
            saveState();
            renderOrders();
        }

        // --- 6. ROI & RENDERING ---
        function renderOrders() {
            const tbody = document.getElementById('orders-body');
            let totalUnrealized = 0;
            
            if (state.orders.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="p-6 text-center text-muted font-black uppercase tracking-widest text-xs">No Active Positions</td></tr>`;
                document.getElementById('wallet-pnl').innerText = `Live ROI: $0.00`;
                document.getElementById('wallet-pnl').className = `text-xs font-bold text-muted font-mono`;
                return;
            }

            let html = '';
            state.orders.forEach(order => {
                // Pull from the livePrices dictionary so background assets update too!
                const currentVal = order.units * (window.livePrices[order.symbol] || order.entry);
                const initialVal = order.margin * order.lev;
                
                const pnl = order.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
                totalUnrealized += pnl;

                const roiPct = (pnl / order.margin) * 100;
                const isProf = pnl >= 0;
                const cColor = isProf ? 'text-[#00ffaa]' : 'text-red-500';
                const sColor = order.side === 'buy' ? 'text-[#00ffaa] bg-[#00ffaa]/10' : 'text-red-500 bg-red-500/10';
                
                html += `
                    <tr class="border-b border-[#1f2937]/50 hover:bg-[#1f2937]/30 transition group">
                        <td class="p-3 font-black text-white">${order.symbol}</td>
                        <td class="p-3"><span class="px-2 py-1 rounded text-[9px] font-black uppercase tracking-widest ${sColor}">${order.side}</span></td>
                        <td class="p-3">${order.lev}x</td>
                        <td class="p-3">$${order.margin.toFixed(2)}</td>
                        <td class="p-3">$${order.entry.toFixed(4)}</td>
                        <td class="p-3 text-right ${cColor} font-black">${isProf?'+':''}$${pnl.toFixed(2)} (${isProf?'+':''}${roiPct.toFixed(2)}%)</td>
                        <td class="p-3 text-center">
                            <button onclick="closeOrder('${order.id}')" class="px-3 py-2 bg-[#1f2937] hover:bg-white hover:text-black text-white rounded text-[9px] uppercase font-black transition md:opacity-0 group-hover:opacity-100">Close</button>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;

            // Portfolio Panel Update
            const pnlColor = totalUnrealized >= 0 ? 'text-[#00ffaa]' : 'text-red-500';
            document.getElementById('wallet-pnl').innerText = `Live ROI: ${totalUnrealized >= 0 ? '+' : ''}$${totalUnrealized.toFixed(2)}`;
            document.getElementById('wallet-pnl').className = `text-xs font-bold font-mono mt-1 ${pnlColor}`;
        }

        function closeOrder(id) {
            const idx = state.orders.findIndex(p => p.id === id);
            if (idx === -1) return;
            
            const o = state.orders[idx];
            const currentVal = o.units * (window.livePrices[o.symbol] || o.entry);
            const initialVal = o.margin * o.lev;
            const pnl = o.side === 'buy' ? (currentVal - initialVal) : (initialVal - currentVal);
            
            state.balance += (o.margin + pnl);
            state.orders.splice(idx, 1);
            
            saveState();
            renderOrders();
        }

        function updateWalletUI() {
            const bal = state.balance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('ui-avail').innerText = bal;
            document.getElementById('wallet-total').innerText = `$${bal}`;
            document.getElementById('wallet-usdt-display').innerText = bal;
        }

        // Boot
        initFeeds();
        updateWalletUI();
        renderOrders();
    </script>
</body>
</html>
