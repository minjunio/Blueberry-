        function openStakeModal(coin, apr) {
            document.getElementById('stake-modal-asset').innerText = coin;
            document.getElementById('stake-modal-apr').innerText = apr + '%';
            
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin] || 0);
            let aEl = document.getElementById('stake-modal-avail');
            aEl.innerText = avail.toFixed(4);
            aEl.dataset.val = avail;
            document.getElementById('stake-amount').value = '';
            
            document.getElementById('stake-amount').dataset.coin = coin;
            document.getElementById('stake-amount').dataset.apr = apr;

            toggleModal('stake-modal');
        }

        function confirmStake() {
            const el = document.getElementById('stake-amount');
            const amt = parseFloat(el.value);
            const coin = el.dataset.coin;
            const apr = parseFloat(el.dataset.apr);
            
            let avail = coin === 'USDT' ? state.usdtBalance : (state.manualAssets[coin] || 0);
            if(isNaN(amt) || amt <= 0 || amt > avail) return alert("Invalid amount.");

            if(coin === 'USDT') state.usdtBalance -= amt;
            else state.manualAssets[coin] -= amt;

            state.stakes.push({ coin, amt, apr, time: Date.now() });
            saveState(); toggleModal('stake-modal'); updateWalletApp();
        }

        function prepSwapModal() {
            buildDynamicDropdowns();
            document.getElementById('swap-asset-from').value = 'USDT';
            document.getElementById('swap-from-selected').innerText = 'USDT';
            document.getElementById('swap-asset-to').value = 'BTC';
            document.getElementById('swap-to-selected').innerText = 'BTC';
            
            // Reset Animation Container
            document.getElementById('swap-form').classList.remove('hidden');
            document.getElementById('swap-processing').classList.add('hidden');
            document.getElementById('swap-close-btn').classList.remove('hidden');
            document.getElementById('swap-amt-from').value = '';
            document.getElementById('swap-amt-to').value = '';
            document.getElementById('swap-rate-text').innerText = '1 -- = -- --';

            updateSwapBals(); 
        }

        function updateSwapBals() {
            let from = document.getElementById('swap-asset-from').value;
            let to = document.getElementById('swap-asset-to').value;
            document.getElementById('swap-bal-from').innerText = `Bal: ${(from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0)).toFixed(4)}`;
            document.getElementById('swap-bal-to').innerText = `Bal: ${(to === 'USDT' ? state.usdtBalance : (state.manualAssets[to]||0)).toFixed(4)}`;
        }

        function calcSwap() {
            let from = document.getElementById('swap-asset-from').value;
            let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            
            if(from === to) { document.getElementById('swap-amt-to').value = amt; document.getElementById('swap-rate-text').innerText = `1 ${from} = 1 ${to}`; return; }
            
            let priceFromUsd = from === 'USDT' ? 1 : (livePrices[from+'USDT'] || 1);
            let priceToUsd = to === 'USDT' ? 1 : (livePrices[to+'USDT'] || 1);
            
            let toAmt = (amt * priceFromUsd) / priceToUsd;
            document.getElementById('swap-amt-to').value = toAmt.toFixed(6);
            document.getElementById('swap-rate-text').innerText = `1 ${from} ≈ ${(priceFromUsd/priceToUsd).toFixed(6)} ${to}`;
        }

        function executeSwap() {
            let from = document.getElementById('swap-asset-from').value;
            let to = document.getElementById('swap-asset-to').value;
            let amt = parseFloat(document.getElementById('swap-amt-from').value) || 0;
            let toAmt = parseFloat(document.getElementById('swap-amt-to').value) || 0;

            if(amt <= 0) return;
            let avail = from === 'USDT' ? state.usdtBalance : (state.manualAssets[from]||0);
            if(amt > avail) return alert("Insufficient balance.");

            // Start Animation
            document.getElementById('swap-form').classList.add('hidden');
            document.getElementById('swap-close-btn').classList.add('hidden');
            const proc = document.getElementById('swap-processing');
            proc.classList.remove('hidden');
            
            // Spinning State
            proc.innerHTML = `
                <div class="spinner w-12 h-12 mb-6"></div>
                <p class="text-[#F3BA2F] font-black uppercase tracking-widest text-sm">Processing Route...</p>
                <p class="text-gray-500 font-mono text-[10px] mt-2">DEX Aggregation</p>
            `;

            setTimeout(() => {
                // Success State with Checkmark
                proc.innerHTML = `
                    <svg class="checkmark mb-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
                        <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
                        <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
                    </svg>
                    <p class="text-[#0ecb81] font-black uppercase tracking-widest text-sm">Swap Successful!</p>
                    <p class="text-white font-mono text-xs mt-2">+${toAmt.toFixed(4)} ${to}</p>
                `;
                
                // Process Math
                if(from === 'USDT') state.usdtBalance -= amt; else state.manualAssets[from] -= amt;
                if(to === 'USDT') state.usdtBalance += toAmt; else {
                    if(!state.manualAssets[to]) state.manualAssets[to] = 0;
                    state.manualAssets[to] += toAmt;
                }
                saveState(); updateWalletApp();

                setTimeout(() => {
                    toggleModal('swap-modal');
                }, 2500);
            }, 1800);
        }

