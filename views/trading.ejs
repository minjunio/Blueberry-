        function generateBackgroundData(symbol, currentPrice, timeGap) {
            let numTrades = Math.min(Math.floor(timeGap / 60000) * 10, 300); let now = Date.now();
            for(let i=0; i<numTrades; i++) {
                let isBuy = Math.random() > 0.5; let usdVal = Math.random() * 30000 + 1000; if(Math.random() > 0.95) usdVal += Math.random() * 200000; 
                let qty = usdVal / currentPrice; let time = now - (Math.random() * timeGap);
                state.globalTradeLogs.push({ addr: '0x' + Math.random().toString(16).substring(2, 8).toUpperCase(), isBuy, qty, price: currentPrice, usdVal, pair: symbol, time });
            }
            state.globalTradeLogs.sort((a,b) => b.time - a.time); if(state.globalTradeLogs.length > 1500) state.globalTradeLogs = state.globalTradeLogs.slice(0, 1500);
            saveState(); renderGlobalLogs(); renderOnChainAlpha();
        }

        function saveAILogic() {
            state.aiLogic = document.getElementById('ai-logic-editor').value; saveState(); toggleModal('ai-code-modal'); calcAIEngine();
        }

        function calcAIEngine() {
            if(ui.chartData.length < 21) return; 
            let gains = 0, losses = 0; const rsiData = ui.chartData.slice(-15);
            for(let i=1; i<rsiData.length; i++) { let diff = rsiData[i].price - rsiData[i-1].price; if(diff >= 0) gains += diff; else losses -= diff; }
            let rs = (gains/14) / ((losses/14) || 1); let rsi = 100 - (100 / (1 + rs));
            const smaData = ui.chartData.slice(-20); let sma = smaData.reduce((acc, val) => acc + val.price, 0) / 20;
            const prices = smaData.map(d => d.price); let vol = Math.max(...prices) - Math.min(...prices);

            document.getElementById('ai-rsi').innerText = rsi.toFixed(1);
            document.getElementById('ai-sma').innerText = sma.toFixed(2);
            document.getElementById('ai-vol').innerText = vol.toFixed(2);
            
            const predEl = document.getElementById('ai-signal');
            try {
                let fn = new Function('rsi', 'sma', 'volatility', 'prices', state.aiLogic); let res = fn(rsi, sma, vol, prices);
                if(res.includes('SELL') || res.includes('BEAR')) { predEl.innerText = res; predEl.className = "text-[10px] font-black uppercase px-3 py-1 rounded-md bg-pink-900/30 text-pink-400 border border-pink-500/20 shadow-inner"; }
                else if(res.includes('BUY') || res.includes('BULL')) { predEl.innerText = res; predEl.className = "text-[10px] font-black uppercase px-3 py-1 rounded-md bg-green-900/30 text-green-400 border border-green-500/20 shadow-inner"; }
                else { predEl.innerText = res || "NEUTRAL"; predEl.className = "text-[10px] font-black uppercase px-3 py-1 rounded-md bg-[#F3BA2F]/20 text-[#F3BA2F] border border-[#F3BA2F]/30 shadow-inner"; }
            } catch(e) { predEl.innerText = "SYNTAX ERR"; predEl.className = "text-[10px] font-black uppercase px-3 py-1 rounded-md bg-red-900/30 text-red-400"; }
        }

