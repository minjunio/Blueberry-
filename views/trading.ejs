        // --- EXECUTION LOGIC ---
        function setSide(side) {
            ui.side = side; 
            document.getElementById('btn-buy').className = side==='buy' ? "flex-1 py-3 text-[11px] font-black uppercase tracking-widest bg-green-500 text-black border-2 border-black transform translate-y-1" : "flex-1 py-3 text-[11px] font-black uppercase tracking-widest bg-[#1e2329] text-white border-2 border-[#2b3139]";
            document.getElementById('btn-sell').className = side==='sell' ? "flex-1 py-3 text-[11px] font-black uppercase tracking-widest bg-pink-500 text-black border-2 border-black transform translate-y-1" : "flex-1 py-3 text-[11px] font-black uppercase tracking-widest bg-[#1e2329] text-white border-2 border-[#2b3139]";
            const exec = document.getElementById('btn-execute'); exec.innerText = side==='buy'?"EXECUTE LONG":"EXECUTE SHORT"; exec.className = side==='buy'?"mt-4 w-full py-4 font-black uppercase tracking-[0.1em] text-[13px] bg-green-500 text-black border-2 border-black hover:bg-green-400 transition" : "mt-4 w-full py-4 font-black uppercase tracking-[0.1em] text-[13px] bg-pink-500 text-black border-2 border-black hover:bg-pink-400 transition";
        }

        document.getElementById('trade-lev').addEventListener('input', (e) => { ui.lev = parseInt(e.target.value); document.getElementById('lev-val').innerText = ui.lev; calcSize(); }); document.getElementById('trade-margin').addEventListener('input', calcSize);
        function calcSize() { const m = parseFloat(document.getElementById('trade-margin').value) || 0; document.getElementById('ui-size').innerText = (m * ui.lev).toLocaleString(undefined, {minimumFractionDigits: 2}) + ' USDT'; }
        function setMax() { document.getElementById('trade-margin').value = Math.floor(w().usdtBalance * 100) / 100; calcSize(); }

        function executeOrder() {
            const m = parseFloat(document.getElementById('trade-margin').value); if (isNaN(m) || m <= 0) return; if (m > w().usdtBalance) return alert("Insufficient USDT in active wallet");
            w().usdtBalance -= m; w().orders.push({ id: Math.random().toString(36).substr(2, 9), pair: ui.pair, side: ui.side, margin: m, lev: ui.lev, entry: ui.price, units: (m * ui.lev) / ui.price, time: Date.now() });
            document.getElementById('trade-margin').value = ''; calcSize(); saveState(); renderOrders(); drawChart(); updateWalletSystem();
        }

        function renderOrders() {
            const container = document.getElementById('orders-body');
            
            // Combine manual trades and API paper trades for display
            let combinedTrades = [...w().orders];
            appState.aiStats.activePaper.forEach(pt => combinedTrades.push({...pt, isAPI: true}));

            if (combinedTrades.length === 0) { container.innerHTML = `<div class="p-6 text-center text-white font-black uppercase text-xs border-4 border-[#2b3139] border-dashed">NO LIVE TRADES</div>`; return; }
            
            let html = '';
            combinedTrades.forEach(o => {
                let livePrice = livePrices[o.pair] || o.entry; let pnl = o.side === 'buy' ? ((o.units || ((o.margin*o.lev)/o.entry)) * livePrice) - (o.margin * o.lev) : ((o.margin * o.lev) - ((o.units || ((o.margin*o.lev)/o.entry)) * livePrice));
                let roi = (pnl / o.margin) * 100; const isProf = pnl >= 0; const coin = o.pair.replace('USDT', '');
                
                let badge = o.isAPI ? `<span class="bg-[#F3BA2F] text-black px-1 text-[8px] border border-black">${o.type}</span>` : `<span class="bg-white text-black px-1 text-[8px] border border-black">MANUAL</span>`;
                let closeBtn = o.isAPI ? `` : `<button onclick="closeOrder('${o.id}')" class="px-3 py-2 bg-red-500 text-black border-2 border-black text-[9px] uppercase font-black hover:bg-red-400">CLOSE</button>`;

                html += `<div class="bold-box p-3 flex flex-col md:flex-row gap-3 items-center justify-between"><div class="flex items-center justify-between w-full md:w-auto min-w-[150px] gap-3"><div class="flex flex-col gap-1">${badge}<div class="flex items-center gap-2">${getIconImg(coin, 'w-6 h-6')}<span class="text-white font-black uppercase text-xs">${o.pair}</span></div></div><span class="px-2 py-1 ${o.side==='buy'?'bg-green-500':'bg-pink-500'} text-black border-2 border-black uppercase text-[10px] font-black">${o.lev}x ${o.side}</span></div><div class="grid grid-cols-2 sm:grid-cols-4 gap-4 w-full text-[10px] md:flex-1 md:justify-around"><div class="flex flex-col"><span class="text-[#848E9C] font-black uppercase">Entry</span><span class="text-white font-mono font-bold">$${o.entry.toFixed(4)}</span></div><div class="flex flex-col"><span class="text-[#848E9C] font-black uppercase">Mark Price</span><span class="text-[#F3BA2F] font-mono font-bold">$${livePrice.toFixed(4)}</span></div><div class="flex flex-col"><span class="text-[#848E9C] font-black uppercase">Margin</span><span class="text-white font-mono font-bold">$${o.margin.toFixed(2)}</span></div><div class="flex flex-col"><span class="text-[#848E9C] font-black uppercase">Total Size</span><span class="text-white font-mono font-bold">$${(o.margin * o.lev).toFixed(2)}</span></div></div><div class="flex items-center justify-between w-full md:w-auto gap-4 border-t-2 md:border-t-0 border-[#363c4e] pt-3 md:pt-0"><div class="flex flex-col text-right"><span class="text-[#848E9C] text-[9px] font-black uppercase">PnL / ROI</span><span class="${isProf?'text-green-400':'text-pink-500'} font-black font-mono text-[11px] bg-[#0b0e11] px-2 py-1 border border-[#363c4e]">${isProf?'+':''}${roi.toFixed(2)}% | ${isProf?'+':''}$${pnl.toFixed(2)}</span></div>${closeBtn}</div></div>`;
            });
            container.innerHTML = html;
        }

        function closeOrder(id) {
            const idx = w().orders.findIndex(p => p.id === id); if(idx===-1) return; const o = w().orders[idx];
            let pnl = o.side === 'buy' ? ((o.units * (livePrices[o.pair]||o.entry)) - (o.margin * o.lev)) : ((o.margin * o.lev) - (o.units * (livePrices[o.pair]||o.entry)));
            w().usdtBalance += (o.margin + pnl); w().history.unshift({ pair: o.pair, pnl: pnl, isAI: false }); if(w().history.length > 50) w().history.pop();
            w().orders.splice(idx, 1); saveState(); renderOrders(); renderHistory(); drawChart(); updateWalletSystem();
        }

        function renderHistory() {
            const container = document.getElementById('history-body'); let html = '';
            w().history.forEach(h => { 
                const coin = h.pair.replace('USDT', '').replace('[AI] ', ''); 
