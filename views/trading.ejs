    <script>
        // --- 1. CORE STATE & ROUTING ---
        const ASSETS = [
            { id: 'BTCUSDT', name: 'BTC/USDT', icon: 'bitcoin-btc-logo.svg?v=029', coin: 'BTC' }, 
            { id: 'ETHUSDT', name: 'ETH/USDT', icon: 'ethereum-eth-logo.svg?v=029', coin: 'ETH' },
            { id: 'SOLUSDT', name: 'SOL/USDT', icon: 'solana-sol-logo.svg?v=029', coin: 'SOL' }, 
            { id: 'BNBUSDT', name: 'BNB/USDT', icon: 'bnb-bnb-logo.svg?v=029', coin: 'BNB' },
            { id: 'XRPUSDT', name: 'XRP/USDT', icon: 'xrp-xrp-logo.svg?v=029', coin: 'XRP' },
            { id: 'DOGEUSDT', name: 'DOGE/USDT', icon: 'dogecoin-doge-logo.svg?v=029', coin: 'DOGE' }, 
            { id: 'ADAUSDT', name: 'ADA/USDT', icon: 'cardano-ada-logo.svg?v=029', coin: 'ADA' },
            { id: 'DOTUSDT', name: 'DOT/USDT', icon: 'polkadot-new-dot-logo.svg?v=029', coin: 'DOT' }, 
            { id: 'MATICUSDT', name: 'MATIC/USDT', icon: 'polygon-matic-logo.svg?v=029', coin: 'MATIC' },
            { id: 'AVAXUSDT', name: 'AVAX/USDT', icon: 'avalanche-avax-logo.svg?v=029', coin: 'AVAX' },
            // ADDED ATOM FIX HERE
            { id: 'ATOMUSDT', name: 'ATOM/USDT', icon: 'cosmos-atom-logo.svg?v=029', coin: 'ATOM' }
        ];

        const STAKING_OPTS = [
            { id: 'ATOM', apr: 14.5, tag: 'High Yield' }, { id: 'DOT', apr: 11.8, tag: 'Hot' },
            { id: 'SOL', apr: 8.5, tag: 'Popular' }, { id: 'AVAX', apr: 6.5, tag: 'Stable' },
            { id: 'ETH', apr: 4.2, tag: 'Secure' }, { id: 'ADA', apr: 3.5, tag: 'Safe' }
        ];

        const FX_RATES = { USD: 1, AED: 3.67, EUR: 0.92, GBP: 0.79, CAD: 1.36, AUD: 1.52 };
        const FX_SYM = { USD: '$', AED: 'د.إ', EUR: '€', GBP: '£', CAD: 'C$', AUD: 'A$' };

        const defaultAI = `// --- AI Logic (Return BUY/SELL/NEUTRAL) ---\nlet score = 0;\nif (rsi > 70) score -= 2;\nif (rsi < 30) score += 2;\nif (score > 1) return "STRONG BUY";\nif (score < -1) return "STRONG SELL";\nreturn "NEUTRAL";`;

        const defaultHolders = [
            {addr: "0x3f9A...8cA1", usd: 1450000, lastAction: "ACCUMULATING", amt: 0},
            {addr: "0x88bC...11C9", usd: 1120000, lastAction: "HOLDING", amt: 0},
            {addr: "0x1aF2...E4F2", usd: 890000, lastAction: "HOLDING", amt: 0},
            {addr: "0x7cE4...00B1", usd: 760000, lastAction: "HOLDING", amt: 0},
            {addr: "0x99D1...FA00", usd: 450000, lastAction: "DISTRIBUTING", amt: 0}
        ];

        let state = JSON.parse(localStorage.getItem('cloudquant_v5')) || {
            usdtBalance: 15000.00, startOfDayValue: 15000.00, orders: [], history: [], manualAssets: { 'BTC': 0.15, 'ETH': 3.0, 'DOT': 150, 'ATOM': 500 }, 
            stakes: [], aiLogic: defaultAI, currency: 'USD', globalTradeLogs: [], topHoldersSim: defaultHolders, lastRunTime: Date.now()
        };
        
        let livePrices = {}; 
        let ui = { side: 'buy', pair: 'BTCUSDT', price: 0, lastPrice: 0, lev: 10, timeframe: '5m', chartData: [], logFilter: 'all', alphaTfMs: 86400000 };
        let wsTicker, wsTrade, chartCtx;
        let flowData = { buy: 0, sell: 0 };
        let canvasHoverPos = null; 
        let isShowingAllAssets = false;

        function switchApp(appName) {
            document.getElementById('app-terminal').style.display = appName === 'terminal' ? 'block' : 'none';
            document.getElementById('app-wallet').style.display = appName === 'wallet' ? 'block' : 'none';
            
            document.getElementById('nav-terminal').className = appName === 'terminal' ? "px-4 py-1.5 rounded-md text-[11px] font-black uppercase tracking-widest bg-[#F3BA2F] text-black transition shadow-[0_0_10px_rgba(243,186,47,0.3)]" : "px-4 py-1.5 rounded-md text-[11px] font-black uppercase tracking-widest text-muted hover:text-white transition";
            document.getElementById('nav-wallet').className = appName === 'wallet' ? "px-4 py-1.5 rounded-md text-[11px] font-black uppercase tracking-widest bg-[#F3BA2F] text-black transition shadow-[0_0_10px_rgba(243,186,47,0.3)]" : "px-4 py-1.5 rounded-md text-[11px] font-black uppercase tracking-widest text-muted hover:text-white transition";
            
            if(appName === 'terminal') { setTimeout(setupCanvas, 50); drawChart(); }
            if(appName === 'wallet') updateWalletApp();
        }

        function init() {
            document.getElementById('currency-select').value = state.currency || 'USD';
            document.getElementById('wallet-currency').value = state.currency || 'USD';
            buildTerminalDropdown(); buildNativeSelects();
            document.getElementById('ai-logic-editor').value = state.aiLogic;
            setupCanvas();
            
            connectMultiStream(); 
            connectGlobalTradeStream();
            
            triggerPairChange(); 
            updateUI(); renderOrders(); renderHistory(); buildStakingGrid();
            setInterval(updateWalletSystem, 1000);
            
            const missedTime = Date.now() - state.lastRunTime;
            if(missedTime > 60000) setTimeout(() => { if(ui.price > 0) generateBackgroundData(ui.pair, ui.price, missedTime); }, 1500);
        }

        // --- 2. HELPERS & ICONS ---
        function getIconPath(coin) {
            if (coin === 'USDT') return 'https://cryptologos.cc/logos/tether-usdt-logo.svg?v=029';
            const a = ASSETS.find(x => x.id.replace('USDT','') === coin || x.coin === coin);
            if (a) return `https://cryptologos.cc/logos/${a.icon}`;
            return `https://ui-avatars.com/api/?name=${coin}&background=1e2329&color=F3BA2F&rounded=true`;
