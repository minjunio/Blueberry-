    <script>
        // --- 1. STATE & ROUTING ---
        const standardBotCode = `// --- PROFESSIONAL DCA LOGIC ENGINE ---
// Evaluated tick-by-tick. Assumes global 'ATH' (All-Time High) is available.

function onTick(price, rsi, volume) {
    if (!bot.state) {
        bot.state = { tickCount: 0, lastBuyPrice: 0, lastBuyTick: -999, targetBasketProfit: 3.5 };
    }
    bot.state.tickCount++;
    const currentExposure = getOpenExposure();
    const pnl = getOpenPnL();

    if (currentExposure > 0 && pnl < -(bot.maxCap * 0.15)) {
        log(\`RISK MANAGER: Max drawdown of 15% reached! Liquidating basket to preserve capital.\`);
        closeAllPositions(); return; 
    }

    if (currentExposure > 0) {
        const avgEntry = getAverageEntry();
        const basketProfitPercent = ((price - avgEntry) / avgEntry) * 100;
        if (basketProfitPercent >= bot.state.targetBasketProfit) setTrailingStop(0.5);
    }

    if (bot.activeTxs.length < bot.maxTx && currentExposure + bot.size <= bot.maxCap) {
        let shouldBuy = false;
        if (bot.activeTxs.length === 0) {
            const dropFromATH = ((ATH - price) / ATH) * 100;
            if (dropFromATH >= bot.dropPercent && rsi < 45) { shouldBuy = true; log(\`INITIAL ENTRY: Dropped \${dropFromATH.toFixed(1)}% from ATH.\`); }
        } else {
            const dropFromLastBuy = ((bot.state.lastBuyPrice - price) / bot.state.lastBuyPrice) * 100;
            const requiredDrop = bot.dropPercent * (1 + (bot.activeTxs.length * 0.5)); 
            const isCooldownFinished = (bot.state.tickCount - bot.state.lastBuyTick) > 150;
            if (dropFromLastBuy >= requiredDrop && isCooldownFinished && rsi < 35) {
                shouldBuy = true; log(\`DCA ENTRY #\${bot.activeTxs.length}: Price dropped \${dropFromLastBuy.toFixed(1)}% from last buy.\`);
            }
        }

        if (shouldBuy) {
            const sizeMultiplier = 1 + (bot.activeTxs.length * 0.2); 
            let executionSize = bot.size * sizeMultiplier;
            if (currentExposure + executionSize > bot.maxCap) executionSize = bot.maxCap - currentExposure; 
            executeMarket({ side: 'buy', size: executionSize, lev: 1 });
            bot.state.lastBuyPrice = price; bot.state.lastBuyTick = bot.state.tickCount;
        }
    }
}`;

        const sniperBotCode = `// --- ADVANCED BOT LOGIC ENGINE ---
// Evaluated tick-by-tick.

function onTick(price, rsi, volume) {
    if (!bot.state) {
        bot.state = { tickCount: 0, lastTradeTick: -999, avgVolume: volume, peakPnL: 0, circuitBreakerTripped: false };
    }
    bot.state.tickCount++;
    bot.state.avgVolume = (bot.state.avgVolume * 19 + volume) / 20;

    if (bot.state.circuitBreakerTripped) { log("SYSTEM HALTED."); return; }

    const exposure = getOpenExposure();
    const currentPnL = getOpenPnL();

    if (exposure > 0 && currentPnL < -(bot.maxCap * 0.05)) {
        log("CRITICAL: Global Drawdown limit reached!");
        closeAllPositions(); bot.state.circuitBreakerTripped = true; return;
    }

    if (bot.activeTxs.length > 0) {
        if (currentPnL > bot.state.peakPnL) bot.state.peakPnL = currentPnL;
        if (currentPnL > (exposure * 0.05)) setTrailingStop(0.5); 
        if (rsi < 50 && currentPnL > 0) {
            log("Momentum exhausted. Manual early exit.");
            closeAllPositions(); bot.state.lastTradeTick = bot.state.tickCount;
        }
        return; 
    } else { bot.state.peakPnL = 0; }

    if (bot.state.tickCount - bot.state.lastTradeTick < 50) return; 

    const isVolumeSpike = volume > (bot.state.avgVolume * 4);
    const isMomentumOptimal = rsi > 72 && rsi < 88;
    let simulatedVolatility = 2.0; 
    const isVolatilitySafe = simulatedVolatility > 1.2 && simulatedVolatility < 6.0;

    if (isVolumeSpike && isMomentumOptimal && isVolatilitySafe) {
        log(\`PUMP DETECTED @ $\${price} | Vol: \${volume} | RSI: \${rsi.toFixed(1)}\`);
        executeMarket({ side: 'buy', size: bot.size, lev: bot.lev });
        setStopLoss(1.5); setTakeProfit(8.0); setTrailingStop(1.0);
        bot.state.lastTradeTick = bot.state.tickCount;
    }
}`;

