<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BlueCrypto Pro Terminal</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800;900&family=JetBrains+Mono:wght@400;700;800&display=swap');
        
        /* Bluebook Dark Mode Theme */
        :root {
            --bg-base: #040914;
            --bg-panel: #0a1326;
            --border: #172645;
            --cyan-glow: #00f3ff;
            --red-glow: #ff2a5f;
        }

        body { background-color: var(--bg-base); color: #f8fafc; font-family: 'Inter', sans-serif; overflow-x: hidden; }
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        
        .bluebook-panel { background-color: var(--bg-panel); border: 1px solid var(--border); border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        .bluebook-input { background: #040914; border: 1px solid #172645; color: white; outline: none; transition: 0.3s; }
        .bluebook-input:focus { border-color: var(--cyan-glow); box-shadow: 0 0 15px rgba(0, 243, 255, 0.15); }

        /* Dramatic Market Flashes */
        @keyframes flashPump {
            0% { box-shadow: inset 0 0 120px rgba(0, 243, 255, 0.2); border-color: var(--cyan-glow); }
            100% { box-shadow: inset 0 0 0 transparent; border-color: var(--border); }
        }
        @keyframes flashDump {
            0% { box-shadow: inset 0 0 120px rgba(255, 42, 95, 0.2); border-color: var(--red-glow); }
            100% { box-shadow: inset 0 0 0 transparent; border-color: var(--border); }
        }
        .animate-pump { animation: flashPump 0.6s ease-out; }
        .animate-dump { animation: flashDump 0.6s ease-out; }
        
        .text-pump { color: var(--cyan-glow) !important; text-shadow: 0 0 20px rgba(0, 243, 255, 0.6); }
        .text-dump { color: var(--red-glow) !important; text-shadow: 0 0 20px rgba(255, 42, 95, 0.6); }

        /* Sliders & Scrollbars */
        input[type=range] { -webkit-appearance: none; background: transparent; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 20px; width: 20px; border-radius: 50%; background: var(--cyan-glow); cursor: pointer; box-shadow: 0 0 10px var(--cyan-glow); }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 6px; background: #172645; border-radius: 4px; }
        
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-base); }
        ::-webkit-scrollbar-thumb { background: #172645; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #263c6b; }
    </style>
</head>
<body class="h-screen flex flex-col">

    <header class="border-b border-[#172645] bg-[#0a1326] shrink-0 p-4 flex justify-between items-center z-50 shadow-md">
        <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-cyan-400 rounded-xl flex items-center justify-center shadow-[0_0_15px_rgba(0,243,255,0.3)]">
                <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path></svg>
            </div>
            <h1 class="text-xl font-black uppercase tracking-widest text-white">BlueCrypto</h1>
        </div>

        <div class="bg-[#040914] p-1 rounded-xl flex border border-[#172645]">
            <button onclick="switchTab('wallet')" id="btn-wallet" class="px-6 py-2 rounded-lg text-xs font-black uppercase tracking-widest text-slate-500 hover:text-white transition">Wallet</button>
            <button onclick="switchTab('trading')" id="btn-trading" class="px-6 py-2 rounded-lg text-xs font-black uppercase tracking-widest bg-[#172645] text-white shadow transition">Terminal</button>
        </div>

        <a href="/admin" class="text-xs font-black uppercase tracking-widest text-slate-400 hover:text-white transition px-4 py-2 border border-[#172645] rounded-xl hover:bg-[#172645]">Exit</a>
    </header>

    <main class="flex-grow relative overflow-hidden bg-[#040914]">
        
        <div id="tab-wallet" class="absolute inset-0 overflow-y-auto hidden p-4 md:p-8">
            <div class="max-w-6xl mx-auto space-y-6">
                <div class="bluebook-panel p-8 md:p-12 relative overflow-hidden">
                    <div class="absolute top-[-50%] right-[-10%] w-96 h-96 bg-cyan-500/20 rounded-full blur-[100px] pointer-events-none"></div>
                    <p class="text-xs font-black uppercase tracking-widest text-cyan-500 mb-2">Available Margin (USDT)</p>
                    <h2 class="text-5xl md:text-7xl font-black font-mono tracking-tight text-white" id="wallet-total">$88,000.00</h2>
                    <div class="flex gap-4 mt-8">
                        <button onclick="resetWallet()" class="bg-slate-800 text-white px-6 py-2 rounded-lg text-xs font-black uppercase tracking-widest border border-slate-700 hover:bg-slate-700">Reset Balance</button>
                    </div>
                </div>
            </div>
        </div>

        <div id="tab-trading" class="absolute inset-0 flex flex-col lg:flex-row p-2 gap-2 overflow-y-auto lg:overflow-hidden">
            
            <div class="flex-grow flex flex-col gap-2 w-full lg:w-3/4">
                
                <div id="chart-container" class="bluebook-panel flex-grow relative overflow-hidden transition-all duration-300" style="min-height: 450px;">
                    
                    <div class="absolute top-4 left-4 z-10 flex flex-col md:flex-row md:items-end gap-4 pointer-events-none">
                        <div class="pointer-events-auto relative">
                            <select id="pair-selector" onchange="changePair()" class="appearance-none bg-[#0a1326]/80 backdrop-blur border border-[#172645] text-white font-black text-2xl px-4 py-2 rounded-xl cursor-pointer hover:border-cyan-500 transition shadow-lg outline-none pr-10">
                                <option value="BTCUSDT">BTC / USDT</option>
                                <option value="ETHUSDT">ETH / USDT</option>
                                <option value="SOLUSDT">SOL / USDT</option>
                                <option value="XRPUSDT">XRP / USDT</option>
                            </select>
                            <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-cyan-500">▼</div>
                        </div>
                        <h2 id="live-price" class="text-4xl md:text-5xl font-black font-mono tracking-tight text-white transition-colors duration-100 drop-shadow-lg">Loading...</h2>
                    </div>
                    
                    <div id="tvchart" style="position: absolute; width: 100%; height: 100%; top: 0; left: 0;"></div>
                </div>

                <div class="bluebook-panel h-[35vh] flex flex-col shrink-0 overflow-hidden">
                    <div class="p-4 border-b border-[#172645] bg-[#0a1326] flex justify-between items-center">
                        <h3 class="text-xs font-black uppercase tracking-widest text-white">Active Positions</h3>
                        <span class="text-[10px] font-bold text-cyan-500 bg-cyan-500/10 px-2 py-1 rounded">LIVE ROI TRACKING</span>
                    </div>
                    <div class="flex-grow overflow-auto">
                        <table class="w-full text-left min-w-[700px]">
                            <thead class="sticky top-0 bg-[#0a1326] shadow-sm z-10">
                                <tr class="text-[10px] font-black uppercase tracking-widest text-slate-500 border-b border-[#172645]">
                                    <th class="p-3">Symbol</th>
                                    <th class="p-3">Side</th>
                                    <th class="p-3">Leverage</th>
                                    <th class="p-3">Margin (USDT)</th>
                                    <th class="p-3">Entry Price</th>
                                    <th class="p-3 text-right">Live PNL / ROI</th>
                                    <th class="p-3 text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody id="active-orders-body" class="text-xs font-mono text-slate-300">
                                </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="bluebook-panel w-full lg:w-1/4 p-5 flex flex-col shrink-0 min-h-[500px]">
                
                <div class="flex gap-2 p-1 bg-[#040914] rounded-xl border border-[#172645] mb-6">
                    <button onclick="setSide('buy')" id="btn-buy" class="flex-1 py-3 rounded-lg font-black uppercase tracking-widest text-xs bg-cyan-500 text-black shadow-[0_0_15px_rgba(0,243,255,0.4)] transition">Long</button>
                    <button onclick="setSide('sell')" id="btn-sell" class="flex-1 py-3 rounded-lg font-black uppercase tracking-widest text-xs text-slate-500 hover:text-white transition">Short</button>
                </div>

                <div class="space-y-6 flex-grow">
                    <div>
                        <div class="flex justify-between mb-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-500">Leverage</label>
                            <span class="text-xs font-black font-mono text-cyan-500"><span id="lev-val">10</span>x</span>
                        </div>
                        <input type="range" id="leverage" min="1" max="100" value="10" class="w-full" oninput="document.getElementById('lev-val').innerText = this.value; updateEst();">
                    </div>

                    <div>
                        <div class="flex justify-between mb-2">
                            <label class="text-[10px] font-black uppercase tracking-widest text-slate-500">Margin (USDT)</label>
                            <span class="text-[10px] font-black text-cyan-500 cursor-pointer" onclick="setMax()">100%</span>
                        </div>
                        <input type="number" id="trade-amount" placeholder="0.00" class="bluebook-input w-full p-4 rounded-xl text-xl font-black font-mono" oninput="updateEst()">
                    </div>

                    <div class="p-4 bg-[#040914] rounded-xl border border-[#172645] space-y-3">
                        <div class="flex justify-between text-[10px] font-black uppercase tracking-widest text-slate-500">
                            <span>Available</span>
                            <span class="font-mono text-white"><span id="trade-avail">88000.00</span></span>
                        </div>
                        <div class="flex justify-between text-[10px] font-black uppercase tracking-widest text-slate-500">
                            <span>Position Size</span>
                            <span class="font-mono text-cyan-500" id="trade-pos">0.00 USDT</span>
                        </div>
                    </div>
                </div>

                <button onclick="executeTrade()" id="btn-execute" class="mt-6 w-full py-5 rounded-xl font-black uppercase tracking-widest text-sm bg-cyan-500 text-black hover:bg-cyan-400 transition-all shadow-[0_0_20px_rgba(0,243,255,0.3)] active:scale-95">
                    Open Long
                </button>
            </div>
        </div>
    </main>

    <script>
        // --- 1. STATE MANAGEMENT (localStorage) ---
        let state = JSON.parse(localStorage.getItem('bluebookState')) || {
            balance: 88000.00,
            orders: []
        };
        state.side = 'buy';
        state.symbol = 'BTCUSDT';
        state.price = 0;
        state.lastPrice = 0;

        function saveState() {
            localStorage.setItem('bluebookState', JSON.stringify({ balance: state.balance, orders: state.orders }));
        }

        // --- 2. TABS ---
        function switchTab(tab) {
            document.getElementById('btn-wallet').className = "px-6 py-2 rounded-lg text-xs font-black uppercase tracking-widest text-slate-500 hover:text-white transition";
            document.getElementById('btn-trading').className = "px-6 py-2 rounded-lg text-xs font-black uppercase tracking-widest text-slate-500 hover:text-white transition";
            document.getElementById(`btn-${tab}`).classList.add('bg-[#172645]', 'text-white', 'shadow');
            document.getElementById(`btn-${tab}`).classList.remove('text-slate-500');

            if(tab === 'wallet') {
                document.getElementById('tab-trading').style.display = 'none';
                document.getElementById('tab-wallet').style.display = 'block';
            } else {
                document.getElementById('tab-wallet').style.display = 'none';
                document.getElementById('tab-trading').style.display = 'flex';
                // Force chart resize
                setTimeout(() => chart.timeScale().fitContent(), 10);
            }
        }

        // --- 3. BLUEBOOK CHART ---
        const chartElement = document.getElementById('tvchart');
        const chart = LightweightCharts.createChart(chartElement, {
            layout: { background: { type: 'solid', color: 'transparent' }, textColor: '#64748b' },
            grid: { vertLines: { color: 'rgba(23, 38, 69, 0.5)' }, horzLines: { color: 'rgba(23, 38, 69, 0.5)' } },
            crosshair: { mode: LightweightCharts.CrosshairMode.Normal },
            rightPriceScale: { borderColor: '#172645' },
            timeScale: { borderColor: '#172645', timeVisible: true },
        });

        const candleSeries = chart.addCandlestickSeries({
            upColor: '#00f3ff', downColor: '#ff2a5f', borderVisible: false,
            wickUpColor: '#00f3ff', wickDownColor: '#ff2a5f'
        });

        // Resize observer to ensure graph fills container
        new ResizeObserver(entries => {
            if (entries.length === 0 || entries[0].target !== chartElement) return;
            const newRect = entries[0].contentRect;
            chart.applyOptions({ height: newRect.height, width: newRect.width });
        }).observe(chartElement);

        // --- 4. BINANCE API (REST + WS) ---
        let ws;

        // Fetch history first so chart isn't empty
        async function fetchHistoryAndConnect(symbol) {
            try {
                const res = await fetch(`https://api.binance.com/api/v3/klines?symbol=${symbol}&interval=1m&limit=100`);
                const data = await res.json();
                const klines = data.map(d => ({
                    time: d[0] / 1000, open: parseFloat(d[1]), high: parseFloat(d[2]), low: parseFloat(d[3]), close: parseFloat(d[4])
                }));
                candleSeries.setData(klines);
                state.lastPrice = klines[klines.length - 1].close;
                connectWS(symbol);
            } catch(e) { console.error("History fetch failed", e); connectWS(symbol); }
        }

        function connectWS(symbol) {
            if(ws) ws.close();
            const priceText = document.getElementById('live-price');
            const container = document.getElementById('chart-container');
            
            ws = new WebSocket(`wss://stream.binance.com:9443/ws/${symbol.toLowerCase()}@kline_1m`);
            
            ws.onmessage = (event) => {
                const k = JSON.parse(event.data).k;
                const closePrice = parseFloat(k.c);
                state.price = closePrice;
                
                const dec = closePrice < 1 ? 4 : 2;
                priceText.innerText = `$${closePrice.toLocaleString(undefined, {minimumFractionDigits: dec})}`;

                // Dramatic Flashes
                if (state.lastPrice !== 0 && closePrice !== state.lastPrice) {
                    container.classList.remove('animate-pump', 'animate-dump');
                    priceText.classList.remove('text-pump', 'text-dump');
                    void container.offsetWidth; // Trigger reflow
                    
                    if (closePrice > state.lastPrice) {
                        container.classList.add('animate-pump');
                        priceText.classList.add('text-pump');
                    } else {
                        container.classList.add('animate-dump');
                        priceText.classList.add('text-dump');
                    }
                }
                state.lastPrice = closePrice;

                candleSeries.update({
                    time: k.t / 1000, open: parseFloat(k.o), high: parseFloat(k.h), low: parseFloat(k.l), close: parseFloat(k.c)
                });

                updateActiveOrdersUI();
            };
        }

        function changePair() {
            state.symbol = document.getElementById('pair-selector').value;
            fetchHistoryAndConnect(state.symbol);
        }

        // --- 5. ORDER ENTRY & LEVERAGE ---
        function setSide(side) {
            state.side = side;
            const buyBtn = document.getElementById('btn-buy');
            const sellBtn = document.getElementById('btn-sell');
            const execBtn = document.getElementById('btn-execute');

            if(side === 'buy') {
                buyBtn.className = "flex-1 py-3 rounded-lg font-black uppercase tracking-widest text-xs bg-cyan-500 text-black shadow-[0_0_15px_rgba(0,243,255,0.4)] transition";
                sellBtn.className = "flex-1 py-3 rounded-lg font-black uppercase tracking-widest text-xs text-slate-500 hover:text-white transition";
                execBtn.className = "mt-6 w-full py-5 rounded-xl font-black uppercase tracking-widest text-sm bg-cyan-500 text-black hover:bg-cyan-400 transition-all shadow-[0_0_20px_rgba(0,243,255,0.3)] active:scale-95";
                execBtn.innerText = "Open Long";
            } else {
                sellBtn.className = "flex-1 py-3 rounded-lg font-black uppercase tracking-widest text-xs bg-[#ff2a5f] text-white shadow-[0_0_15px_rgba(255,42,95,0.4)] transition";
                buyBtn.className = "flex-1 py-3 rounded-lg font-black uppercase tracking-widest text-xs text-slate-500 hover:text-white transition";
                execBtn.className = "mt-6 w-full py-5 rounded-xl font-black uppercase tracking-widest text-sm bg-[#ff2a5f] text-white hover:bg-pink-600 transition-all shadow-[0_0_20px_rgba(255,42,95,0.3)] active:scale-95";
                execBtn.innerText = "Open Short";
            }
        }

        function setMax() {
            document.getElementById('trade-amount').value = Math.floor(state.balance * 100)/100;
            updateEst();
        }

        function updateEst() {
            const margin = parseFloat(document.getElementById('trade-amount').value) || 0;
            const lev = parseInt(document.getElementById('leverage').value);
            document.getElementById('trade-pos').innerText = (margin * lev).toLocaleString() + ' USDT';
        }

        function executeTrade() {
            const margin = parseFloat(document.getElementById('trade-amount').value);
            const lev = parseInt(document.getElementById('leverage').value);
            
            if (isNaN(margin) || margin <= 0) return alert("Enter valid margin.");
            if (margin > state.balance) return alert("Insufficient USDT margin.");

            state.balance -= margin;
            
            // Calculate units based on total leveraged position size
            const positionSize = margin * lev;
            const units = positionSize / state.price;
            
            const newOrder = {
                id: Math.random().toString(36).substr(2, 9),
                symbol: state.symbol,
                side: state.side,
                margin: margin,
                leverage: lev,
                entryPrice: state.price,
                units: units
            };
            
            state.orders.push(newOrder);
            saveState();
            
            document.getElementById('trade-amount').value = '';
            updateEst();
            updateUI();
        }

        // --- 6. ROI & ACTIVE ORDERS ---
        function updateActiveOrdersUI() {
            const tbody = document.getElementById('active-orders-body');
            if(state.orders.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="p-6 text-center text-[#172645] font-black uppercase">No active positions</td></tr>`;
                return;
            }

            let html = '';
            state.orders.forEach(order => {
                let pnl = 0;
                
                // Calculate ROI based on actual units held
                if (order.symbol === state.symbol) {
                    const currentVal = order.units * state.price;
                    const entryVal = order.units * order.entryPrice;
                    pnl = order.side === 'buy' ? (currentVal - entryVal) : (entryVal - currentVal);
                }

                const roiPercent = (pnl / order.margin) * 100;
                const isProfit = pnl >= 0;
                const color = isProfit ? 'text-cyan-500' : 'text-[#ff2a5f]';
                const sign = isProfit ? '+' : '';
                const sideColor = order.side === 'buy' ? 'text-cyan-500 bg-cyan-500/10' : 'text-[#ff2a5f] bg-[#ff2a5f]/10';

                html += `
                    <tr class="border-b border-[#172645]/50 hover:bg-[#172645]/30 transition group">
                        <td class="p-3 font-black text-white">${order.symbol}</td>
                        <td class="p-3"><span class="px-2 py-1 rounded text-[10px] font-black uppercase ${sideColor}">${order.side}</span></td>
                        <td class="p-3">${order.leverage}x</td>
                        <td class="p-3">${order.margin.toFixed(2)}</td>
                        <td class="p-3">${order.entryPrice.toFixed(4)}</td>
                        <td class="p-3 text-right ${color} font-black drop-shadow-md">
                            ${sign}${pnl.toFixed(2)} (${sign}${roiPercent.toFixed(2)}%)
                        </td>
                        <td class="p-3 text-right">
                            <button onclick="closeOrder('${order.id}')" class="px-3 py-1.5 bg-[#172645] hover:bg-slate-700 text-white rounded text-[10px] uppercase font-black tracking-widest transition lg:opacity-0 group-hover:opacity-100">Close</button>
                        </td>
                    </tr>
                `;
            });
            tbody.innerHTML = html;
        }

        function closeOrder(id) {
            const index = state.orders.findIndex(o => o.id === id);
            if (index === -1) return;
            
            const order = state.orders[index];
            let pnl = 0;
            
            if (order.symbol === state.symbol) {
                const currentVal = order.units * state.price;
                const entryVal = order.units * order.entryPrice;
                pnl = order.side === 'buy' ? (currentVal - entryVal) : (entryVal - currentVal);
            }
            
            // Return original margin + profits (or minus losses)
            state.balance += (order.margin + pnl);
            state.orders.splice(index, 1);
            
            saveState();
            updateUI();
        }

        function updateUI() {
            const bal = state.balance.toLocaleString(undefined, {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('wallet-total').innerText = `$${bal}`;
            document.getElementById('trade-avail').innerText = bal;
            updateActiveOrdersUI();
        }

        function resetWallet() {
            if(confirm("Reset entire wallet to $88,000 and close all orders?")) {
                state.balance = 88000.00;
                state.orders = [];
                saveState();
                updateUI();
            }
        }

        // Init
        updateUI();
        switchTab('trading');
        fetchHistoryAndConnect(state.symbol);
    </script>
</body>
</html>
