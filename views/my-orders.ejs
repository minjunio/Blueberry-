<!DOCTYPE html>
<html lang="en">
<head>
    <title>My Orders - ExamHub Professional</title>
    <%- include('partials/head') %>
</head>
<body class="antialiased flex flex-col min-h-screen bg-gray-50 text-gray-800">
    
    <nav class="border-b border-gray-200 bg-white sticky top-0 z-40 shadow-sm">
        <div class="py-4 px-6 md:px-8 flex justify-between items-center max-w-7xl mx-auto w-full">
            <a href="/" class="text-2xl font-extrabold tracking-tight text-gray-900">Exam<span class="text-blue-600">Hub</span></a>
            
            <div class="flex items-center gap-3">
                <a href="https://discord.gg/bg6wKj45w3" target="_blank" class="hidden md:flex items-center gap-2 bg-[#5865F2] hover:bg-[#4752C4] text-white px-4 py-2 rounded-md font-semibold text-sm transition">
                    Discord Support
                </a>
                <a href="/buyer-logout" class="ml-2 text-sm font-medium text-gray-500 hover:text-red-600 transition">Logout</a>
            </div>
        </div>
    </nav>

    <main class="flex-grow w-full max-w-6xl mx-auto px-4 md:px-8 py-10 relative z-20">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-8 gap-4">
            <div>
                <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Order History</h1>
                <p class="text-sm font-medium text-gray-500 mt-2">Authenticated as: <span class="text-gray-900 font-bold"><%= buyerEmail %></span></p>
            </div>
            <% if (error === 'max_orders') { %>
                <div class="bg-red-50 text-red-700 border border-red-200 px-4 py-2 rounded-md text-sm font-bold shadow-sm">
                    Max active orders reached (3). Close completed orders to create new ones.
                </div>
            <% } %>
        </div>

        <div class="bg-white border border-gray-200 shadow-sm rounded-md overflow-hidden">
            <% if (!orders || orders.length === 0) { %>
                <div class="p-12 text-center text-gray-500 font-medium">
                    <p class="text-4xl mb-3">📦</p>
                    <p>No orders found in your history.</p>
                    <a href="/" class="inline-block mt-4 text-blue-600 font-bold hover:underline">Browse Marketplace</a>
                </div>
            <% } else { %>
                <div class="overflow-x-auto">
                    <table class="w-full text-left whitespace-nowrap">
                        <thead>
                            <tr class="bg-gray-50 border-b border-gray-200">
                                <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Order ID</th>
                                <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Product</th>
                                <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Amount</th>
                                <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-4 text-xs font-bold text-gray-500 uppercase tracking-wider text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% orders.forEach(order => { %>
                                <tr class="hover:bg-gray-50/50 transition">
                                    <td class="px-6 py-5">
                                        <div class="font-mono text-sm font-bold text-gray-900"><%= order.order_id %></div>
                                        <div class="text-[11px] text-gray-400 mt-0.5"><%= new Date(order.created_at).toLocaleDateString() %></div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <div class="font-bold text-gray-900 text-sm truncate max-w-[200px] md:max-w-xs"><%= order.product_title || 'Item Unavailable' %></div>
                                        <div class="text-xs text-gray-500 mt-0.5"><%= order.payment_method %> • <%= order.tier %></div>
                                    </td>
                                    <td class="px-6 py-5">
                                        <span class="font-bold text-gray-900 text-sm">$<%= parseFloat(order.product_price || 0).toFixed(2) %></span>
                                    </td>
                                    <td class="px-6 py-5">
                                        <% 
                                            let statusClass = "bg-gray-100 text-gray-700 border-gray-200";
                                            if (order.status === 'Pending Payment') statusClass = "bg-orange-50 text-orange-700 border-orange-200";
                                            else if (order.status.includes('Paid') || order.status === 'Completed') statusClass = "bg-green-50 text-green-700 border-green-200";
                                            else if (order.status === 'Closed') statusClass = "bg-red-50 text-red-700 border-red-200";
                                        %>
                                        <span class="px-2.5 py-1 rounded-sm border text-[11px] font-bold uppercase tracking-wide <%= statusClass %>">
                                            <%= order.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-5 text-right flex items-center justify-end gap-3">
                                        <a href="/order/<%= order.order_id %>" class="text-sm font-bold text-blue-600 hover:text-blue-800 transition">View Receipt</a>
                                        
                                        <% if (order.status !== 'Closed') { %>
                                            <form action="/buyer/close-order" method="POST" class="inline" onsubmit="return confirm('Are you sure you want to close this order permanently?');">
                                                <input type="hidden" name="order_id" value="<%= order.order_id %>">
                                                <button type="submit" class="text-sm font-medium text-gray-400 hover:text-red-600 transition">Close</button>
                                            </form>
                                        <% } else { %>
                                            <span class="text-sm font-medium text-gray-300 select-none">Closed</span>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

    </main>

    <footer class="bg-white border-t border-gray-200 mt-auto relative z-20">
        <div class="max-w-7xl mx-auto px-6 md:px-8 py-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-xl font-bold text-gray-900">Exam<span class="text-blue-600">Hub</span></p>
            <p class="text-sm font-medium text-gray-500">© 2026 Professional Marketplace. All rights reserved.</p>
        </div>
    </footer>
</body>
</html>
