    <!-- PayPal SDK + Button Logic -->
    <script src="https://www.paypal.com/sdk/js?client-id=AdYs8Oioh_11zKXw-9qhanNJL2z8C3eouUvREy4RZJvhCbLpe4n_nbTFs7q3FruGeaDW7dCc4OLUgLLc&vault=true&intent=subscription" data-sdk-integration-source="button-factory"></script>
    <script>
        // Tailwind script
        function initializeTailwind() {
            document.documentElement.style.setProperty('--accent', '#3b82f6');
        }

        // Navbar scroll effect
        function initNavbar() {
            const navbar = document.getElementById('navbar');
            let lastScroll = 0;
            
            window.addEventListener('scroll', () => {
                const currentScroll = window.scrollY;
                
                if (currentScroll > 80) {
                    navbar.classList.add('nav-scrolled', 'shadow-xl');
                } else {
                    navbar.classList.remove('nav-scrolled', 'shadow-xl');
                }
                
                lastScroll = currentScroll;
            });
        }

        // PayPal Button
        function initializePayPal() {
            paypal.Buttons({
                style: {
                    shape: 'rect',
                    color: 'gold',
                    layout: 'vertical',
                    label: 'subscribe',
                    height: 48
                },
                createSubscription: function(data, actions) {
                    return actions.subscription.create({
                        plan_id: 'P-6H169433JR622882NNJFZJHI'
                    });
                },
                onApprove: function(data, actions) {
                    // Hide button container
                    const container = document.getElementById('paypal-button-container-P-6H169433JR622882NNJFZJHI');
                    if (container) container.style.display = 'none';

                    // Show success
                    const successDiv = document.getElementById('success-message');
                    const subIdSpan = document.getElementById('sub-id-display');
                    
                    if (successDiv && subIdSpan) {
                        subIdSpan.textContent = data.subscriptionID || 'ACTIVE';
                        successDiv.classList.remove('hidden');
                        successDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }

                    // Optional: You can POST subscriptionID to your backend here
                    console.log('%c[ExamHub] New subscription activated:', 'color:#166534', data.subscriptionID);
                    
                    // In production you would:
                    // fetch('/api/activate-premium', { 
                    //     method: 'POST', 
                    //     body: JSON.stringify({ subscriptionID: data.subscriptionID }) 
                    // })
                },
                onError: function(err) {
                    console.error('PayPal error:', err);
                    alert('There was an issue processing your subscription. Please try again or contact support@examhub.shop');
                }
            }).render('#paypal-button-container-P-6H169433JR622882NNJFZJHI');
        }

        // Keyboard hint
        function initKeyboardHints() {
            document.addEventListener('keydown', function(e) {
                if (e.key === '/' && document.activeElement.tagName === 'BODY') {
                    e.preventDefault();
                    const pricing = document.getElementById('pricing');
                    pricing.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
            
            // Easter egg: Konami-ish for fun
            let keys = [];
            document.addEventListener('keydown', function(e) {
                keys.push(e.key);
                if (keys.length > 5) keys.shift();
                if (keys.join('') === 'ArrowUpArrowUpArrowDown') {
                    const hero = document.querySelector('h1');
                    if (hero) {
                        hero.style.transition = 'all 400ms cubic-bezier(0.23,1,0.32,1)';
                        hero.style.transform = 'scale(1.015)';
                        setTimeout(() => hero.style.transform = 'scale(1)', 600);
                    }
                }
            });
        }

        // Boot everything
        function boot() {
            initializeTailwind();
            initNavbar();
            initializePayPal();
            initKeyboardHints();

            // Smooth scroll for anchor links
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function(e) {
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        e.preventDefault();
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            });

            // Accessibility: announce PayPal ready
            console.log('%c[ExamHub Premium] EJS template initialized with PayPal subscription flow.', 'color:#64748b');
        }

        window.onload = boot;
    </script>
</body>
</html>