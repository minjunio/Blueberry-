                        <!-- Card Button -->
                        <button class="gateway-btn w-full relative flex items-center justify-between px-5 py-3.5 bg-white rounded-xl text-slate-900 font-bold shadow-[0_4px_14px_0_rgba(255,255,255,0.1)] hover:bg-slate-50 border-2 border-transparent hover:border-slate-200">
                            <div class="flex items-center gap-3">
