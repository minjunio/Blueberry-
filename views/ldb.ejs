<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ExamHub Premium • Universal Stealth Browser</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        stealth: {
                            50: '#f5f3ff',
                            100: '#ede9fe',
                            400: '#a78bfa',
                            500: '#8b5cf6', // Core Indigo/Purple
                            600: '#7c3aed',
                            800: '#1e1b4b',
                            900: '#0f0e17', // Deep Space Background
                            950: '#07060b', // Darkest
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        display: ['Space Grotesk', 'Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap');
        
        body {
            background-color: #07060b;
            background-image: 
                radial-gradient(circle at 20% 0%, rgba(124, 58, 237, 0.05), transparent 30%),
                radial-gradient(circle at 80% 40%, rgba(139, 92, 246, 0.05), transparent 30%);
        }

        .glass-panel {
            background: rgba(15, 14, 23, 0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(139, 92, 246, 0.1);
        }

        .stealth-gradient {
            background: linear-gradient(135deg, #8b5cf6 0%, #6d28d9 100%);
        }

        .text-gradient {
            background: linear-gradient(to right, #c4b5fd, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .feature-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: linear-gradient(180deg, rgba(30, 27, 75, 0.3) 0%, rgba(15, 14, 23, 0.8) 100%);
            border: 1px solid rgba(139, 92, 246, 0.1);
        }
        
        .feature-card:hover {
            transform: translateY(-4px);
            border-color: rgba(139, 92, 246, 0.4);
            box-shadow: 0 20px 40px -10px rgba(124, 58, 237, 0.15);
        }

        /* Upgraded Payment Gateway Styling */
        .pay-card {
            background: linear-gradient(180deg, rgba(23, 23, 30, 0.95) 0%, rgba(10, 10, 15, 0.98) 100%);
            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.05), 0 30px 60px -15px rgba(0, 0, 0, 0.8);
            position: relative;
        }
        
        .pay-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; height: 3px;
            background: linear-gradient(90deg, #8b5cf6, #c4b5fd, #8b5cf6);
            border-radius: 24px 24px 0 0;
            background-size: 200% auto;
            animation: gradientShine 3s linear infinite;
        }

        @keyframes gradientShine {
            to { background-position: 200% center; }
        }

        .gateway-btn {
            transition: all 0.2s ease;
        }
        .gateway-btn:hover {
            transform: translateY(-2px);
        }
        .gateway-btn:active {
            transform: translateY(0);
        }

        /* Platform Badges */
        .platform-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            background: rgba(30, 27, 75, 0.5);
            border: 1px solid rgba(139, 92, 246, 0.2);
            color: #ddd6fe;
        }
    </style>
</head>
<body class="text-slate-200 antialiased selection:bg-stealth-600 selection:text-white">

    <!-- Navbar -->
