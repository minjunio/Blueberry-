                <p
                    id="emailAuthError"
                    class="hidden rounded-xl border border-red-200 bg-red-50 text-sm font-bold text-red-700 px-4 py-3 mt-4"
                ></p>

                <button
                    type="button"
                    onclick="sendOtp()"
                    id="sendOtpBtn"
                    class="w-full mt-5 bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-extrabold py-3.5 rounded-xl hover:shadow-lg hover:shadow-blue-600/25 disabled:opacity-60 disabled:cursor-not-allowed transition"
