                                    >
                                        <path
                                            d="M12 8v5M12 17h.01"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                        />

                                        <path
                                            d="M10.3 4.7 2.9 17.5A1.7 1.7 0 0 0 4.4 20h15.2a1.7 1.7 0 0 0 1.5-2.5L13.7 4.7a2 2 0 0 0-3.4 0Z"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linejoin="round"
                                        />
                                    </svg>

                                    <div>
                                        <p
                                            class="text-sm font-black text-amber-800"
                                        >
                                            Card checkout is unavailable
                                        </p>

                                        <p
                                            id="cardUnavailableMessage"
                                            class="mt-1 text-xs font-medium leading-5 text-amber-700"
