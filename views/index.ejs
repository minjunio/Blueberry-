<!DOCTYPE html>
<html lang="en">
<head>
    <%
        const safeProducts = Array.isArray(products) ? products : [];
        const safeCategories = Array.isArray(categories) ? categories : [];

        const safePosts =
            typeof posts !== 'undefined' && Array.isArray(posts)
                ? posts
                : [];

        const safeAnnouncements =
            typeof announcements !== 'undefined' && Array.isArray(announcements)
                ? announcements
                : [];

        const currentCategory =
            typeof categoryFilter !== 'undefined' && categoryFilter
                ? categoryFilter
                : 'All';

        const currentSearch =
            typeof searchQuery !== 'undefined' && searchQuery
                ? searchQuery
                : '';

        const currentBuyerEmail =
            typeof buyerEmail !== 'undefined' && buyerEmail
                ? buyerEmail
                : '';

        const defaultPayPalButtonId = 'QZ7HHN9DJGNSA';

        const seoTitle =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_title
                ? categoryRow.seo_title
                : 'ExamHub ✨ Marketplace';

        const seoDesc =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_desc
                ? categoryRow.seo_desc
                : 'The ultimate exam marketplace for top-rated study tools.';

        const seoKeywords =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_keywords
                ? categoryRow.seo_keywords
                : 'exams, study tools, marketplace, preparation, learning';

        const ogImage =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.og_image
                ? categoryRow.og_image
                : 'https://examhub.shop/favicon.png';

        const canonicalUrl =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.canonical_url
                ? categoryRow.canonical_url
                : '';

        function formatPostText(text) {
            if (!text) return '';

            let safeText = String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');

            safeText = safeText.replace(
                /\*\*([\s\S]*?)\*\*/g,
                '<strong class="font-bold text-gray-900">$1</strong>'
            );

            safeText = safeText.replace(
                /#([^#\n]+)#/g,
                '<span class="text-xl md:text-2xl font-bold block mt-4 mb-2 text-gray-900 leading-tight">$1</span>'
            );

            safeText = safeText.replace(/\n/g, '<br>');

            return safeText;
        }
    %>

    <meta charset="UTF-8">
    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title><%= seoTitle %></title>

    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">
    <meta
        name="robots"
        content="index, follow, max-image-preview:large"
    >

    <% if (canonicalUrl) { %>
        <link rel="canonical" href="<%= canonicalUrl %>">
    <% } %>

    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">

    <link rel="icon" type="image/png" href="/favicon.png">

    <%- include('partials/head') %>

    <!--
        Load the PayPal SDK only once.

        HostedButtons requires:
        components=hosted-buttons
    -->
    <script
        src="https://www.paypal.com/sdk/js?client-id=BAACqOV8IkLP3i0-_Ty6IA7zt5_OxtawbH5tAUCjenPO6KcpDgcEscgNhhZCTP9dVtHBQB6BrxF5QoOBnM&components=hosted-buttons&disable-funding=venmo&currency=USD"
        data-sdk-integration-source="button-factory"
        defer
    ></script>

    <style>
        [data-modal-panel] {
            max-height: calc(100vh - 2rem);
        }

        body.modal-open {
            overflow: hidden;
        }

        .paypal-instance {
            width: 100%;
            min-height: 94px;
            position: relative;
            z-index: 20;
            pointer-events: auto;
        }

        .paypal-instance iframe {
            position: relative !important;
            z-index: 30 !important;
            pointer-events: auto !important;
        }

        #paypal-hosted-root {
            position: relative;
            z-index: 25;
            pointer-events: auto;
        }
    </style>
</head>

<body class="antialiased min-h-screen flex flex-col bg-[#f8fafc] text-gray-800">

    <!-- NAVIGATION -->
    <nav
        class="py-5 px-4 md:px-8 flex justify-between items-center max-w-7xl mx-auto w-full relative z-20 border-b border-gray-200 bg-white shadow-sm"
    >
        <a
            href="/"
            class="text-2xl font-black text-gray-900 tracking-tight"
        >
            Exam<span class="text-blue-600">Hub</span>
        </a>

        <div class="flex items-center gap-3">

            <a
                href="https://discord.gg/bg6wKj45w3"
                target="_blank"
                rel="noopener noreferrer"
                class="hidden md:flex items-center gap-1.5 bg-[#5865F2] hover:bg-[#4752C4] text-white px-4 py-2 rounded-lg font-bold text-sm transition"
            >
                Discord
            </a>

            <% if (currentBuyerEmail) { %>
                <a
                    href="/my-orders"
                    class="bg-gray-900 text-white hover:bg-gray-800 px-4 py-2 rounded-lg font-bold text-sm transition flex items-center gap-2"
                >
                    My Orders

                    <% if (
                        typeof activeOrderCount !== 'undefined' &&
                        Number(activeOrderCount) > 0
                    ) { %>
                        <span
                            class="bg-red-500 text-white text-[10px] px-2 py-0.5 rounded-full"
                        >
                            <%= activeOrderCount %>
                        </span>
                    <% } %>
                </a>

                <a
                    href="/buyer-logout"
                    class="ml-1 text-sm font-medium text-gray-500 hover:text-red-600 transition hidden md:block"
                >
                    Logout
                </a>
            <% } %>

            <% if (typeof user !== 'undefined' && user) { %>
                <a
                    href="/admin"
                    class="ml-2 bg-white hover:bg-gray-50 px-4 py-2 rounded-lg font-bold text-sm transition border border-gray-300 shadow-sm text-gray-700"
                >
                    Admin
                </a>
            <% } else if (!currentBuyerEmail) { %>
                <a
                    href="/login"
                    class="ml-2 bg-white hover:bg-gray-50 px-4 py-2 rounded-lg font-bold text-sm transition border border-gray-300 shadow-sm text-gray-700"
                >
                    Login
                </a>
            <% } %>

        </div>
    </nav>

    <!-- HEADER -->
    <header
        class="flex flex-col items-center text-center px-4 pt-12 pb-12 relative z-10"
    >
        <h1
            class="text-4xl md:text-5xl font-black mb-4 text-gray-900 tracking-tight"
        >
            Master Your
            <span class="text-blue-600">Exams</span>
        </h1>

        <p class="text-gray-500 mb-8 font-medium max-w-lg">
            Browse top-rated study tools, preparation resources, and
            digital services.
        </p>

        <div class="w-full max-w-2xl relative">

            <form
                action="/"
                method="GET"
                class="relative"
                role="search"
            >
                <% if (
                    currentCategory &&
                    currentCategory !== 'All'
                ) { %>
                    <input
                        type="hidden"
                        name="category"
                        value="<%= currentCategory %>"
                    >
                <% } %>

                <input
                    type="search"
                    id="searchInput"
                    name="q"
                    autocomplete="off"
                    value="<%= currentSearch %>"
                    placeholder="Search products and study tools..."
                    aria-label="Search marketplace"
                    aria-controls="searchDropdown"
                    class="w-full bg-white border border-gray-300 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 rounded-xl py-4 pl-6 pr-24 outline-none shadow-sm text-base font-medium transition"
                >

                <button
                    type="submit"
                    class="absolute right-2 top-2 bg-blue-600 text-white px-5 py-2 rounded-lg font-bold hover:bg-blue-700 transition"
                >
                    Search
                </button>
            </form>

            <div
                id="searchDropdown"
                class="hidden absolute top-full left-0 w-full bg-white border border-gray-200 rounded-xl mt-2 shadow-xl overflow-hidden z-50 flex-col text-left"
                role="listbox"
            ></div>

        </div>

        <div
            class="flex flex-wrap justify-center gap-2 mt-8 max-w-4xl"
        >
            <a
                href="/"
                class="px-4 py-2 rounded-lg font-bold text-xs md:text-sm border <%= (!currentCategory || currentCategory === 'All') ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-600 border-gray-200 hover:border-gray-400' %> transition"
            >
                All
            </a>

            <% safeCategories.forEach(cat => { %>
                <a
                    href="/category/<%= encodeURIComponent(cat.name) %>"
                    class="px-4 py-2 rounded-lg font-bold text-xs md:text-sm border <%= currentCategory === cat.name ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-600 border-gray-200 hover:border-gray-400' %> transition"
                >
                    <%= cat.name %>
                </a>
            <% }) %>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <main
        class="flex-grow w-full max-w-6xl mx-auto px-4 md:px-6 relative z-20 pb-20"
    >

        <!-- ANNOUNCEMENTS -->
        <% if (safeAnnouncements.length > 0) { %>
            <div class="mb-12 space-y-6">

                <% safeAnnouncements.forEach(ann => { %>
                    <article
                        class="bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-blue-100"
                    >
                        <div
                            class="inline-block bg-blue-50 text-blue-700 font-bold text-[10px] px-2 py-1 rounded uppercase tracking-wider mb-3"
                        >
                            <%= ann.category || 'Marketplace' %> Update
                        </div>

                        <h2
                            class="text-2xl font-bold mb-4 text-gray-900"
                        >
                            <%= ann.title %>
                        </h2>

                        <% if (ann.image1 || ann.image2) { %>
                            <div
                                class="flex flex-col md:flex-row gap-4 mb-4"
                            >
                                <% if (ann.image1) { %>
                                    <img
                                        src="<%= ann.image1 %>"
                                        alt="<%= ann.title %>"
                                        loading="lazy"
                                        class="w-full md:w-1/2 rounded-xl object-cover border border-gray-100 max-h-[300px]"
                                    >
                                <% } %>

                                <% if (ann.image2) { %>
                                    <img
                                        src="<%= ann.image2 %>"
                                        alt="<%= ann.title %>"
                                        loading="lazy"
                                        class="w-full md:w-1/2 rounded-xl object-cover border border-gray-100 max-h-[300px]"
                                    >
                                <% } %>
                            </div>
                        <% } %>

                        <div
                            class="text-sm font-medium text-gray-600 leading-relaxed"
                        >
                            <%- formatPostText(ann.content) %>
                        </div>
                    </article>
                <% }) %>

            </div>

            <div class="flex items-center gap-4 mb-8">
                <div class="flex-grow h-px bg-gray-200"></div>

                <span
                    class="font-bold text-gray-400 uppercase tracking-widest text-xs"
                >
                    Marketplace Catalog
                </span>

                <div class="flex-grow h-px bg-gray-200"></div>
            </div>
        <% } %>

        <!-- TABS -->
        <div
            class="flex gap-6 mb-6 border-b border-gray-200 select-none justify-center md:justify-start"
            role="tablist"
        >
            <button
                type="button"
                onclick="switchTab('store')"
                id="tab-store"
                role="tab"
                aria-controls="store-grid"
                aria-selected="true"
                class="font-bold text-sm md:text-base text-blue-600 border-b-2 border-blue-600 pb-3 px-2 transition"
            >
                Store
            </button>

            <button
                type="button"
                onclick="switchTab('posts')"
                id="tab-posts"
                role="tab"
                aria-controls="posts-grid"
                aria-selected="false"
                class="font-bold text-sm md:text-base text-gray-500 border-b-2 border-transparent hover:text-gray-800 pb-3 px-2 transition"
            >
                Articles & Updates
            </button>
        </div>

        <!-- PRODUCT GRID -->
        <section
            id="store-grid"
            role="tabpanel"
            aria-labelledby="tab-store"
        >
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
            >

                <% if (safeProducts.length === 0) { %>
                    <div
                        class="col-span-full text-center py-10 font-bold text-lg text-gray-400"
                    >
                        No products found.
                    </div>
                <% } else { %>

                    <% safeProducts.forEach(product => { %>
                        <article
                            class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full p-5 relative"
                        >

                            <div class="flex items-start gap-4 mb-4">

                                <div
                                    class="w-16 h-16 shrink-0 bg-gray-50 rounded-lg overflow-hidden border border-gray-100"
                                >
                                    <img
                                        src="<%= product.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(product.title || 'Product')}&background=random&size=512` %>"
                                        alt="<%= product.title || 'Product' %>"
                                        loading="lazy"
                                        class="w-full h-full object-cover"
                                    >
                                </div>

                                <div class="flex-grow min-w-0">

                                    <span
                                        class="inline-block bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider mb-1"
                                    >
                                        <%= product.category || 'General' %>
                                    </span>

                                    <h3
                                        class="font-bold text-lg text-gray-900 leading-tight mb-1 truncate"
                                        title="<%= product.title %>"
                                    >
                                        <%= product.title %>
                                    </h3>

                                    <div
                                        class="flex items-center gap-2 flex-wrap"
                                    >
                                        <span
                                            class="text-green-600 font-black text-sm"
                                        >
                                            $<%= Number(product.price || 0).toFixed(2) %>
                                        </span>

                                        <span
                                            class="bg-gray-100 text-gray-600 font-bold text-[10px] px-2 py-0.5 rounded uppercase"
                                        >
                                            <%= product.tier || 'Standard' %>
                                        </span>
                                    </div>

                                </div>
                            </div>

                            <div
                                class="text-sm text-gray-500 mb-6 flex-grow leading-relaxed"
                            >
                                <%- formatPostText(product.description) %>
                            </div>

                            <div
                                class="mt-auto pt-4 border-t border-gray-100"
                            >
                                <button
                                    type="button"
                                    class="purchase-button w-full bg-gray-900 text-white font-bold py-2.5 rounded-lg text-sm hover:bg-gray-800 focus:ring-4 focus:ring-gray-200 transition"
                                    data-product-id="<%= product.id %>"
                                    data-product-title="<%= product.title %>"
                                    data-product-tier="<%= product.tier || 'Standard' %>"
                                    data-product-price="<%= Number(product.price || 0) %>"
                                    data-paypal-button-id="<%= product.paypal_button_id || defaultPayPalButtonId %>"
                                >
                                    Purchase
                                </button>
                            </div>

                        </article>
                    <% }) %>

                <% } %>

            </div>
        </section>

        <!-- POSTS GRID -->
        <section
            id="posts-grid"
            class="hidden"
            role="tabpanel"
            aria-labelledby="tab-posts"
        >
            <div
                class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
            >

                <% if (safePosts.length > 0) { %>

                    <% safePosts.forEach(post => { %>
                        <a
                            href="/post/<%= post.id %>"
                            class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full p-5"
                        >
                            <div
                                class="flex items-center gap-3 mb-3"
                            >
                                <span
                                    class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[10px] font-bold uppercase"
                                >
                                    Update
                                </span>

                                <span
                                    class="text-[10px] text-gray-400 font-medium"
                                >
                                    <%= new Date(post.created_at).toLocaleDateString() %>
                                </span>
                            </div>

                            <h3
                                class="font-bold text-lg text-gray-900 leading-tight mb-2"
                            >
                                <%= post.title %>
                            </h3>

                            <p
                                class="text-sm text-gray-500 line-clamp-3 mb-4 flex-grow"
                            >
                                <%= post.seo_desc || 'Read the full update...' %>
                            </p>

                            <div
                                class="text-blue-600 font-bold text-sm mt-auto"
                            >
                                Read Article &rarr;
                            </div>
                        </a>
                    <% }) %>

                <% } else { %>
                    <div
                        class="col-span-full text-center py-10 font-bold text-lg text-gray-400"
                    >
                        No updates posted yet.
                    </div>
                <% } %>

            </div>
        </section>

    </main>

    <!-- EMAIL MODAL -->
    <div
        id="emailModal"
        class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm justify-center items-center z-50 p-4"
        aria-hidden="true"
    >
        <div
            data-modal-panel
            class="bg-white rounded-2xl w-full max-w-sm overflow-y-auto shadow-2xl p-8 border border-gray-200"
            role="dialog"
            aria-modal="true"
            aria-labelledby="emailModalTitle"
        >
            <h2
                id="emailModalTitle"
                class="text-xl font-bold text-gray-900 mb-1"
            >
                Sign In / Guest
            </h2>

            <p class="text-sm text-gray-500 mb-6">
                Enter your email to receive a secure sign-in code.
            </p>

            <label
                for="authEmailInput"
                class="sr-only"
            >
                Email address
            </label>

            <input
                type="email"
                id="authEmailInput"
                placeholder="you@email.com"
                autocomplete="email"
                class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-3 font-medium outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100 text-sm mb-4"
            >

            <p
                id="emailAuthError"
                class="hidden text-sm font-semibold text-red-600 mb-4"
            ></p>

            <button
                type="button"
                onclick="sendOtp()"
                id="sendOtpBtn"
                class="w-full bg-blue-600 text-white font-bold py-3 rounded-lg hover:bg-blue-700 disabled:opacity-60 disabled:cursor-not-allowed transition"
            >
                Send Code
            </button>

            <button
                type="button"
                onclick="closeModals()"
                class="w-full mt-3 text-sm font-medium text-gray-500 hover:text-gray-800"
            >
                Cancel
            </button>
        </div>
    </div>

    <!-- OTP MODAL -->
    <div
        id="otpModal"
        class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm justify-center items-center z-50 p-4"
        aria-hidden="true"
    >
        <div
            data-modal-panel
            class="bg-white rounded-2xl w-full max-w-sm overflow-y-auto shadow-2xl p-8 border border-gray-200 text-center"
            role="dialog"
            aria-modal="true"
            aria-labelledby="otpModalTitle"
        >
            <h2
                id="otpModalTitle"
                class="text-xl font-bold text-gray-900 mb-1"
            >
                Verify Code
            </h2>

            <p class="text-sm text-gray-500 mb-6">
                Check your inbox for the six-digit code.
            </p>

            <label
                for="authOtpInput"
                class="sr-only"
            >
                Verification code
            </label>

            <input
                type="text"
                id="authOtpInput"
                inputmode="numeric"
                autocomplete="one-time-code"
                placeholder="123456"
                maxlength="6"
                class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-3 font-bold text-2xl tracking-widest outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100 mb-4 text-center text-gray-900"
            >

            <p
                id="otpAuthError"
                class="hidden text-sm font-semibold text-red-600 mb-4"
            ></p>

            <button
                type="button"
                onclick="verifyOtp()"
                id="verifyOtpBtn"
                class="w-full bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-700 disabled:opacity-60 disabled:cursor-not-allowed transition"
            >
                Verify
            </button>

            <button
                type="button"
                onclick="closeModals()"
                class="w-full mt-3 text-sm font-medium text-gray-500 hover:text-gray-800"
            >
                Cancel
            </button>
        </div>
    </div>

    <!-- CHECKOUT MODAL -->
    <div
        id="buyModal"
        class="hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm justify-center items-center z-50 p-4 overflow-y-auto"
        aria-hidden="true"
    >
        <div
            data-modal-panel
            class="bg-white rounded-2xl w-full max-w-md overflow-y-auto shadow-2xl border border-gray-200 my-auto"
            role="dialog"
            aria-modal="true"
            aria-labelledby="buyModalTitle"
        >

            <div
                class="sticky top-0 z-10 p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50"
            >
                <h2
                    id="buyModalTitle"
                    class="text-lg font-bold text-gray-900"
                >
                    Checkout
                </h2>

                <button
                    type="button"
                    onclick="closeModals()"
                    aria-label="Close checkout"
                    class="text-gray-400 hover:text-gray-700 font-bold text-2xl leading-none"
                >
                    &times;
                </button>
            </div>

            <div class="p-6">

                <div
                    class="bg-green-50 text-green-700 text-xs font-bold px-3 py-2 rounded-lg mb-5 flex items-center gap-2 border border-green-200"
                >
                    <span>Account:</span>

                    <span class="truncate">
                        <%= currentBuyerEmail %>
                    </span>
                </div>

                <div
                    class="flex items-center justify-between gap-4 mb-6 pb-4 border-b border-gray-100"
                >
                    <div class="min-w-0">
                        <p
                            class="text-xs text-gray-500 uppercase tracking-wider font-bold mb-1"
                        >
                            Item
                        </p>

                        <p
                            id="modalItemTitle"
                            class="font-bold text-gray-900 text-sm truncate"
                        ></p>

                        <p
                            id="modalItemTier"
                            class="text-xs font-medium text-gray-500 mt-1"
                        ></p>
                    </div>

                    <div class="text-right shrink-0">
                        <p
                            class="text-xs text-gray-500 uppercase tracking-wider font-bold mb-1"
                        >
                            Displayed total
                        </p>

                        <p
                            id="modalItemPrice"
                            class="font-black text-green-600 text-lg"
                        ></p>
                    </div>
                </div>

                <!--
                    This form is submitted only for Crypto or Giftcard.

                    PayPal is intentionally outside this form so PayPal's
                    generated Checkout button cannot trigger /checkout.
                -->
                <form
                    id="buyForm"
                    action="/checkout"
                    method="POST"
                    novalidate
                >
                    <input
                        type="hidden"
                        id="hiddenProductId"
                        name="product_id"
                    >

                    <input
                        type="hidden"
                        id="hiddenProductTier"
                        name="tier"
                    >

                    <input
                        type="hidden"
                        id="hiddenPaymentMethod"
                        name="payment_method"
                        value="PayPal"
                    >

                    <div class="mb-5">
                        <label
                            for="discordUsername"
                            class="block text-xs font-bold text-gray-700 mb-2"
                        >
                            Discord Username (Optional)
                        </label>

                        <input
                            type="text"
                            id="discordUsername"
                            name="discord_username"
                            placeholder="username"
                            autocomplete="off"
                            class="w-full bg-white border border-gray-300 rounded-lg px-3 py-2.5 font-medium outline-none focus:border-blue-500 focus:ring-4 focus:ring-blue-100 text-sm"
                        >
                    </div>

                    <fieldset class="mb-5">
