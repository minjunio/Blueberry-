                    <!--
                        This is a direct PayPal fallback.

                        It opens the hosted payment page in a normal tab and
                        avoids browser popup or iframe restrictions.
                    -->
                    <a
                        id="paypalFallbackLink"
                        href="https://www.paypal.com/ncp/payment/<%= defaultPayPalButtonId %>"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="mt-3 w-full border border-gray-300 bg-white text-gray-900 font-bold py-3 rounded-lg hover:bg-gray-50 transition flex items-center justify-center text-sm"
                    >
                        Open secure PayPal checkout in a new page
                    </a>

                    <p
                        class="text-[11px] leading-relaxed text-gray-500 mt-3 text-center"
                    >
                        PayPal displays the exact item, total, currency, and
                        payment options configured for this hosted button.
                    </p>
                </div>

            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer
        class="bg-white border-t border-gray-200 mt-20 relative z-20"
    >
        <div
            class="max-w-7xl mx-auto px-4 md:px-8 py-8 text-center"
        >
            <p class="text-sm font-bold text-gray-500">
                © 2026 ExamHub Marketplace. All rights reserved.
            </p>
        </div>
    </footer>

    <script>
        'use strict';

        const isAuthenticated =
            <%- JSON.stringify(Boolean(currentBuyerEmail)) %>;

        const DEFAULT_PAYPAL_BUTTON_ID =
            <%- JSON.stringify(defaultPayPalButtonId) %>;

        let userEmailToVerify = '';

        let activeProduct = {
            id: '',
            title: '',
            tier: '',
            price: 0,
            paypalButtonId: DEFAULT_PAYPAL_BUTTON_ID
        };

        /*
         * Each PayPal Hosted Button ID is rendered only once.
         *
         * Destroying and re-rendering the same hosted button repeatedly can
         * make the second generated Checkout button stop responding.
         */
        const renderedPayPalButtons = new Map();

        let searchTimer = null;
        let searchController = null;

        function getElement(id) {
            return document.getElementById(id);
        }

        function showElement(element, displayClass = 'flex') {
            if (!element) return;

            element.classList.remove('hidden');

            if (displayClass) {
                element.classList.add(displayClass);
            }

            element.setAttribute('aria-hidden', 'false');
            document.body.classList.add('modal-open');
        }

        function hideElement(element, displayClass = 'flex') {
            if (!element) return;

            element.classList.add('hidden');

            if (displayClass) {
                element.classList.remove(displayClass);
            }

            element.setAttribute('aria-hidden', 'true');
        }

        function setMessage(elementId, message) {
            const element = getElement(elementId);

            if (!element) return;

            if (message) {
                element.textContent = message;
                element.classList.remove('hidden');
            } else {
                element.textContent = '';
                element.classList.add('hidden');
            }
        }

        function normalizePayPalButtonId(value) {
            const cleaned = String(value || '')
                .trim()
                .replace(/[^a-zA-Z0-9_-]/g, '');

            return cleaned || DEFAULT_PAYPAL_BUTTON_ID;
        }

        function paypalPaymentLink(buttonId) {
            return (
                'https://www.paypal.com/ncp/payment/' +
                encodeURIComponent(buttonId)
            );
        }

        /*
         * Wait for the deferred PayPal SDK to finish loading.
         */
        function waitForPayPal(timeoutMs = 12000) {
            return new Promise((resolve, reject) => {
                const startedAt = Date.now();

                function checkPayPal() {
                    if (
                        window.paypal &&
                        typeof window.paypal.HostedButtons === 'function'
                    ) {
                        resolve(window.paypal);
                        return;
                    }

                    if (Date.now() - startedAt >= timeoutMs) {
                        reject(
                            new Error(
                                'PayPal SDK did not finish loading.'
                            )
                        );
                        return;
                    }

                    window.setTimeout(checkPayPal, 100);
                }

                checkPayPal();
            });
        }

        /*
         * Render the hosted PayPal component.
         *
         * A button ID is never rendered more than once.
         */
        async function showHostedPayPalButton(rawButtonId) {
            const buttonId =
                normalizePayPalButtonId(rawButtonId);

            const root =
                getElement('paypal-hosted-root');

            const loading =
                getElement('paypalLoading');

            const errorBox =
                getElement('paypalError');

            const fallbackLink =
                getElement('paypalFallbackLink');

            fallbackLink.href =
                paypalPaymentLink(buttonId);

            errorBox.classList.add('hidden');
            setMessage('paypalErrorMessage', '');

            /*
             * Hide previously rendered PayPal button containers.
             */
            root
                .querySelectorAll('.paypal-instance')
                .forEach(instance => {
                    instance.classList.add('hidden');
                });

            /*
             * Reuse the existing rendered PayPal iframe when the user
             * opens the same product again.
             */
            if (renderedPayPalButtons.has(buttonId)) {
                const existing =
                    renderedPayPalButtons.get(buttonId);

                existing.classList.remove('hidden');
                loading.classList.add('hidden');

                return;
            }

            loading.textContent =
                'Loading secure PayPal checkout...';

            loading.classList.remove('hidden');

            const instance =
                document.createElement('div');

            instance.className =
                'paypal-instance';

            instance.dataset.paypalButtonId =
                buttonId;

            const container =
                document.createElement('div');

            container.id =
                `paypal-container-${buttonId}`;

            container.className =
                'w-full relative z-20 pointer-events-auto';

            instance.appendChild(container);
            root.appendChild(instance);

            renderedPayPalButtons.set(
                buttonId,
                instance
            );

            try {
                const paypalApi =
                    await waitForPayPal();

                /*
                 * Wait until the modal is visible and has a real width.
                 *
                 * Rendering while display:none can cause an incorrectly sized
                 * or unresponsive PayPal iframe.
                 */
                await new Promise(resolve => {
                    requestAnimationFrame(() => {
                        requestAnimationFrame(resolve);
                    });
                });

                await paypalApi.HostedButtons({
                    hostedButtonId: buttonId
                }).render(
                    `#paypal-container-${buttonId}`
                );

                loading.classList.add('hidden');
            } catch (error) {
                console.error(
                    'PayPal HostedButtons error:',
                    error
                );

                loading.classList.add('hidden');

                renderedPayPalButtons.delete(
                    buttonId
                );

                instance.remove();

                errorBox.classList.remove('hidden');

                setMessage(
                    'paypalErrorMessage',
                    error && error.message
                        ? error.message
                        : 'PayPal could not display the embedded checkout.'
                );
            }
        }

        function openEmailModal() {
            setMessage('emailAuthError', '');

            showElement(
                getElement('emailModal')
            );

            window.setTimeout(() => {
                getElement('authEmailInput')?.focus();
            }, 50);
        }

        function openOtpModal() {
            hideElement(
                getElement('emailModal')
            );

            setMessage('otpAuthError', '');

            showElement(
                getElement('otpModal')
            );

            window.setTimeout(() => {
                getElement('authOtpInput')?.focus();
            }, 50);
        }

        function handleBuyClick(product) {
            activeProduct = {
                id: String(product.id || ''),
                title: String(
                    product.title || 'Product'
                ),
                tier: String(
                    product.tier || 'Standard'
                ),
                price: Number(
                    product.price || 0
                ),
                paypalButtonId:
                    normalizePayPalButtonId(
                        product.paypalButtonId
                    )
            };

            if (
                !Number.isFinite(activeProduct.price) ||
                activeProduct.price < 0
            ) {
                activeProduct.price = 0;
            }

            if (isAuthenticated) {
                openBuyModal();
                return;
            }

            sessionStorage.setItem(
                'pendingBuy',
                JSON.stringify(activeProduct)
            );

            openEmailModal();
        }

        function openBuyModal() {
            getElement('modalItemTitle').textContent =
                activeProduct.title;

            getElement('modalItemTier').textContent =
                activeProduct.tier;

            getElement('modalItemPrice').textContent =
                `$${activeProduct.price.toFixed(2)}`;

            getElement('hiddenProductId').value =
                activeProduct.id;

            getElement('hiddenProductTier').value =
                activeProduct.tier;

            const paypalChoice =
                document.querySelector(
                    'input[name="payment_method_choice"][value="PayPal"]'
                );

            if (paypalChoice) {
                paypalChoice.checked = true;
            }

            const giftcardLabel =
                getElement('giftcardLabel');

            const giftcardChoice =
                document.querySelector(
                    'input[name="payment_method_choice"][value="Giftcard"]'
                );

            const restrictedGiftCard =
                activeProduct.price > 900 ||
                ['custom', 'ultra'].includes(
                    activeProduct.tier.toLowerCase()
                );

            giftcardLabel.classList.toggle(
                'hidden',
                restrictedGiftCard
            );

            if (
                restrictedGiftCard &&
                giftcardChoice?.checked &&
                paypalChoice
            ) {
                paypalChoice.checked = true;
            }

            /*
             * Make the modal visible before rendering PayPal.
             */
            showElement(
                getElement('buyModal')
            );

            handlePaymentMethodChange();
        }

        function handlePaymentMethodChange() {
            const selected =
                document.querySelector(
                    'input[name="payment_method_choice"]:checked'
                );

            const paymentMethod =
                selected
                    ? selected.value
                    : 'PayPal';

            const paypalContainer =
                getElement('paypal-action-container');

            const normalContainer =
                getElement('normal-action-container');

            const hiddenPaymentMethod =
                getElement('hiddenPaymentMethod');

            hiddenPaymentMethod.value =
                paymentMethod;

            if (paymentMethod === 'PayPal') {
                paypalContainer.classList.remove(
                    'hidden'
                );

                normalContainer.classList.add(
                    'hidden'
                );

                showHostedPayPalButton(
                    activeProduct.paypalButtonId
                );
            } else {
                paypalContainer.classList.add(
                    'hidden'
                );

                normalContainer.classList.remove(
                    'hidden'
                );
            }
        }

        async function sendOtp() {
            const emailInput =
                getElement('authEmailInput');

            const button =
                getElement('sendOtpBtn');

            const email =
                emailInput.value
                    .trim()
                    .toLowerCase();

            const emailPattern =
                /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            setMessage('emailAuthError', '');

            if (!emailPattern.test(email)) {
                setMessage(
                    'emailAuthError',
                    'Enter a valid email address.'
                );

                emailInput.focus();
                return;
            }

            button.disabled = true;
            button.textContent = 'Sending...';

            try {
                const response = await fetch(
                    '/api/send-otp',
                    {
                        method: 'POST',
                        headers: {
                            'Content-Type':
                                'application/json'
                        },
                        body: JSON.stringify({
                            email
                        })
                    }
                );

                const data =
                    await response
                        .json()
                        .catch(() => ({}));

                if (
                    !response.ok ||
                    !data.success
                ) {
                    throw new Error(
                        data.message ||
                        'Unable to send the verification code.'
                    );
                }

                userEmailToVerify = email;

                openOtpModal();
            } catch (error) {
                setMessage(
                    'emailAuthError',
                    error.message ||
                    'Unable to send the verification code.'
                );
            } finally {
                button.disabled = false;
                button.textContent = 'Send Code';
            }
        }

        async function verifyOtp() {
            const otpInput =
                getElement('authOtpInput');

            const button =
                getElement('verifyOtpBtn');

            const code =
                otpInput.value
                    .replace(/\D/g, '')
                    .slice(0, 6);

            otpInput.value = code;

            setMessage('otpAuthError', '');

            if (!userEmailToVerify) {
                setMessage(
                    'otpAuthError',
                    'Your email session expired. Please request another code.'
                );

                return;
            }

            if (code.length !== 6) {
                setMessage(
                    'otpAuthError',
                    'Enter the complete six-digit code.'
                );

                otpInput.focus();
                return;
            }

            button.disabled = true;
            button.textContent = 'Verifying...';

            try {
                const response = await fetch(
                    '/api/verify-otp',
                    {
                        method: 'POST',
                        headers: {
                            'Content-Type':
                                'application/json'
                        },
                        body: JSON.stringify({
                            email:
                                userEmailToVerify,
                            code
                        })
                    }
                );

                const data =
                    await response
                        .json()
                        .catch(() => ({}));

                if (
                    !response.ok ||
                    !data.success
                ) {
                    throw new Error(
                        data.message ||
                        'The code is invalid or expired.'
                    );
                }

                window.location.reload();
            } catch (error) {
                setMessage(
                    'otpAuthError',
                    error.message ||
                    'The code is invalid or expired.'
                );
            } finally {
                button.disabled = false;
                button.textContent = 'Verify';
            }
        }

        function closeModals() {
            hideElement(
                getElement('emailModal')
            );

            hideElement(
                getElement('otpModal')
            );

            hideElement(
                getElement('buyModal')
            );

            document.body.classList.remove(
                'modal-open'
            );

            setMessage('emailAuthError', '');
            setMessage('otpAuthError', '');
        }

        function switchTab(tabId) {
            const storeButton =
                getElement('tab-store');

            const postsButton =
                getElement('tab-posts');

            const storeGrid =
                getElement('store-grid');

            const postsGrid =
                getElement('posts-grid');

            const showStore =
                tabId === 'store';

            storeGrid.classList.toggle(
                'hidden',
                !showStore
            );

            postsGrid.classList.toggle(
                'hidden',
                showStore
            );

            storeButton.setAttribute(
                'aria-selected',
                String(showStore)
            );

            postsButton.setAttribute(
                'aria-selected',
                String(!showStore)
            );

            storeButton.className =
                showStore
                    ? 'font-bold text-sm md:text-base text-blue-600 border-b-2 border-blue-600 pb-3 px-2 transition'
                    : 'font-bold text-sm md:text-base text-gray-500 border-b-2 border-transparent hover:text-gray-800 pb-3 px-2 transition';

            postsButton.className =
                !showStore
                    ? 'font-bold text-sm md:text-base text-blue-600 border-b-2 border-blue-600 pb-3 px-2 transition'
                    : 'font-bold text-sm md:text-base text-gray-500 border-b-2 border-transparent hover:text-gray-800 pb-3 px-2 transition';
        }

        function renderSearchResults(items) {
            const dropdown =
                getElement('searchDropdown');

            dropdown.replaceChildren();

            if (
                !Array.isArray(items) ||
                items.length === 0
            ) {
                dropdown.classList.add('hidden');
                dropdown.classList.remove('flex');
                return;
            }

            items.forEach(item => {
                const link =
                    document.createElement('a');

                link.href =
                    '/?q=' +
                    encodeURIComponent(
                        String(item.title || '')
                    );

                link.className =
                    'block px-4 py-3 hover:bg-gray-50 border-b border-gray-100 last:border-0';

                link.setAttribute(
                    'role',
                    'option'
                );

                const title =
                    document.createElement('div');

                title.className =
                    'font-bold text-sm text-gray-900';

                title.textContent =
                    String(
                        item.title || 'Untitled'
                    );

                const category =
                    document.createElement('div');

                category.className =
                    'text-[10px] font-bold text-gray-400 uppercase mt-0.5';

                category.textContent =
                    String(
                        item.category || 'Product'
                    );

                link.append(
                    title,
                    category
                );

                dropdown.appendChild(link);
            });

            dropdown.classList.remove('hidden');
            dropdown.classList.add('flex');
        }

        async function searchMarketplace(query) {
            if (searchController) {
                searchController.abort();
            }

            searchController =
                new AbortController();

            try {
                const response = await fetch(
                    '/api/search?q=' +
                    encodeURIComponent(query),
                    {
                        headers: {
                            Accept:
                                'application/json'
                        },
                        signal:
                            searchController.signal
                    }
                );

                if (!response.ok) {
                    throw new Error(
                        'Search request failed.'
                    );
                }

                const data =
                    await response.json();

                renderSearchResults(data);
            } catch (error) {
                if (
                    error.name !==
                    'AbortError'
                ) {
                    console.error(
                        'Search error:',
                        error
                    );

                    renderSearchResults([]);
                }
            }
        }

        document.addEventListener(
            'DOMContentLoaded',
            () => {
                const searchInput =
                    getElement('searchInput');

                const searchDropdown =
                    getElement('searchDropdown');

                const otpInput =
                    getElement('authOtpInput');

                const buyForm =
                    getElement('buyForm');

                const urlParams =
                    new URLSearchParams(
                        window.location.search
                    );

                if (
                    urlParams.get('tab') ===
                    'posts'
                ) {
                    switchTab('posts');
                }

                /*
                 * Product buttons.
                 */
                document
                    .querySelectorAll(
                        '.purchase-button'
                    )
                    .forEach(button => {
                        button.addEventListener(
                            'click',
                            () => {
                                handleBuyClick({
                                    id:
                                        button.dataset
                                            .productId,

                                    title:
                                        button.dataset
                                            .productTitle,

                                    tier:
                                        button.dataset
                                            .productTier,

                                    price:
                                        button.dataset
                                            .productPrice,

                                    paypalButtonId:
                                        button.dataset
                                            .paypalButtonId
                                });
                            }
                        );
                    });

                /*
                 * Payment-method selection.
                 */
                document
                    .querySelectorAll(
                        'input[name="payment_method_choice"]'
                    )
                    .forEach(input => {
                        input.addEventListener(
                            'change',
                            handlePaymentMethodChange
                        );
                    });

                /*
                 * Search suggestions.
                 */
                if (
                    searchInput &&
                    searchDropdown
                ) {
                    searchInput.addEventListener(
                        'input',
                        event => {
                            const value =
                                event.target.value.trim();

                            window.clearTimeout(
                                searchTimer
                            );

                            if (
                                value.length < 2
                            ) {
                                if (
                                    searchController
                                ) {
                                    searchController.abort();
                                }

                                renderSearchResults(
                                    []
                                );

                                return;
                            }

                            searchTimer =
                                window.setTimeout(
                                    () => {
                                        searchMarketplace(
                                            value
                                        );
                                    },
                                    250
                                );
                        }
                    );
                }

                document.addEventListener(
                    'click',
                    event => {
                        if (
                            searchDropdown &&
                            searchInput &&
                            !searchDropdown.contains(
                                event.target
                            ) &&
                            event.target !==
                                searchInput
                        ) {
                            searchDropdown.classList.add(
                                'hidden'
                            );

                            searchDropdown.classList.remove(
                                'flex'
                            );
                        }
                    }
                );

                /*
                 * OTP input cleanup.
                 */
                if (otpInput) {
                    otpInput.addEventListener(
                        'input',
                        () => {
                            otpInput.value =
                                otpInput.value
                                    .replace(
                                        /\D/g,
                                        ''
                                    )
                                    .slice(
                                        0,
                                        6
                                    );
                        }
                    );

                    otpInput.addEventListener(
                        'keydown',
                        event => {
                            if (
                                event.key ===
                                'Enter'
                            ) {
                                verifyOtp();
                            }
                        }
                    );
                }

                getElement(
                    'authEmailInput'
                )?.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Enter'
                        ) {
                            sendOtp();
                        }
                    }
                );

                /*
                 * Crypto and gift-card checkout only.
                 *
                 * PayPal never submits this form.
                 */
                if (buyForm) {
                    buyForm.addEventListener(
                        'submit',
                        event => {
                            const selected =
                                document.querySelector(
                                    'input[name="payment_method_choice"]:checked'
                                );

                            const method =
                                selected
                                    ? selected.value
                                    : 'PayPal';

                            if (
                                method ===
                                'PayPal'
                            ) {
                                event.preventDefault();

                                handlePaymentMethodChange();

                                return;
                            }

                            const submitButton =
                                getElement(
                                    'normalCheckoutButton'
                                );

                            submitButton.disabled =
                                true;

                            submitButton.textContent =
                                'Submitting...';
                        }
                    );
                }

                /*
                 * Close when the dark backdrop itself is clicked.
                 */
                [
                    getElement('emailModal'),
                    getElement('otpModal'),
                    getElement('buyModal')
                ].forEach(modal => {
                    modal?.addEventListener(
                        'mousedown',
                        event => {
                            if (
                                event.target ===
                                modal
                            ) {
                                closeModals();
                            }
                        }
                    );
                });

                document.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Escape'
                        ) {
                            closeModals();
                        }
                    }
                );

                /*
                 * Resume purchase after OTP sign-in.
                 */
                if (isAuthenticated) {
                    const pending =
                        sessionStorage.getItem(
                            'pendingBuy'
                        );

                    if (pending) {
                        try {
                            const parsed =
                                JSON.parse(
                                    pending
                                );

                            activeProduct = {
                                id:
                                    String(
                                        parsed.id ||
                                        ''
                                    ),

                                title:
                                    String(
                                        parsed.title ||
                                        'Product'
                                    ),

                                tier:
                                    String(
                                        parsed.tier ||
                                        'Standard'
                                    ),

                                price:
                                    Number(
                                        parsed.price ||
                                        0
                                    ),

                                paypalButtonId:
                                    normalizePayPalButtonId(
                                        parsed.paypalButtonId
                                    )
                            };

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );

                            window.setTimeout(
                                openBuyModal,
                                250
                            );
                        } catch (error) {
                            console.error(
                                'Could not restore pending purchase:',
                                error
                            );

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );
                        }
                    }
                }
            }
        );
    </script>
</body>
</html>