                            <div
                                class="text-blue-600 font-extrabold text-sm inline-flex items-center gap-2"
                            >
                                Read article

                                <svg
                                    viewBox="0 0 24 24"
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="m9 18 6-6-6-6"/>
                                </svg>
                            </div>
                        </a>
