<!DOCTYPE html>
<html lang="en">
<head>
    <%
        const safeProducts = Array.isArray(products) ? products : [];
        const safeCategories = Array.isArray(categories) ? categories : [];

        const safePosts =
            typeof posts !== 'undefined' && Array.isArray(posts)
                ? posts
                : [];

        const safeAnnouncements =
            typeof announcements !== 'undefined' && Array.isArray(announcements)
                ? announcements
                : [];

        const currentCategory =
            typeof categoryFilter !== 'undefined' && categoryFilter
                ? categoryFilter
                : 'All';

        const currentSearch =
            typeof searchQuery !== 'undefined' && searchQuery
                ? searchQuery
                : '';

        const currentBuyerEmail =
            typeof buyerEmail !== 'undefined' && buyerEmail
                ? buyerEmail
                : '';

        /*
         * Fallback PayPal payment-link ID.
         *
         * Each differently priced product should have its own
         * paypal_button_id in the product database.
         */
        const defaultPayPalButtonId = '9JMDPQQNKG9PA';

        const seoTitle =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_title
                ? categoryRow.seo_title
                : 'ExamHub Marketplace';

        const seoDesc =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_desc
                ? categoryRow.seo_desc
                : 'Browse premium digital learning tools and study resources.';

        const seoKeywords =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_keywords
                ? categoryRow.seo_keywords
                : 'exams, study tools, digital resources, education, marketplace';

        const ogImage =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.og_image
                ? categoryRow.og_image
                : 'https://examhub.shop/favicon.png';

        const canonicalUrl =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.canonical_url
                ? categoryRow.canonical_url
                : '';

        function formatPostText(text) {
            if (!text) return '';

            let safeText = String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');

            safeText = safeText.replace(
                /\*\*([\s\S]*?)\*\*/g,
                '<strong class="font-extrabold text-slate-950">$1</strong>'
            );

            safeText = safeText.replace(
                /#([^#\n]+)#/g,
                '<span class="block mt-5 mb-2 text-xl md:text-2xl font-black text-slate-950 leading-tight">$1</span>'
            );

            safeText = safeText.replace(/\n/g, '<br>');

            return safeText;
        }
    %>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1, viewport-fit=cover"
    >

    <title><%= seoTitle %></title>

    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">

    <meta
        name="robots"
        content="index, follow, max-image-preview:large"
    >

    <% if (canonicalUrl) { %>
        <link rel="canonical" href="<%= canonicalUrl %>">
    <% } %>

    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">

    <link rel="icon" type="image/png" href="/favicon.png">

    <%- include('partials/head') %>

    <style>
        :root {
            color-scheme: light;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            min-height: 100vh;
        }

        body.modal-open {
            overflow: hidden;
        }

        .page-background {
            background:
                radial-gradient(
                    circle at 12% 5%,
                    rgba(37, 99, 235, 0.11),
                    transparent 29rem
                ),
                radial-gradient(
                    circle at 90% 10%,
                    rgba(6, 182, 212, 0.10),
                    transparent 28rem
                ),
                linear-gradient(
                    180deg,
                    #f8fbff 0%,
                    #f8fafc 48%,
                    #f1f5f9 100%
                );
        }

        .background-grid {
            background-image:
                linear-gradient(
                    rgba(15, 23, 42, 0.03) 1px,
                    transparent 1px
                ),
                linear-gradient(
                    90deg,
                    rgba(15, 23, 42, 0.03) 1px,
                    transparent 1px
                );

            background-size: 38px 38px;

            -webkit-mask-image:
                linear-gradient(
                    to bottom,
                    black,
                    transparent 72%
                );

            mask-image:
                linear-gradient(
                    to bottom,
                    black,
                    transparent 72%
                );
        }

        .product-card {
            transition:
                transform 180ms ease,
                border-color 180ms ease,
                box-shadow 180ms ease;
        }

        .product-card:hover {
            transform: translateY(-3px);
            border-color: rgba(37, 99, 235, 0.25);
            box-shadow:
                0 22px 55px -32px rgba(15, 23, 42, 0.42);
        }

        .product-image {
            transition: transform 220ms ease;
        }

        .product-card:hover .product-image {
            transform: scale(1.05);
        }

        .modal-panel {
            max-height: calc(100dvh - 1.5rem);
        }

        .card-payment-button {
            position: relative;
            isolation: isolate;
            overflow: hidden;
        }

        .card-payment-button::before {
            content: '';
            position: absolute;
            inset: 0;
            z-index: -1;

            background:
                linear-gradient(
                    110deg,
                    transparent 25%,
                    rgba(255, 255, 255, 0.19) 45%,
                    transparent 65%
                );

            transform: translateX(-120%);
            transition: transform 500ms ease;
        }

        .card-payment-button:hover::before {
            transform: translateX(120%);
        }

        .card-payment-button.is-loading {
            pointer-events: none;
            opacity: 0.82;
        }

        .payment-spinner {
            width: 18px;
            height: 18px;
            border: 2px solid rgba(255, 255, 255, 0.35);
            border-top-color: #ffffff;
            border-radius: 9999px;
            animation: payment-spin 650ms linear infinite;
        }

        @keyframes payment-spin {
            to {
                transform: rotate(360deg);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                scroll-behavior: auto !important;
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>

