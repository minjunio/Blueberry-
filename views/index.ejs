<!DOCTYPE html>
<html lang="en">
<head>
    <% 
        const seoTitle = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_title) ? categoryRow.seo_title : 'ExamHub - Professional Marketplace';
        const seoDesc = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_desc) ? categoryRow.seo_desc : 'The ultimate exam marketplace for top-rated study tools and bypasses.';
        const seoKeywords = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_keywords) ? categoryRow.seo_keywords : 'exams, study tools, bypasses, marketplace';
        const ogImage = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.og_image) ? categoryRow.og_image : 'https://examhub.shop/favicon.png';
        const canonicalUrl = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.canonical_url) ? categoryRow.canonical_url : '';

        function formatPostText(text) {
            if (!text) return '';
            let safeText = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&apos;');
            safeText = safeText.replace(/\*\*([\s\S]*?)\*\*/g, '<strong class="font-bold text-gray-900">$1</strong>');
            safeText = safeText.replace(/#([\s\S]*?)#/g, '<span class="text-xl md:text-2xl font-bold block mt-4 mb-2 text-gray-900 leading-tight">$1</span>');
            safeText = safeText.replace(/\n/g, '<br>');
            return safeText;
        }
    %>
    <title><%= seoTitle %></title>
    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">
    <meta name="robots" content="index, follow, max-image-preview:large">
    <% if (canonicalUrl) { %> <link rel="canonical" href="<%= canonicalUrl %>"> <% } %>
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>

    <script src="https://www.paypal.com/sdk/js?client-id=BAACqOV8IkLP3i0-_Ty6IA7zt5_OxtawbH5tAUCjenPO6KcpDgcEscgNhhZCTP9dVtHBQB6BrxF5QoOBnM&currency=USD&components=buttons"></script>
</head>

<body class="antialiased flex flex-col bg-gray-50 text-gray-800">
    <nav class="border-b border-gray-200 bg-white sticky top-0 z-40 shadow-sm">
        <div class="py-4 px-6 md:px-8 flex justify-between items-center max-w-7xl mx-auto w-full">
            <a href="/" class="text-2xl font-extrabold tracking-tight text-gray-900">Exam<span class="text-blue-600">Hub</span></a>
            
            <div class="flex items-center gap-3">
                <a href="https://discord.gg/bg6wKj45w3" target="_blank" class="hidden md:flex items-center gap-2 bg-[#5865F2] hover:bg-[#4752C4] text-white px-4 py-2 rounded-md font-semibold text-sm transition">
                    Discord Support
                </a>
                
                <% if (typeof buyerEmail !== 'undefined' && buyerEmail) { %>
                    <a href="/my-orders" class="bg-gray-900 text-white hover:bg-gray-800 px-4 py-2 rounded-md font-semibold text-sm transition flex items-center gap-2">
                        My Orders
                        <% if (typeof activeOrderCount !== 'undefined' && activeOrderCount > 0) { %>
                            <span class="bg-blue-500 text-white text-xs px-2 py-0.5 rounded-sm"><%= activeOrderCount %></span>
                        <% } %>
                    </a>
                    <a href="/buyer-logout" class="ml-2 text-sm font-medium text-gray-500 hover:text-red-600 transition hidden md:block">Logout</a>
                <% } %>

                <% if (typeof user !== 'undefined' && user) { %>
                    <a href="/admin" class="ml-2 bg-white hover:bg-gray-50 px-4 py-2 rounded-md font-semibold text-sm transition border border-gray-300">Admin Panel</a>
                <% } else if (typeof buyerEmail === 'undefined' || !buyerEmail) { %>
                    <a href="/login" class="ml-2 bg-white hover:bg-gray-50 px-4 py-2 rounded-md font-semibold text-sm transition border border-gray-300">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <header class="flex flex-col items-center text-center px-4 pt-16 pb-12 relative z-10 bg-white border-b border-gray-200">
        <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900 mb-4">Professional <span class="text-blue-600">Study Marketplace</span></h1>
        <p class="text-gray-500 font-medium mb-8 max-w-xl">Securely browse and acquire top-tier exams, tools, and bypasses tailored for academic excellence.</p>
        
        <div class="w-full max-w-2xl relative">
            <form action="/" method="GET" class="relative flex shadow-sm rounded-md">
                <% if (typeof categoryFilter !== 'undefined' && categoryFilter && categoryFilter !== 'All') { %> <input type="hidden" name="category" value="<%= categoryFilter %>"> <% } %>
                <input type="text" id="searchInput" name="q" autocomplete="off" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" placeholder="Search products, tools..." class="w-full bg-white border border-gray-300 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 rounded-l-md py-3 pl-4 pr-10 outline-none text-base font-medium transition">
                <button type="submit" class="bg-blue-600 text-white px-6 py-3 rounded-r-md font-semibold hover:bg-blue-700 transition border border-transparent">Search</button>
            </form>
            <div id="searchDropdown" class="hidden absolute top-full left-0 w-full bg-white border border-gray-200 rounded-md mt-1 shadow-lg overflow-hidden z-50 flex flex-col text-left"></div>
        </div>

        <div class="flex flex-wrap justify-center gap-2 mt-8 max-w-4xl">
            <a href="/" class="px-4 py-1.5 rounded-md font-semibold text-sm border <%= (!typeof categoryFilter !== 'undefined' || categoryFilter === 'All') ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-600 border-gray-300 hover:border-gray-400' %>">All</a>
            <% categories.forEach(cat => { %>
                <a href="/category/<%= encodeURIComponent(cat.name) %>" class="px-4 py-1.5 rounded-md font-semibold text-sm border <%= typeof categoryFilter !== 'undefined' && categoryFilter === cat.name ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-600 border-gray-300 hover:border-gray-400' %>"><%= cat.name %></a>
            <% }) %>
        </div>
    </header>

    <main class="flex-grow w-full max-w-7xl mx-auto px-4 md:px-8 relative z-20 py-12">
        
        <% if (typeof announcements !== 'undefined' && announcements && announcements.length > 0) { %>
            <div class="mb-12 space-y-6">
                <% announcements.forEach(ann => { %>
                    <div class="bg-white rounded-md p-6 md:p-8 shadow-sm border border-blue-200 border-l-4 border-l-blue-600">
                        <div class="inline-block bg-blue-100 text-blue-800 font-bold text-xs px-2 py-1 rounded-sm uppercase tracking-wide mb-3"><%= ann.category %> Update</div>
                        <h2 class="text-2xl font-bold text-gray-900 mb-4"><%= ann.title %></h2>
                        
                        <div class="flex flex-col md:flex-row gap-4 mb-4">
                            <% if (ann.image1) { %>
                                <img src="<%= ann.image1 %>" alt="Announcement Image 1" class="w-full md:w-1/2 rounded-md object-cover border border-gray-200" style="max-height: 300px;">
                            <% } %>
                            <% if (ann.image2) { %>
                                <img src="<%= ann.image2 %>" alt="Announcement Image 2" class="w-full md:w-1/2 rounded-md object-cover border border-gray-200" style="max-height: 300px;">
                            <% } %>
                        </div>
                        
                        <div class="text-sm font-medium text-gray-600 leading-relaxed"><%- formatPostText(ann.content) %></div>
                    </div>
                <% }) %>
            </div>
            <hr class="border-gray-200 mb-10">
        <% } %>

        <div class="flex gap-8 mb-8 border-b border-gray-200 select-none">
            <button onclick="switchTab('store')" id="tab-store" class="font-bold text-lg text-blue-600 border-b-2 border-blue-600 pb-3 px-1 transition whitespace-nowrap">Catalog</button>
            <button onclick="switchTab('posts')" id="tab-posts" class="font-bold text-lg text-gray-500 border-b-2 border-transparent hover:text-gray-800 pb-3 px-1 transition whitespace-nowrap">News & Updates</button>
        </div>

        <div id="store-grid">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                <% if (products.length === 0) { %>
                    <div class="col-span-full text-center py-12 font-medium text-gray-500 border border-dashed border-gray-300 rounded-md">No products found for this category.</div>
                <% } else { %>
                    <% products.forEach(product => { %>
                        <div class="bg-white border border-gray-200 rounded-md shadow-sm hover:shadow-md transition flex flex-col h-full overflow-hidden">
                            <div class="p-5 border-b border-gray-100 flex items-start gap-4 bg-gray-50/50">
                                <div class="w-16 h-16 shrink-0 bg-white rounded-md overflow-hidden border border-gray-200">
                                    <img src="<%= product.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(product.title || 'Product')}&background=random&size=512` %>" alt="<%= product.title %>" class="w-full h-full object-cover">
                                </div>
                                <div class="flex-grow pt-1">
                                    <span class="inline-block bg-gray-200 text-gray-700 px-2 py-0.5 rounded-sm font-bold text-[10px] uppercase tracking-wide mb-1.5"><%= product.category %></span>
                                    <h3 class="font-bold text-base text-gray-900 leading-tight break-words"><%= product.title %></h3>
                                </div>
                            </div>
                            
                            <div class="p-5 flex-grow flex flex-col">
                                <div class="flex items-center justify-between mb-4">
                                    <span class="text-xl font-extrabold text-gray-900">$<%= Number(product.price || 0).toFixed(2) %></span>
                                    <span class="bg-blue-50 text-blue-700 font-semibold text-xs px-2 py-1 rounded-sm border border-blue-100"><%= product.tier || 'Standard' %></span>
                                </div>
                                <div class="text-sm text-gray-600 mb-6 flex-grow line-clamp-3"><%- formatPostText(product.description) %></div>
                                
                                <button onclick="handleBuyClick('<%= product.id %>', '<%= product.title.replace(/'/g, "\\'") %>', '<%= product.tier || 'Standard' %>', '<%= product.price %>')" class="w-full bg-gray-900 text-white font-semibold py-2.5 rounded-md hover:bg-gray-800 transition text-sm">
                                    Purchase Item
                                </button>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <div id="posts-grid" class="hidden">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                        <a href="/post/<%= post.id %>" class="bg-white border border-gray-200 rounded-md shadow-sm hover:shadow-md transition flex flex-col h-full p-5">
                            <div class="flex items-center gap-3 mb-3">
                                <span class="bg-gray-100 text-gray-600 px-2 py-0.5 rounded-sm font-bold text-[10px] uppercase tracking-wide">Article</span>
                                <span class="text-xs text-gray-400 font-medium"><%= new Date(post.created_at).toLocaleDateString() %></span>
                            </div>
                            <h3 class="font-bold text-lg text-gray-900 mb-2 group-hover:text-blue-600 transition"><%= post.title %></h3>
                            <p class="text-sm text-gray-600 mb-4 flex-grow"><%= post.seo_desc || 'Read the full update to learn more...' %></p>
                            <span class="text-sm font-semibold text-blue-600">Read More &rarr;</span>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-12 font-medium text-gray-500 border border-dashed border-gray-300 rounded-md">No updates posted yet.</div>
                <% } %>
            </div>
        </div>
    </main>

    <div id="emailModal" class="hidden fixed inset-0 bg-gray-900/80 justify-center items-center z-50 p-4">
        <div class="bg-white rounded-md w-full max-w-sm shadow-2xl p-6 border border-gray-200">
            <div class="mb-5 border-b border-gray-100 pb-4">
                <h2 class="text-xl font-bold text-gray-900">Identity Verification</h2>
                <p class="text-xs text-gray-500 mt-1">Enter your email to receive a secure access code.</p>
            </div>
            <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Email Address</label>
            <input type="email" id="authEmailInput" placeholder="address@domain.com" class="w-full bg-white border border-gray-300 rounded-md px-3 py-2.5 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-sm mb-4">
            
            <div class="flex gap-3 mt-6">
                <button onclick="closeModals()" class="flex-1 bg-gray-100 text-gray-700 font-semibold py-2.5 rounded-md hover:bg-gray-200 transition text-sm">Cancel</button>
                <button onclick="sendOtp()" id="sendOtpBtn" class="flex-1 bg-blue-600 text-white font-semibold py-2.5 rounded-md hover:bg-blue-700 transition text-sm shadow-sm">Send Code</button>
            </div>
        </div>
    </div>

    <div id="otpModal" class="hidden fixed inset-0 bg-gray-900/80 justify-center items-center z-50 p-4">
        <div class="bg-white rounded-md w-full max-w-sm shadow-2xl p-6 border border-gray-200">
            <div class="mb-5 border-b border-gray-100 pb-4">
                <h2 class="text-xl font-bold text-gray-900">Enter Security Code</h2>
                <p class="text-xs text-gray-500 mt-1">Check your inbox for the 6-digit pin.</p>
            </div>
            <input type="text" id="authOtpInput" placeholder="••••••" maxlength="6" class="w-full bg-white border border-gray-300 rounded-md px-4 py-3 font-mono text-2xl tracking-[0.5em] text-center outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 mb-4">
            
            <div class="flex gap-3 mt-6">
                <button onclick="closeModals()" class="flex-1 bg-gray-100 text-gray-700 font-semibold py-2.5 rounded-md hover:bg-gray-200 transition text-sm">Cancel</button>
                <button onclick="verifyOtp()" id="verifyOtpBtn" class="flex-1 bg-gray-900 text-white font-semibold py-2.5 rounded-md hover:bg-gray-800 transition text-sm shadow-sm">Verify</button>
            </div>
        </div>
    </div>

    <div id="buyModal" class="hidden fixed inset-0 bg-gray-900/80 justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white rounded-md w-full max-w-md shadow-2xl border border-gray-200 my-8">
            
            <div class="p-5 border-b border-gray-200 bg-gray-50 flex justify-between items-center rounded-t-md">
                <h2 class="text-lg font-bold text-gray-900">Secure Checkout</h2>
                <button onclick="closeModals()" class="text-gray-400 hover:text-gray-600 font-bold text-xl leading-none">&times;</button>
            </div>

            <div class="p-6">
                <div class="bg-blue-50 text-blue-800 text-xs font-semibold px-3 py-2 rounded-sm mb-6 border border-blue-100 flex items-center gap-2">
                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    Authenticated as: <span class="truncate"><%= typeof buyerEmail !== 'undefined' ? buyerEmail : '' %></span>
                </div>
                
                <div class="flex justify-between items-center mb-6 pb-6 border-b border-gray-100">
                    <div>
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1">Item Selected</p>
                        <p id="modalItemTitle" class="font-bold text-gray-900 text-sm"></p>
                    </div>
                    <div class="text-right">
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1">Total</p>
                        <p id="modalItemPrice" class="font-extrabold text-lg text-gray-900"></p>
                    </div>
                </div>

                <form id="buyForm" action="/checkout" method="POST">
                    <input type="hidden" id="hiddenProductId" name="product_id">
                    <input type="hidden" id="hiddenProductTier" name="tier">

                    <div class="mb-5">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Discord Username (Optional)</label>
                        <input type="text" name="discord_username" placeholder="user#1234 or @user" class="w-full bg-white border border-gray-300 rounded-md px-3 py-2 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 text-sm">
                    </div>

                    <div class="mb-2">
                        <label class="block text-xs font-bold text-gray-700 uppercase tracking-wide mb-2">Payment Method</label>
                        <div class="grid grid-cols-2 gap-3">
                            
                            <label class="cursor-pointer relative block">
                                <input type="radio" name="payment_method" value="PayPal" class="peer sr-only" checked onchange="togglePaymentView()">
                                <div class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition text-center shadow-sm">
                                    <p class="font-bold text-sm text-gray-900">PayPal / Card</p>
                                </div>
                            </label>

                            <label class="cursor-pointer relative block">
                                <input type="radio" name="payment_method" value="Crypto" class="peer sr-only" onchange="togglePaymentView()">
                                <div class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50 peer-checked:border-gray-900 peer-checked:bg-gray-50 transition text-center shadow-sm">
                                    <p class="font-bold text-sm text-gray-900">Crypto</p>
                                </div>
                            </label>

                            <label id="giftcardLabel" class="cursor-pointer relative block col-span-2">
                                <input type="radio" name="payment_method" value="Giftcard" class="peer sr-only" onchange="togglePaymentView()">
                                <div class="rounded-md border border-gray-300 bg-white p-3 hover:bg-gray-50 peer-checked:border-gray-900 peer-checked:bg-gray-50 transition text-center shadow-sm">
                                    <p class="font-bold text-sm text-gray-900">Kinguin / G2A Giftcard</p>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div id="paypalSection" class="mt-6">
                        <div id="paypal-button-container" class="w-full min-h-[150px] relative z-0"></div>
                    </div>

                    <div id="alternateSubmitSection" class="mt-6 hidden">
                        <button type="submit" class="w-full bg-gray-900 text-white font-semibold py-3 rounded-md hover:bg-gray-800 transition shadow-sm">
                            Create Manual Order
                        </button>
                        <p class="text-[11px] text-center text-gray-500 font-medium mt-3">You will receive instructions on the next page.</p>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <footer class="bg-white border-t border-gray-200 mt-20 relative z-20">
        <div class="max-w-7xl mx-auto px-6 md:px-8 py-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-xl font-bold text-gray-900">Exam<span class="text-blue-600">Hub</span></p>
            <p class="text-sm font-medium text-gray-500">© 2026 Professional Marketplace. All rights reserved.</p>
        </div>
    </footer>

    <script>
        const isAuthenticated = <%= typeof buyerEmail !== 'undefined' && !!buyerEmail %>;
        let pendingBuyData = null;
        let userEmailToVerify = null;
        let currentProductPrice = 0;
        let paypalButtonsRendered = false;

        // UI toggles
        function togglePaymentView() {
            const method = document.querySelector('input[name="payment_method"]:checked').value;
            if(method === 'PayPal') {
                document.getElementById('paypalSection').classList.remove('hidden');
                document.getElementById('alternateSubmitSection').classList.add('hidden');
            } else {
                document.getElementById('paypalSection').classList.add('hidden');
                document.getElementById('alternateSubmitSection').classList.remove('hidden');
            }
        }

        // ==================== LOGIN + BUY FLOW ====================
        function handleBuyClick(id, title, tier, price) {
            if (isAuthenticated) {
                openBuyModal(id, title, tier, price);
            } else {
                pendingBuyData = { id, title, tier, price };
                sessionStorage.setItem('pendingBuy', JSON.stringify(pendingBuyData));
                document.getElementById('emailModal').classList.remove('hidden');
                document.getElementById('emailModal').classList.add('flex');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            if(urlParams.get('tab') === 'posts') switchTab('posts');

            if (isAuthenticated) {
                const savedPending = sessionStorage.getItem('pendingBuy');
                if (savedPending) {
                    const data = JSON.parse(savedPending);
                    sessionStorage.removeItem('pendingBuy'); 
                    setTimeout(() => openBuyModal(data.id, data.title, data.tier, data.price), 300);
                }
            }
        });

        // SEARCH
        const searchInput = document.getElementById('searchInput');
        const searchDropdown = document.getElementById('searchDropdown');

        if(searchInput && searchDropdown) {
            searchInput.addEventListener('input', async (e) => {
                const val = e.target.value.trim();
                if (val.length < 2) { searchDropdown.classList.add('hidden'); return; }
                const res = await fetch('/api/search?q=' + encodeURIComponent(val));
                const data = await res.json();
                if (data.length > 0) {
                    searchDropdown.innerHTML = data.map(item => `<a href="/?q=\( {encodeURIComponent(item.title)}" class="block px-4 py-3 hover:bg-gray-50 border-b border-gray-100 last:border-0"><div class="font-bold text-sm text-gray-900"> \){item.title}</div><div class="text-[10px] font-bold text-gray-500 uppercase tracking-wide">${item.category}</div></a>`).join('');
                    searchDropdown.classList.remove('hidden');
                } else { searchDropdown.classList.add('hidden'); }
            });
        }

        async function sendOtp() {
            const email = document.getElementById('authEmailInput').value;
            if (!email || !email.includes('@')) return alert("Enter a valid email.");
            
            document.getElementById('sendOtpBtn').innerText = 'Sending...';
            document.getElementById('sendOtpBtn').disabled = true;

            const res = await fetch('/api/send-otp', {
                method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ email })
            });
            const data = await res.json();
            
            if (data.success) {
                userEmailToVerify = email;
                document.getElementById('emailModal').classList.add('hidden');
                document.getElementById('otpModal').classList.remove('hidden');
                document.getElementById('otpModal').classList.add('flex');
            } else {
                alert("Error sending email. Please try again.");
                document.getElementById('sendOtpBtn').innerText = 'Send Code';
                document.getElementById('sendOtpBtn').disabled = false;
            }
        }

        async function verifyOtp() {
            const code = document.getElementById('authOtpInput').value;
            if (code.length !== 6) return alert("Enter the 6 digit code.");
            
            const res = await fetch('/api/verify-otp', {
                method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ email: userEmailToVerify, code })
            });
            const data = await res.json();

            if (data.success) {
                window.location.reload();
            } else {
                alert("Invalid or expired code.");
            }
        }

        function openBuyModal(id, title, tier, price) {
            document.getElementById('modalItemTitle').innerText = title;
            document.getElementById('modalItemPrice').innerText = `$${parseFloat(price).toFixed(2)}`;
            document.getElementById('hiddenProductId').value = id;
            document.getElementById('hiddenProductTier').value = tier;
            currentProductPrice = parseFloat(price || 0);

            const giftcardLabel = document.getElementById('giftcardLabel');
            
            document.querySelector('input[name="payment_method"][value="PayPal"]').checked = true;
            togglePaymentView();

            if (currentProductPrice > 900 || tier === 'Custom' || tier === 'Ultra') {
                giftcardLabel.classList.add('hidden');
            } else {
                giftcardLabel.classList.remove('hidden');
            }

            document.getElementById('buyModal').classList.remove('hidden');
            document.getElementById('buyModal').classList.add('flex');

            // Render PayPal Buttons Dynamically
            renderPayPal();
        }

        function renderPayPal() {
            const container = document.getElementById('paypal-button-container');
            container.innerHTML = ''; // Clear previous instances
            
            if (typeof paypal !== 'undefined') {
                paypal.Buttons({
                    style: {
                        layout: 'vertical',
                        color:  'blue',
                        shape:  'rect',
                        label:  'checkout',
                        height: 45
                    },
                    createOrder: function(data, actions) {
                        return actions.order.create({
                            purchase_units: [{
                                amount: { value: currentProductPrice.toFixed(2) },
                                description: 'ExamHub Order - ' + document.getElementById('modalItemTitle').innerText
                            }]
                        });
                    },
                    onApprove: function(data, actions) {
                        return actions.order.capture().then(function(details) {
                            // Step 1: Create Order via Form Submission in background
                            const formData = new URLSearchParams(new FormData(document.getElementById('buyForm')));
                            fetch('/checkout', {
                                method: 'POST',
                                body: formData
                            }).then(res => {
                                // Step 2: Grab the order ID from the redirected URL path
                                const url = new URL(res.url);
                                const orderId = url.pathname.split('/').pop();
                                
                                if(orderId && orderId !== 'checkout') {
                                    // Step 3: Update Order Status to Paid
                                    fetch('/api/order/' + orderId + '/update', {
                                        method: 'POST',
                                        headers: {'Content-Type': 'application/json'},
                                        body: JSON.stringify({ 
                                            status: 'Paid - Awaiting delivery', 
                                            paypal_capture_id: details.id 
                                        })
                                    }).then(() => {
                                        // Final Step: Redirect to order page to show Success State
                                        window.location.href = res.url;
                                    });
                                } else {
                                    window.location.href = '/my-orders';
                                }
                            });
                        });
                    },
                    onError: function(err) {
                        console.error('PayPal Error', err);
                        alert('Payment failed or cancelled.');
                    }
                }).render('#paypal-button-container');
            }
        }

        function closeModals() {
            document.getElementById('emailModal').classList.add('hidden');
            document.getElementById('emailModal').classList.remove('flex');
            document.getElementById('otpModal').classList.add('hidden');
            document.getElementById('otpModal').classList.remove('flex');
            document.getElementById('buyModal').classList.add('hidden');
            document.getElementById('buyModal').classList.remove('flex');
            document.getElementById('buyForm').reset();
            document.getElementById('paypal-button-container').innerHTML = '';
        }

        function switchTab(tabId) {
            const storeBtn = document.getElementById('tab-store');
            const postsBtn = document.getElementById('tab-posts');
            const storeGrid = document.getElementById('store-grid');
            const postsGrid = document.getElementById('posts-grid');

            if (tabId === 'store') {
                storeGrid.classList.remove('hidden');
                postsGrid.classList.add('hidden');
                storeBtn.classList.add('border-blue-600', 'text-blue-600');
                storeBtn.classList.remove('border-transparent', 'text-gray-500');
                postsBtn.classList.remove('border-blue-600', 'text-blue-600');
                postsBtn.classList.add('border-transparent', 'text-gray-500');
            } else {
                postsGrid.classList.remove('hidden');
                storeGrid.classList.add('hidden');
                postsBtn.classList.add('border-blue-600', 'text-blue-600');
                postsBtn.classList.remove('border-transparent', 'text-gray-500');
                storeBtn.classList.remove('border-blue-600', 'text-blue-600');
                storeBtn.classList.add('border-transparent', 'text-gray-500');
            }
        }
    </script>
</body>
</html>
