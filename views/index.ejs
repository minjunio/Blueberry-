<!DOCTYPE html>
<html lang="en">
<head>
    <% 
        const seoTitle = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_title) ? categoryRow.seo_title : 'ExamHub ✨ Marketplace';
        const seoDesc = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_desc) ? categoryRow.seo_desc : 'The ultimate exam marketplace for top-rated study tools and bypasses.';
        const seoKeywords = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_keywords) ? categoryRow.seo_keywords : 'exams, study tools, bypasses, marketplace, honorlock, lockdown browser';
        const ogImage = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.og_image) ? categoryRow.og_image : 'https://examhub.shop/favicon.png';
        const canonicalUrl = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.canonical_url) ? categoryRow.canonical_url : '';

        function formatPostText(text) {
            if (!text) return '';
            let safeText = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');
            safeText = safeText.replace(/\*\*(.*?)\*\*/g, '<strong class="font-black text-anime-textMain">$1</strong>');
            safeText = safeText.replace(/#(.*?)#/g, '<span class="text-xl md:text-2xl font-black block mt-4 mb-2 text-anime-textMain leading-tight">$1</span>');
            safeText = safeText.replace(/\n/g, '<br>');
            return safeText;
        }
    %>
    <title><%= seoTitle %></title>
    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">
    <meta name="robots" content="index, follow, max-image-preview:large">
    <% if (canonicalUrl) { %> <link rel="canonical" href="<%= canonicalUrl %>"> <% } %>
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
</head>
<body class="antialiased flex flex-col">
    <nav class="py-6 px-4 md:px-8 flex justify-between items-center max-w-7xl mx-auto w-full relative z-20">
        <a href="/" class="text-2xl md:text-3xl font-black text-anime-textMain">Exam<span class="text-anime-accent">Hub</span></a>
        
        <div class="flex items-center gap-2">
            <a href="https://discord.gg/bg6wKj45w3" target="_blank" class="hidden md:flex items-center gap-1.5 bg-[#5865F2] hover:bg-[#4752C4] text-white px-4 py-2 rounded-full font-black text-sm shadow-sm transition">Discord</a>
            
            <% if (typeof buyerEmail !== 'undefined' && buyerEmail) { %>
                <a href="/my-orders" class="bg-gray-100 hover:bg-gray-200 px-4 py-2 rounded-full font-black text-sm text-anime-textMain transition shadow-sm border border-gray-200">📦 My Orders</a>
                <a href="/buyer-logout" class="ml-1 text-sm font-bold text-gray-400 hover:text-red-500 transition">Logout</a>
            <% } %>

            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/admin" class="ml-2 bg-white hover:bg-anime-pink px-4 md:px-5 py-2 rounded-full font-black text-sm shadow-sm transition border border-gray-200">Admin</a>
            <% } else { %>
                <a href="/login" class="ml-2 bg-white hover:bg-anime-pink px-4 md:px-5 py-2 rounded-full font-black text-sm shadow-sm transition border border-gray-200">Login</a>
            <% } %>
        </div>
    </nav>

    <header class="flex flex-col items-center text-center px-4 pt-6 pb-10 relative z-10 animate-fade-in-up">
        <h1 class="text-4xl md:text-6xl font-black mb-6">Master Your <span class="text-anime-accent relative inline-block">Exams</span></h1>
        <div class="w-full max-w-2xl relative">
            <form action="/" method="GET" class="relative">
                <% if (categoryFilter && categoryFilter !== 'All') { %> <input type="hidden" name="category" value="<%= categoryFilter %>"> <% } %>
                <input type="text" id="searchInput" name="q" autocomplete="off" value="<%= searchQuery || '' %>" placeholder="Search exams, bypasses..." class="w-full bg-white border-2 border-white focus:border-anime-accent rounded-full py-4 pl-6 pr-24 outline-none shadow-[0_8px_20px_rgba(0,0,0,0.04)] text-base md:text-lg font-bold transition">
                <button type="submit" class="absolute right-2 top-2 bg-anime-accent text-white px-4 md:px-6 py-2 rounded-full font-black">Search</button>
            </form>
            <div id="searchDropdown" class="hidden absolute top-full left-0 w-full bg-white/95 backdrop-blur-xl border-2 border-white rounded-2xl mt-2 shadow-xl overflow-hidden z-50 flex flex-col text-left"></div>
        </div>

        <div class="flex flex-wrap justify-center gap-2 mt-8 max-w-4xl">
            <a href="/" class="px-3 md:px-4 py-2 rounded-full font-black text-xs md:text-sm border-2 <%= (!categoryFilter || categoryFilter === 'All') ? 'bg-anime-textMain text-white border-anime-textMain' : 'bg-white/80 border-transparent hover:border-anime-accent' %>">All</a>
            <% categories.forEach(cat => { %>
                <a href="/category/<%= encodeURIComponent(cat.name) %>" class="px-3 md:px-4 py-2 rounded-full font-black text-xs md:text-sm border-2 <%= categoryFilter === cat.name ? 'bg-anime-textMain text-white border-anime-textMain' : 'bg-white/80 border-transparent hover:border-anime-accent' %>"><%= cat.name %></a>
            <% }) %>
        </div>
    </header>

    <main class="flex-grow w-full max-w-6xl mx-auto px-4 md:px-6 relative z-20 pb-20">
        
        <% if (announcements && announcements.length > 0) { %>
            <div class="mb-12 space-y-10">
                <% announcements.forEach(ann => { %>
                    <div class="bg-white rounded-3xl p-6 md:p-10 shadow-xl border-4 border-anime-skyLight animate-fade-in-up">
                        <div class="inline-block bg-blue-100 text-blue-700 font-black text-[10px] px-3 py-1 rounded-full uppercase tracking-wider mb-4"><%= ann.category %> Announcement</div>
                        <h2 class="text-3xl md:text-4xl font-black mb-6 text-anime-textMain"><%= ann.title %></h2>
                        
                        <div class="flex flex-col md:flex-row gap-4 mb-6">
                            <% if (ann.image1) { %>
                                <img src="<%= ann.image1 %>" alt="Announcement Image 1" class="w-full md:w-1/2 rounded-2xl object-cover border-2 border-gray-100 shadow-sm" style="max-height: 400px;">
                            <% } %>
                            <% if (ann.image2) { %>
                                <img src="<%= ann.image2 %>" alt="Announcement Image 2" class="w-full md:w-1/2 rounded-2xl object-cover border-2 border-gray-100 shadow-sm" style="max-height: 400px;">
                            <% } %>
                        </div>
                        
                        <div class="text-sm md:text-base font-medium text-gray-700 leading-relaxed"><%- formatPostText(ann.content) %></div>
                    </div>
                <% }) %>
            </div>
            <div class="flex items-center gap-4 mb-10 opacity-50">
                <div class="flex-grow h-[2px] bg-gray-300 rounded-full"></div>
                <span class="font-black text-gray-400 uppercase tracking-widest text-xs">Store Catalog</span>
                <div class="flex-grow h-[2px] bg-gray-300 rounded-full"></div>
            </div>
        <% } %>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            <% if (products.length === 0) { %>
                <div class="col-span-full text-center py-10 font-black text-xl md:text-2xl text-anime-textDark">No products found.</div>
            <% } else { %>
                <% products.forEach(product => { %>
                    <div class="glass-card group hover:scale-[1.02] transition-all duration-300 flex flex-col h-full p-5 md:p-6 relative">
                        <div class="flex items-start gap-4 mb-4 mt-2">
                            <div class="w-16 h-16 md:w-20 md:h-20 shrink-0 bg-gray-100 rounded-2xl overflow-hidden shadow-sm border-2 border-white">
                                <img src="<%= product.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(product.title || 'Product')}&background=random&size=512` %>" alt="<%= product.title %>" class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                            </div>
                            <div class="flex-grow pt-1 overflow-hidden">
                                <span class="inline-block bg-gray-100 border border-gray-200 px-2 py-0.5 rounded-md font-black text-[10px] text-gray-500 uppercase tracking-wider mb-2"><%= product.category %></span>
                                <h3 class="font-black text-lg md:text-xl text-anime-textMain leading-tight mb-2 break-words"><%= product.title %></h3>
                                <div class="flex items-center gap-2 flex-wrap">
                                    <span class="bg-green-100 text-green-700 font-black text-sm px-2 py-0.5 rounded-lg">$<%= Number(product.price || 0).toFixed(2) %></span>
                                    <span class="bg-purple-100 text-purple-700 font-black text-xs px-2 py-1 rounded-lg uppercase tracking-wider"><%= product.tier || 'Standard' %></span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="text-sm font-medium text-gray-600 mb-6 flex-grow leading-relaxed break-words"><%- formatPostText(product.description) %></div>
                        <div class="mt-auto pt-4 border-t-2 border-dashed border-gray-100">
                            <div class="flex gap-2">
                                <button onclick="handleBuyClick('<%= product.id %>', '<%= product.title %>', '<%= product.tier || 'Standard' %>', '<%= product.price %>')" class="flex-grow bg-anime-textMain text-white font-black py-2.5 rounded-xl text-sm hover:bg-gray-800 transition">Buy Now</button>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <div id="emailModal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm justify-center items-center z-50 p-4">
        <div class="bg-white rounded-3xl w-full max-w-md overflow-hidden shadow-2xl p-8 text-center animate-fade-in-up">
            <h2 class="text-2xl font-black text-anime-textMain mb-2">Secure Checkout</h2>
            <p class="text-sm font-bold text-gray-500 mb-6">Enter your email to receive your secure login code.</p>
            <input type="email" id="authEmailInput" placeholder="you@email.com" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm mb-4 text-center">
            <button onclick="sendOtp()" id="sendOtpBtn" class="w-full bg-anime-accent text-white font-black py-4 rounded-xl hover:scale-[1.02] transition shadow-md">Send Verification Code</button>
            <button onclick="closeModals()" class="mt-4 text-xs font-bold text-gray-400 hover:text-gray-600">Cancel</button>
        </div>
    </div>

    <div id="otpModal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm justify-center items-center z-50 p-4">
        <div class="bg-white rounded-3xl w-full max-w-md overflow-hidden shadow-2xl p-8 text-center animate-fade-in-up">
            <h2 class="text-2xl font-black text-anime-textMain mb-2">Enter Code</h2>
            <p class="text-sm font-bold text-gray-500 mb-6">Check your inbox for the 6-digit verification code.</p>
            <input type="text" id="authOtpInput" placeholder="123456" maxlength="6" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-black text-2xl tracking-widest outline-none focus:border-anime-accent mb-4 text-center">
            <button onclick="verifyOtp()" id="verifyOtpBtn" class="w-full bg-[#00b67a] text-white font-black py-4 rounded-xl hover:scale-[1.02] transition shadow-md">Verify & Proceed</button>
            <button onclick="closeModals()" class="mt-4 text-xs font-bold text-gray-400 hover:text-gray-600">Cancel</button>
        </div>
    </div>

    <div id="buyModal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm justify-center items-center z-50 p-4">
        <div class="bg-white rounded-3xl w-full max-w-md overflow-hidden shadow-2xl animate-fade-in-up">
            <div id="buyFormContainer" class="p-6 md:p-8">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-2xl font-black text-anime-textMain">Checkout</h2>
                    <button onclick="closeModals()" class="text-gray-400 hover:text-gray-600 bg-gray-100 p-2 rounded-full">×</button>
                </div>
                <div class="bg-green-50 text-green-700 text-xs font-black px-3 py-1.5 rounded-lg mb-4 flex items-center gap-2 border border-green-200">
                    <span>✓ Verified as:</span> <span class="truncate"><%= typeof buyerEmail !== 'undefined' ? buyerEmail : '' %></span>
                </div>
                <p id="modalItemTitle" class="font-bold text-anime-textMain text-sm mb-6 pb-4 border-b-2 border-dashed border-gray-100 break-words"></p>

                <form id="buyForm" action="/checkout" method="POST" class="space-y-4">
                    <input type="hidden" id="hiddenProductId" name="product_id">
                    <input type="hidden" id="hiddenProductTier" name="tier">

                    <div>
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-wider mb-1">Discord Username (Optional)</label>
                        <input type="text" name="discord_username" placeholder="user#1234 or @user" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                    </div>

                    <div class="pt-2">
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-wider mb-2">Select Payment Method</label>
                        <div class="grid grid-cols-2 gap-3">
                            <label class="cursor-pointer relative">
                                <input type="radio" id="radioCrypto" name="payment_method" value="Crypto" required class="peer sr-only" checked>
                                <div class="rounded-xl border-2 border-gray-200 bg-white p-3 hover:bg-gray-50 peer-checked:border-anime-accent peer-checked:bg-anime-skyLight transition text-center shadow-sm">
                                    <p class="font-black text-sm text-anime-textMain">Crypto</p>
                                    <p class="text-[10px] font-bold text-anime-accent mt-1 uppercase tracking-wider">Fastest</p>
                                </div>
                            </label>
                            
                            <label id="giftcardLabel" class="cursor-pointer relative">
                                <input type="radio" name="payment_method" value="Giftcard" class="peer sr-only">
                                <div class="rounded-xl border-2 border-gray-200 bg-white p-3 hover:bg-gray-50 peer-checked:border-anime-accent peer-checked:bg-anime-skyLight transition text-center shadow-sm">
                                    <p class="font-black text-sm text-anime-textMain">Giftcard</p>
                                    <p class="text-[10px] font-bold text-gray-500 mt-1 uppercase tracking-wider">G2A Cards</p>
                                </div>
                            </label>

                            <label id="discordLabel" class="cursor-pointer relative hidden">
                                <input type="radio" name="payment_method" value="DiscordMethod" class="peer sr-only">
                                <div class="rounded-xl border-2 border-gray-200 bg-white p-3 hover:bg-purple-50 peer-checked:border-purple-500 peer-checked:bg-purple-100 transition text-center shadow-sm">
                                    <p class="font-black text-sm text-purple-800">Other</p>
                                    <p class="text-[10px] font-bold text-purple-600 mt-1 uppercase tracking-wider">Via Discord</p>
                                </div>
                            </label>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full bg-anime-accent text-white font-black py-4 rounded-xl hover:scale-[1.02] transition shadow-md mt-4">Complete Purchase →</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        const isAuthenticated = <%= typeof buyerEmail !== 'undefined' && !!buyerEmail %>;
        let pendingBuyData = null;
        let userEmailToVerify = null;

        const searchInput = document.getElementById('searchInput');
        const searchDropdown = document.getElementById('searchDropdown');

        searchInput.addEventListener('input', async (e) => {
            const val = e.target.value.trim();
            if (val.length < 2) { searchDropdown.classList.add('hidden'); return; }
            const res = await fetch('/api/search?q=' + encodeURIComponent(val));
            const data = await res.json();
            if (data.length > 0) {
                searchDropdown.innerHTML = data.map(item => `<a href="/?q=${encodeURIComponent(item.title)}" class="block px-6 py-3 hover:bg-gray-50 border-b border-gray-50 last:border-0"><div class="font-black text-sm text-anime-textMain">${item.title}</div><div class="text-[10px] font-bold text-anime-accent uppercase tracking-wider">${item.category}</div></a>`).join('');
                searchDropdown.classList.remove('hidden');
            } else { searchDropdown.classList.add('hidden'); }
        });

        function handleBuyClick(id, title, tier, price) {
            if (isAuthenticated) {
                openBuyModal(id, title, tier, price);
            } else {
                pendingBuyData = { id, title, tier, price };
                document.getElementById('emailModal').classList.remove('hidden');
                document.getElementById('emailModal').classList.add('flex');
            }
        }

        async function sendOtp() {
            const email = document.getElementById('authEmailInput').value;
            if (!email || !email.includes('@')) return alert("Enter a valid email.");
            
            document.getElementById('sendOtpBtn').innerText = 'Sending...';
            document.getElementById('sendOtpBtn').disabled = true;

            const res = await fetch('/api/send-otp', {
                method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ email })
            });
            const data = await res.json();
            
            if (data.success) {
                userEmailToVerify = email;
                document.getElementById('emailModal').classList.add('hidden');
                document.getElementById('otpModal').classList.remove('hidden');
                document.getElementById('otpModal').classList.add('flex');
            } else {
                alert("Error sending email.");
                document.getElementById('sendOtpBtn').innerText = 'Send Verification Code';
                document.getElementById('sendOtpBtn').disabled = false;
            }
        }

        async function verifyOtp() {
            const code = document.getElementById('authOtpInput').value;
            if (code.length !== 6) return alert("Enter the 6 digit code.");
            
            const res = await fetch('/api/verify-otp', {
                method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ email: userEmailToVerify, code })
            });
            const data = await res.json();

            if (data.success) {
                window.location.reload();
            } else {
                alert("Invalid or expired code.");
            }
        }

        function openBuyModal(id, title, tier, price) {
            document.getElementById('modalItemTitle').innerText = title;
            document.getElementById('hiddenProductId').value = id;
            document.getElementById('hiddenProductTier').value = tier;

            const numericPrice = parseFloat(price || 0);
            const giftcardLabel = document.getElementById('giftcardLabel');
            const discordLabel = document.getElementById('discordLabel');

            if (numericPrice > 900 || tier === 'Custom' || tier === 'Ultra') {
                giftcardLabel.classList.add('hidden');
                discordLabel.classList.remove('hidden');
                document.getElementById('radioCrypto').checked = true;
            } else {
                giftcardLabel.classList.remove('hidden');
                discordLabel.classList.add('hidden');
            }

            document.getElementById('buyModal').classList.remove('hidden');
            document.getElementById('buyModal').classList.add('flex');
        }

        function closeModals() {
            document.getElementById('emailModal').classList.add('hidden');
            document.getElementById('emailModal').classList.remove('flex');
            document.getElementById('otpModal').classList.add('hidden');
            document.getElementById('otpModal').classList.remove('flex');
            document.getElementById('buyModal').classList.add('hidden');
            document.getElementById('buyModal').classList.remove('flex');
            document.getElementById('buyForm').reset();
        }
    </script>
</body>
</html>
