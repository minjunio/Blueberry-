                            <span class="relative flex h-2 w-2">
                              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                              <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                            </span>
                            1,842 Members
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </header>

    <!-- MAIN -->
    <main
        class="relative z-10 mx-auto w-full max-w-7xl flex-grow px-4 pb-24 md:px-8"
    >

        <!-- ANNOUNCEMENTS -->
        <% if (safeAnnouncements.length > 0) { %>
            <section class="mb-14 space-y-6">

                <% safeAnnouncements.forEach(ann => { %>
                    <article
                        class="overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-xl shadow-blue-900/5"
                    >
                        <div
                            class="border-b border-blue-100 bg-gradient-to-r from-blue-50 to-cyan-50 px-6 py-4 md:px-8"
                        >
                            <div
                                class="flex flex-wrap items-center justify-between gap-3"
                            >
                                <span
                                    class="rounded-full bg-blue-600 px-3 py-1 text-[10px] font-black uppercase tracking-[0.16em] text-white"
                                >
                                    <%= ann.category || 'Marketplace' %> update
                                </span>

                                <span
                                    class="text-xs font-bold text-blue-700"
                                >
                                    ExamHub announcement
                                </span>
                            </div>
                        </div>

                        <div class="p-6 md:p-8">

                            <h2
                                class="mb-5 text-2xl font-black tracking-tight text-slate-950 md:text-3xl"
                            >
                                <%= ann.title %>
                            </h2>

                            <% if (ann.image1 || ann.image2) { %>
                                <div
                                    class="mb-6 grid gap-4 <%= ann.image1 && ann.image2 ? 'md:grid-cols-2' : 'grid-cols-1' %>"
                                >
                                    <% if (ann.image1) { %>
                                        <img
                                            src="<%= ann.image1 %>"
                                            alt="<%= ann.title %>"
                                            loading="lazy"
                                            class="h-64 w-full rounded-2xl border border-slate-100 object-cover"
                                        >
                                    <% } %>

                                    <% if (ann.image2) { %>
                                        <img
                                            src="<%= ann.image2 %>"
                                            alt="<%= ann.title %>"
                                            loading="lazy"
                                            class="h-64 w-full rounded-2xl border border-slate-100 object-cover"
                                        >
                                    <% } %>
                                </div>
                            <% } %>

                            <div
                                class="text-sm font-medium leading-7 text-slate-600"
                            >
                                <%- formatPostText(ann.content) %>
                            </div>

                        </div>
                    </article>
                <% }) %>

            </section>
        <% } %>

        <!-- SECTION HEADER -->
        <section
            class="mb-7 flex flex-col gap-5 border-b border-slate-200 md:flex-row md:items-end md:justify-between"
        >
            <div class="pb-5">
                <p
                    class="mb-2 text-xs font-black uppercase tracking-[0.18em] text-blue-600"
                >
                    Explore ExamHub
                </p>

                <h2
                    class="text-2xl font-black tracking-tight text-slate-950 md:text-3xl"
                >
                    Marketplace catalogue
                </h2>
            </div>

            <div
                class="flex gap-7"
                role="tablist"
            >
                <button
                    type="button"
                    id="tab-store"
                    onclick="switchTab('store')"
                    role="tab"
                    aria-selected="true"
                    aria-controls="store-grid"
                    class="border-b-2 border-blue-600 px-1 pb-4 text-sm font-black text-blue-600 transition"
                >
                    Store
                </button>

                <button
                    type="button"
                    id="tab-posts"
                    onclick="switchTab('posts')"
                    role="tab"
                    aria-selected="false"
                    aria-controls="posts-grid"
                    class="border-b-2 border-transparent px-1 pb-4 text-sm font-black text-slate-400 transition hover:text-slate-800"
                >
                    Articles & Updates
                </button>
            </div>
        </section>

        <!-- PRODUCTS -->
        <section
            id="store-grid"
            role="tabpanel"
            aria-labelledby="tab-store"
        >
            <div
                class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3"
            >
                <% if (safeProducts.length === 0) { %>
                    <div
                        class="col-span-full rounded-3xl border border-dashed border-slate-300 bg-white/70 py-20 text-center"
                    >
                        <div
                            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100 text-slate-400"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                class="h-6 w-6"
                                aria-hidden="true"
                            >
                                <path
                                    d="M5 5h14v14H5V5Z"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                />

                                <path
                                    d="m7.5 16 3.2-3.3 2.2 2.2 1.5-1.5 2.1 2.6"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                />
                            </svg>
                        </div>

                        <p class="font-black text-slate-500">
                            No products were found.
                        </p>
                    </div>
                <% } else { %>

                    <% safeProducts.forEach(product => { %>
                        <article
                            class="product-card flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
                        >
                            <!-- Product image at upper left -->
                            <div class="mb-5 flex items-start gap-4">

                                <div
                                    class="h-[76px] w-[76px] shrink-0 overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-sm"
                                >
                                    <img
                                        src="<%= product.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(product.title || 'Product')}&background=0f172a&color=ffffff&size=512` %>"
                                        alt="<%= product.title || 'Product' %>"
                                        loading="lazy"
                                        class="product-image h-full w-full object-cover"
                                    >
                                </div>

                                <div class="min-w-0 flex-grow">

                                    <div
                                        class="mb-2 flex flex-wrap items-center gap-2"
                                    >
                                        <span
                                            class="rounded-lg bg-blue-50 px-2.5 py-1 text-[9px] font-black uppercase tracking-[0.12em] text-blue-700"
                                        >
                                            <%= product.category || 'General' %>
                                        </span>

                                        <span
                                            class="rounded-lg bg-slate-100 px-2.5 py-1 text-[9px] font-black uppercase tracking-[0.12em] text-slate-600"
                                        >
                                            <%= product.tier || 'Standard' %>
                                        </span>
                                    </div>

                                    <h3
                                        class="line-clamp-2 text-lg font-black leading-tight tracking-tight text-slate-950"
                                    >
                                        <%= product.title %>
                                    </h3>

                                    <div
                                        class="mt-2 flex items-center justify-between gap-3"
                                    >
                                        <span
                                            class="text-lg font-black text-emerald-600"
                                        >
                                            $<%= Number(product.price || 0).toFixed(2) %>
                                        </span>

                                        <span
                                            class="flex items-center gap-1.5 text-[10px] font-bold text-emerald-600"
                                        >
                                            <span
                                                class="h-1.5 w-1.5 rounded-full bg-emerald-500"
                                            ></span>

                                            Available
                                        </span>
                                    </div>

                                </div>
                            </div>

                            <div
                                class="mb-5 flex-grow text-sm font-medium leading-6 text-slate-500"
                            >
                                <%- formatPostText(product.description) %>
                            </div>

                            <div
                                class="border-t border-slate-100 pt-4"
                            >
                                <button
                                    type="button"
                                    class="purchase-button group flex w-full items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-slate-950 to-slate-800 px-4 py-3 text-sm font-black text-white shadow-lg shadow-slate-900/10 transition hover:from-blue-700 hover:to-blue-600 hover:shadow-blue-500/20"
                                    data-product-id="<%= product.id %>"
                                    data-product-title="<%= product.title %>"
                                    data-product-tier="<%= product.tier || 'Standard' %>"
                                    data-product-price="<%= Number(product.price || 0) %>"
                                    data-paypal-button-id="<%= product.paypal_button_id || defaultPayPalButtonId %>"
                                >
                                    Purchase securely

                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        class="h-4 w-4 transition group-hover:translate-x-1"
                                        aria-hidden="true"
                                    >
                                        <path
                                            d="M5 12h14M14 7l5 5-5 5"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        />
                                    </svg>
                                </button>
                            </div>

                        </article>
                    <% }) %>

                <% } %>
            </div>
        </section>

        <!-- POSTS -->
        <section
            id="posts-grid"
            class="hidden"
            role="tabpanel"
            aria-labelledby="tab-posts"
        >
            <div
                class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3"
            >
                <% if (safePosts.length > 0) { %>

                    <% safePosts.forEach(post => { %>
                        <a
                            href="/post/<%= post.id %>"
                            class="product-card flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm"
                        >
                            <div
                                class="mb-4 flex items-center justify-between gap-3"
                            >
                                <span
                                    class="rounded-lg bg-blue-50 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.12em] text-blue-700"
                                >
                                    Update
                                </span>

                                <span
                                    class="text-xs font-semibold text-slate-400"
                                >
                                    <%= new Date(post.created_at).toLocaleDateString() %>
                                </span>
                            </div>

                            <h3
                                class="mb-3 text-xl font-black leading-tight tracking-tight text-slate-950"
                            >
                                <%= post.title %>
                            </h3>

                            <p
                                class="mb-6 line-clamp-3 flex-grow text-sm font-medium leading-6 text-slate-500"
                            >
                                <%= post.seo_desc || 'Read the complete ExamHub update.' %>
                            </p>

                            <span
                                class="flex items-center gap-2 text-sm font-black text-blue-600"
                            >
                                Read article
                                <span aria-hidden="true">&rarr;</span>
                            </span>
                        </a>
                    <% }) %>

                <% } else { %>
                    <div
                        class="col-span-full rounded-3xl border border-dashed border-slate-300 bg-white/70 py-20 text-center font-black text-slate-400"
                    >
                        No updates have been published yet.
                    </div>
                <% } %>
            </div>
        </section>

    </main>

    <!-- EMAIL MODAL -->
    <div
        id="emailModal"
        class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-slate-950/65 p-4 backdrop-blur-md"
        aria-hidden="true"
    >
        <div
            class="modal-panel w-full max-w-md overflow-y-auto rounded-3xl border border-white/60 bg-white shadow-2xl"
            role="dialog"
            aria-modal="true"
            aria-labelledby="emailModalTitle"
        >
            <div
                class="border-b border-slate-100 bg-gradient-to-br from-blue-50 to-white p-7"
            >
                <div
                    class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-blue-600 text-white shadow-lg shadow-blue-500/20"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class="h-6 w-6"
                        aria-hidden="true"
                    >
                        <path
                            d="M4 6h16v12H4V6Z"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linejoin="round"
                        />

                        <path
                            d="m5 7 7 6 7-6"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        />
                    </svg>
                </div>

                <h2
                    id="emailModalTitle"
                    class="text-2xl font-black tracking-tight text-slate-950"
                >
                    Continue to checkout
                </h2>

                <p class="mt-2 text-sm font-medium leading-6 text-slate-500">
                    Enter your email to receive a secure sign-in code and
                    access your order.
                </p>
            </div>

            <div class="p-7">

                <label
                    for="authEmailInput"
                    class="mb-2 block text-xs font-black uppercase tracking-[0.12em] text-slate-600"
                >
                    Email address
                </label>

                <input
                    type="email"
                    id="authEmailInput"
                    placeholder="you@example.com"
                    autocomplete="email"
                    class="w-full rounded-xl border border-slate-200 bg-slate-50 px-4 py-3.5 text-sm font-semibold text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-blue-500 focus:bg-white focus:ring-4 focus:ring-blue-100"
                >

                <p
                    id="emailAuthError"
                    class="mt-3 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-bold text-red-600"
                ></p>

                <button
                    type="button"
                    id="sendOtpBtn"
                    onclick="sendOtp()"
                    class="mt-5 w-full rounded-xl bg-gradient-to-r from-blue-600 to-sky-500 py-3.5 text-sm font-black text-white shadow-lg shadow-blue-500/20 transition hover:from-blue-700 hover:to-sky-600 disabled:cursor-not-allowed disabled:opacity-60"
                >
                    Send verification code
                </button>

                <button
                    type="button"
                    onclick="closeModals()"
                    class="mt-3 w-full rounded-xl py-3 text-sm font-bold text-slate-500 transition hover:bg-slate-50 hover:text-slate-800"
                >
                    Cancel
                </button>

            </div>
        </div>
    </div>

    <!-- OTP MODAL -->
    <div
        id="otpModal"
        class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-slate-950/65 p-4 backdrop-blur-md"
        aria-hidden="true"
    >
        <div
            class="modal-panel w-full max-w-md overflow-y-auto rounded-3xl border border-white/60 bg-white shadow-2xl"
            role="dialog"
            aria-modal="true"
            aria-labelledby="otpModalTitle"
        >
            <div class="p-8 text-center">

                <div
                    class="mx-auto mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-emerald-100 text-emerald-600"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class="h-7 w-7"
                        aria-hidden="true"
                    >
                        <path
                            d="M7 10V8a5 5 0 0 1 10 0v2"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                        />

                        <rect
                            x="5"
                            y="10"
                            width="14"
                            height="11"
                            rx="2"
                            stroke="currentColor"
                            stroke-width="1.8"
                        />

                        <path
                            d="M12 14v3"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                        />
                    </svg>
                </div>

                <h2
                    id="otpModalTitle"
                    class="text-2xl font-black tracking-tight text-slate-950"
                >
                    Check your email
                </h2>

                <p class="mt-2 text-sm font-medium leading-6 text-slate-500">
                    Enter the six-digit verification code sent to your inbox.
                </p>

                <label
                    for="authOtpInput"
                    class="sr-only"
                >
                    Verification code
                </label>

                <input
                    type="text"
                    id="authOtpInput"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    placeholder="000000"
                    maxlength="6"
                    class="mt-6 w-full rounded-2xl border border-slate-200 bg-slate-50 px-4 py-4 text-center text-3xl font-black tracking-[0.35em] text-slate-950 outline-none transition focus:border-emerald-500 focus:bg-white focus:ring-4 focus:ring-emerald-100"
                >

                <p
                    id="otpAuthError"
                    class="mt-3 hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm font-bold text-red-600"
                ></p>

                <button
                    type="button"
                    id="verifyOtpBtn"
                    onclick="verifyOtp()"
                    class="mt-5 w-full rounded-xl bg-gradient-to-r from-emerald-600 to-green-500 py-3.5 text-sm font-black text-white shadow-lg shadow-emerald-500/20 transition hover:from-emerald-700 hover:to-green-600 disabled:cursor-not-allowed disabled:opacity-60"
                >
                    Verify and continue
                </button>

                <button
                    type="button"
                    onclick="closeModals()"
                    class="mt-3 w-full rounded-xl py-3 text-sm font-bold text-slate-500 transition hover:bg-slate-50 hover:text-slate-800"
                >
                    Cancel
                </button>

            </div>
        </div>
    </div>

    <!-- DIRECT CARD CHECKOUT MODAL -->
    <div
        id="buyModal"
        class="fixed inset-0 z-50 hidden items-center justify-center overflow-y-auto bg-slate-950/70 p-3 backdrop-blur-md md:p-6"
        aria-hidden="true"
    >
        <div
            class="modal-panel my-auto w-full max-w-lg overflow-y-auto rounded-3xl border border-white/70 bg-white shadow-2xl"
            role="dialog"
            aria-modal="true"
            aria-labelledby="buyModalTitle"
        >
            <!-- Modal header -->
            <div
                class="relative overflow-hidden border-b border-slate-100 bg-gradient-to-br from-blue-50 via-white to-cyan-50 px-6 pb-6 pt-7 md:px-8"
            >
                <div
                    class="pointer-events-none absolute -right-14 -top-16 h-40 w-40 rounded-full bg-blue-200/45 blur-3xl"
                    aria-hidden="true"
                ></div>

                <button
                    type="button"
                    onclick="closeModals()"
                    aria-label="Close checkout"
                    class="absolute right-5 top-5 z-10 flex h-10 w-10 items-center justify-center rounded-full border border-slate-200 bg-white/90 text-xl font-bold text-slate-500 shadow-sm transition hover:bg-slate-100 hover:text-slate-900"
                >
                    &times;
                </button>

                <div
                    class="relative flex items-center gap-4 pr-12"
                >
                    <span
                        class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-blue-700 to-sky-500 text-white shadow-lg shadow-blue-500/25"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            class="h-7 w-7"
                            aria-hidden="true"
                        >
                            <rect
                                x="3"
                                y="5"
                                width="18"
                                height="14"
                                rx="2"
                                stroke="currentColor"
                                stroke-width="1.8"
                            />

                            <path
                                d="M3 9h18M7 15h4"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"
                            />
                        </svg>
                    </span>

                    <div>
                        <p
                            class="text-[10px] font-black uppercase tracking-[0.18em] text-blue-600"
                        >
                            Secure card payment
                        </p>

                        <h2
                            id="buyModalTitle"
                            class="mt-1 text-2xl font-black tracking-tight text-slate-950"
                        >
                            Complete your purchase
                        </h2>
                    </div>
                </div>
            </div>

            <div class="p-6 md:p-8">

                <!-- Signed-in account -->
                <div
                    class="mb-6 flex items-center gap-3 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3"
                >
                    <span
                        class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-emerald-100 text-emerald-600"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            class="h-4 w-4"
                            aria-hidden="true"
                        >
                            <path
                                d="m6 12 4 4 8-8"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            />
                        </svg>
                    </span>

                    <div class="min-w-0">
                        <p
                            class="text-[10px] font-black uppercase tracking-[0.12em] text-emerald-700"
                        >
                            Signed in as
                        </p>

                        <p
                            class="truncate text-sm font-bold text-emerald-800"
                        >
                            <%= currentBuyerEmail %>
                        </p>
                    </div>
                </div>

                <!-- Product summary -->
                <div
                    class="rounded-2xl border border-slate-200 bg-slate-50 p-5"
                >
                    <div
                        class="flex items-start justify-between gap-5"
                    >
                        <div class="min-w-0">
                            <p
                                class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-400"
                            >
                                Your order
                            </p>

                            <h3
                                id="modalItemTitle"
                                class="mt-2 text-lg font-black leading-tight text-slate-950"
                            ></h3>

                            <span
                                id="modalItemTier"
                                class="mt-3 inline-flex rounded-lg bg-blue-100 px-2.5 py-1 text-[10px] font-black uppercase tracking-[0.1em] text-blue-700"
                            ></span>
                        </div>

                        <div class="shrink-0 text-right">
                            <p
                                class="text-[10px] font-black uppercase tracking-[0.14em] text-slate-400"
                            >
                                Total
                            </p>

                            <p
                                id="modalItemPrice"
                                class="mt-1 text-2xl font-black tracking-tight text-emerald-600"
                            ></p>
                        </div>
                    </div>
                </div>

                <!-- Optional Discord -->
                <div class="mt-6">
                    <label
                        for="discordUsername"
                        class="mb-2 block text-xs font-black uppercase tracking-[0.12em] text-slate-600"
                    >
                        Discord username

                        <span
                            class="font-semibold normal-case tracking-normal text-slate-400"
                        >
                            — optional
                        </span>
                    </label>

                    <div class="relative">
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400"
                            aria-hidden="true"
                        >
                            <circle
                                cx="9"
                                cy="8"
                                r="3"
                                stroke="currentColor"
                                stroke-width="1.8"
                            />

                            <path
                                d="M4 19c.4-3 2.2-5 5-5s4.6 2 5 5M16 9h4M18 7v4"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"
                            />
                        </svg>

                        <input
                            type="text"
                            id="discordUsername"
                            name="discord_username"
                            placeholder="Your Discord username"
                            autocomplete="off"
                            class="w-full rounded-xl border border-slate-200 bg-white py-3.5 pl-12 pr-4 text-sm font-semibold text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-blue-500 focus:ring-4 focus:ring-blue-100"
                        >
                    </div>
                </div>

                <!-- Card panel -->
                <div
                    class="mt-6 overflow-hidden rounded-2xl border border-blue-100 bg-gradient-to-br from-blue-50 via-white to-cyan-50 p-5"
                >
                    <div
                        class="mb-4 flex items-center justify-between gap-3"
                    >
                        <div class="flex items-center gap-3">

                            <span
                                class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-blue-600 text-white shadow-lg shadow-blue-500/20"
                            >
                                <svg
                                    viewBox="0 0 24 24"
