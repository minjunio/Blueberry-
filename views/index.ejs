                                    class="text-[11px] text-slate-400 font-bold"
                                >
                                    <%= new Date(post.created_at).toLocaleDateString() %>
                                </span>
                            </div>

                            <h3
                                class="font-black text-xl text-slate-950 leading-tight tracking-tight mb-3"
                            >
                                <%= post.title %>
                            </h3>

                            <p
                                class="text-sm text-slate-500 leading-relaxed line-clamp-3 mb-6 flex-grow"
                            >
                                <%= post.seo_desc || 'Read the full marketplace update.' %>
