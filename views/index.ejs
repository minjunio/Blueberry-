                                    <svg
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        class="h-3.5 w-3.5"
                                        aria-hidden="true"
                                    >
                                        <path
                                            d="M7 10V8a5 5 0 0 1 10 0v2"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                        />

                                        <rect
                                            x="5"
                                            y="10"
                                            width="14"
                                            height="11"
                                            rx="2"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                        />
