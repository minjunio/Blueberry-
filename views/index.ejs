    <script>
        'use strict';

        const isAuthenticated =
            <%- JSON.stringify(Boolean(currentBuyerEmail)) %>;

        const DEFAULT_PAYPAL_BUTTON_ID =
            <%- JSON.stringify(defaultPayPalButtonId) %>;

        let userEmailToVerify = '';

        let activeProduct = {
            id: '',
            title: '',
            tier: '',
            price: 0,
            paypalButtonId: DEFAULT_PAYPAL_BUTTON_ID
        };

        let searchTimer = null;
        let searchController = null;

        function element(id) {
            return document.getElementById(id);
        }

        function safeString(value, fallback = '') {
            if (
                value === null ||
                value === undefined
            ) {
                return fallback;
            }

            return String(value);
        }

        function safePrice(value) {
            const price = Number(value);

            if (
                !Number.isFinite(price) ||
                price <= 0
            ) {
                return 0;
            }

            return Math.round(price * 100) / 100;
        }

        function normalizePayPalButtonId(value) {
            const cleaned =
                safeString(value)
                    .trim()
                    .replace(
                        /[^a-zA-Z0-9_-]/g,
                        ''
                    );

            return (
                cleaned ||
                DEFAULT_PAYPAL_BUTTON_ID
            );
        }

        function buildPayPalPaymentLink(buttonId) {
            return (
                'https://www.paypal.com/ncp/payment/' +
                encodeURIComponent(
                    normalizePayPalButtonId(
                        buttonId
                    )
                )
            );
        }

        function showModal(id) {
            const modal =
                element(id);

            if (!modal) return;

            modal.classList.remove(
                'hidden'
            );

            modal.classList.add(
                'flex'
            );

            modal.setAttribute(
                'aria-hidden',
                'false'
            );

            document.body.classList.add(
                'modal-open'
            );
        }

        function hideModal(id) {
            const modal =
                element(id);

            if (!modal) return;

            modal.classList.add(
                'hidden'
            );

            modal.classList.remove(
                'flex'
            );

            modal.setAttribute(
                'aria-hidden',
                'true'
            );
        }

        function setMessage(id, message) {
            const target =
                element(id);

            if (!target) return;

            target.textContent =
                message || '';

            target.classList.toggle(
                'hidden',
                !message
            );
        }

        function openEmailModal() {
            setMessage(
                'emailAuthError',
                ''
            );

            showModal(
                'emailModal'
            );

            window.setTimeout(() => {
                element(
                    'authEmailInput'
                )?.focus();
            }, 80);
        }

        function openOtpModal() {
            hideModal(
                'emailModal'
            );

            setMessage(
                'otpAuthError',
                ''
            );

            showModal(
                'otpModal'
            );

            window.setTimeout(() => {
                element(
                    'authOtpInput'
                )?.focus();
            }, 80);
        }

        function handleBuyClick(product) {
            activeProduct = {
                id:
                    safeString(
                        product.id
                    ),

                title:
                    safeString(
                        product.title,
                        'Digital product'
                    ),

                tier:
                    safeString(
                        product.tier,
                        'Standard'
                    ),

                price:
                    safePrice(
                        product.price
                    ),

                paypalButtonId:
                    normalizePayPalButtonId(
                        product.paypalButtonId
                    )
            };

            if (
                !activeProduct.id ||
                !activeProduct.title ||
                activeProduct.price <= 0
            ) {
                alert(
                    'This product has invalid checkout information.'
                );

                return;
            }

            if (isAuthenticated) {
                openBuyModal();
                return;
            }

            sessionStorage.setItem(
                'pendingBuy',
                JSON.stringify(
                    activeProduct
                )
            );

            openEmailModal();
        }

        function resetCardButton() {
            const cardLink =
                element(
                    'paypalCardLink'
                );

            const icon =
                element(
                    'paypalCardButtonIcon'
                );

            const arrow =
                element(
                    'paypalCardButtonArrow'
                );

            const text =
                element(
                    'paypalCardButtonText'
                );

            cardLink.classList.remove(
                'is-loading'
            );

            text.textContent =
                'Pay with Credit / Debit Card';

            icon.innerHTML = `
                <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    class="h-5 w-5"
                    aria-hidden="true"
                >
                    <rect
                        x="3"
                        y="5"
                        width="18"
                        height="14"
                        rx="2"
                        stroke="currentColor"
                        stroke-width="1.8"
                    ></rect>

                    <path
                        d="M3 9h18M7 15h4"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                    ></path>
                </svg>
            `;

            arrow.classList.remove(
                'hidden'
            );
        }

        function openBuyModal() {
            element(
                'modalItemTitle'
            ).textContent =
                activeProduct.title;

            element(
                'modalItemTier'
            ).textContent =
                activeProduct.tier;

            element(
                'modalItemPrice'
            ).textContent =
                `$${activeProduct.price.toFixed(2)}`;

            element(
                'hiddenProductId'
            ).value =
                activeProduct.id;

            element(
                'hiddenProductTier'
            ).value =
                activeProduct.tier;

            setMessage(
                'paypalLinkError',
                ''
            );

            resetCardButton();

            const cardChoice =
                document.querySelector(
                    'input[name="payment_method_choice"][value="PayPalCardLink"]'
                );

            if (cardChoice) {
                cardChoice.checked =
                    true;
            }

            const giftcardLabel =
                element(
                    'giftcardLabel'
                );

            const giftcardChoice =
                document.querySelector(
                    'input[name="payment_method_choice"][value="Giftcard"]'
                );

            const giftCardRestricted =
                activeProduct.price > 900 ||
                ['custom', 'ultra'].includes(
                    activeProduct.tier
                        .toLowerCase()
                );

            giftcardLabel.classList.toggle(
                'hidden',
                giftCardRestricted
            );

            if (
                giftCardRestricted &&
                giftcardChoice &&
                giftcardChoice.checked &&
                cardChoice
            ) {
                cardChoice.checked =
                    true;
            }

            const paypalLink =
                buildPayPalPaymentLink(
                    activeProduct.paypalButtonId
                );

            element(
                'paypalCardLink'
            ).href =
                paypalLink;

            showModal(
                'buyModal'
            );

            handlePaymentMethodChange();
        }

        function handlePaymentMethodChange() {
            const selected =
                document.querySelector(
                    'input[name="payment_method_choice"]:checked'
                );

            const paymentMethod =
                selected
                    ? selected.value
                    : 'PayPalCardLink';

            element(
                'hiddenPaymentMethod'
            ).value =
                paymentMethod;

            const cardAction =
                element(
                    'cardActionContainer'
                );

            const normalAction =
                element(
                    'normalActionContainer'
                );

            const normalButton =
                element(
                    'normalCheckoutButton'
                );

            if (
                paymentMethod ===
                'PayPalCardLink'
            ) {
                cardAction.classList.remove(
                    'hidden'
                );

                normalAction.classList.add(
                    'hidden'
                );

                return;
            }

            cardAction.classList.add(
                'hidden'
            );

            normalAction.classList.remove(
                'hidden'
            );

            if (
                paymentMethod ===
                'Crypto'
            ) {
                normalButton.innerHTML = `
                    Continue to crypto payment

                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class="h-4 w-4"
                        aria-hidden="true"
                    >
                        <path
                            d="M5 12h14M14 7l5 5-5 5"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        ></path>
                    </svg>
                `;
            } else {
                normalButton.innerHTML = `
                    Continue with gift card

                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class="h-4 w-4"
                        aria-hidden="true"
                    >
                        <path
                            d="M5 12h14M14 7l5 5-5 5"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        ></path>
                    </svg>
                `;
            }
        }

        function handleCardLinkClick(event) {
            const link =
                element(
                    'paypalCardLink'
                );

            const buttonId =
                normalizePayPalButtonId(
                    activeProduct.paypalButtonId
                );

            if (
                !buttonId ||
                !activeProduct.id
            ) {
                event.preventDefault();

                setMessage(
                    'paypalLinkError',
                    'This product does not have a valid PayPal payment-link ID.'
                );

                return;
            }

            /*
             * Save the selected order locally before leaving ExamHub.
             * This does not prove payment. Your PayPal webhook/server must
             * still confirm the transaction.
             */
            sessionStorage.setItem(
                'paypalPendingProduct',
                JSON.stringify({
                    id:
                        activeProduct.id,

                    title:
                        activeProduct.title,

                    tier:
                        activeProduct.tier,

                    price:
                        activeProduct.price,

                    paypalButtonId:
                        buttonId,

                    discordUsername:
                        element(
                            'discordUsername'
                        ).value.trim(),

                    openedAt:
                        new Date()
                            .toISOString()
                })
            );

            link.classList.add(
                'is-loading'
            );

            element(
                'paypalCardButtonText'
            ).textContent =
                'Opening secure checkout...';

            element(
                'paypalCardButtonIcon'
            ).innerHTML =
                '<span class="spinner"></span>';

            element(
                'paypalCardButtonArrow'
            ).classList.add(
                'hidden'
            );

            /*
             * Do not call preventDefault here.
             *
             * The browser follows the normal href directly to PayPal.
             * A normal link is more reliable than window.open(), an iframe,
             * or a JavaScript-rendered PayPal button.
             */
        }

        async function sendOtp() {
            const input =
                element(
                    'authEmailInput'
                );

            const button =
                element(
                    'sendOtpBtn'
                );

            const email =
                input.value
                    .trim()
                    .toLowerCase();

            const emailPattern =
                /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            setMessage(
                'emailAuthError',
                ''
            );

            if (
                !emailPattern.test(
                    email
                )
            ) {
                setMessage(
                    'emailAuthError',
                    'Enter a valid email address.'
                );

                input.focus();
                return;
            }

            button.disabled =
                true;

            button.textContent =
                'Sending code...';

            try {
                const response =
                    await fetch(
                        '/api/send-otp',
                        {
                            method:
                                'POST',

                            headers: {
                                'Content-Type':
                                    'application/json',

                                Accept:
                                    'application/json'
                            },

                            body:
                                JSON.stringify({
                                    email
                                })
                        }
                    );

                const result =
                    await response
                        .json()
                        .catch(
                            () => ({})
                        );

                if (
                    !response.ok ||
                    !result.success
                ) {
                    throw new Error(
                        result.message ||
                        'The verification code could not be sent.'
                    );
                }

                userEmailToVerify =
                    email;

                openOtpModal();
            } catch (error) {
                setMessage(
                    'emailAuthError',
                    error &&
                    error.message
                        ? error.message
                        : 'The verification code could not be sent.'
                );
            } finally {
                button.disabled =
                    false;

                button.textContent =
                    'Send verification code';
            }
        }

        async function verifyOtp() {
            const input =
                element(
                    'authOtpInput'
                );

            const button =
                element(
                    'verifyOtpBtn'
                );

            const code =
                input.value
                    .replace(/\D/g, '')
                    .slice(0, 6);

            input.value =
                code;

            setMessage(
                'otpAuthError',
                ''
            );

            if (!userEmailToVerify) {
                setMessage(
                    'otpAuthError',
                    'Your verification session expired. Request another code.'
                );

                return;
            }

            if (code.length !== 6) {
                setMessage(
                    'otpAuthError',
                    'Enter the complete six-digit code.'
                );

                input.focus();
                return;
            }

            button.disabled =
                true;

            button.textContent =
                'Verifying...';

            try {
                const response =
                    await fetch(
                        '/api/verify-otp',
                        {
                            method:
                                'POST',

                            headers: {
                                'Content-Type':
                                    'application/json',

                                Accept:
                                    'application/json'
                            },

                            body:
                                JSON.stringify({
                                    email:
                                        userEmailToVerify,

                                    code
                                })
                        }
                    );

                const result =
                    await response
                        .json()
                        .catch(
                            () => ({})
                        );

                if (
                    !response.ok ||
                    !result.success
                ) {
                    throw new Error(
                        result.message ||
                        'The verification code is invalid or expired.'
                    );
                }

                window.location.reload();
            } catch (error) {
                setMessage(
                    'otpAuthError',
                    error &&
                    error.message
                        ? error.message
                        : 'The verification code is invalid or expired.'
                );
            } finally {
                button.disabled =
                    false;

                button.textContent =
                    'Verify and continue';
            }
        }

        function closeModals() {
            hideModal(
                'emailModal'
            );

            hideModal(
                'otpModal'
            );

            hideModal(
                'buyModal'
            );

            document.body.classList.remove(
                'modal-open'
            );

            setMessage(
                'emailAuthError',
                ''
            );

            setMessage(
                'otpAuthError',
                ''
            );

            setMessage(
                'paypalLinkError',
                ''
            );

            resetCardButton();
        }

        function switchTab(tabId) {
            const showStore =
                tabId ===
                'store';

            const storeButton =
                element(
                    'tab-store'
                );

            const postsButton =
                element(
                    'tab-posts'
                );

            const storeGrid =
                element(
                    'store-grid'
                );

            const postsGrid =
                element(
                    'posts-grid'
                );

            storeGrid.classList.toggle(
                'hidden',
                !showStore
            );

            postsGrid.classList.toggle(
                'hidden',
                showStore
            );

            storeButton.setAttribute(
                'aria-selected',
                String(showStore)
            );

            postsButton.setAttribute(
                'aria-selected',
                String(!showStore)
            );

            storeButton.className =
                showStore
                    ? 'border-b-2 border-blue-600 px-1 pb-4 text-sm font-black text-blue-600 transition'
                    : 'border-b-2 border-transparent px-1 pb-4 text-sm font-black text-slate-400 transition hover:text-slate-800';

            postsButton.className =
                !showStore
                    ? 'border-b-2 border-blue-600 px-1 pb-4 text-sm font-black text-blue-600 transition'
                    : 'border-b-2 border-transparent px-1 pb-4 text-sm font-black text-slate-400 transition hover:text-slate-800';
        }

        function renderSearchResults(items) {
            const dropdown =
                element(
                    'searchDropdown'
                );

            dropdown.replaceChildren();

            if (
                !Array.isArray(items) ||
                items.length === 0
            ) {
                dropdown.classList.add(
                    'hidden'
                );

                dropdown.classList.remove(
                    'flex'
                );

                return;
            }

            items.forEach(item => {
                const link =
                    document.createElement(
                        'a'
                    );

                link.href =
                    '/?q=' +
                    encodeURIComponent(
                        safeString(
                            item.title
                        )
                    );

                link.className =
                    'flex items-center justify-between gap-4 border-b border-slate-100 px-5 py-4 transition last:border-0 hover:bg-blue-50';

                link.setAttribute(
                    'role',
                    'option'
                );

                const content =
                    document.createElement(
                        'div'
                    );

                content.className =
                    'min-w-0';

                const title =
                    document.createElement(
                        'div'
                    );

                title.className =
                    'truncate text-sm font-black text-slate-900';

                title.textContent =
                    safeString(
                        item.title,
                        'Untitled product'
                    );

                const category =
                    document.createElement(
                        'div'
                    );

                category.className =
                    'mt-1 text-[10px] font-black uppercase tracking-[0.12em] text-blue-600';

                category.textContent =
                    safeString(
                        item.category,
                        'Product'
                    );

                const arrow =
                    document.createElement(
                        'span'
                    );

                arrow.className =
                    'shrink-0 text-blue-500';

                arrow.textContent =
                    '→';

                content.append(
                    title,
                    category
                );

                link.append(
                    content,
                    arrow
                );

                dropdown.appendChild(
                    link
                );
            });

            dropdown.classList.remove(
                'hidden'
            );

            dropdown.classList.add(
                'flex'
            );
        }

        async function searchMarketplace(query) {
            if (searchController) {
                searchController.abort();
            }

            searchController =
                new AbortController();

            try {
                const response =
                    await fetch(
                        '/api/search?q=' +
                        encodeURIComponent(
                            query
                        ),
                        {
                            headers: {
                                Accept:
                                    'application/json'
                            },

                            signal:
                                searchController.signal
                        }
                    );

                if (!response.ok) {
                    throw new Error(
                        'Search failed.'
                    );
                }

                const results =
                    await response.json();

                renderSearchResults(
                    results
                );
            } catch (error) {
                if (
                    error.name !==
                    'AbortError'
                ) {
                    console.error(
                        'Search error:',
                        error
                    );

                    renderSearchResults(
                        []
                    );
                }
            }
        }

        document.addEventListener(
            'DOMContentLoaded',
            () => {
                const searchInput =
                    element(
                        'searchInput'
                    );

                const searchDropdown =
                    element(
                        'searchDropdown'
                    );

                const otpInput =
                    element(
                        'authOtpInput'
                    );

                const buyForm =
                    element(
                        'buyForm'
                    );

                const cardLink =
                    element(
                        'paypalCardLink'
                    );

                const urlParameters =
                    new URLSearchParams(
                        window.location.search
                    );

                if (
                    urlParameters.get(
                        'tab'
                    ) === 'posts'
                ) {
                    switchTab(
                        'posts'
                    );
                }

                document
                    .querySelectorAll(
                        '.purchase-button'
                    )
                    .forEach(button => {
                        button.addEventListener(
                            'click',
                            () => {
                                handleBuyClick({
                                    id:
                                        button.dataset
                                            .productId,

                                    title:
                                        button.dataset
                                            .productTitle,

                                    tier:
                                        button.dataset
                                            .productTier,

                                    price:
                                        button.dataset
                                            .productPrice,

                                    paypalButtonId:
                                        button.dataset
                                            .paypalButtonId
                                });
                            }
                        );
                    });

                document
                    .querySelectorAll(
                        'input[name="payment_method_choice"]'
                    )
                    .forEach(input => {
                        input.addEventListener(
                            'change',
                            handlePaymentMethodChange
                        );
                    });

                cardLink.addEventListener(
                    'click',
                    handleCardLinkClick
                );

                if (
                    searchInput &&
                    searchDropdown
                ) {
                    searchInput.addEventListener(
                        'input',
                        event => {
                            const query =
                                event.target.value.trim();

                            window.clearTimeout(
                                searchTimer
                            );

                            if (
                                query.length < 2
                            ) {
                                if (
                                    searchController
                                ) {
                                    searchController.abort();
                                }

                                renderSearchResults(
                                    []
                                );

                                return;
                            }

                            searchTimer =
                                window.setTimeout(
                                    () => {
                                        searchMarketplace(
                                            query
                                        );
                                    },
                                    250
                                );
                        }
                    );
                }

                document.addEventListener(
                    'click',
                    event => {
                        if (
                            searchDropdown &&
                            searchInput &&
                            !searchDropdown.contains(
                                event.target
                            ) &&
                            event.target !==
                                searchInput
                        ) {
                            searchDropdown.classList.add(
                                'hidden'
                            );

                            searchDropdown.classList.remove(
                                'flex'
                            );
                        }
                    }
                );

                if (otpInput) {
                    otpInput.addEventListener(
                        'input',
                        () => {
                            otpInput.value =
                                otpInput.value
                                    .replace(
                                        /\D/g,
                                        ''
                                    )
                                    .slice(
                                        0,
                                        6
                                    );
                        }
                    );

                    otpInput.addEventListener(
                        'keydown',
                        event => {
                            if (
                                event.key ===
                                'Enter'
                            ) {
                                verifyOtp();
                            }
                        }
                    );
                }

                element(
                    'authEmailInput'
                )?.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Enter'
                        ) {
                            sendOtp();
                        }
                    }
                );

                /*
                 * Crypto and gift-card payments use /checkout.
                 * The PayPal card link never submits this form.
                 */
                buyForm.addEventListener(
                    'submit',
                    event => {
                        const selected =
                            document.querySelector(
                                'input[name="payment_method_choice"]:checked'
                            );

                        const paymentMethod =
                            selected
                                ? selected.value
                                : 'PayPalCardLink';

                        if (
                            paymentMethod ===
                            'PayPalCardLink'
                        ) {
                            event.preventDefault();

                            cardLink.click();
                            return;
                        }

                        const normalButton =
                            element(
                                'normalCheckoutButton'
                            );

                        normalButton.disabled =
                            true;

                        normalButton.textContent =
                            'Preparing checkout...';
                    }
                );

                [
                    element('emailModal'),
                    element('otpModal'),
                    element('buyModal')
                ].forEach(modal => {
                    modal?.addEventListener(
                        'mousedown',
                        event => {
                            if (
                                event.target ===
                                modal
                            ) {
                                closeModals();
                            }
                        }
                    );
                });

                document.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Escape'
                        ) {
                            closeModals();
                        }
                    }
                );

                /*
                 * Resume checkout after OTP verification.
                 */
                if (isAuthenticated) {
                    const pending =
                        sessionStorage.getItem(
                            'pendingBuy'
                        );

                    if (pending) {
                        try {
                            const parsed =
                                JSON.parse(
                                    pending
                                );

                            activeProduct = {
                                id:
                                    safeString(
                                        parsed.id
                                    ),

                                title:
                                    safeString(
                                        parsed.title,
                                        'Digital product'
                                    ),

                                tier:
                                    safeString(
                                        parsed.tier,
                                        'Standard'
                                    ),

                                price:
                                    safePrice(
                                        parsed.price
                                    ),

                                paypalButtonId:
                                    normalizePayPalButtonId(
                                        parsed.paypalButtonId
                                    )
                            };

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );

                            if (
                                activeProduct.id &&
                                activeProduct.price > 0
                            ) {
                                window.setTimeout(
                                    openBuyModal,
                                    250
                                );
                            }
                        } catch (error) {
                            console.error(
                                'Could not restore pending purchase:',
                                error
                            );

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );
                        }
                    }
                }
            }
        );
    </script>
</body>
</html>