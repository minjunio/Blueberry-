<!DOCTYPE html>
<html lang="en">
<head>
    <%
        const safeProducts = Array.isArray(products) ? products : [];
        const safeCategories = Array.isArray(categories) ? categories : [];

        const safePosts =
            typeof posts !== 'undefined' && Array.isArray(posts)
                ? posts
                : [];

        const safeAnnouncements =
            typeof announcements !== 'undefined' && Array.isArray(announcements)
                ? announcements
                : [];

        const currentCategory =
            typeof categoryFilter !== 'undefined' && categoryFilter
                ? categoryFilter
                : 'All';

        const currentSearch =
            typeof searchQuery !== 'undefined' && searchQuery
                ? searchQuery
                : '';

        const currentBuyerEmail =
            typeof buyerEmail !== 'undefined' && buyerEmail
                ? buyerEmail
                : '';

        const paypalPublicClientId =
            typeof paypalClientId !== 'undefined' && paypalClientId
                ? paypalClientId
                : 'BAACqOV8IkLP3i0-_Ty6IA7zt5_OxtawbH5tAUCjenPO6KcpDgcEscgNhhZCTP9dVtHBQB6BrxF5QoOBnM';

        const seoTitle =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_title
                ? categoryRow.seo_title
                : 'ExamHub Marketplace';

        const seoDesc =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_desc
                ? categoryRow.seo_desc
                : 'Premium digital learning resources and study tools.';

        const seoKeywords =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_keywords
                ? categoryRow.seo_keywords
                : 'exams, study tools, marketplace, preparation, learning';

        const ogImage =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.og_image
                ? categoryRow.og_image
                : 'https://examhub.shop/favicon.png';

        const canonicalUrl =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.canonical_url
                ? categoryRow.canonical_url
                : '';

        function formatPostText(text) {
            if (!text) return '';

            let output = String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');

            output = output.replace(
                /\*\*([\s\S]*?)\*\*/g,
                '<strong class="font-extrabold text-slate-950">$1</strong>'
            );

            output = output.replace(
                /#([^#\n]+)#/g,
                '<span class="block mt-5 mb-2 text-xl md:text-2xl font-black text-slate-950">$1</span>'
            );

            output = output.replace(/\n/g, '<br>');

            return output;
        }
    %>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1, viewport-fit=cover"
    >

    <title><%= seoTitle %></title>

    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">

    <meta
        name="robots"
        content="index, follow, max-image-preview:large"
    >

    <% if (canonicalUrl) { %>
        <link rel="canonical" href="<%= canonicalUrl %>">
    <% } %>

    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">

    <link rel="icon" type="image/png" href="/favicon.png">

    <%- include('partials/head') %>

    <!--
        Card Fields only.

        No PayPal wallet button and no hosted-button stack are loaded.
    -->
    <script
        src="https://www.paypal.com/sdk/js?client-id=<%= encodeURIComponent(paypalPublicClientId) %>&currency=USD&intent=capture&components=card-fields"
        data-sdk-integration-source="developer-studio"
        defer
    ></script>

    <style>
        :root {
            --brand: #2563eb;
            --brand-dark: #1d4ed8;
            --brand-soft: #eff6ff;
            --ink: #0f172a;
            --muted: #64748b;
            --line: #e2e8f0;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            min-height: 100vh;
        }

        body.modal-open {
            overflow: hidden;
        }

        .page-background {
            background:
                radial-gradient(
                    circle at 10% 5%,
                    rgba(59, 130, 246, 0.13),
                    transparent 26rem
                ),
                radial-gradient(
                    circle at 92% 10%,
                    rgba(99, 102, 241, 0.10),
                    transparent 24rem
                ),
                linear-gradient(
                    180deg,
                    #f8fbff 0%,
                    #f8fafc 42%,
                    #f1f5f9 100%
                );
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.86);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
        }

        .premium-card {
            position: relative;
            overflow: hidden;
            transition:
                transform 180ms ease,
                box-shadow 180ms ease,
                border-color 180ms ease;
        }

        .premium-card::before {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            opacity: 0;
            background:
                linear-gradient(
                    135deg,
                    rgba(37, 99, 235, 0.07),
                    transparent 42%
                );
            transition: opacity 180ms ease;
        }

        .premium-card:hover {
            transform: translateY(-4px);
            border-color: #bfdbfe;
            box-shadow:
                0 22px 55px rgba(15, 23, 42, 0.10),
                0 4px 12px rgba(15, 23, 42, 0.04);
        }

        .premium-card:hover::before {
            opacity: 1;
        }

        .modal-backdrop {
            background: rgba(2, 6, 23, 0.70);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .checkout-shell {
            max-height: calc(100vh - 2rem);
        }

        .paypal-card-field {
            height: 54px;
            width: 100%;
            padding: 0 14px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            background: #ffffff;
            transition:
                border-color 160ms ease,
                box-shadow 160ms ease,
                background 160ms ease;
        }

        .paypal-card-field:hover {
            border-color: #94a3b8;
        }

        .paypal-card-field.field-focused {
            border-color: #2563eb;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.11);
            background: #ffffff;
        }

        .paypal-card-field.field-invalid {
            border-color: #ef4444;
            box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.09);
        }

        .loading-shimmer {
            position: relative;
            overflow: hidden;
            background: #e2e8f0;
        }

        .loading-shimmer::after {
            content: "";
            position: absolute;
            inset: 0;
            transform: translateX(-100%);
            background:
                linear-gradient(
                    90deg,
                    transparent,
                    rgba(255, 255, 255, 0.72),
                    transparent
                );
            animation: shimmer 1.35s infinite;
        }

        @keyframes shimmer {
            100% {
                transform: translateX(100%);
            }
        }

        .button-spinner {
            width: 19px;
            height: 19px;
            border: 2px solid rgba(255, 255, 255, 0.40);
            border-top-color: #ffffff;
            border-radius: 999px;
            animation: spin 700ms linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .card-chip {
            background:
                linear-gradient(
                    135deg,
                    #f8d76e,
                    #c99b2f
                );
        }

        .secure-grid {
            background-image:
                linear-gradient(
                    rgba(255,255,255,0.035) 1px,
                    transparent 1px
                ),
                linear-gradient(
                    90deg,
                    rgba(255,255,255,0.035) 1px,
                    transparent 1px
                );
            background-size: 24px 24px;
        }

        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }

        .no-scrollbar {
            scrollbar-width: none;
        }
    </style>
</head>

<body class="page-background antialiased flex flex-col text-slate-800">

    <!-- NAVIGATION -->
    <nav
        class="sticky top-0 z-40 border-b border-white/70 glass-panel shadow-[0_1px_14px_rgba(15,23,42,0.04)]"
    >
        <div
            class="max-w-7xl mx-auto w-full px-4 md:px-8 py-4 flex items-center justify-between"
        >
            <a
                href="/"
                class="flex items-center gap-3 group"
            >
                <span
                    class="w-10 h-10 rounded-2xl bg-gradient-to-br from-blue-600 to-indigo-600 text-white flex items-center justify-center shadow-lg shadow-blue-600/20 group-hover:scale-105 transition"
                >
                    <svg
                        viewBox="0 0 24 24"
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H6.5A2.5 2.5 0 0 0 4 21.5z"/>
                        <path d="M4 5.5v16"/>
                        <path d="M8 7h8"/>
                        <path d="M8 11h7"/>
                    </svg>
                </span>

                <span
                    class="text-2xl font-black tracking-tight text-slate-950"
                >
                    Exam<span class="text-blue-600">Hub</span>
                </span>
            </a>

            <div class="flex items-center gap-2 md:gap-3">
                <a
                    href="https://discord.gg/bg6wKj45w3"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hidden md:inline-flex items-center gap-2 bg-[#5865F2] hover:bg-[#4752C4] text-white px-4 py-2.5 rounded-xl font-extrabold text-sm transition shadow-sm"
                >
                    <svg
                        viewBox="0 0 24 24"
                        class="w-4 h-4"
                        fill="currentColor"
                    >
                        <path d="M19.54 5.34A17.3 17.3 0 0 0 15.3 4l-.52 1.06a15.4 15.4 0 0 0-5.56 0L8.7 4a17.2 17.2 0 0 0-4.24 1.34C1.78 9.33 1.05 13.22 1.42 17.05a17 17 0 0 0 5.2 2.61l1.26-1.72a11 11 0 0 1-1.98-.96l.49-.38a12.3 12.3 0 0 0 11.22 0l.5.38a11.6 11.6 0 0 1-1.99.96l1.26 1.72a17 17 0 0 0 5.2-2.61c.44-4.44-.75-8.29-3.04-11.71ZM8.41 14.68c-1.1 0-2-1.01-2-2.24s.88-2.24 2-2.24c1.13 0 2.02 1.02 2 2.24 0 1.23-.88 2.24-2 2.24Zm7.18 0c-1.1 0-2-1.01-2-2.24s.88-2.24 2-2.24c1.13 0 2.02 1.02 2 2.24 0 1.23-.87 2.24-2 2.24Z"/>
                    </svg>

                    Community
                </a>

                <% if (currentBuyerEmail) { %>
                    <a
                        href="/my-orders"
                        class="inline-flex items-center gap-2 bg-slate-950 text-white hover:bg-slate-800 px-4 py-2.5 rounded-xl font-extrabold text-sm transition shadow-sm"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M6 2h12l1 5H5z"/>
                            <path d="M5 7v15h14V7"/>
                            <path d="M9 11h6"/>
                        </svg>

                        <span class="hidden sm:inline">My Orders</span>

                        <% if (
                            typeof activeOrderCount !== 'undefined' &&
                            Number(activeOrderCount) > 0
                        ) { %>
                            <span
                                class="min-w-5 h-5 px-1.5 rounded-full bg-red-500 text-white text-[10px] flex items-center justify-center"
                            >
                                <%= activeOrderCount %>
                            </span>
                        <% } %>
                    </a>

                    <a
                        href="/buyer-logout"
                        class="hidden md:inline-flex text-sm font-bold text-slate-500 hover:text-red-600 px-2 py-2 transition"
                    >
                        Logout
                    </a>
                <% } %>

                <% if (typeof user !== 'undefined' && user) { %>
                    <a
                        href="/admin"
                        class="inline-flex items-center bg-white hover:bg-slate-50 border border-slate-200 text-slate-700 px-4 py-2.5 rounded-xl font-extrabold text-sm transition shadow-sm"
                    >
                        Admin
                    </a>
                <% } else if (!currentBuyerEmail) { %>
                    <a
                        href="/login"
                        class="inline-flex items-center bg-white hover:bg-slate-50 border border-slate-200 text-slate-700 px-4 py-2.5 rounded-xl font-extrabold text-sm transition shadow-sm"
                    >
                        Login
                    </a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- HERO -->
    <header class="relative overflow-hidden">
        <div
            class="absolute -top-28 -left-24 w-80 h-80 bg-blue-300/20 blur-3xl rounded-full pointer-events-none"
        ></div>

        <div
            class="absolute top-0 -right-24 w-96 h-96 bg-indigo-300/20 blur-3xl rounded-full pointer-events-none"
        ></div>

        <div
            class="relative max-w-7xl mx-auto px-4 md:px-8 pt-14 md:pt-20 pb-12"
        >
            <div class="max-w-4xl mx-auto text-center">

                <div
                    class="inline-flex items-center gap-2 rounded-full border border-blue-200 bg-white/80 px-4 py-2 text-xs font-extrabold text-blue-700 shadow-sm mb-6"
                >
                    <span class="relative flex w-2 h-2">
                        <span
                            class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"
                        ></span>

                        <span
                            class="relative inline-flex w-2 h-2 rounded-full bg-green-500"
                        ></span>
                    </span>

                    Secure digital marketplace
                </div>

                <h1
                    class="text-4xl sm:text-5xl md:text-7xl font-black tracking-[-0.045em] text-slate-950 leading-[1.02]"
                >
                    Build your skills.
                    <span
                        class="block text-transparent bg-clip-text bg-gradient-to-r from-blue-600 via-indigo-600 to-violet-600"
                    >
                        Master every exam.
                    </span>
                </h1>

                <p
                    class="max-w-2xl mx-auto mt-6 text-base md:text-lg text-slate-500 font-medium leading-relaxed"
                >
                    Discover detailed digital resources, learning tools and
                    premium preparation packages in one secure marketplace.
                </p>

                <div class="max-w-2xl mx-auto mt-9 relative">

                    <form
                        action="/"
                        method="GET"
                        class="relative group"
                        role="search"
                    >
                        <% if (
                            currentCategory &&
                            currentCategory !== 'All'
                        ) { %>
                            <input
                                type="hidden"
                                name="category"
                                value="<%= currentCategory %>"
                            >
                        <% } %>

                        <div
                            class="absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <circle cx="11" cy="11" r="7"/>
                                <path d="m20 20-3.5-3.5"/>
                            </svg>
                        </div>

                        <input
                            type="search"
                            id="searchInput"
                            name="q"
                            autocomplete="off"
                            value="<%= currentSearch %>"
                            placeholder="Search the marketplace..."
                            aria-label="Search marketplace"
                            aria-controls="searchDropdown"
                            class="w-full h-16 bg-white/95 border border-slate-200 focus:border-blue-500 focus:ring-4 focus:ring-blue-100 rounded-2xl pl-14 pr-32 outline-none shadow-[0_18px_50px_rgba(15,23,42,0.10)] text-base font-semibold transition"
                        >

                        <button
                            type="submit"
                            class="absolute right-2 top-2 bottom-2 bg-gradient-to-r from-blue-600 to-indigo-600 text-white px-6 rounded-xl font-extrabold hover:shadow-lg hover:shadow-blue-600/25 hover:-translate-y-0.5 transition"
                        >
                            Search
                        </button>
                    </form>

                    <div
                        id="searchDropdown"
                        class="hidden absolute top-full left-0 w-full bg-white border border-slate-200 rounded-2xl mt-3 shadow-2xl overflow-hidden z-50 flex-col text-left"
                        role="listbox"
                    ></div>
                </div>

                <div
                    class="flex flex-wrap justify-center gap-2 mt-8 max-w-4xl mx-auto"
                >
                    <a
                        href="/"
                        class="px-4 py-2.5 rounded-xl font-extrabold text-xs md:text-sm border <%= currentCategory === 'All' ? 'bg-slate-950 text-white border-slate-950 shadow-lg shadow-slate-950/15' : 'bg-white/80 text-slate-600 border-slate-200 hover:border-blue-300 hover:text-blue-700' %> transition"
                    >
                        All products
                    </a>

                    <% safeCategories.forEach(cat => { %>
                        <a
                            href="/category/<%= encodeURIComponent(cat.name) %>"
                            class="px-4 py-2.5 rounded-xl font-extrabold text-xs md:text-sm border <%= currentCategory === cat.name ? 'bg-slate-950 text-white border-slate-950 shadow-lg shadow-slate-950/15' : 'bg-white/80 text-slate-600 border-slate-200 hover:border-blue-300 hover:text-blue-700' %> transition"
                        >
                            <%= cat.name %>
                        </a>
                    <% }) %>
                </div>

                <div
                    class="flex flex-wrap justify-center gap-x-6 gap-y-3 mt-9 text-xs font-bold text-slate-500"
                >
                    <span class="inline-flex items-center gap-2">
                        <svg
                            viewBox="0 0 24 24"
                            class="w-4 h-4 text-green-600"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="m5 12 4 4L19 6"/>
                        </svg>

                        Secure card processing
                    </span>

                    <span class="inline-flex items-center gap-2">
                        <svg
                            viewBox="0 0 24 24"
                            class="w-4 h-4 text-blue-600"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M12 3 4 6v5c0 5 3.4 8.6 8 10 4.6-1.4 8-5 8-10V6z"/>
                        </svg>

                        Encrypted checkout
                    </span>

                    <span class="inline-flex items-center gap-2">
                        <svg
                            viewBox="0 0 24 24"
                            class="w-4 h-4 text-indigo-600"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path d="M4 6h16v12H4z"/>
                            <path d="M4 10h16"/>
                        </svg>

                        Visa, Mastercard and Amex
                    </span>
                </div>
            </div>
        </div>
    </header>

    <!-- MAIN -->
    <main
        class="flex-grow w-full max-w-7xl mx-auto px-4 md:px-8 relative z-20 pb-20"
    >
        <% if (safeAnnouncements.length > 0) { %>
            <section class="mb-12 space-y-6">
                <% safeAnnouncements.forEach(ann => { %>
                    <article
                        class="bg-white/90 rounded-3xl p-6 md:p-8 shadow-sm border border-blue-100 overflow-hidden"
                    >
                        <div
                            class="inline-flex items-center gap-2 bg-blue-50 text-blue-700 font-extrabold text-[10px] px-3 py-1.5 rounded-full uppercase tracking-wider mb-4"
                        >
                            <span class="w-1.5 h-1.5 rounded-full bg-blue-600"></span>
                            <%= ann.category || 'Marketplace' %> update
                        </div>

                        <h2
                            class="text-2xl md:text-3xl font-black mb-5 text-slate-950 tracking-tight"
                        >
                            <%= ann.title %>
                        </h2>

                        <% if (ann.image1 || ann.image2) { %>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
                                <% if (ann.image1) { %>
                                    <img
                                        src="<%= ann.image1 %>"
                                        alt="<%= ann.title %>"
                                        loading="lazy"
                                        class="w-full h-60 rounded-2xl object-cover border border-slate-100"
                                    >
                                <% } %>

                                <% if (ann.image2) { %>
                                    <img
                                        src="<%= ann.image2 %>"
                                        alt="<%= ann.title %>"
                                        loading="lazy"
                                        class="w-full h-60 rounded-2xl object-cover border border-slate-100"
                                    >
                                <% } %>
                            </div>
                        <% } %>

                        <div
                            class="text-sm md:text-base font-medium text-slate-600 leading-relaxed"
                        >
                            <%- formatPostText(ann.content) %>
                        </div>
                    </article>
                <% }) %>
            </section>
        <% } %>

        <div
            class="flex flex-col sm:flex-row sm:items-end justify-between gap-5 mb-8"
        >
            <div>
                <span
                    class="text-xs uppercase tracking-[0.24em] font-black text-blue-600"
                >
                    ExamHub catalog
                </span>

                <h2
                    class="text-3xl md:text-4xl font-black text-slate-950 tracking-tight mt-2"
                >
                    Explore the marketplace
                </h2>

                <p class="text-sm text-slate-500 font-medium mt-2">
                    Select a package to view its secure card checkout.
                </p>
            </div>

            <div
                class="inline-flex self-start sm:self-auto gap-1 rounded-2xl border border-slate-200 bg-white p-1.5 shadow-sm"
                role="tablist"
            >
                <button
                    type="button"
                    onclick="switchTab('store')"
                    id="tab-store"
                    role="tab"
                    aria-selected="true"
                    class="rounded-xl px-5 py-2.5 text-sm font-extrabold bg-slate-950 text-white shadow-sm transition"
                >
                    Store
                </button>

                <button
                    type="button"
                    onclick="switchTab('posts')"
                    id="tab-posts"
                    role="tab"
                    aria-selected="false"
                    class="rounded-xl px-5 py-2.5 text-sm font-extrabold text-slate-500 hover:text-slate-950 transition"
                >
                    Updates
                </button>
            </div>
        </div>

        <!-- PRODUCTS -->
        <section
            id="store-grid"
            role="tabpanel"
            aria-labelledby="tab-store"
        >
            <div
                class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6"
            >
                <% if (safeProducts.length === 0) { %>
                    <div
                        class="col-span-full rounded-3xl border border-dashed border-slate-300 bg-white/70 text-center py-20 px-6"
                    >
                        <div
                            class="w-16 h-16 mx-auto rounded-2xl bg-slate-100 text-slate-400 flex items-center justify-center mb-4"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                class="w-8 h-8"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.7"
                            >
                                <path d="M4 6h16v12H4z"/>
                                <path d="M8 10h8"/>
                                <path d="M8 14h5"/>
                            </svg>
                        </div>

                        <p class="font-black text-xl text-slate-700">
                            No products found
                        </p>

                        <p class="text-sm text-slate-500 mt-2">
                            Try another search or marketplace category.
                        </p>
                    </div>
                <% } else { %>
                    <% safeProducts.forEach(product => { %>
                        <article
                            class="premium-card bg-white rounded-3xl border border-slate-200 shadow-[0_8px_28px_rgba(15,23,42,0.055)] flex flex-col h-full"
                        >
                            <div class="relative p-5 pb-0">
                                <div
                                    class="relative h-52 rounded-2xl overflow-hidden bg-gradient-to-br from-slate-100 to-slate-50 border border-slate-100"
                                >
                                    <img
