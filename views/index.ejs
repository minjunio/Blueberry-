                    class="w-full mt-5 bg-gradient-to-r from-green-600 to-emerald-600 text-white font-extrabold py-3.5 rounded-xl hover:shadow-lg hover:shadow-green-600/20 disabled:opacity-60 disabled:cursor-not-allowed transition"
