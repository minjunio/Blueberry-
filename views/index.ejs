                                    </label>

                                    <div
                                        id="card-expiry-field-container"
                                        class="paypal-card-field"
                                    ></div>
                                </div>

                                <div>
                                    <label
                                        class="block text-xs font-extrabold text-slate-700 mb-2"
                                    >
                                        Security code
                                    </label>

                                    <div
                                        id="card-cvv-field-container"
                                        class="paypal-card-field"
                                    ></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CARD ERROR -->
                    <div
                        id="cardPaymentError"
                        class="hidden mt-5 rounded-2xl border border-red-200 bg-red-50 px-4 py-4"
                        role="alert"
                    >
                        <div class="flex items-start gap-3">
                            <div
                                class="w-8 h-8 rounded-full bg-red-100 text-red-600 flex items-center justify-center shrink-0"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    class="w-4 h-4"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M12 9v4"/>
                                    <path d="M12 17h.01"/>
                                    <path d="M10.3 3.7 2.5 17.2A2 2 0 0 0 4.2 20h15.6a2 2 0 0 0 1.7-2.8L13.7 3.7a2 2 0 0 0-3.4 0Z"/>
                                </svg>
                            </div>

                            <div>
                                <p class="text-sm font-black text-red-800">
                                    Card payment could not continue
                                </p>

                                <p
                                    id="cardPaymentErrorMessage"
                                    class="text-xs font-semibold text-red-700 mt-1 leading-relaxed"
                                ></p>

                                <button
                                    type="button"
                                    onclick="retryCardFields()"
                                    id="retryCardFieldsButton"
                                    class="hidden mt-3 text-xs font-black text-red-800 underline"
                                >
                                    Try loading card checkout again
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- SUCCESS -->
                    <div
                        id="cardPaymentSuccess"
                        class="hidden mt-5 rounded-2xl border border-green-200 bg-green-50 px-4 py-4"
                    >
                        <div class="flex items-center gap-3">
                            <div
                                class="w-9 h-9 rounded-full bg-green-600 text-white flex items-center justify-center"
                            >
                                <svg
                                    viewBox="0 0 24 24"
                                    class="w-5 h-5"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                >
                                    <path d="m5 12 4 4L19 6"/>
                                </svg>
                            </div>

                            <div>
                                <p class="text-sm font-black text-green-800">
                                    Payment completed
                                </p>

                                <p class="text-xs font-semibold text-green-700 mt-1">
                                    Preparing your order now...
                                </p>
                            </div>
                        </div>
                    </div>

                    <!-- ONLY CHECKOUT BUTTON -->
                    <button
                        type="button"
                        id="cardPaymentButton"
                        onclick="submitCardPayment()"
                        disabled
                        class="w-full mt-6 min-h-[58px] bg-gradient-to-r from-blue-600 via-blue-600 to-indigo-600 text-white font-black py-4 px-5 rounded-2xl hover:-translate-y-0.5 hover:shadow-xl hover:shadow-blue-600/25 focus:ring-4 focus:ring-blue-100 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0 disabled:hover:shadow-none transition flex items-center justify-center gap-3"
                    >
                        <span
                            id="cardPaymentButtonIcon"
                            class="w-8 h-8 rounded-xl bg-white/15 flex items-center justify-center"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <rect x="3" y="5" width="18" height="14" rx="2"/>
                                <path d="M3 10h18"/>
                                <path d="M7 15h3"/>
                            </svg>
                        </span>

                        <span id="cardPaymentButtonText">
                            Pay securely by card
                        </span>
                    </button>

                    <div
                        class="flex items-center justify-center gap-2 mt-4 text-[10px] font-bold text-slate-400"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <rect x="5" y="10" width="14" height="10" rx="2"/>
                            <path d="M8 10V7a4 4 0 0 1 8 0v3"/>
                        </svg>

                        Card information is entered into PayPal-hosted
                        encrypted fields
                    </div>
                </section>
            </div>
        </div>
    </div>

    <!--
        After PayPal captures the card payment, this form passes the verified
        capture into your existing /checkout route so your existing order
        creation and delivery logic can continue.
    -->
    <form
        id="completedPaymentForm"
        action="/checkout"
        method="POST"
        class="hidden"
    >
        <input type="hidden" name="product_id" id="completedProductId">
        <input type="hidden" name="tier" id="completedProductTier">
        <input type="hidden" name="discord_username" id="completedDiscordUsername">
        <input type="hidden" name="payment_method" value="PayPal">
        <input type="hidden" name="paypal_order_id" id="completedPayPalOrderId">
        <input type="hidden" name="paypal_capture_id" id="completedPayPalCaptureId">
    </form>

    <!-- FOOTER -->
    <footer class="bg-slate-950 text-white mt-10 relative overflow-hidden">
        <div
            class="absolute inset-0 secure-grid opacity-50 pointer-events-none"
        ></div>

        <div
            class="relative max-w-7xl mx-auto px-4 md:px-8 py-10 flex flex-col md:flex-row items-center justify-between gap-5"
        >
            <div class="flex items-center gap-3">
                <span
                    class="w-10 h-10 rounded-2xl bg-blue-600 flex items-center justify-center"
                >
                    <svg
                        viewBox="0 0 24 24"
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H6.5A2.5 2.5 0 0 0 4 21.5z"/>
                        <path d="M4 5.5v16"/>
                    </svg>
                </span>

                <div>
                    <p class="font-black text-lg">
                        ExamHub
                    </p>

                    <p class="text-xs text-slate-400 font-semibold">
                        Digital learning marketplace
                    </p>
                </div>
            </div>

            <p class="text-xs md:text-sm font-bold text-slate-400 text-center">
                © 2026 ExamHub Marketplace. All rights reserved.
            </p>
        </div>
    </footer>

    <script>
        'use strict';

        const isAuthenticated =
            <%- JSON.stringify(Boolean(currentBuyerEmail)) %>;

        let userEmailToVerify = '';

        let activeProduct = {
            id: '',
            title: '',
            tier: '',
            price: 0,
            image: ''
        };

        let cardFieldsInstance = null;
        let cardFieldsInitializing = false;
        let cardFieldsReady = false;
        let paymentProcessing = false;

        let searchTimer = null;
        let searchController = null;

        function byId(id) {
            return document.getElementById(id);
        }

        function setText(id, text) {
            const element = byId(id);

            if (element) {
                element.textContent = String(text || '');
            }
        }

        function showModal(id) {
            const modal = byId(id);

            if (!modal) return;

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            modal.setAttribute('aria-hidden', 'false');

            document.body.classList.add('modal-open');
        }

        function hideModal(id) {
            const modal = byId(id);

            if (!modal) return;

            modal.classList.add('hidden');
            modal.classList.remove('flex');
            modal.setAttribute('aria-hidden', 'true');
        }

        function showError(containerId, messageId, message, retry = false) {
            const container = byId(containerId);
            const messageElement = byId(messageId);
            const retryButton = byId('retryCardFieldsButton');

            if (messageElement) {
                messageElement.textContent =
                    String(message || 'Something went wrong.');
            }

            if (container) {
                container.classList.remove('hidden');
            }

            if (retryButton) {
                retryButton.classList.toggle('hidden', !retry);
            }
        }

        function clearError(containerId, messageId) {
            const container = byId(containerId);
            const messageElement = byId(messageId);

            if (container) {
                container.classList.add('hidden');
            }

            if (messageElement) {
                messageElement.textContent = '';
            }
        }

        function setButtonLoading(loading, text = '') {
            const button = byId('cardPaymentButton');
            const icon = byId('cardPaymentButtonIcon');
            const label = byId('cardPaymentButtonText');

            if (!button || !icon || !label) return;

            button.disabled = Boolean(
                loading ||
                !cardFieldsReady ||
                paymentProcessing
            );

            if (loading) {
                icon.innerHTML =
                    '<span class="button-spinner"></span>';

                label.textContent =
                    text || 'Processing secure payment...';
            } else {
                icon.innerHTML = `
                    <svg
                        viewBox="0 0 24 24"
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <rect x="3" y="5" width="18" height="14" rx="2"></rect>
                        <path d="M3 10h18"></path>
                        <path d="M7 15h3"></path>
                    </svg>
                `;

                label.textContent =
                    `Pay $${activeProduct.price.toFixed(2)} securely`;
            }
        }

        function waitForPayPalCardFields(timeout = 15000) {
            return new Promise((resolve, reject) => {
                const startedAt = Date.now();

                const check = () => {
                    if (
                        window.paypal &&
                        typeof window.paypal.CardFields === 'function'
                    ) {
                        resolve(window.paypal);
                        return;
                    }

                    if (Date.now() - startedAt >= timeout) {
                        reject(
                            new Error(
                                'The secure card service did not finish loading.'
                            )
                        );

                        return;
                    }

                    window.setTimeout(check, 100);
                };

                check();
            });
        }

        async function initializeCardFields() {
            if (cardFieldsReady || cardFieldsInitializing) {
                return;
            }

            cardFieldsInitializing = true;

            clearError(
                'cardPaymentError',
                'cardPaymentErrorMessage'
            );

            byId('cardFieldsLoading')?.classList.remove('hidden');
            byId('cardFieldsContainer')?.classList.add('hidden');

            try {
                const paypalApi =
                    await waitForPayPalCardFields();

                const commonStyle = {
                    input: {
                        'font-family':
                            'Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif',

                        'font-size': '15px',
                        'font-weight': '600',
                        color: '#0f172a',
                        padding: '15px 0',
                        height: '52px',
                        outline: 'none',
                        background: 'transparent'
                    },

                    '.invalid': {
                        color: '#dc2626'
                    },

                    '.valid': {
                        color: '#0f172a'
                    }
                };

                cardFieldsInstance =
                    paypalApi.CardFields({
                        style: commonStyle,

                        inputEvents: {
                            onFocus() {
                                const focused =
                                    document.activeElement;

                                document
                                    .querySelectorAll(
                                        '.paypal-card-field'
                                    )
                                    .forEach(element => {
                                        element.classList.remove(
                                            'field-invalid'
                                        );
                                    });
                            },

                            onChange(data) {
                                const button =
                                    byId('cardPaymentButton');

                                if (button && !paymentProcessing) {
                                    button.disabled =
                                        !data.isFormValid;
                                }
                            },

                            onInputSubmitRequest(data) {
                                if (data.isFormValid) {
                                    submitCardPayment();
                                }
                            }
                        },

                        createOrder: async function () {
                            if (
                                !activeProduct.id ||
                                activeProduct.price <= 0
                            ) {
                                throw new Error(
                                    'The selected product is invalid.'
                                );
                            }

                            const response = await fetch(
                                '/api/paypal/create-order',
                                {
                                    method: 'POST',

                                    headers: {
                                        'Content-Type':
                                            'application/json',

                                        Accept:
                                            'application/json'
                                    },

                                    body: JSON.stringify({
                                        product_id:
                                            activeProduct.id,

                                        discord_username:
                                            byId('discordUsername')
                                                ?.value
                                                ?.trim() || ''
                                    })
                                }
                            );

                            const result =
                                await response
                                    .json()
                                    .catch(() => ({}));

                            if (
                                !response.ok ||
                                !result.orderID
                            ) {
                                throw new Error(
                                    result.message ||
                                    result.error ||
                                    'The payment order could not be created.'
                                );
                            }

                            return result.orderID;
                        },

                        onApprove: async function (data) {
                            setButtonLoading(
                                true,
                                'Confirming your payment...'
                            );

                            const response = await fetch(
                                '/api/paypal/capture-order',
                                {
                                    method: 'POST',

                                    headers: {
                                        'Content-Type':
                                            'application/json',

                                        Accept:
                                            'application/json'
                                    },

                                    body: JSON.stringify({
                                        orderID:
                                            data.orderID
                                    })
                                }
                            );

                            const result =
                                await response
                                    .json()
                                    .catch(() => ({}));

                            if (
                                !response.ok ||
                                !result.success ||
                                !result.captureID
                            ) {
                                throw new Error(
                                    result.message ||
                                    result.error ||
                                    'The card payment could not be confirmed.'
                                );
                            }

                            byId('cardPaymentSuccess')
                                ?.classList
                                .remove('hidden');

                            byId('cardFieldsContainer')
                                ?.classList
                                .add('hidden');

                            byId('completedProductId').value =
                                activeProduct.id;

                            byId('completedProductTier').value =
                                activeProduct.tier;

                            byId('completedDiscordUsername').value =
                                byId('discordUsername')
                                    ?.value
                                    ?.trim() || '';

                            byId('completedPayPalOrderId').value =
                                data.orderID;

                            byId('completedPayPalCaptureId').value =
                                result.captureID;

                            window.setTimeout(() => {
                                byId('completedPaymentForm')
                                    ?.submit();
                            }, 850);
                        },

                        onError: function (error) {
                            console.error(
                                'PayPal Card Fields error:',
                                error
                            );

                            paymentProcessing = false;

                            setButtonLoading(false);

                            showError(
                                'cardPaymentError',
                                'cardPaymentErrorMessage',
                                extractCardErrorMessage(error),
                                false
                            );
                        },

                        onCancel: function () {
                            paymentProcessing = false;

                            setButtonLoading(false);

                            showError(
                                'cardPaymentError',
                                'cardPaymentErrorMessage',
                                'Card verification was cancelled. No payment was completed.',
                                false
                            );
                        }
                    });

                if (!cardFieldsInstance.isEligible()) {
                    throw new Error(
                        'Credit and debit card payments are not enabled for this PayPal business account.'
                    );
                }

                await Promise.all([
                    cardFieldsInstance
                        .NameField({
                            placeholder: 'Full name as shown on card'
                        })
                        .render('#card-name-field-container'),

                    cardFieldsInstance
                        .NumberField({
                            placeholder: '1234 5678 9012 3456'
                        })
                        .render('#card-number-field-container'),

                    cardFieldsInstance
                        .ExpiryField({
                            placeholder: 'MM / YY'
                        })
                        .render('#card-expiry-field-container'),

                    cardFieldsInstance
                        .CVVField({
                            placeholder: 'CVV'
                        })
                        .render('#card-cvv-field-container')
                ]);

                cardFieldsReady = true;

                byId('cardFieldsLoading')
                    ?.classList
                    .add('hidden');

                byId('cardFieldsContainer')
                    ?.classList
                    .remove('hidden');

                setButtonLoading(false);
            } catch (error) {
                console.error(
                    'Card Fields initialization error:',
                    error
                );

                cardFieldsInstance = null;
                cardFieldsReady = false;

                byId('cardFieldsLoading')
                    ?.classList
                    .add('hidden');

                byId('cardFieldsContainer')
                    ?.classList
                    .add('hidden');

                showError(
                    'cardPaymentError',
                    'cardPaymentErrorMessage',
                    extractCardErrorMessage(error),
                    true
                );
            } finally {
                cardFieldsInitializing = false;
            }
        }

        function extractCardErrorMessage(error) {
            if (!error) {
                return 'The card payment could not continue.';
            }

            const text =
                error.message ||
                error.details?.[0]?.description ||
                String(error);

            if (
                /instrument_declined/i.test(text) ||
                /declined/i.test(text)
            ) {
                return 'Your card was declined. Check the card information or use another card.';
            }

            if (/eligible|enabled/i.test(text)) {
                return 'Card Fields are not enabled for this PayPal business account. Enable Expanded Credit and Debit Card Payments in the PayPal Developer Dashboard.';
            }

            if (/network|fetch/i.test(text)) {
                return 'The payment service could not be reached. Check your connection and try again.';
            }

            return text;
        }

        async function retryCardFields() {
            const retryButton =
                byId('retryCardFieldsButton');

            if (retryButton) {
                retryButton.classList.add('hidden');
            }

            clearError(
                'cardPaymentError',
                'cardPaymentErrorMessage'
            );

            cardFieldsInstance = null;
            cardFieldsReady = false;

            [
                'card-name-field-container',
                'card-number-field-container',
                'card-expiry-field-container',
                'card-cvv-field-container'
            ].forEach(id => {
                const element = byId(id);

                if (element) {
                    element.replaceChildren();
                }
            });

            await initializeCardFields();
        }

        async function submitCardPayment() {
            if (
                paymentProcessing ||
                !cardFieldsInstance ||
                !cardFieldsReady
            ) {
                return;
            }

            clearError(
                'cardPaymentError',
                'cardPaymentErrorMessage'
            );

            try {
                const state =
                    await cardFieldsInstance.getState();

                if (!state.isFormValid) {
                    showError(
                        'cardPaymentError',
                        'cardPaymentErrorMessage',
                        'Check the cardholder name, card number, expiry date and security code.',
                        false
                    );

                    return;
                }

                paymentProcessing = true;

                setButtonLoading(
                    true,
                    'Processing encrypted card payment...'
                );

                await cardFieldsInstance.submit();
            } catch (error) {
                console.error(
                    'Card submission error:',
                    error
                );

                paymentProcessing = false;

                setButtonLoading(false);

                showError(
                    'cardPaymentError',
                    'cardPaymentErrorMessage',
                    extractCardErrorMessage(error),
                    false
                );
            }
        }

        function openEmailModal() {
            clearError(
                'emailAuthError',
                'emailAuthError'
            );

            showModal('emailModal');

            window.setTimeout(() => {
                byId('authEmailInput')?.focus();
            }, 80);
        }

        function openBuyModal() {
            setText(
                'modalItemTitle',
                activeProduct.title
            );

            setText(
                'modalItemTier',
                activeProduct.tier
            );

            setText(
                'modalItemPrice',
                `$${activeProduct.price.toFixed(2)}`
            );

            setText(
                'cardPaymentButtonText',
                `Pay $${activeProduct.price.toFixed(2)} securely`
            );

            const image =
                byId('modalProductImage');

            const placeholder =
                byId('modalProductPlaceholder');

            if (activeProduct.image) {
                image.src = activeProduct.image;
                image.alt = activeProduct.title;

                image.classList.remove('hidden');
                placeholder.classList.add('hidden');
            } else {
                image.removeAttribute('src');
                image.classList.add('hidden');
                placeholder.classList.remove('hidden');
            }

            byId('cardPaymentSuccess')
                ?.classList
                .add('hidden');

            clearError(
                'cardPaymentError',
                'cardPaymentErrorMessage'
            );

            showModal('buyModal');

            /*
             * Render only after the modal is visible and has a measurable width.
             */
            window.requestAnimationFrame(() => {
                window.requestAnimationFrame(() => {
                    initializeCardFields();
                });
            });
        }

        function handleBuyClick(product) {
            activeProduct = {
                id: String(product.id || ''),
                title: String(
                    product.title || 'Product'
                ),
                tier: String(
                    product.tier || 'Standard'
                ),
                price: Number(
                    product.price || 0
                ),
                image: String(
                    product.image || ''
                )
            };

            if (
                !Number.isFinite(activeProduct.price) ||
                activeProduct.price <= 0
            ) {
                window.alert(
                    'This product does not have a valid price.'
                );

                return;
            }

            if (isAuthenticated) {
                openBuyModal();
                return;
            }

            sessionStorage.setItem(
                'pendingBuy',
                JSON.stringify(activeProduct)
            );

            openEmailModal();
        }

        async function sendOtp() {
            const input =
                byId('authEmailInput');

            const button =
                byId('sendOtpBtn');

            const email =
                input.value
                    .trim()
                    .toLowerCase();

            const validEmail =
                /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            byId('emailAuthError')
                ?.classList
                .add('hidden');

            if (!validEmail.test(email)) {
                setText(
                    'emailAuthError',
                    'Enter a valid email address.'
                );

                byId('emailAuthError')
                    ?.classList
                    .remove('hidden');

                input.focus();
                return;
            }

            button.disabled = true;
            button.textContent = 'Sending code...';

            try {
                const response = await fetch(
                    '/api/send-otp',
                    {
                        method: 'POST',

                        headers: {
                            'Content-Type':
                                'application/json'
                        },

                        body: JSON.stringify({
                            email
                        })
                    }
                );

                const result =
                    await response
                        .json()
                        .catch(() => ({}));

                if (
                    !response.ok ||
                    !result.success
                ) {
                    throw new Error(
                        result.message ||
                        'The verification code could not be sent.'
                    );
                }

                userEmailToVerify = email;

                hideModal('emailModal');
                showModal('otpModal');

                window.setTimeout(() => {
                    byId('authOtpInput')?.focus();
                }, 80);
            } catch (error) {
                setText(
                    'emailAuthError',
                    error.message ||
                    'The verification code could not be sent.'
                );

                byId('emailAuthError')
                    ?.classList
                    .remove('hidden');
            } finally {
                button.disabled = false;
                button.textContent =
                    'Send verification code';
            }
        }

        async function verifyOtp() {
            const input =
                byId('authOtpInput');

            const button =
                byId('verifyOtpBtn');

            const code =
                input.value
                    .replace(/\D/g, '')
                    .slice(0, 6);

            input.value = code;

            byId('otpAuthError')
                ?.classList
                .add('hidden');

            if (!userEmailToVerify) {
                setText(
                    'otpAuthError',
                    'Your verification session expired. Request another code.'
                );

                byId('otpAuthError')
                    ?.classList
                    .remove('hidden');

                return;
            }

            if (code.length !== 6) {
                setText(
                    'otpAuthError',
                    'Enter the complete six-digit code.'
                );

                byId('otpAuthError')
                    ?.classList
                    .remove('hidden');

                input.focus();
                return;
            }

            button.disabled = true;
            button.textContent = 'Verifying...';

            try {
                const response = await fetch(
                    '/api/verify-otp',
                    {
                        method: 'POST',

                        headers: {
                            'Content-Type':
                                'application/json'
                        },

                        body: JSON.stringify({
                            email:
                                userEmailToVerify,

                            code
                        })
                    }
                );

                const result =
                    await response
                        .json()
                        .catch(() => ({}));

                if (
                    !response.ok ||
                    !result.success
                ) {
                    throw new Error(
                        result.message ||
                        'The code is invalid or expired.'
                    );
                }

                window.location.reload();
            } catch (error) {
                setText(
                    'otpAuthError',
                    error.message ||
                    'The code is invalid or expired.'
                );

                byId('otpAuthError')
                    ?.classList
                    .remove('hidden');
            } finally {
                button.disabled = false;
                button.textContent =
                    'Verify and continue';
            }
        }

        function closeModals() {
            if (paymentProcessing) {
                return;
            }

            hideModal('emailModal');
            hideModal('otpModal');
            hideModal('buyModal');

            document.body.classList.remove(
                'modal-open'
            );
        }

        function switchTab(tabId) {
            const showStore =
                tabId === 'store';

            const store =
                byId('store-grid');

            const posts =
                byId('posts-grid');

            const storeButton =
                byId('tab-store');

            const postsButton =
                byId('tab-posts');

            store.classList.toggle(
                'hidden',
                !showStore
            );

            posts.classList.toggle(
                'hidden',
                showStore
            );

            storeButton.setAttribute(
                'aria-selected',
                String(showStore)
            );

            postsButton.setAttribute(
                'aria-selected',
                String(!showStore)
            );

            storeButton.className =
                showStore
                    ? 'rounded-xl px-5 py-2.5 text-sm font-extrabold bg-slate-950 text-white shadow-sm transition'
                    : 'rounded-xl px-5 py-2.5 text-sm font-extrabold text-slate-500 hover:text-slate-950 transition';

            postsButton.className =
                !showStore
                    ? 'rounded-xl px-5 py-2.5 text-sm font-extrabold bg-slate-950 text-white shadow-sm transition'
                    : 'rounded-xl px-5 py-2.5 text-sm font-extrabold text-slate-500 hover:text-slate-950 transition';
        }

        function renderSearchResults(items) {
            const dropdown =
                byId('searchDropdown');

            dropdown.replaceChildren();

            if (
                !Array.isArray(items) ||
                items.length === 0
            ) {
                dropdown.classList.add('hidden');
                dropdown.classList.remove('flex');
                return;
            }

            items.forEach(item => {
                const link =
                    document.createElement('a');

                link.href =
                    '/?q=' +
                    encodeURIComponent(
                        String(item.title || '')
                    );

                link.className =
                    'flex items-center justify-between gap-4 px-5 py-4 hover:bg-blue-50 border-b border-slate-100 last:border-0 transition';

                link.setAttribute(
                    'role',
                    'option'
                );

                const content =
                    document.createElement('div');

                content.className =
                    'min-w-0';

                const title =
                    document.createElement('div');

                title.className =
                    'font-extrabold text-sm text-slate-950 truncate';

                title.textContent =
                    String(
                        item.title ||
                        'Untitled product'
                    );

                const category =
                    document.createElement('div');

                category.className =
                    'text-[10px] font-black text-slate-400 uppercase tracking-wider mt-1';

                category.textContent =
                    String(
                        item.category ||
                        'Marketplace'
                    );

                const arrow =
                    document.createElement('span');

                arrow.className =
                    'w-8 h-8 shrink-0 rounded-xl bg-slate-100 text-slate-500 flex items-center justify-center';

                arrow.innerHTML = '&rarr;';

                content.append(
                    title,
                    category
                );

                link.append(
                    content,
                    arrow
                );

                dropdown.appendChild(link);
            });

            dropdown.classList.remove('hidden');
            dropdown.classList.add('flex');
        }

        async function searchMarketplace(query) {
            if (searchController) {
                searchController.abort();
            }

            searchController =
                new AbortController();

            try {
                const response = await fetch(
                    '/api/search?q=' +
                    encodeURIComponent(query),
                    {
                        headers: {
                            Accept:
                                'application/json'
                        },

                        signal:
                            searchController.signal
                    }
                );

                if (!response.ok) {
                    throw new Error(
                        'Search failed.'
                    );
                }

                const result =
                    await response.json();

                renderSearchResults(result);
            } catch (error) {
                if (
                    error.name !==
                    'AbortError'
                ) {
                    console.error(
                        'Marketplace search error:',
                        error
                    );

                    renderSearchResults([]);
                }
            }
        }

        document.addEventListener(
            'DOMContentLoaded',
            () => {
                const searchInput =
                    byId('searchInput');

                const searchDropdown =
                    byId('searchDropdown');

                const otpInput =
                    byId('authOtpInput');

                const emailInput =
                    byId('authEmailInput');

                const urlParameters =
                    new URLSearchParams(
                        window.location.search
                    );

                if (
                    urlParameters.get('tab') ===
                    'posts'
                ) {
                    switchTab('posts');
                }

                document
                    .querySelectorAll(
                        '.purchase-button'
                    )
                    .forEach(button => {
                        button.addEventListener(
                            'click',
                            () => {
                                handleBuyClick({
                                    id:
                                        button.dataset
                                            .productId,

                                    title:
                                        button.dataset
                                            .productTitle,

                                    tier:
                                        button.dataset
                                            .productTier,

                                    price:
                                        button.dataset
                                            .productPrice,

                                    image:
                                        button.dataset
                                            .productImage
                                });
                            }
                        );
                    });

                if (
                    searchInput &&
                    searchDropdown
                ) {
                    searchInput.addEventListener(
                        'input',
                        event => {
                            const query =
                                event.target.value.trim();

                            window.clearTimeout(
                                searchTimer
                            );

                            if (query.length < 2) {
                                searchController?.abort();

                                renderSearchResults([]);

                                return;
                            }

                            searchTimer =
                                window.setTimeout(
                                    () => {
                                        searchMarketplace(
                                            query
                                        );
                                    },
                                    250
                                );
                        }
                    );
                }

                otpInput?.addEventListener(
                    'input',
                    () => {
                        otpInput.value =
                            otpInput.value
                                .replace(/\D/g, '')
                                .slice(0, 6);
                    }
                );

                otpInput?.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Enter'
                        ) {
                            verifyOtp();
                        }
                    }
                );

                emailInput?.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Enter'
                        ) {
                            sendOtp();
                        }
                    }
                );

                document.addEventListener(
                    'click',
                    event => {
                        if (
                            searchDropdown &&
                            searchInput &&
                            !searchDropdown.contains(
                                event.target
                            ) &&
                            event.target !==
                                searchInput
                        ) {
                            searchDropdown.classList.add(
                                'hidden'
                            );

                            searchDropdown.classList.remove(
                                'flex'
                            );
                        }
                    }
                );

                [
                    byId('emailModal'),
                    byId('otpModal'),
                    byId('buyModal')
                ].forEach(modal => {
                    modal?.addEventListener(
                        'mousedown',
                        event => {
                            if (
                                event.target ===
                                modal
                            ) {
                                closeModals();
                            }
                        }
                    );
                });

                document.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Escape'
                        ) {
                            closeModals();
                        }
                    }
                );

                if (isAuthenticated) {
                    const pendingPurchase =
                        sessionStorage.getItem(
                            'pendingBuy'
                        );

                    if (pendingPurchase) {
                        try {
                            const restored =
                                JSON.parse(
                                    pendingPurchase
                                );

                            activeProduct = {
                                id:
                                    String(
                                        restored.id ||
                                        ''
                                    ),

                                title:
                                    String(
                                        restored.title ||
                                        'Product'
                                    ),

                                tier:
                                    String(
                                        restored.tier ||
                                        'Standard'
                                    ),

                                price:
                                    Number(
                                        restored.price ||
                                        0
                                    ),

                                image:
                                    String(
                                        restored.image ||
                                        ''
                                    )
                            };

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );

                            window.setTimeout(
                                openBuyModal,
                                300
                            );
                        } catch (error) {
                            console.error(
                                'Could not restore purchase:',
                                error
                            );

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );
                        }
                    }
                }
            }
        );
    </script>
</body>
</html>