<!DOCTYPE html>
<html lang="en">
<head>
    <%
        const safeProducts = Array.isArray(products) ? products : [];
        const safeCategories = Array.isArray(categories) ? categories : [];

        const safePosts =
            typeof posts !== 'undefined' && Array.isArray(posts)
                ? posts
                : [];

        const safeAnnouncements =
            typeof announcements !== 'undefined' && Array.isArray(announcements)
                ? announcements
                : [];

        const currentCategory =
            typeof categoryFilter !== 'undefined' && categoryFilter
                ? categoryFilter
                : 'All';

        const currentSearch =
            typeof searchQuery !== 'undefined' && searchQuery
                ? searchQuery
                : '';

        const currentBuyerEmail =
            typeof buyerEmail !== 'undefined' && buyerEmail
                ? buyerEmail
                : '';

        /*
         * This is used only when a product does not have its own
         * paypal_button_id.
         *
         * Every differently priced product should have its own PayPal
         * payment-link/button ID.
         */
        const defaultPayPalButtonId = 'QZ7HHN9DJGNSA';

        const seoTitle =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_title
                ? categoryRow.seo_title
                : 'ExamHub Marketplace';

        const seoDesc =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_desc
                ? categoryRow.seo_desc
                : 'Browse premium digital learning tools and study resources.';

        const seoKeywords =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.seo_keywords
                ? categoryRow.seo_keywords
                : 'exams, study tools, digital resources, marketplace, education';

        const ogImage =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.og_image
                ? categoryRow.og_image
                : 'https://examhub.shop/favicon.png';

        const canonicalUrl =
            typeof categoryRow !== 'undefined' &&
            categoryRow &&
            categoryRow.canonical_url
                ? categoryRow.canonical_url
                : '';

        function formatPostText(text) {
            if (!text) return '';

            let safeText = String(text)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#39;');

            safeText = safeText.replace(
                /\*\*([\s\S]*?)\*\*/g,
                '<strong class="font-extrabold text-slate-950">$1</strong>'
            );

            safeText = safeText.replace(
                /#([^#\n]+)#/g,
                '<span class="block mt-5 mb-2 text-xl md:text-2xl font-black text-slate-950 leading-tight">$1</span>'
            );

            safeText = safeText.replace(/\n/g, '<br>');

            return safeText;
        }
    %>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1, viewport-fit=cover"
    >

    <title><%= seoTitle %></title>

    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">

    <meta
        name="robots"
        content="index, follow, max-image-preview:large"
    >

    <% if (canonicalUrl) { %>
        <link rel="canonical" href="<%= canonicalUrl %>">
    <% } %>

    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">

    <link rel="icon" type="image/png" href="/favicon.png">

    <%- include('partials/head') %>

    <!--
        No PayPal JavaScript SDK is loaded.

        The credit-card button opens the official PayPal payment link
        directly. This avoids:
        - Hosted button iframe problems
        - Popup rendering failures
        - paypal.FUNDING.CARD eligibility errors
        - Duplicate PayPal button instances
    -->

    <style>
        :root {
            color-scheme: light;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            min-height: 100vh;
        }

        body.modal-open {
            overflow: hidden;
        }

        .page-background {
            background:
                radial-gradient(
                    circle at 12% 5%,
                    rgba(37, 99, 235, 0.11),
                    transparent 29rem
                ),
                radial-gradient(
                    circle at 90% 10%,
                    rgba(6, 182, 212, 0.10),
                    transparent 28rem
                ),
                linear-gradient(
                    180deg,
                    #f8fbff 0%,
                    #f8fafc 48%,
                    #f1f5f9 100%
                );
        }

        .background-grid {
            background-image:
                linear-gradient(
                    rgba(15, 23, 42, 0.03) 1px,
                    transparent 1px
                ),
                linear-gradient(
                    90deg,
                    rgba(15, 23, 42, 0.03) 1px,
                    transparent 1px
                );

            background-size: 38px 38px;

            -webkit-mask-image:
                linear-gradient(
                    to bottom,
                    black,
                    transparent 72%
                );

            mask-image:
                linear-gradient(
                    to bottom,
                    black,
                    transparent 72%
                );
        }

        .product-card {
            transition:
                transform 180ms ease,
                border-color 180ms ease,
                box-shadow 180ms ease;
        }

        .product-card:hover {
            transform: translateY(-3px);
            border-color: rgba(37, 99, 235, 0.25);
            box-shadow:
                0 22px 55px -32px rgba(15, 23, 42, 0.42);
        }

        .product-image {
            transition: transform 220ms ease;
        }

        .product-card:hover .product-image {
            transform: scale(1.04);
        }

        .modal-panel {
            max-height: calc(100dvh - 1.5rem);
        }

        .payment-choice {
            transition:
                transform 150ms ease,
                border-color 150ms ease,
                background-color 150ms ease,
                box-shadow 150ms ease;
        }

        .payment-choice:hover {
            transform: translateY(-1px);
        }

        .card-payment-button {
            position: relative;
            isolation: isolate;
            overflow: hidden;
        }

        .card-payment-button::before {
            content: '';
            position: absolute;
            inset: 0;
            z-index: -1;

            background:
                linear-gradient(
                    110deg,
                    transparent 25%,
                    rgba(255, 255, 255, 0.18) 45%,
                    transparent 65%
                );

            transform: translateX(-120%);
            transition: transform 500ms ease;
        }

        .card-payment-button:hover::before {
            transform: translateX(120%);
        }

        .card-payment-button.is-loading {
            pointer-events: none;
            opacity: 0.78;
        }

        .spinner {
            width: 18px;
            height: 18px;

            border: 2px solid rgba(255, 255, 255, 0.35);
            border-top-color: white;
            border-radius: 9999px;

            animation: spin 650ms linear infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        @media (prefers-reduced-motion: reduce) {
            *,
            *::before,
            *::after {
                scroll-behavior: auto !important;
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>

<body class="page-background antialiased flex min-h-screen flex-col text-slate-800">

    <div
        class="background-grid pointer-events-none fixed inset-0 z-0"
        aria-hidden="true"
    ></div>

    <!-- NAVIGATION -->
    <nav
        class="sticky top-0 z-40 border-b border-white/70 bg-white/85 backdrop-blur-xl"
    >
        <div
            class="mx-auto flex w-full max-w-7xl items-center justify-between px-4 py-4 md:px-8"
        >
            <a
                href="/"
                class="group flex items-center gap-3"
                aria-label="ExamHub home"
            >
                <span
                    class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-blue-600 to-cyan-500 text-white shadow-lg shadow-blue-500/20 transition group-hover:scale-105"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class="h-5 w-5"
                        aria-hidden="true"
                    >
                        <path
                            d="M5 4.75A1.75 1.75 0 0 1 6.75 3h10.5A1.75 1.75 0 0 1 19 4.75v14.5A1.75 1.75 0 0 1 17.25 21H6.75A1.75 1.75 0 0 1 5 19.25V4.75Z"
                            stroke="currentColor"
                            stroke-width="1.8"
                        />

                        <path
                            d="M8.5 8h7M8.5 12h7M8.5 16h4"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                        />
                    </svg>
                </span>

                <span
                    class="text-2xl font-black tracking-tight text-slate-950"
                >
                    Exam<span class="text-blue-600">Hub</span>
                </span>
            </a>

            <div class="flex items-center gap-2 md:gap-3">

                <a
                    href="https://discord.gg/bg6wKj45w3"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hidden items-center gap-2 rounded-xl bg-[#5865F2] px-4 py-2.5 text-sm font-bold text-white shadow-sm transition hover:bg-[#4752C4] md:flex"
                >
                    <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="h-4 w-4"
                        aria-hidden="true"
                    >
                        <path
                            d="M19.54 5.34A16.5 16.5 0 0 0 15.4 4l-.5 1.02a15.3 15.3 0 0 0-5.8 0L8.6 4a16.7 16.7 0 0 0-4.15 1.35C1.83 9.2 1.12 12.97 1.48 16.7a16.85 16.85 0 0 0 5.08 2.55l1.22-1.67a10.9 10.9 0 0 1-1.92-.92l.47-.37c3.7 1.7 7.72 1.7 11.38 0l.47.37c-.61.36-1.25.67-1.92.92l1.22 1.67a16.76 16.76 0 0 0 5.07-2.55c.43-4.32-.74-8.05-3.01-11.36ZM8.18 14.42c-1.1 0-2.01-1.01-2.01-2.25s.89-2.26 2.01-2.26c1.13 0 2.04 1.02 2.02 2.26 0 1.24-.89 2.25-2.02 2.25Zm7.64 0c-1.11 0-2.02-1.01-2.02-2.25s.89-2.26 2.02-2.26c1.12 0 2.03 1.02 2.01 2.26 0 1.24-.89 2.25-2.01 2.25Z"
                        />
                    </svg>

                    Discord
                </a>

                <% if (currentBuyerEmail) { %>
                    <a
                        href="/my-orders"
                        class="flex items-center gap-2 rounded-xl bg-slate-950 px-4 py-2.5 text-sm font-bold text-white shadow-lg shadow-slate-900/10 transition hover:bg-slate-800"
                    >
                        <svg
                            viewBox="0 0 24 24"
                            fill="none"
                            class="h-4 w-4"
                            aria-hidden="true"
                        >
                            <path
                                d="M6 7h12l-1 13H7L6 7Z"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linejoin="round"
                            />

                            <path
                                d="M9 9V6a3 3 0 0 1 6 0v3"
                                stroke="currentColor"
                                stroke-width="1.8"
                                stroke-linecap="round"
                            />
                        </svg>

                        <span class="hidden sm:inline">
                            My Orders
                        </span>

                        <% if (
                            typeof activeOrderCount !== 'undefined' &&
                            Number(activeOrderCount) > 0
                        ) { %>
                            <span
                                class="rounded-full bg-red-500 px-2 py-0.5 text-[10px] text-white"
                            >
                                <%= activeOrderCount %>
                            </span>
                        <% } %>
                    </a>

                    <a
                        href="/buyer-logout"
                        class="hidden rounded-xl px-3 py-2 text-sm font-semibold text-slate-500 transition hover:bg-red-50 hover:text-red-600 md:block"
                    >
                        Logout
                    </a>
                <% } %>

                <% if (typeof user !== 'undefined' && user) { %>
                    <a
                        href="/admin"
                        class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 shadow-sm transition hover:border-slate-300 hover:bg-slate-50"
                    >
                        Admin
                    </a>
                <% } else if (!currentBuyerEmail) { %>
                    <a
                        href="/login"
                        class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm font-bold text-slate-700 shadow-sm transition hover:border-blue-300 hover:text-blue-600"
                    >
                        Login
                    </a>
                <% } %>

            </div>
        </div>
    </nav>

    <!-- HERO -->
    <header
        class="relative z-10 px-4 pb-12 pt-14 text-center md:pb-16 md:pt-20"
    >
        <div class="mx-auto max-w-4xl">

            <div
                class="mb-5 inline-flex items-center gap-2 rounded-full border border-blue-200 bg-blue-50/90 px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-blue-700 shadow-sm"
            >
                <span
                    class="h-2 w-2 animate-pulse rounded-full bg-blue-500"
                ></span>

                Digital marketplace
            </div>

            <h1
                class="mx-auto max-w-3xl text-4xl font-black leading-[1.05] tracking-tight text-slate-950 sm:text-5xl md:text-6xl"
            >
                Prepare smarter with

                <span
                    class="bg-gradient-to-r from-blue-600 via-sky-500 to-cyan-500 bg-clip-text text-transparent"
                >
                    better resources
                </span>
            </h1>

            <p
                class="mx-auto mt-6 max-w-2xl text-base font-medium leading-7 text-slate-500 md:text-lg"
            >
                Explore premium digital tools, detailed resources, and
                carefully prepared learning products.
            </p>

            <!-- SEARCH -->
            <div class="relative mx-auto mt-9 w-full max-w-2xl">

                <form
                    action="/"
                    method="GET"
                    role="search"
                    class="relative rounded-2xl border border-slate-200 bg-white p-2 shadow-xl shadow-slate-900/5"
                >
                    <% if (
                        currentCategory &&
                        currentCategory !== 'All'
                    ) { %>
                        <input
                            type="hidden"
                            name="category"
                            value="<%= currentCategory %>"
                        >
                    <% } %>

                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        class="pointer-events-none absolute left-5 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400"
                        aria-hidden="true"
                    >
                        <circle
                            cx="11"
                            cy="11"
                            r="7"
                            stroke="currentColor"
                            stroke-width="1.8"
                        />

                        <path
                            d="m16.2 16.2 4 4"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                        />
                    </svg>

                    <input
                        type="search"
                        id="searchInput"
                        name="q"
                        autocomplete="off"
                        value="<%= currentSearch %>"
                        placeholder="Search products and resources..."
                        aria-label="Search marketplace"
                        aria-controls="searchDropdown"
                        class="w-full rounded-xl bg-transparent py-3.5 pl-12 pr-28 text-sm font-semibold text-slate-900 outline-none placeholder:text-slate-400 md:text-base"
                    >

                    <button
                        type="submit"
                        class="absolute bottom-2 right-2 top-2 rounded-xl bg-gradient-to-r from-blue-600 to-sky-500 px-5 text-sm font-black text-white shadow-lg shadow-blue-500/20 transition hover:from-blue-700 hover:to-sky-600"
                    >
                        Search
                    </button>
                </form>

                <div
                    id="searchDropdown"
                    class="absolute left-0 top-full z-50 mt-3 hidden w-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white text-left shadow-2xl shadow-slate-900/15"
                    role="listbox"
                ></div>

            </div>

            <!-- CATEGORIES -->
            <div
                class="mt-7 flex flex-wrap justify-center gap-2"
            >
                <a
                    href="/"
                    class="rounded-xl border px-4 py-2.5 text-xs font-black transition md:text-sm <%= (!currentCategory || currentCategory === 'All') ? 'border-slate-950 bg-slate-950 text-white shadow-md' : 'border-slate-200 bg-white/80 text-slate-600 hover:border-blue-300 hover:text-blue-600' %>"
                >
                    All products
                </a>

                <% safeCategories.forEach(cat => { %>
                    <a
                        href="/category/<%= encodeURIComponent(cat.name) %>"
                        class="rounded-xl border px-4 py-2.5 text-xs font-black transition md:text-sm <%= currentCategory === cat.name ? 'border-slate-950 bg-slate-950 text-white shadow-md' : 'border-slate-200 bg-white/80 text-slate-600 hover:border-blue-300 hover:text-blue-600' %>"
                    >
                        <%= cat.name %>
                    </a>
                <% }) %>
            </div>

        </div>
    </header>

    <!-- MAIN -->
    <main
        class="relative z-10 mx-auto w-full max-w-7xl flex-grow px-4 pb-24 md:px-8"
    >

        <!-- ANNOUNCEMENTS -->
        <% if (safeAnnouncements.length > 0) { %>
            <section class="mb-14 space-y-6">

                <% safeAnnouncements.forEach(ann => { %>
                    <article
                        class="overflow-hidden rounded-3xl border border-blue-100 bg-white shadow-xl shadow-blue-900/5"
                    >
                        <div
                            class="border-b border-blue-100 bg-gradient-to-r from-blue-50 to-cyan-50 px-6 py-4 md:px-8"
                        >
                            <div
                                class="flex flex-wrap items-center justify-between gap-3"
                            >
                                <span
                                    class="rounded-full bg-blue-600 px-3 py-1 text-[10px] font-black uppercase tracking-[0.16em] text-white"
                                >
                                    <%= ann.category || 'Marketplace' %> update
                                </span>

                                <span
                                    class="text-xs font-bold text-blue-700"
                                >
                                    ExamHub announcement
                                </span>
                            </div>
                        </div>

                        <div class="p-6 md:p-8">

                            <h2
                                class="mb-5 text-2xl font-black tracking-tight text-slate-950 md:text-3xl"
                            >
                                <%= ann.title %>
                            </h2>

                            <% if (ann.image1 || ann.image2) { %>
                                <div
                                    class="mb-6 grid gap-4 <%= ann.image1 && ann.image2 ? 'md:grid-cols-2' : 'grid-cols-1' %>"
                                >
                                    <% if (ann.image1) { %>
                                        <img
                                            src="<%= ann.image1 %>"
                                            alt="<%= ann.title %>"
                                            loading="lazy"
                                            class="h-64 w-full rounded-2xl border border-slate-100 object-cover"
                                        >
                                    <% } %>

                                    <% if (ann.image2) { %>
                                        <img
                                            src="<%= ann.image2 %>"
                                            alt="<%= ann.title %>"
                                            loading="lazy"
                                            class="h-64 w-full rounded-2xl border border-slate-100 object-cover"
                                        >
                                    <% } %>
                                </div>
                            <% } %>

                            <div
                                class="text-sm font-medium leading-7 text-slate-600"
                            >
                                <%- formatPostText(ann.content) %>
                            </div>

                        </div>
                    </article>
                <% }) %>

            </section>
        <% } %>

        <!-- SECTION HEADER -->
        <section
            class="mb-7 flex flex-col gap-5 border-b border-slate-200 md:flex-row md:items-end md:justify-between"
        >
            <div class="pb-5">
                <p
                    class="mb-2 text-xs font-black uppercase tracking-[0.18em] text-blue-600"
                >
                    Explore ExamHub
                </p>

                <h2
                    class="text-2xl font-black tracking-tight text-slate-950 md:text-3xl"
                >
                    Marketplace catalogue
                </h2>
            </div>

            <div
                class="flex gap-7"
                role="tablist"
            >
                <button
                    type="button"
                    id="tab-store"
                    onclick="switchTab('store')"
                    role="tab"
                    aria-selected="true"
                    aria-controls="store-grid"
                    class="border-b-2 border-blue-600 px-1 pb-4 text-sm font-black text-blue-600 transition"
                >
                    Store
                </button>

                <button
                    type="button"
                    id="tab-posts"
                    onclick="switchTab('posts')"
                    role="tab"
                    aria-selected="false"
                    aria-controls="posts-grid"
                    class="border-b-2 border-transparent px-1 pb-4 text-sm font-black text-slate-400 transition hover:text-slate-800"
                >
                    Articles & Updates
                </button>
            </div>
        </section>

        <!-- PRODUCTS -->
        <section
            id="store-grid"
            role="tabpanel"
            aria-labelledby="tab-store"
        >
            <div
                class="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3"
            >
                <% if (safeProducts.length === 0) { %>
                    <div
                        class="col-span-full rounded-3xl border border-dashed border-slate-300 bg-white/70 py-20 text-center"
                    >
                        <div
                            class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-slate-100 text-slate-400"
                        >
                            <svg
                                viewBox="0 0 24 24"
                                fill="none"
                                class="h-6 w-6"
                                aria-hidden="true"
                            >
                                <path
                                    d="M5 5h14v14H5V5Z"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                />

                                <path
                                    d="m7.5 16 3.2-3.3 2.2 2.2 1.5-1.5 2.1 2.6"
                                    stroke="currentColor"
                                    stroke-width="1.8"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                />
                            </svg>
                        </div>

                        <p class="font-black text-slate-500">
                            No products were found.
                        </p>
                    </div>
                <% } else { %>

                    <% safeProducts.forEach(product => { %>
                        <article
                            class="product-card flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
                        >
                            <!--
                                Compact top row:
                                image is in the upper-left corner like before.
                            -->
                            <div class="mb-5 flex items-start gap-4">

                                <div
                                    class="h-[76px] w-[76px] shrink-0 overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-sm"
                                >
                                    <img
                                        src="<%= product.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(product.title || 'Product')}&background=0f172a&color=ffffff&size=512` %>"
                                        alt="<%= product.title || 'Product' %>"
                                        loading="lazy"
                                        class="product-image h-full w-full object-cover"
                                    >
                                </div>

                                <div class="min-w-0 flex-grow">

                                    <div
                                        class="mb-2 flex flex-wrap items-center gap-2"
                                    >
                                        <span
                                            class="rounded-lg bg-blue-50 px-2.5 py-1 text-[9px] font-black uppercase tracking-[0.12em] text-blue-700"
                                        >
                                            <%= product.category || 'General' %>
                                        </span>

                                        <span
                                            class="rounded-lg bg-slate-100 px-2.5 py-1 text-[9px] font-black uppercase tracking-[0.12em] text-slate-600"
                                        >
                                            <%= product.tier || 'Standard' %>
                                        </span>
                                    </div>

                                    <h3
                                        class="line-clamp-2 text-lg font-black leading-tight tracking-tight text-slate-950"
                                    >
                                        <%= product.title %>
                                    </h3>

                                    <div
                                        class="mt-2 flex items-center justify-between gap-3"
                                    >
                                        <span
                                            class="text-lg font-black text-emerald-600"
                                        >
                                            $<%= Number(product.price || 0).toFixed(2) %>
                                        </span>

                                        <span
                                            class="flex items-center gap-1.5 text-[10px] font-bold text-emerald-600"
                                        >
                                            <span
                                                class="h-1.5 w-1.5 rounded-full bg-emerald-500"
                                            ></span>

                                            Available
                                        </span>
                                    </div>

                                </div>
                            </div>

                            <div
