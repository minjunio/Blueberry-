<!DOCTYPE html>
<html lang="en">
<head>
    <% 
        const seoTitle = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_title) ? categoryRow.seo_title : 'ExamHub ✨ Marketplace';
        const seoDesc = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_desc) ? categoryRow.seo_desc : 'The ultimate exam marketplace for top-rated study tools and bypasses.';
        const seoKeywords = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.seo_keywords) ? categoryRow.seo_keywords : 'exams, study tools, bypasses, marketplace, honorlock, lockdown browser';
        const ogImage = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.og_image) ? categoryRow.og_image : 'https://examhub.shop/favicon.png';
        const canonicalUrl = (typeof categoryRow !== 'undefined' && categoryRow && categoryRow.canonical_url) ? categoryRow.canonical_url : '';

        function formatPostText(text) {
            if (!text) return '';
            let safeText = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&apos;');
            safeText = safeText.replace(/\*\*([\s\S]*?)\*\*/g, '<strong class="font-bold text-gray-900">$1</strong>');
            safeText = safeText.replace(/#([\s\S]*?)#/g, '<span class="text-xl md:text-2xl font-bold block mt-4 mb-2 text-gray-900 leading-tight">$1</span>');
            safeText = safeText.replace(/\n/g, '<br>');
            return safeText;
        }
    %>
    <title><%= seoTitle %></title>
    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">
    <meta name="robots" content="index, follow, max-image-preview:large">
    <% if (canonicalUrl) { %> <link rel="canonical" href="<%= canonicalUrl %>"> <% } %>
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>

    <script src="https://www.paypal.com/sdk/js?client-id=BAACqOV8IkLP3i0-_Ty6IA7zt5_OxtawbH5tAUCjenPO6KcpDgcEscgNhhZCTP9dVtHBQB6BrxF5QoOBnM&components=buttons&disable-funding=venmo&currency=USD"></script>
</head>

<body class="antialiased flex flex-col bg-[#f8fafc] text-gray-800">
    <nav class="py-5 px-4 md:px-8 flex justify-between items-center max-w-7xl mx-auto w-full relative z-20 border-b border-gray-200 bg-white shadow-sm">
        <a href="/" class="text-2xl font-black text-gray-900 tracking-tight">Exam<span class="text-blue-600">Hub</span></a>
        
        <div class="flex items-center gap-3">
            <a href="https://discord.gg/bg6wKj45w3" target="_blank" class="hidden md:flex items-center gap-1.5 bg-[#5865F2] hover:bg-[#4752C4] text-white px-4 py-2 rounded-lg font-bold text-sm transition">Discord</a>
            
            <% if (typeof buyerEmail !== 'undefined' && buyerEmail) { %>
                <a href="/my-orders" class="bg-gray-900 text-white hover:bg-gray-800 px-4 py-2 rounded-lg font-bold text-sm transition flex items-center gap-2">
                    My Orders
                    <% if (typeof activeOrderCount !== 'undefined' && activeOrderCount > 0) { %>
                        <span class="bg-red-500 text-white text-[10px] px-2 py-0.5 rounded-full"><%= activeOrderCount %></span>
                    <% } %>
                </a>
                <a href="/buyer-logout" class="ml-1 text-sm font-medium text-gray-500 hover:text-red-600 transition hidden md:block">Logout</a>
            <% } %>

            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/admin" class="ml-2 bg-white hover:bg-gray-50 px-4 py-2 rounded-lg font-bold text-sm transition border border-gray-300 shadow-sm text-gray-700">Admin</a>
            <% } else if (typeof buyerEmail === 'undefined' || !buyerEmail) { %>
                <a href="/login" class="ml-2 bg-white hover:bg-gray-50 px-4 py-2 rounded-lg font-bold text-sm transition border border-gray-300 shadow-sm text-gray-700">Login</a>
            <% } %>
        </div>
    </nav>

    <header class="flex flex-col items-center text-center px-4 pt-12 pb-12 relative z-10">
        <h1 class="text-4xl md:text-5xl font-black mb-4 text-gray-900 tracking-tight">Master Your <span class="text-blue-600">Exams</span></h1>
        <p class="text-gray-500 mb-8 font-medium max-w-lg">The ultimate marketplace for top-rated study tools and secure bypasses.</p>
        <div class="w-full max-w-2xl relative">
            <form action="/" method="GET" class="relative">
                <% if (typeof categoryFilter !== 'undefined' && categoryFilter && categoryFilter !== 'All') { %> <input type="hidden" name="category" value="<%= categoryFilter %>"> <% } %>
                <input type="text" id="searchInput" name="q" autocomplete="off" value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>" placeholder="Search exams, bypasses..." class="w-full bg-white border border-gray-300 focus:border-blue-500 rounded-xl py-4 pl-6 pr-24 outline-none shadow-sm text-base font-medium transition">
                <button type="submit" class="absolute right-2 top-2 bg-blue-600 text-white px-5 py-2 rounded-lg font-bold hover:bg-blue-700 transition">Search</button>
            </form>
            <div id="searchDropdown" class="hidden absolute top-full left-0 w-full bg-white border border-gray-200 rounded-xl mt-2 shadow-lg overflow-hidden z-50 flex flex-col text-left"></div>
        </div>

        <div class="flex flex-wrap justify-center gap-2 mt-8 max-w-4xl">
            <a href="/" class="px-4 py-2 rounded-lg font-bold text-xs md:text-sm border <%= (!typeof categoryFilter !== 'undefined' || categoryFilter === 'All') ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-600 border-gray-200 hover:border-gray-400' %> transition">All</a>
            <% categories.forEach(cat => { %>
                <a href="/category/<%= encodeURIComponent(cat.name) %>" class="px-4 py-2 rounded-lg font-bold text-xs md:text-sm border <%= typeof categoryFilter !== 'undefined' && categoryFilter === cat.name ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-600 border-gray-200 hover:border-gray-400' %> transition"><%= cat.name %></a>
            <% }) %>
        </div>
    </header>

    <main class="flex-grow w-full max-w-6xl mx-auto px-4 md:px-6 relative z-20 pb-20">
        
        <% if (typeof announcements !== 'undefined' && announcements && announcements.length > 0) { %>
            <div class="mb-12 space-y-6">
                <% announcements.forEach(ann => { %>
                    <div class="bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-blue-100">
                        <div class="inline-block bg-blue-50 text-blue-700 font-bold text-[10px] px-2 py-1 rounded uppercase tracking-wider mb-3"><%= ann.category %> Update</div>
                        <h2 class="text-2xl font-bold mb-4 text-gray-900"><%= ann.title %></h2>
                        
                        <div class="flex flex-col md:flex-row gap-4 mb-4">
                            <% if (ann.image1) { %> <img src="<%= ann.image1 %>" class="w-full md:w-1/2 rounded-xl object-cover border border-gray-100" style="max-height: 300px;"> <% } %>
                            <% if (ann.image2) { %> <img src="<%= ann.image2 %>" class="w-full md:w-1/2 rounded-xl object-cover border border-gray-100" style="max-height: 300px;"> <% } %>
                        </div>
                        
                        <div class="text-sm font-medium text-gray-600 leading-relaxed"><%- formatPostText(ann.content) %></div>
                    </div>
                <% }) %>
            </div>
            <div class="flex items-center gap-4 mb-8">
                <div class="flex-grow h-px bg-gray-200"></div>
                <span class="font-bold text-gray-400 uppercase tracking-widest text-xs">Marketplace Catalog</span>
                <div class="flex-grow h-px bg-gray-200"></div>
            </div>
        <% } %>

        <div class="flex gap-6 mb-6 border-b border-gray-200 pb-0 select-none justify-center md:justify-start">
            <button onclick="switchTab('store')" id="tab-store" class="font-bold text-sm md:text-base text-blue-600 border-b-2 border-blue-600 pb-3 px-2 transition">Store</button>
            <button onclick="switchTab('posts')" id="tab-posts" class="font-bold text-sm md:text-base text-gray-500 border-b-2 border-transparent hover:text-gray-800 pb-3 px-2 transition">Articles & Updates</button>
        </div>

        <div id="store-grid">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (products.length === 0) { %>
                    <div class="col-span-full text-center py-10 font-bold text-lg text-gray-400">No products found.</div>
                <% } else { %>
                    <% products.forEach(product => { %>
                        <div class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full p-5 relative">
                            <div class="flex items-start gap-4 mb-4">
                                <div class="w-16 h-16 shrink-0 bg-gray-50 rounded-lg overflow-hidden border border-gray-100">
                                    <img src="<%= product.image_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(product.title || 'Product')}&background=random&size=512` %>" class="w-full h-full object-cover">
                                </div>
                                <div class="flex-grow overflow-hidden">
                                    <span class="inline-block bg-gray-100 text-gray-600 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider mb-1"><%= product.category %></span>
                                    <h3 class="font-bold text-lg text-gray-900 leading-tight mb-1 truncate"><%= product.title %></h3>
                                    <div class="flex items-center gap-2">
                                        <span class="text-green-600 font-black text-sm">$<%= Number(product.price || 0).toFixed(2) %></span>
                                        <span class="bg-gray-100 text-gray-600 font-bold text-[10px] px-2 py-0.5 rounded uppercase"><%= product.tier || 'Standard' %></span>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="text-sm text-gray-500 mb-6 flex-grow leading-relaxed"><%- formatPostText(product.description) %></div>
                            <div class="mt-auto pt-4 border-t border-gray-100">
                                <button onclick="handleBuyClick('<%= product.id %>', '<%= product.title.replace(/'/g, "\\'") %>', '<%= product.tier || 'Standard' %>', '<%= product.price %>')" class="w-full bg-gray-900 text-white font-bold py-2.5 rounded-lg text-sm hover:bg-gray-800 transition">Purchase</button>
                            </div>
                        </div>
                    <% }) %>
                <% } %>
            </div>
        </div>

        <div id="posts-grid" class="hidden">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                    <% posts.forEach(post => { %>
                        <a href="/post/<%= post.id %>" class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow flex flex-col h-full p-5">
                            <div class="flex items-center gap-3 mb-3">
                                <span class="bg-blue-50 text-blue-600 px-2 py-0.5 rounded text-[10px] font-bold uppercase">Update</span>
                                <span class="text-[10px] text-gray-400 font-medium"><%= new Date(post.created_at).toLocaleDateString() %></span>
                            </div>
                            <h3 class="font-bold text-lg text-gray-900 leading-tight mb-2"><%= post.title %></h3>
                            <p class="text-sm text-gray-500 line-clamp-3 mb-4 flex-grow"><%= post.seo_desc || 'Read the full update...' %></p>
                            <div class="text-blue-600 font-bold text-sm flex items-center justify-between mt-auto">
                                Read Article &rarr;
                            </div>
                        </a>
                    <% }) %>
                <% } else { %>
                    <div class="col-span-full text-center py-10 font-bold text-lg text-gray-400">No updates posted yet.</div>
                <% } %>
            </div>
        </div>
    </main>

    <div id="emailModal" class="hidden fixed inset-0 bg-gray-900/60 justify-center items-center z-50 p-4">
        <div class="bg-white rounded-2xl w-full max-w-sm overflow-hidden shadow-xl p-8 border border-gray-200">
            <h2 class="text-xl font-bold text-gray-900 mb-1">Sign In / Guest</h2>
            <p class="text-sm text-gray-500 mb-6">Enter email to receive secure code.</p>
            <input type="email" id="authEmailInput" placeholder="you@email.com" class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-3 font-medium outline-none focus:border-blue-500 text-sm mb-4">
            <button onclick="sendOtp()" id="sendOtpBtn" class="w-full bg-blue-600 text-white font-bold py-3 rounded-lg hover:bg-blue-700 transition">Send Code</button>
            <button onclick="closeModals()" class="w-full mt-3 text-sm font-medium text-gray-500 hover:text-gray-800">Cancel</button>
        </div>
    </div>

    <div id="otpModal" class="hidden fixed inset-0 bg-gray-900/60 justify-center items-center z-50 p-4">
        <div class="bg-white rounded-2xl w-full max-w-sm overflow-hidden shadow-xl p-8 border border-gray-200 text-center">
            <h2 class="text-xl font-bold text-gray-900 mb-1">Verify Code</h2>
            <p class="text-sm text-gray-500 mb-6">Check your inbox for the 6-digit code.</p>
            <input type="text" id="authOtpInput" placeholder="123456" maxlength="6" class="w-full bg-gray-50 border border-gray-300 rounded-lg px-4 py-3 font-bold text-2xl tracking-widest outline-none focus:border-blue-500 mb-4 text-center text-gray-900">
            <button onclick="verifyOtp()" id="verifyOtpBtn" class="w-full bg-green-600 text-white font-bold py-3 rounded-lg hover:bg-green-700 transition">Verify</button>
            <button onclick="closeModals()" class="w-full mt-3 text-sm font-medium text-gray-500 hover:text-gray-800">Cancel</button>
        </div>
    </div>

    <div id="buyModal" class="hidden fixed inset-0 bg-gray-900/60 justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white rounded-2xl w-full max-w-md overflow-hidden shadow-xl border border-gray-200 my-8">
            <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50">
                <h2 class="text-lg font-bold text-gray-900">Checkout</h2>
                <button onclick="closeModals()" class="text-gray-400 hover:text-gray-600 font-bold text-xl">&times;</button>
            </div>
            
            <div class="p-6">
                <div class="bg-green-50 text-green-700 text-xs font-bold px-3 py-2 rounded-lg mb-5 flex items-center gap-2 border border-green-200">
                    <span>Account:</span> <span class="truncate"><%= typeof buyerEmail !== 'undefined' ? buyerEmail : '' %></span>
                </div>
                
                <div class="flex items-center justify-between mb-6 pb-4 border-b border-gray-100">
                    <div>
                        <p class="text-xs text-gray-500 uppercase tracking-wider font-bold mb-1">Item</p>
                        <p id="modalItemTitle" class="font-bold text-gray-900 text-sm max-w-[200px] truncate"></p>
                    </div>
                    <div class="text-right">
                        <p class="text-xs text-gray-500 uppercase tracking-wider font-bold mb-1">Total</p>
                        <p id="modalItemPrice" class="font-black text-green-600 text-lg"></p>
                    </div>
                </div>

                <form id="buyForm" action="/checkout" method="POST">
                    <input type="hidden" id="hiddenProductId" name="product_id">
                    <input type="hidden" id="hiddenProductTier" name="tier">
                    <input type="hidden" id="hiddenPayPalCaptureId" name="paypal_capture_id">

                    <div class="mb-5">
                        <label class="block text-xs font-bold text-gray-700 mb-2">Discord Username (Optional)</label>
                        <input type="text" name="discord_username" placeholder="user#1234" class="w-full bg-white border border-gray-300 rounded-lg px-3 py-2.5 font-medium outline-none focus:border-blue-500 text-sm">
                    </div>

                    <div class="mb-5">
                        <label class="block text-xs font-bold text-gray-700 mb-2">Payment Method</label>
                        <div class="space-y-2">
                            
                            <label class="relative block cursor-pointer">
                                <input type="radio" name="payment_method" value="PayPal" class="peer sr-only" checked onchange="handlePaymentMethodChange()">
                                <div class="rounded-lg border border-gray-200 bg-white p-3 hover:bg-gray-50 peer-checked:border-blue-600 peer-checked:ring-1 peer-checked:ring-blue-600 transition flex items-center">
                                    <div class="mr-3">
                                        <svg viewBox="0 0 130 35" width="60" height="16"><path fill="#253B80" d="M14.9,3.7h-3.8c-0.6,0-1.1,0.4-1.2,1.1l-2,12.7c0,0.2,0.2,0.4,0.4,0.4h2.5c0.6,0,1.1-0.4,1.2-1.1l0.6-3.8h2.3c3.5,0,5.6-1.7,6.3-5.1C21.8,5.1,19.3,3.7,14.9,3.7z M15.4,8.8h-2.1l0.5-3.3h2.1c1.8,0,2.9,0.8,2.6,2.3C18.1,8.8,16.5,8.8,15.4,8.8z"/><path fill="#179BD7" d="M30.6,3.7H27c-0.6,0-1.1,0.4-1.2,1l-2,12.7c-0.1,0.3,0.1,0.5,0.4,0.5h2.8c0.6,0,1.1-0.4,1.2-1.1l1.1-7.1c0.1-0.6,0.6-1.1,1.2-1.1h1.1L30,14.6c0,0.1,0.1,0.2,0.2,0.2h2.9c0.2,0,0.4-0.2,0.4-0.4L35.4,4C35.5,3.8,35.3,3.7,35,3.7H31.9c-0.5,0-0.9,0.3-1,0.8l-0.1,0.9L30.6,3.7z M36.3,17.5h2.5c0.6,0,1.1-0.4,1.2-1.1l2-12.7c0-0.2-0.2-0.4-0.4-0.4H39c-0.6,0-1.1,0.4-1.2,1.1l-2,12.7C35.8,17.3,36,17.5,36.3,17.5z M47,3.7h-3.8c-0.6,0-1.1,0.4-1.2,1.1l-2,12.7c0,0.2,0.2,0.4,0.4,0.4h2.5c0.6,0,1.1-0.4,1.2-1l0.6-3.8h2.3c3.5,0,5.6-1.7,6.3-5.1C53.9,5.1,51.4,3.7,47,3.7z M47.5,8.8h-2.1l0.5-3.3h2.1c1.8,0,2.9,0.8,2.6,2.3C50.2,8.8,48.6,8.8,47.5,8.8z M57.3,3.7h-3.6c-0.6,0-1.1,0.4-1.2,1l-2,12.7c-0.1,0.3,0.1,0.5,0.4,0.5h2.8c0.6,0,1.1-0.4,1.2-1.1l1.1-7.1c0.1-0.6,0.6-1.1,1.2-1.1h1.1l-1.5,5.9c0,0.1,0.1,0.2,0.2,0.2h2.9c0.2,0,0.4-0.2,0.4-0.4L62,4C62.1,3.8,61.9,3.7,61.6,3.7H58.6c-0.5,0-0.9,0.3-1,0.8l-0.1,0.9L57.3,3.7z M65,3.7h-2.5c-0.6,0-1.1,0.4-1.2,1.1L59.3,17.5h2.8c0.6,0,1.1-0.4,1.2-1.1l2-12.7C65.5,3.8,65.3,3.7,65,3.7z"/></svg>
                                    </div>
                                    <div class="flex-grow">
                                        <p class="font-bold text-sm text-gray-900">PayPal Checkout</p>
                                    </div>
                                    <div class="w-4 h-4 rounded-full border border-gray-300 peer-checked:border-blue-600 peer-checked:bg-blue-600 flex items-center justify-center shrink-0">
                                        <div class="w-1.5 h-1.5 bg-white rounded-full opacity-0 peer-checked:opacity-100"></div>
                                    </div>
                                </div>
                            </label>

                            <label class="relative block cursor-pointer">
                                <input type="radio" name="payment_method" value="Crypto" class="peer sr-only" onchange="handlePaymentMethodChange()">
                                <div class="rounded-lg border border-gray-200 bg-white p-3 hover:bg-gray-50 peer-checked:border-gray-900 peer-checked:ring-1 peer-checked:ring-gray-900 transition flex items-center">
                                    <div class="mr-3 text-lg">🪙</div>
                                    <div class="flex-grow">
                                        <p class="font-bold text-sm text-gray-900">Crypto (Solana)</p>
                                    </div>
                                    <div class="w-4 h-4 rounded-full border border-gray-300 peer-checked:border-gray-900 peer-checked:bg-gray-900 flex items-center justify-center shrink-0">
                                        <div class="w-1.5 h-1.5 bg-white rounded-full opacity-0 peer-checked:opacity-100"></div>
                                    </div>
                                </div>
                            </label>
                            
                            <label id="giftcardLabel" class="relative block cursor-pointer">
                                <input type="radio" name="payment_method" value="Giftcard" class="peer sr-only" onchange="handlePaymentMethodChange()">
                                <div class="rounded-lg border border-gray-200 bg-white p-3 hover:bg-gray-50 peer-checked:border-gray-900 peer-checked:ring-1 peer-checked:ring-gray-900 transition flex items-center">
                                    <div class="mr-3 text-lg">🎁</div>
                                    <div class="flex-grow">
                                        <p class="font-bold text-sm text-gray-900">Kinguin / G2A Giftcard</p>
                                    </div>
                                    <div class="w-4 h-4 rounded-full border border-gray-300 peer-checked:border-gray-900 peer-checked:bg-gray-900 flex items-center justify-center shrink-0">
                                        <div class="w-1.5 h-1.5 bg-white rounded-full opacity-0 peer-checked:opacity-100"></div>
                                    </div>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div id="paypal-action-container" class="mt-6">
                        <div id="paypal-button-render"></div>
                    </div>

                    <div id="normal-action-container" class="mt-6 hidden">
                        <button type="submit" class="w-full bg-gray-900 text-white font-bold py-3.5 rounded-lg hover:bg-gray-800 transition">Place Order &rarr;</button>
                    </div>

                </form>
            </div>
        </div>
    </div>

    <footer class="bg-white border-t border-gray-200 mt-20 relative z-20">
        <div class="max-w-7xl mx-auto px-4 md:px-8 py-8 text-center">
            <p class="text-sm font-bold text-gray-500">© 2026 ExamHub Marketplace. All rights reserved.</p>
        </div>
    </footer>

    <script>
        const isAuthenticated = <%= typeof buyerEmail !== 'undefined' && !!buyerEmail %>;
        let userEmailToVerify = null;
        let activeProduct = { id: '', title: '', tier: '', price: 0 };

        // SEARCH
        const searchInput = document.getElementById('searchInput');
        const searchDropdown = document.getElementById('searchDropdown');

        if(searchInput && searchDropdown) {
            searchInput.addEventListener('input', async (e) => {
                const val = e.target.value.trim();
                if (val.length < 2) { searchDropdown.classList.add('hidden'); return; }
                const res = await fetch('/api/search?q=' + encodeURIComponent(val));
                const data = await res.json();
                if (data.length > 0) {
                    searchDropdown.innerHTML = data.map(item => `<a href="/?q=\( {encodeURIComponent(item.title)}" class="block px-4 py-3 hover:bg-gray-50 border-b border-gray-100 last:border-0"><div class="font-bold text-sm text-gray-900"> \){item.title}</div><div class="text-[10px] font-bold text-gray-400 uppercase">${item.category}</div></a>`).join('');
                    searchDropdown.classList.remove('hidden');
                } else { searchDropdown.classList.add('hidden'); }
            });
        }

        // INIT PURCHASE
        function handleBuyClick(id, title, tier, price) {
            activeProduct = { id, title, tier, price: parseFloat(price || 0) };
            
            if (isAuthenticated) {
                openBuyModal();
            } else {
                sessionStorage.setItem('pendingBuy', JSON.stringify(activeProduct));
                document.getElementById('emailModal').classList.remove('hidden');
                document.getElementById('emailModal').classList.add('flex');
            }
        }

        // AUTO RESUME
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            if(urlParams.get('tab') === 'posts') switchTab('posts');

            if (isAuthenticated) {
                const savedPending = sessionStorage.getItem('pendingBuy');
                if (savedPending) {
                    activeProduct = JSON.parse(savedPending);
                    sessionStorage.removeItem('pendingBuy');
                    setTimeout(() => openBuyModal(), 400);
                }
            }
        });

        // AUTH
        async function sendOtp() {
            const email = document.getElementById('authEmailInput').value;
            if (!email || !email.includes('@')) return alert("Enter a valid email.");
            
            document.getElementById('sendOtpBtn').innerText = 'Sending...';
            document.getElementById('sendOtpBtn').disabled = true;

            const res = await fetch('/api/send-otp', {
                method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ email })
            });
            const data = await res.json();
            
            if (data.success) {
                userEmailToVerify = email;
                document.getElementById('emailModal').classList.add('hidden');
                document.getElementById('otpModal').classList.remove('hidden');
                document.getElementById('otpModal').classList.add('flex');
            } else {
                alert("Error sending email.");
                document.getElementById('sendOtpBtn').innerText = 'Send Code';
                document.getElementById('sendOtpBtn').disabled = false;
            }
        }

        async function verifyOtp() {
            const code = document.getElementById('authOtpInput').value;
            if (code.length !== 6) return alert("Enter the 6 digit code.");
            
            const res = await fetch('/api/verify-otp', {
                method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ email: userEmailToVerify, code })
            });
            const data = await res.json();

            if (data.success) { window.location.reload(); } 
            else { alert("Invalid or expired code."); }
        }

        // MODAL & PAYPAL RENDER
        function openBuyModal() {
            document.getElementById('modalItemTitle').innerText = activeProduct.title;
            document.getElementById('modalItemPrice').innerText = `$${activeProduct.price.toFixed(2)}`;
            document.getElementById('hiddenProductId').value = activeProduct.id;
            document.getElementById('hiddenProductTier').value = activeProduct.tier;

            const giftcardLabel = document.getElementById('giftcardLabel');
            document.querySelector('input[name="payment_method"][value="PayPal"]').checked = true;

            if (activeProduct.price > 900 || activeProduct.tier === 'Custom' || activeProduct.tier === 'Ultra') {
                giftcardLabel.classList.add('hidden');
            } else {
                giftcardLabel.classList.remove('hidden');
            }

            document.getElementById('buyModal').classList.remove('hidden');
            document.getElementById('buyModal').classList.add('flex');
            
            handlePaymentMethodChange(); // Init UI state
        }

        function handlePaymentMethodChange() {
            const selected = document.querySelector('input[name="payment_method"]:checked').value;
            const paypalContainer = document.getElementById('paypal-action-container');
            const normalContainer = document.getElementById('normal-action-container');

            if (selected === 'PayPal') {
                paypalContainer.classList.remove('hidden');
                normalContainer.classList.add('hidden');
                renderPayPalButtons();
            } else {
                paypalContainer.classList.add('hidden');
                normalContainer.classList.remove('hidden');
            }
        }

        function renderPayPalButtons() {
            const renderDiv = document.getElementById('paypal-button-render');
            renderDiv.innerHTML = ''; // Clear previous instances
            
            if (typeof paypal !== 'undefined') {
                paypal.Buttons({
                    style: { layout: 'vertical', color: 'blue', shape: 'rect', label: 'checkout' },
                    createOrder: function(data, actions) {
                        return actions.order.create({
                            purchase_units: [{
                                amount: { value: activeProduct.price.toFixed(2) },
                                description: activeProduct.title
                            }]
                        });
                    },
                    onApprove: function(data, actions) {
                        return actions.order.capture().then(function(details) {
                            // Inject capture ID and submit form to server
                            document.getElementById('hiddenPayPalCaptureId').value = details.id;
                            document.getElementById('buyForm').submit();
                        });
                    },
                    onError: function(err) {
                        console.error('PayPal Error', err);
                        alert('Payment failed or was closed.');
                    }
                }).render('#paypal-button-render');
            } else {
                renderDiv.innerHTML = '<p class="text-red-500 font-bold text-sm">PayPal failed to load. Please refresh.</p>';
            }
        }

        function closeModals() {
            document.getElementById('emailModal').classList.add('hidden');
            document.getElementById('otpModal').classList.add('hidden');
            document.getElementById('buyModal').classList.add('hidden');
            document.getElementById('buyForm').reset();
            document.getElementById('paypal-button-render').innerHTML = ''; // Clean up
        }

        // TABS
        function switchTab(tabId) {
            const storeBtn = document.getElementById('tab-store');
            const postsBtn = document.getElementById('tab-posts');
            const storeGrid = document.getElementById('store-grid');
            const postsGrid = document.getElementById('posts-grid');

            if (tabId === 'store') {
                storeGrid.classList.remove('hidden');
                postsGrid.classList.add('hidden');
                storeBtn.className = "font-bold text-sm md:text-base text-blue-600 border-b-2 border-blue-600 pb-3 px-2 transition";
                postsBtn.className = "font-bold text-sm md:text-base text-gray-500 border-b-2 border-transparent hover:text-gray-800 pb-3 px-2 transition";
            } else {
                postsGrid.classList.remove('hidden');
                storeGrid.classList.add('hidden');
                postsBtn.className = "font-bold text-sm md:text-base text-blue-600 border-b-2 border-blue-600 pb-3 px-2 transition";
                storeBtn.className = "font-bold text-sm md:text-base text-gray-500 border-b-2 border-transparent hover:text-gray-800 pb-3 px-2 transition";
            }
        }
    </script>
</body>
</html>
