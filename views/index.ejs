                                    <span
                                        class="absolute bottom-3 left-3 inline-flex items-center rounded-full bg-slate-950/80 backdrop-blur px-3 py-1.5 text-[10px] uppercase tracking-wider font-black text-white"
                                    >
                                        <%= product.tier || 'Standard' %>
                                    </span>
                                </div>
                            </div>

                            <div class="relative flex flex-col flex-grow p-6">
                                <div class="flex items-start justify-between gap-4">
                                    <h3
                                        class="font-black text-xl text-slate-950 leading-tight tracking-tight"
                                    >
                                        <%= product.title %>
