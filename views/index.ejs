                </form>

                <p
                    class="mt-5 text-center text-[11px] font-medium leading-5 text-slate-400"
                >
                    By completing your payment, you confirm that the product
                    and order information shown above are correct.
                </p>

            </section>
        </div>
    </div>

    <!-- FOOTER -->
    <footer
        class="relative z-10 mt-10 border-t border-slate-200 bg-white/80 backdrop-blur"
    >
        <div
            class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-4 px-4 py-8 text-center md:flex-row md:px-8 md:text-left"
        >
            <div>
                <p class="font-black text-slate-800">
                    Exam<span class="text-blue-600">Hub</span>
                </p>

                <p class="mt-1 text-xs font-medium text-slate-400">
                    Premium digital marketplace
                </p>
            </div>

            <p class="text-xs font-bold text-slate-400">
                © 2026 ExamHub Marketplace. All rights reserved.
            </p>
        </div>
    </footer>

    <script>
        'use strict';

        const isAuthenticated =
            <%- JSON.stringify(Boolean(currentBuyerEmail)) %>;

        let userEmailToVerify = '';

        let activeProduct = {
            id: '',
            title: '',
            tier: '',
            price: 0
        };

        let cardButtonRendered = false;
        let cardButtonRenderPromise = null;
        let paymentInProgress = false;

        let searchTimer = null;
        let searchController = null;

        function element(id) {
            return document.getElementById(id);
        }

        function setHidden(id, hidden) {
            const target = element(id);

            if (!target) return;

            target.classList.toggle('hidden', hidden);
        }

        function showModal(id) {
            const modal = element(id);

            if (!modal) return;

            modal.classList.remove('hidden');
            modal.classList.add('flex');
            modal.setAttribute('aria-hidden', 'false');

            document.body.classList.add('modal-open');
        }

        function hideModal(id) {
            const modal = element(id);

            if (!modal) return;

            modal.classList.add('hidden');
            modal.classList.remove('flex');
            modal.setAttribute('aria-hidden', 'true');
        }

        function setMessage(id, message) {
            const target = element(id);

            if (!target) return;

            target.textContent = message || '';
            target.classList.toggle('hidden', !message);
        }

        function safeString(value, fallback = '') {
            if (
                value === null ||
                value === undefined
            ) {
                return fallback;
            }

            return String(value);
        }

        function safePrice(value) {
            const price = Number(value);

            if (
                !Number.isFinite(price) ||
                price <= 0
            ) {
                return 0;
            }

            return Math.round(price * 100) / 100;
        }

        function waitForPayPal(timeoutMs = 15000) {
            return new Promise((resolve, reject) => {
                const startedAt = Date.now();

                function check() {
                    if (
                        window.paypal &&
                        typeof window.paypal.Buttons === 'function' &&
                        window.paypal.FUNDING
                    ) {
                        resolve(window.paypal);
                        return;
                    }

                    if (
                        Date.now() - startedAt >= timeoutMs
                    ) {
                        reject(
                            new Error(
                                'The secure payment service did not finish loading.'
                            )
                        );

                        return;
                    }

                    window.setTimeout(check, 100);
                }

                check();
            });
        }

        function clearPaymentState() {
            paymentInProgress = false;

            setHidden(
                'paymentProcessing',
                true
            );

            setHidden(
                'paymentError',
                true
            );

            setMessage(
                'paymentErrorMessage',
                ''
            );

            if (cardButtonRendered) {
                setHidden(
                    'card-button-container',
                    false
                );
            }
        }

        function showPaymentError(message) {
            paymentInProgress = false;

            setHidden(
                'paymentProcessing',
                true
            );

            setHidden(
                'card-button-container',
                !cardButtonRendered
            );

            setMessage(
                'paymentErrorMessage',
                message ||
                'The payment was not completed. Please try again.'
            );

            setHidden(
                'paymentError',
                false
            );
        }

        function showPaymentProcessing(title) {
            paymentInProgress = true;

            element(
                'paymentProcessingTitle'
            ).textContent =
                title ||
                'Completing your payment';

            setHidden(
                'paymentError',
                true
            );

            setHidden(
                'card-button-container',
                true
            );

            setHidden(
                'paymentProcessing',
                false
            );
        }

        async function renderCardButton() {
            if (cardButtonRendered) {
                setHidden(
                    'cardButtonLoading',
                    true
                );

                setHidden(
                    'card-button-container',
                    false
                );

                return;
            }

            if (cardButtonRenderPromise) {
                return cardButtonRenderPromise;
            }

            cardButtonRenderPromise =
                (async () => {
                    setHidden(
                        'cardButtonLoading',
                        false
                    );

                    setHidden(
                        'cardUnavailable',
                        true
                    );

                    setHidden(
                        'card-button-container',
                        true
                    );

                    try {
                        const paypalApi =
                            await waitForPayPal();

                        /*
                         * Standalone card funding source only.
                         *
                         * No paypal.FUNDING.PAYPAL button is rendered.
                         */
                        const cardButton =
                            paypalApi.Buttons({
                                fundingSource:
                                    paypalApi.FUNDING.CARD,

                                style: {
                                    layout: 'vertical',
                                    shape: 'rect',
                                    color: 'black',
                                    height: 52,
                                    tagline: false
                                },

                                onClick() {
                                    setHidden(
                                        'paymentError',
                                        true
                                    );

                                    setMessage(
                                        'paymentErrorMessage',
                                        ''
                                    );

                                    if (
                                        !activeProduct.id ||
                                        !activeProduct.title ||
                                        activeProduct.price <= 0
                                    ) {
                                        showPaymentError(
                                            'The selected product information is invalid. Close checkout and select the product again.'
                                        );

                                        throw new Error(
                                            'Invalid product information.'
                                        );
                                    }
                                },

                                createOrder(data, actions) {
                                    const price =
                                        activeProduct.price.toFixed(
                                            2
                                        );

                                    const productTitle =
                                        activeProduct.title
                                            .slice(0, 127);

                                    const productId =
                                        activeProduct.id
                                            .slice(0, 127);

                                    /*
                                     * The server must verify the product price
                                     * and PayPal transaction before delivering
                                     * the product.
                                     */
                                    return actions.order.create({
                                        intent: 'CAPTURE',

                                        purchase_units: [
                                            {
                                                reference_id:
                                                    productId,

                                                custom_id:
                                                    productId,

                                                description:
                                                    productTitle,

                                                amount: {
                                                    currency_code:
                                                        'USD',

                                                    value:
                                                        price,

                                                    breakdown: {
                                                        item_total: {
                                                            currency_code:
                                                                'USD',

                                                            value:
                                                                price
                                                        }
                                                    }
                                                },

                                                items: [
                                                    {
                                                        name:
                                                            productTitle,

                                                        description:
                                                            activeProduct.tier
                                                                .slice(
                                                                    0,
                                                                    127
                                                                ),

                                                        quantity:
                                                            '1',

                                                        category:
                                                            'DIGITAL_GOODS',

                                                        unit_amount: {
                                                            currency_code:
                                                                'USD',

                                                            value:
                                                                price
                                                        }
                                                    }
                                                ]
                                            }
                                        ],

                                        application_context: {
                                            brand_name:
                                                'ExamHub',

                                            landing_page:
                                                'BILLING',

                                            shipping_preference:
                                                'NO_SHIPPING',

                                            user_action:
                                                'PAY_NOW'
                                        }
                                    });
                                },

                                async onApprove(data, actions) {
                                    try {
                                        showPaymentProcessing(
                                            'Confirming your card payment'
                                        );

                                        const details =
                                            await actions.order.capture();

                                        const purchaseUnit =
                                            details &&
                                            Array.isArray(
                                                details.purchase_units
                                            )
                                                ? details
                                                    .purchase_units[0]
                                                : null;

                                        const payments =
                                            purchaseUnit &&
                                            purchaseUnit.payments
                                                ? purchaseUnit.payments
                                                : null;

                                        const capture =
                                            payments &&
                                            Array.isArray(
                                                payments.captures
                                            )
                                                ? payments.captures[0]
                                                : null;

                                        const orderId =
                                            data.orderID ||
                                            details.id ||
                                            '';

                                        const captureId =
                                            capture &&
                                            capture.id
                                                ? capture.id
                                                : '';

                                        const captureStatus =
                                            capture &&
                                            capture.status
                                                ? capture.status
                                                : details.status || '';

                                        if (
                                            !orderId ||
                                            !captureId ||
                                            captureStatus !==
                                                'COMPLETED'
                                        ) {
                                            throw new Error(
                                                'PayPal did not return a completed card capture.'
                                            );
                                        }

                                        element(
                                            'hiddenPayPalOrderId'
                                        ).value =
                                            orderId;

                                        element(
                                            'hiddenPayPalCaptureId'
                                        ).value =
                                            captureId;

                                        element(
                                            'hiddenPayPalStatus'
                                        ).value =
                                            captureStatus;

                                        element(
                                            'hiddenPaymentMethod'
                                        ).value =
                                            'PayPalCard';

                                        /*
                                         * Submit the completed transaction
                                         * information to the existing server
                                         * checkout route.
                                         *
                                         * The server must verify the capture
                                         * directly with PayPal before marking
                                         * the order paid.
                                         */
                                        element(
                                            'buyForm'
                                        ).submit();
                                    } catch (error) {
                                        console.error(
                                            'Card capture error:',
                                            error
                                        );

                                        showPaymentError(
                                            error &&
                                            error.message
                                                ? error.message
                                                : 'The card payment could not be confirmed.'
                                        );
                                    }
                                },

                                onCancel() {
                                    showPaymentError(
                                        'The card checkout was cancelled. No completed payment was recorded.'
                                    );
                                },

                                onError(error) {
                                    console.error(
                                        'PayPal card button error:',
                                        error
                                    );

                                    showPaymentError(
                                        'The secure card checkout encountered an error. Check your card details or try again.'
                                    );
                                }
                            });

                        if (!cardButton.isEligible()) {
                            setHidden(
                                'cardButtonLoading',
                                true
                            );

                            setHidden(
                                'card-button-container',
                                true
                            );

                            setHidden(
                                'cardUnavailable',
                                false
                            );

                            element(
                                'cardUnavailableMessage'
                            ).textContent =
                                'Debit and credit card checkout is not currently eligible for this buyer, browser, region, or PayPal merchant account.';

                            return;
                        }

                        /*
                         * The modal is visible before rendering so PayPal can
                         * calculate the correct iframe width.
                         */
                        await new Promise(resolve => {
                            requestAnimationFrame(() => {
                                requestAnimationFrame(
                                    resolve
                                );
                            });
                        });

                        await cardButton.render(
                            '#card-button-container'
                        );

                        cardButtonRendered = true;

                        setHidden(
                            'cardButtonLoading',
                            true
                        );

                        setHidden(
                            'card-button-container',
                            false
                        );
                    } catch (error) {
                        console.error(
                            'Card button loading error:',
                            error
                        );

                        setHidden(
                            'cardButtonLoading',
                            true
                        );

                        setHidden(
                            'card-button-container',
                            true
                        );

                        setHidden(
                            'cardUnavailable',
                            false
                        );

                        element(
                            'cardUnavailableMessage'
                        ).textContent =
                            error &&
                            error.message
                                ? error.message
                                : 'The secure card checkout could not be loaded.';
                    } finally {
                        cardButtonRenderPromise =
                            null;
                    }
                })();

            return cardButtonRenderPromise;
        }

        function handleBuyClick(product) {
            activeProduct = {
                id:
                    safeString(
                        product.id
                    ),

                title:
                    safeString(
                        product.title,
                        'Digital product'
                    ),

                tier:
                    safeString(
                        product.tier,
                        'Standard'
                    ),

                price:
                    safePrice(
                        product.price
                    )
            };

            if (
                !activeProduct.id ||
                !activeProduct.title ||
                activeProduct.price <= 0
            ) {
                alert(
                    'This product has invalid checkout information.'
                );

                return;
            }

            if (isAuthenticated) {
                openBuyModal();
                return;
            }

            sessionStorage.setItem(
                'pendingBuy',
                JSON.stringify(
                    activeProduct
                )
            );

            openEmailModal();
        }

        function openEmailModal() {
            setMessage(
                'emailAuthError',
                ''
            );

            showModal(
                'emailModal'
            );

            window.setTimeout(() => {
                element(
                    'authEmailInput'
                )?.focus();
            }, 80);
        }

        function openOtpModal() {
            hideModal(
                'emailModal'
            );

            setMessage(
                'otpAuthError',
                ''
            );

            showModal(
                'otpModal'
            );

            window.setTimeout(() => {
                element(
                    'authOtpInput'
                )?.focus();
            }, 80);
        }

        function openBuyModal() {
            clearPaymentState();

            element(
                'modalItemTitle'
            ).textContent =
                activeProduct.title;

            element(
                'modalItemTier'
            ).textContent =
                activeProduct.tier;

            element(
                'modalItemPrice'
            ).textContent =
                `$${activeProduct.price.toFixed(2)}`;

            element(
                'hiddenProductId'
            ).value =
                activeProduct.id;

            element(
                'hiddenProductTier'
            ).value =
                activeProduct.tier;

            element(
                'hiddenPayPalOrderId'
            ).value =
                '';

            element(
                'hiddenPayPalCaptureId'
            ).value =
                '';

            element(
                'hiddenPayPalStatus'
            ).value =
                '';

            const cardChoice =
                document.querySelector(
                    'input[name="payment_method_choice"][value="PayPalCard"]'
                );

            if (cardChoice) {
                cardChoice.checked =
                    true;
            }

            const giftcardLabel =
                element(
                    'giftcardLabel'
                );

            const giftcardChoice =
                document.querySelector(
                    'input[name="payment_method_choice"][value="Giftcard"]'
                );

            const giftCardRestricted =
                activeProduct.price > 900 ||
                ['custom', 'ultra'].includes(
                    activeProduct.tier
                        .toLowerCase()
                );

            giftcardLabel.classList.toggle(
                'hidden',
                giftCardRestricted
            );

            if (
                giftCardRestricted &&
                giftcardChoice &&
                giftcardChoice.checked
            ) {
                cardChoice.checked =
                    true;
            }

            showModal(
                'buyModal'
            );

            handlePaymentMethodChange();
        }

        function handlePaymentMethodChange() {
            const selected =
                document.querySelector(
                    'input[name="payment_method_choice"]:checked'
                );

            const paymentMethod =
                selected
                    ? selected.value
                    : 'PayPalCard';

            element(
                'hiddenPaymentMethod'
            ).value =
                paymentMethod;

            if (
                paymentMethod ===
                'PayPalCard'
            ) {
                setHidden(
                    'card-action-container',
                    false
                );

                setHidden(
                    'normal-action-container',
                    true
                );

                renderCardButton();
                return;
            }

            setHidden(
                'card-action-container',
                true
            );

            setHidden(
                'normal-action-container',
                false
            );

            const button =
                element(
                    'normalCheckoutButton'
                );

            if (
                paymentMethod ===
                'Crypto'
            ) {
                button.innerHTML = `
                    Continue to crypto payment

                    <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
                        <path d="M5 12h14M14 7l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                `;
            } else {
                button.innerHTML = `
                    Continue with gift card

                    <svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" aria-hidden="true">
                        <path d="M5 12h14M14 7l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                `;
            }
        }

        async function sendOtp() {
            const input =
                element(
                    'authEmailInput'
                );

            const button =
                element(
                    'sendOtpBtn'
                );

            const email =
                input.value
                    .trim()
                    .toLowerCase();

            const emailPattern =
                /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

            setMessage(
                'emailAuthError',
                ''
            );

            if (
                !emailPattern.test(
                    email
                )
            ) {
                setMessage(
                    'emailAuthError',
                    'Enter a valid email address.'
                );

                input.focus();
                return;
            }

            button.disabled = true;
            button.textContent =
                'Sending code...';

            try {
                const response =
                    await fetch(
                        '/api/send-otp',
                        {
                            method:
                                'POST',

                            headers: {
                                'Content-Type':
                                    'application/json',

                                Accept:
                                    'application/json'
                            },

                            body:
                                JSON.stringify({
                                    email
                                })
                        }
                    );

                const result =
                    await response
                        .json()
                        .catch(
                            () => ({})
                        );

                if (
                    !response.ok ||
                    !result.success
                ) {
                    throw new Error(
                        result.message ||
                        'The verification code could not be sent.'
                    );
                }

                userEmailToVerify =
                    email;

                openOtpModal();
            } catch (error) {
                setMessage(
                    'emailAuthError',
                    error &&
                    error.message
                        ? error.message
                        : 'The verification code could not be sent.'
                );
            } finally {
                button.disabled = false;
                button.textContent =
                    'Send verification code';
            }
        }

        async function verifyOtp() {
            const input =
                element(
                    'authOtpInput'
                );

            const button =
                element(
                    'verifyOtpBtn'
                );

            const code =
                input.value
                    .replace(/\D/g, '')
                    .slice(0, 6);

            input.value =
                code;

            setMessage(
                'otpAuthError',
                ''
            );

            if (!userEmailToVerify) {
                setMessage(
                    'otpAuthError',
                    'Your email verification session expired. Request another code.'
                );

                return;
            }

            if (code.length !== 6) {
                setMessage(
                    'otpAuthError',
                    'Enter the complete six-digit code.'
                );

                input.focus();
                return;
            }

            button.disabled = true;
            button.textContent =
                'Verifying...';

            try {
                const response =
                    await fetch(
                        '/api/verify-otp',
                        {
                            method:
                                'POST',

                            headers: {
                                'Content-Type':
                                    'application/json',

                                Accept:
                                    'application/json'
                            },

                            body:
                                JSON.stringify({
                                    email:
                                        userEmailToVerify,

                                    code
                                })
                        }
                    );

                const result =
                    await response
                        .json()
                        .catch(
                            () => ({})
                        );

                if (
                    !response.ok ||
                    !result.success
                ) {
                    throw new Error(
                        result.message ||
                        'The verification code is invalid or expired.'
                    );
                }

                window.location.reload();
            } catch (error) {
                setMessage(
                    'otpAuthError',
                    error &&
                    error.message
                        ? error.message
                        : 'The verification code is invalid or expired.'
                );
            } finally {
                button.disabled = false;
                button.textContent =
                    'Verify and continue';
            }
        }

        function closeModals() {
            if (paymentInProgress) {
                return;
            }

            hideModal(
                'emailModal'
            );

            hideModal(
                'otpModal'
            );

            hideModal(
                'buyModal'
            );

            document.body.classList.remove(
                'modal-open'
            );

            setMessage(
                'emailAuthError',
                ''
            );

            setMessage(
                'otpAuthError',
                ''
            );

            setHidden(
                'paymentError',
                true
            );
        }

        function switchTab(tabId) {
            const showStore =
                tabId ===
                'store';

            const storeButton =
                element(
                    'tab-store'
                );

            const postsButton =
                element(
                    'tab-posts'
                );

            const storeGrid =
                element(
                    'store-grid'
                );

            const postsGrid =
                element(
                    'posts-grid'
                );

            storeGrid.classList.toggle(
                'hidden',
                !showStore
            );

            postsGrid.classList.toggle(
                'hidden',
                showStore
            );

            storeButton.setAttribute(
                'aria-selected',
                String(showStore)
            );

            postsButton.setAttribute(
                'aria-selected',
                String(!showStore)
            );

            storeButton.className =
                showStore
                    ? 'border-b-2 border-blue-600 px-1 pb-4 text-sm font-black text-blue-600 transition'
                    : 'border-b-2 border-transparent px-1 pb-4 text-sm font-black text-slate-400 transition hover:text-slate-800';

            postsButton.className =
                !showStore
                    ? 'border-b-2 border-blue-600 px-1 pb-4 text-sm font-black text-blue-600 transition'
                    : 'border-b-2 border-transparent px-1 pb-4 text-sm font-black text-slate-400 transition hover:text-slate-800';
        }

        function renderSearchResults(items) {
            const dropdown =
                element(
                    'searchDropdown'
                );

            dropdown.replaceChildren();

            if (
                !Array.isArray(items) ||
                items.length === 0
            ) {
                dropdown.classList.add(
                    'hidden'
                );

                dropdown.classList.remove(
                    'flex'
                );

                return;
            }

            items.forEach(item => {
                const link =
                    document.createElement(
                        'a'
                    );

                link.href =
                    '/?q=' +
                    encodeURIComponent(
                        safeString(
                            item.title
                        )
                    );

                link.className =
                    'flex items-center justify-between gap-4 border-b border-slate-100 px-5 py-4 transition last:border-0 hover:bg-blue-50';

                link.setAttribute(
                    'role',
                    'option'
                );

                const content =
                    document.createElement(
                        'div'
                    );

                content.className =
                    'min-w-0';

                const title =
                    document.createElement(
                        'div'
                    );

                title.className =
                    'truncate text-sm font-black text-slate-900';

                title.textContent =
                    safeString(
                        item.title,
                        'Untitled product'
                    );

                const category =
                    document.createElement(
                        'div'
                    );

                category.className =
                    'mt-1 text-[10px] font-black uppercase tracking-[0.12em] text-blue-600';

                category.textContent =
                    safeString(
                        item.category,
                        'Product'
                    );

                const arrow =
                    document.createElement(
                        'span'
                    );

                arrow.className =
                    'shrink-0 text-blue-500';

                arrow.textContent =
                    '→';

                content.append(
                    title,
                    category
                );

                link.append(
                    content,
                    arrow
                );

                dropdown.appendChild(
                    link
                );
            });

            dropdown.classList.remove(
                'hidden'
            );

            dropdown.classList.add(
                'flex'
            );
        }

        async function searchMarketplace(query) {
            if (searchController) {
                searchController.abort();
            }

            searchController =
                new AbortController();

            try {
                const response =
                    await fetch(
                        '/api/search?q=' +
                        encodeURIComponent(
                            query
                        ),
                        {
                            headers: {
                                Accept:
                                    'application/json'
                            },

                            signal:
                                searchController.signal
                        }
                    );

                if (!response.ok) {
                    throw new Error(
                        'Search failed.'
                    );
                }

                const results =
                    await response.json();

                renderSearchResults(
                    results
                );
            } catch (error) {
                if (
                    error.name !==
                    'AbortError'
                ) {
                    console.error(
                        'Search error:',
                        error
                    );

                    renderSearchResults(
                        []
                    );
                }
            }
        }

        document.addEventListener(
            'DOMContentLoaded',
            () => {
                const searchInput =
                    element(
                        'searchInput'
                    );

                const searchDropdown =
                    element(
                        'searchDropdown'
                    );

                const otpInput =
                    element(
                        'authOtpInput'
                    );

                const buyForm =
                    element(
                        'buyForm'
                    );

                const urlParameters =
                    new URLSearchParams(
                        window.location.search
                    );

                if (
                    urlParameters.get(
                        'tab'
                    ) === 'posts'
                ) {
                    switchTab(
                        'posts'
                    );
                }

                document
                    .querySelectorAll(
                        '.purchase-button'
                    )
                    .forEach(button => {
                        button.addEventListener(
                            'click',
                            () => {
                                handleBuyClick({
                                    id:
                                        button.dataset
                                            .productId,

                                    title:
                                        button.dataset
                                            .productTitle,

                                    tier:
                                        button.dataset
                                            .productTier,

                                    price:
                                        button.dataset
                                            .productPrice
                                });
                            }
                        );
                    });

                document
                    .querySelectorAll(
                        'input[name="payment_method_choice"]'
                    )
                    .forEach(input => {
                        input.addEventListener(
                            'change',
                            handlePaymentMethodChange
                        );
                    });

                if (
                    searchInput &&
                    searchDropdown
                ) {
                    searchInput.addEventListener(
                        'input',
                        event => {
                            const query =
                                event.target.value.trim();

                            window.clearTimeout(
                                searchTimer
                            );

                            if (
                                query.length < 2
                            ) {
                                if (
                                    searchController
                                ) {
                                    searchController.abort();
                                }

                                renderSearchResults(
                                    []
                                );

                                return;
                            }

                            searchTimer =
                                window.setTimeout(
                                    () => {
                                        searchMarketplace(
                                            query
                                        );
                                    },
                                    250
                                );
                        }
                    );
                }

                document.addEventListener(
                    'click',
                    event => {
                        if (
                            searchDropdown &&
                            searchInput &&
                            !searchDropdown.contains(
                                event.target
                            ) &&
                            event.target !==
                                searchInput
                        ) {
                            searchDropdown.classList.add(
                                'hidden'
                            );

                            searchDropdown.classList.remove(
                                'flex'
                            );
                        }
                    }
                );

                if (otpInput) {
                    otpInput.addEventListener(
                        'input',
                        () => {
                            otpInput.value =
                                otpInput.value
                                    .replace(
                                        /\D/g,
                                        ''
                                    )
                                    .slice(
                                        0,
                                        6
                                    );
                        }
                    );

                    otpInput.addEventListener(
                        'keydown',
                        event => {
                            if (
                                event.key ===
                                'Enter'
                            ) {
                                verifyOtp();
                            }
                        }
                    );
                }

                element(
                    'authEmailInput'
                )?.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Enter'
                        ) {
                            sendOtp();
                        }
                    }
                );

                if (buyForm) {
                    buyForm.addEventListener(
                        'submit',
                        event => {
                            const selected =
                                document.querySelector(
                                    'input[name="payment_method_choice"]:checked'
                                );

                            const method =
                                selected
                                    ? selected.value
                                    : 'PayPalCard';

                            /*
                             * Card payments may only be submitted after
                             * PayPal onApprove captures the transaction.
                             */
                            if (
                                method ===
                                'PayPalCard'
                            ) {
                                event.preventDefault();

                                renderCardButton();
                                return;
                            }

                            const button =
                                element(
                                    'normalCheckoutButton'
                                );

                            button.disabled =
                                true;

                            button.textContent =
                                'Preparing checkout...';
                        }
                    );
                }

                [
                    element('emailModal'),
                    element('otpModal'),
                    element('buyModal')
                ].forEach(modal => {
                    modal?.addEventListener(
                        'mousedown',
                        event => {
                            if (
                                event.target ===
                                modal
                            ) {
                                closeModals();
                            }
                        }
                    );
                });

                document.addEventListener(
                    'keydown',
                    event => {
                        if (
                            event.key ===
                            'Escape'
                        ) {
                            closeModals();
                        }
                    }
                );

                /*
                 * Resume the purchase after successful OTP verification.
                 */
                if (isAuthenticated) {
                    const pending =
                        sessionStorage.getItem(
                            'pendingBuy'
                        );

                    if (pending) {
                        try {
                            const parsed =
                                JSON.parse(
                                    pending
                                );

                            activeProduct = {
                                id:
                                    safeString(
                                        parsed.id
                                    ),

                                title:
                                    safeString(
                                        parsed.title,
                                        'Digital product'
                                    ),

                                tier:
                                    safeString(
                                        parsed.tier,
                                        'Standard'
                                    ),

                                price:
                                    safePrice(
                                        parsed.price
                                    )
                            };

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );

                            if (
                                activeProduct.id &&
                                activeProduct.price > 0
                            ) {
                                window.setTimeout(
                                    openBuyModal,
                                    250
                                );
                            }
                        } catch (error) {
                            console.error(
                                'Could not restore pending purchase:',
                                error
                            );

                            sessionStorage.removeItem(
                                'pendingBuy'
                            );
                        }
                    }
                }
            }
        );
    </script>
</body>
</html>