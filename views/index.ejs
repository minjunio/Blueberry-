                </form>

                <!--
                    PAYPAL IS OUTSIDE buyForm.

                    Do not move it inside the form.
                -->
                <div
                    id="paypal-action-container"
                    class="mt-6"
                >
                    <div
                        id="paypalLoading"
                        class="rounded-xl border border-blue-100 bg-blue-50 px-4 py-4 text-sm font-semibold text-blue-700 text-center"
                    >
                        Loading secure PayPal checkout...
                    </div>

                    <div
                        id="paypal-hosted-root"
                        class="relative z-20 w-full pointer-events-auto"
                    ></div>

                    <div
                        id="paypalError"
                        class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-4 text-sm text-red-700 mt-3"
                    >
                        <p class="font-bold">
                            The embedded PayPal checkout could not open.
                        </p>

                        <p
                            id="paypalErrorMessage"
                            class="mt-1"
                        >
                            Use the secure payment-page button below.
                        </p>
