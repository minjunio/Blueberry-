<!DOCTYPE html>
<html lang="en">
<head>
    <% 
        const seoTitle = post.seo_title || post.title;
        const seoDesc = post.seo_desc || 'Read this post on ExamHub.';
        const seoKeywords = post.seo_keywords || 'examhub, update, post';
        const ogImage = post.og_image || 'https://examhub.shop/favicon.png';
        const canonicalUrl = post.canonical_url || `https://${host}/post/${post.id}`;
        
        function formatPostText(text, linkedProduct) {
            if (!text) return '';
            let safeText = text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&apos;');
            
            // FIXED: Using [\s\S]*? allows the bolding and headers to span across multiple paragraphs and line breaks!
            safeText = safeText.replace(/\*\*([\s\S]*?)\*\*/g, '<strong class="font-black text-anime-textMain">$1</strong>');
            safeText = safeText.replace(/#([\s\S]*?)#/g, '<span class="text-2xl md:text-3xl font-black block mt-10 mb-4 text-anime-textMain leading-tight">$1</span>');
            
            safeText = safeText.replace(/\[img\](.*?)\[\/img\]/gi, '<img src="$1" class="rounded-2xl w-full my-8 shadow-md border-2 border-gray-100 object-cover">');
            safeText = safeText.replace(/\n/g, '<br>');
            
            // Inject the Product Card if [product] is typed and a product is linked
            if (linkedProduct) {
                const productHtml = `
                <div class="my-10 bg-white rounded-3xl p-4 md:p-6 shadow-xl border-2 border-gray-100 max-w-sm mx-auto transform transition duration-300 hover:-translate-y-1">
                    <div class="w-full h-48 bg-gray-100 rounded-2xl mb-4 overflow-hidden relative shadow-inner">
                        <img src="${linkedProduct.image_url || '/favicon.png'}" class="w-full h-full object-cover">
                        <div class="absolute top-3 right-3 bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-black shadow-sm">${linkedProduct.category}</div>
                    </div>
                    <h3 class="text-xl font-black text-anime-textMain mb-1 leading-tight">${linkedProduct.title}</h3>
                    <p class="text-sm font-bold text-gray-400 mb-6">$${linkedProduct.price}</p>
                    <a href="/?q=${linkedProduct.id}" class="flex justify-center items-center gap-2 w-full bg-anime-accent text-white font-black py-3 rounded-xl shadow-md hover:scale-105 transition">View Product →</a>
                </div>`;
                safeText = safeText.replace(/\[product\]/g, productHtml);
            } else {
                safeText = safeText.replace(/\[product\]/g, ''); // Clear placeholder if nothing linked
            }
            return safeText;
        }
    %>
    <title><%= seoTitle %></title>
    <meta name="description" content="<%= seoDesc %>">
    <meta name="keywords" content="<%= seoKeywords %>">
    <link rel="canonical" href="<%= canonicalUrl %>">
    <meta property="og:title" content="<%= seoTitle %>">
    <meta property="og:description" content="<%= seoDesc %>">
    <meta property="og:image" content="<%= ogImage %>">
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
</head>
<body class="antialiased flex flex-col min-h-screen bg-gray-50">
    <nav class="pt-8 pb-4 px-4 md:px-8 flex flex-col md:flex-row justify-between items-center max-w-7xl mx-auto w-full relative z-20 gap-4">
        <a href="/" class="text-3xl font-black text-anime-textMain">Exam<span class="text-anime-accent">Hub</span></a>
        <a href="/?tab=posts" class="bg-white border-2 border-gray-200 px-5 py-2.5 rounded-full font-black text-sm text-gray-600 hover:text-black shadow-sm transition flex items-center">← Back to Posts</a>
    </nav>
    
    <main class="flex-grow w-full max-w-3xl mx-auto px-4 md:px-8 py-6 md:py-10 relative z-10">
        <article class="bg-white rounded-3xl shadow-sm border-2 border-gray-100 p-6 md:p-12 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-32 h-32 bg-anime-skyLight rounded-bl-full opacity-20 pointer-events-none"></div>
            
            <h1 class="text-3xl md:text-5xl font-black text-anime-textMain mb-4 leading-tight"><%= post.title %></h1>
            <p class="text-xs text-gray-400 font-black mb-10 uppercase tracking-widest flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                <%= new Date(post.created_at).toLocaleDateString() %>
                <% if (post.category_name) { %> <span class="bg-gray-100 px-2 py-1 rounded-md text-gray-600 ml-2"><%= post.category_name %></span> <% } %>
            </p>
            
            <div class="text-gray-700 leading-relaxed font-medium text-lg mobile-post-content">
                <%- formatPostText(post.content, linkedProduct) %>
            </div>
            
        </article>
    </main>
</body>
</html>
