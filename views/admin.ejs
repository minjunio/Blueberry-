<!DOCTYPE html>
<html lang="en">
<head>
    <title>Admin - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
</head>
<body class="p-4 md:p-8 bg-gray-50">
    <div class="max-w-7xl mx-auto relative z-10 mt-6">
        
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4 border-b-2 border-gray-200 pb-6">
            <h1 class="text-3xl md:text-4xl font-black text-anime-textMain">ExamHub Admin 🛡️</h1>
            <div class="flex flex-wrap gap-2">
                <button onclick="document.getElementById('createAnnModal').classList.remove('hidden')" class="bg-blue-600 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">📢 Announcement</button>
                <button onclick="document.getElementById('createPostModal').classList.remove('hidden')" class="bg-anime-accent text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">+ Product</button>
                <a href="/admin/casino" class="bg-[#00b67a] text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition flex items-center gap-2">
                    🎰 Casino Lounge
                </a>
                <a href="/logout" class="bg-red-500 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:bg-red-600 transition">Logout</a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <div class="flex justify-between items-center mb-4 border-b-2 border-dashed border-gray-200 pb-2">
                    <h2 class="text-xl md:text-2xl font-black text-gray-800">Manage Blog Posts</h2>
                    <button onclick="document.getElementById('createBlogPostModal').classList.remove('hidden')" class="bg-purple-600 text-white font-black px-4 py-2 rounded-xl text-sm hover:scale-105 transition">+ Create Post</button>
                </div>
                <div class="flex flex-col gap-3 max-h-[300px] overflow-y-auto pr-2">
                    <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                        <% posts.forEach(post => { %>
                            <div class="bg-gray-50 border-2 border-gray-100 p-4 rounded-xl flex justify-between items-center group">
                                <div>
                                    <h3 class="font-black text-gray-800 text-sm"><%= post.title %></h3>
                                    <p class="text-xs text-gray-500 font-bold mt-1">SEO Title: <%= post.seo_title || 'N/A' %></p>
                                </div>
                                <form action="/admin/delete-post" method="POST" onsubmit="return confirm('Delete this post permanently?');">
                                    <input type="hidden" name="id" value="<%= post.id %>">
                                    <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                </form>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <p class="text-sm font-bold text-gray-400">No blog posts yet.</p>
                    <% } %>
                </div>
            </div>

            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <div class="flex justify-between items-center mb-4 border-b-2 border-dashed border-gray-200 pb-2">
                    <h2 class="text-xl md:text-2xl font-black text-gray-800">Manage Categories</h2>
                    <button onclick="document.getElementById('createCatModal').classList.remove('hidden')" class="bg-gray-800 text-white font-black px-4 py-2 rounded-xl text-sm hover:scale-105 transition">+ Category</button>
                </div>
                <div class="flex flex-col gap-3 max-h-[300px] overflow-y-auto pr-2">
                    <% categories.forEach(cat => { %>
                        <div class="bg-gray-50 border-2 border-gray-100 p-4 rounded-xl flex justify-between items-center group">
                            <div>
                                <h3 class="font-black text-gray-800 text-sm"><%= cat.name %></h3>
                                <p class="text-xs text-gray-500 font-bold mt-1"><%= cat.seo_desc || 'No SEO desc' %></p>
                            </div>
                            <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition">
                                <button onclick="openEditCatModal(this)" data-name="<%= cat.name %>" data-title="<%= cat.seo_title %>" data-desc="<%= cat.seo_desc %>" data-keywords="<%= cat.seo_keywords %>" data-ogimage="<%= cat.og_image %>" data-canonical="<%= cat.canonical_url %>" class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-blue-500 hover:text-white transition">Edit</button>
                                <form action="/admin/delete-category" method="POST" onsubmit="return confirm('Delete this category?');">
                                    <input type="hidden" name="category_name" value="<%= cat.name %>">
                                    <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <h2 class="text-xl md:text-2xl font-black text-gray-800 mb-4 border-b-2 border-dashed border-gray-200 pb-2">Active Orders</h2>
                <div class="flex flex-col gap-3 max-h-[400px] overflow-y-auto pr-2">
                    <% orders.forEach(order => { %>
                        <div class="bg-gray-50 border-2 border-gray-100 p-4 rounded-xl">
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <span class="text-xs font-bold text-gray-400">ID: <%= order.order_id %></span>
                                    <h3 class="font-black text-gray-800"><%= order.product_title || 'Unknown Product' %></h3>
                                </div>
                                <span class="text-[10px] font-black uppercase tracking-widest px-2 py-1 rounded bg-gray-200 text-gray-600"><%= order.status %></span>
                            </div>
                            <div class="text-xs font-bold text-gray-500 space-y-1 mb-3">
                                <p>Email: <span class="text-anime-accent"><%= order.email %></span></p>
                                <% if(order.discord_username) { %><p>Discord: <span class="text-anime-textMain"><%= order.discord_username %></span></p><% } %>
                                <p>Method: <%= order.payment_method %> (<%= order.tier %>)</p>
                                <% if(order.giftcard_code) { %><p class="text-red-500 break-all">Code: <%= order.giftcard_code %></p><% } %>
                            </div>
                            <div class="flex gap-2 border-t-2 border-gray-200 pt-3">
                                <button onclick="updateOrderStatus('<%= order.order_id %>', 'Completed')" class="flex-1 bg-green-100 text-green-600 py-2 rounded-lg text-xs font-black hover:bg-green-500 hover:text-white transition">Complete</button>
                                <form action="/admin/close-order" method="POST" class="flex-1" onsubmit="return confirm('Close order?');">
                                    <input type="hidden" name="order_id" value="<%= order.order_id %>">
                                    <button type="submit" class="w-full bg-red-100 text-red-600 py-2 rounded-lg text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <h2 class="text-xl md:text-2xl font-black text-gray-800 mb-4 border-b-2 border-dashed border-gray-200 pb-2">Active Products</h2>
                <div class="flex flex-col gap-3 max-h-[400px] overflow-y-auto pr-2">
                    <% products.forEach(product => { %>
                        <div class="bg-gray-50 border-2 border-gray-100 p-4 rounded-xl flex justify-between items-center group">
                            <div>
                                <h3 class="font-black text-gray-800 text-sm"><%= product.title %></h3>
                                <p class="text-xs text-gray-500 font-bold mt-1">$<%= product.price %> - <%= product.category %></p>
                            </div>
                            <form action="/admin/delete-product" method="POST" onsubmit="return confirm('Delete this product permanently?');">
                                <input type="hidden" name="id" value="<%= product.id %>">
                                <button type="submit" class="opacity-0 group-hover:opacity-100 bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                            </form>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <div id="createBlogPostModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white rounded-3xl w-full max-w-3xl overflow-hidden shadow-2xl my-8">
            <div class="p-6 md:p-8">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-black text-gray-800">Create New Post</h2>
                    <button onclick="document.getElementById('createBlogPostModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 font-black text-xl">&times;</button>
                </div>
                <form action="/admin/add-post" method="POST" class="space-y-4">
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Headline Title</label>
                        <input type="text" name="title" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-purple-500 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Article Content</label>
                        <p class="text-xs text-gray-400 mb-2 font-bold">Use <code class="bg-gray-200 px-1 rounded"># text #</code> for big headers, <code class="bg-gray-200 px-1 rounded">**text**</code> for bold text, and <code class="bg-gray-200 px-1 rounded">[img]URL[/img]</code> for images.</p>
                        <textarea name="content" required rows="8" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-purple-500 text-sm resize-y"></textarea>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Link Product ID (Optional)</label>
                            <input type="number" name="product_id" placeholder="e.g. 5" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold outline-none focus:border-purple-500 text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Link Category (Optional)</label>
                            <input type="text" name="category_name" placeholder="e.g. Bypasses" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold outline-none focus:border-purple-500 text-sm">
                        </div>
                    </div>
                    <div class="border-t-2 border-gray-100 pt-4 mt-2">
                        <h3 class="font-black text-gray-800 mb-3">SEO Configuration</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <input type="text" name="seo_title" placeholder="SEO Title Tag" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-purple-500">
                            <input type="text" name="seo_desc" placeholder="SEO Description" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-purple-500">
                            <input type="text" name="seo_keywords" placeholder="Keywords (comma separated)" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-purple-500">
                            <input type="text" name="canonical_url" placeholder="Canonical URL (Optional)" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-purple-500">
                        </div>
                        <input type="url" name="og_image" placeholder="OpenGraph Thumbnail Image URL" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-purple-500">
                    </div>
                    <button type="submit" class="w-full bg-purple-600 text-white py-4 rounded-xl font-black text-sm hover:scale-[1.02] transition shadow-md">Publish Post</button>
                </form>
            </div>
        </div>
    </div>

    <div id="createCatModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex justify-center items-center z-50 p-4">
        <div class="bg-white rounded-3xl w-full max-w-md overflow-hidden shadow-2xl">
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-black text-gray-800">Add Category</h2>
                    <button onclick="document.getElementById('createCatModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 font-black text-xl">&times;</button>
                </div>
                <form action="/admin/add-category" method="POST" class="space-y-3">
                    <input type="text" name="category_name" required placeholder="Category Name" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-gray-800">
                    <input type="text" name="seo_title" placeholder="SEO Title Tag" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-gray-800">
                    <input type="text" name="seo_desc" placeholder="SEO Description" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-gray-800">
                    <input type="text" name="seo_keywords" placeholder="Keywords" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-gray-800">
                    <input type="text" name="canonical_url" placeholder="Canonical URL" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-gray-800">
                    <input type="url" name="og_image" placeholder="Image URL" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-gray-800">
                    <button type="submit" class="w-full bg-gray-800 text-white py-3 rounded-xl font-black text-sm hover:scale-[1.02] transition shadow-md">Save Category</button>
                </form>
            </div>
        </div>
    </div>

    <div id="editCatModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex justify-center items-center z-50 p-4">
        <div class="bg-white rounded-3xl w-full max-w-md overflow-hidden shadow-2xl">
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-black text-gray-800">Edit Category</h2>
                    <button onclick="document.getElementById('editCatModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 font-black text-xl">&times;</button>
                </div>
                <form action="/admin/edit-category" method="POST" class="space-y-3">
                    <input type="hidden" name="original_name" id="editOriginalName">
                    <input type="text" name="category_name" id="editCatName" required placeholder="Category Name" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <input type="text" name="seo_title" id="editSeoTitle" placeholder="SEO Title Tag" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <input type="text" name="seo_desc" id="editSeoDesc" placeholder="SEO Description" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <input type="text" name="seo_keywords" id="editSeoKeywords" placeholder="Keywords" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <input type="text" name="canonical_url" id="editCanonicalUrl" placeholder="Canonical URL" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <input type="url" name="og_image" id="editOgImage" placeholder="Image URL" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-xl font-black text-sm hover:scale-[1.02] transition shadow-md">Update Category</button>
                </form>
            </div>
        </div>
    </div>

    <div id="createAnnModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex justify-center items-center z-50 p-4">
        <div class="bg-white rounded-3xl w-full max-w-md overflow-hidden shadow-2xl">
            <div class="p-6">
                <div class="flex justify-between items-center mb-4">
                    <h2 class="text-xl font-black text-gray-800">Post Announcement</h2>
                    <button onclick="document.getElementById('createAnnModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 font-black text-xl">&times;</button>
                </div>
                <form action="/admin/add-announcement" method="POST" class="space-y-3">
                    <input type="text" name="title" required placeholder="Announcement Title" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <select name="category" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                        <option value="All">All Categories</option>
                        <% categories.forEach(cat => { %><option value="<%= cat.name %>"><%= cat.name %></option><% }) %>
                    </select>
                    <input type="url" name="image1" placeholder="Image URL 1" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <input type="url" name="image2" placeholder="Image URL 2 (Optional)" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500">
                    <textarea name="content" required placeholder="Description..." rows="3" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-2 font-bold text-sm outline-none focus:border-blue-500"></textarea>
                    <button type="submit" class="w-full bg-blue-600 text-white py-3 rounded-xl font-black text-sm hover:scale-[1.02] transition shadow-md">Post Announcement</button>
                </form>
            </div>
        </div>
    </div>

    <div id="createPostModal" class="hidden fixed inset-0 bg-black/50 backdrop-blur-sm flex justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white rounded-3xl w-full max-w-2xl overflow-hidden shadow-2xl my-8">
            <div class="p-6 md:p-8">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-black text-gray-800">Add Product</h2>
                    <button onclick="document.getElementById('createPostModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 font-black text-xl">&times;</button>
                </div>
                <form action="/admin/add-product" method="POST" class="space-y-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Product Title</label>
                            <input type="text" name="title" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Category</label>
                            <select name="category" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                                <% categories.forEach(cat => { %><option value="<%= cat.name %>"><%= cat.name %></option><% }) %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Price ($)</label>
                            <input type="number" step="0.01" name="price" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Tier Override</label>
                            <select name="tier" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                                <option value="Standard">Standard (Auto)</option>
                                <option value="Custom">Custom Method (BTC Only)</option>
                                <option value="Ultra">Ultra ($900+ Auto)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Image URL</label>
                            <input type="url" name="image_url" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Tags (Comma separated)</label>
                            <input type="text" name="tags" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Description</label>
                        <textarea name="description" required rows="4" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm resize-none"></textarea>
                    </div>
                    <button type="submit" class="w-full bg-anime-accent text-white py-4 rounded-xl font-black text-sm hover:scale-[1.02] transition shadow-md">Publish Product</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        function updateOrderStatus(orderId, status) {
            fetch(`/api/order/${orderId}/update`, {
                method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status })
            }).then(() => window.location.reload());
        }

        function openEditCatModal(element) {
            document.getElementById('editOriginalName').value = element.getAttribute('data-name');
            document.getElementById('editCatName').value = element.getAttribute('data-name');
            document.getElementById('editSeoTitle').value = element.getAttribute('data-title');
            document.getElementById('editSeoDesc').value = element.getAttribute('data-desc');
            document.getElementById('editSeoKeywords').value = element.getAttribute('data-keywords');
            document.getElementById('editOgImage').value = element.getAttribute('data-ogimage');
            document.getElementById('editCanonicalUrl').value = element.getAttribute('data-canonical');
            document.getElementById('editCatModal').classList.remove('hidden'); 
        }
    </script>
</body>
</html>
