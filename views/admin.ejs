<!DOCTYPE html>
<html lang="en">
<head>
    <title>Admin - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
    <style>
        .playing-card {
            width: 60px; height: 85px; background: white; border-radius: 8px; border: 1px solid #e2e8f0;
            display: flex; justify-content: center; items-center; font-weight: 900; font-size: 1.5rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); position: relative;
        }
        .card-red { color: #ef4444; }
        .card-black { color: #1f2937; }
        .card-suit-top { position: absolute; top: 4px; left: 6px; font-size: 0.75rem; }
        .card-suit-bottom { position: absolute; bottom: 4px; right: 6px; font-size: 0.75rem; transform: rotate(180deg); }
    </style>
</head>
<body class="p-4 md:p-8 bg-gray-50">
    <div class="max-w-7xl mx-auto relative z-10 mt-6">
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
            <h1 class="text-3xl md:text-4xl font-black text-anime-textMain">ExamHub Admin 🛡️</h1>
            <div class="flex flex-wrap gap-2">
                <button onclick="document.getElementById('createAnnModal').classList.remove('hidden')" class="bg-blue-600 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">📢 Post Announcement</button>
                <button onclick="document.getElementById('createPostModal').classList.remove('hidden')" class="bg-anime-accent text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">+ Create Product</button>
                <a href="/" class="bg-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:bg-anime-pink transition border border-gray-200">View Store</a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
            
            <div class="lg:col-span-2 space-y-6">
                <div class="glass-card p-6">
                    <div class="flex justify-between items-center mb-4 border-b-2 border-dashed border-gray-200 pb-2">
                        <h2 class="text-xl md:text-2xl font-black">Manage Categories</h2>
                        <button onclick="document.getElementById('catModal').classList.remove('hidden')" class="bg-[#00b67a] text-white font-black px-4 py-2 rounded-xl text-sm hover:scale-105 transition">+ Add Category</button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <% categories.forEach(cat => { %>
                            <div class="bg-white border-2 border-gray-200 px-3 py-1.5 rounded-xl flex items-center gap-2 group cursor-pointer hover:border-anime-accent transition shadow-sm"
                                 data-name="<%= cat.name %>" data-title="<%= cat.seo_title || '' %>" data-desc="<%= cat.seo_desc || '' %>"
                                 data-keywords="<%= cat.seo_keywords || '' %>" data-ogimage="<%= cat.og_image || '' %>" data-canonical="<%= cat.canonical_url || '' %>"
                                 onclick="openEditCatModal(this)">
                                <span class="font-bold text-sm"><%= cat.name %></span>
                                <form action="/admin/delete-category" method="POST" class="inline m-0 p-0 ml-1" onsubmit="event.stopPropagation(); return confirm('Are you sure?');">
                                    <input type="hidden" name="category_name" value="<%= cat.name %>">
                                    <button type="submit" class="text-gray-300 hover:text-red-500 font-black">×</button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                    <p class="text-[10px] font-bold text-gray-400 mt-3">* Click on a category pill to open Google SEO settings.</p>
                </div>

                <div class="glass-card p-6">
                    <h2 class="text-xl md:text-2xl font-black mb-4 border-b-2 border-dashed border-gray-200 pb-2">Manage Announcements</h2>
                    <div class="flex flex-col gap-3 max-h-[300px] overflow-y-auto pr-2">
                        <% if (announcements && announcements.length > 0) { %>
                            <% announcements.forEach(ann => { %>
                                <div class="bg-blue-50 border-2 border-blue-100 p-4 rounded-xl flex justify-between items-center group">
                                    <div class="truncate pr-4">
                                        <p class="font-black text-sm text-blue-900 truncate"><%= ann.title %></p>
                                        <p class="text-[10px] font-bold text-blue-500 mt-1 uppercase tracking-wider">Directory: <%= ann.category %></p>
                                    </div>
                                    <div class="flex gap-2">
                                        <button type="button" 
                                            data-id="<%= ann.id %>" data-title="<%= ann.title %>" data-category="<%= ann.category %>"
                                            data-img1="<%= ann.image1 %>" data-img2="<%= ann.image2 %>" data-content="<%= ann.content %>"
                                            onclick="openEditAnnModal(this)"
                                            class="bg-blue-200 text-blue-800 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-blue-500 hover:text-white transition">
                                            Edit
                                        </button>
                                        <form action="/admin/delete-announcement" method="POST" class="inline" onsubmit="return confirm('Delete this announcement?');">
                                            <input type="hidden" name="id" value="<%= ann.id %>">
                                            <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-sm font-bold text-gray-400 text-center py-4">No active announcements.</p>
                        <% } %>
                    </div>
                </div>

                <div class="glass-card p-6">
                    <h2 class="text-xl md:text-2xl font-black mb-4 border-b-2 border-dashed border-gray-200 pb-2">Manage Products</h2>
                    <div class="flex flex-col gap-3 max-h-[400px] overflow-y-auto pr-2">
                        <% if (products && products.length > 0) { %>
                            <% products.forEach(product => { %>
                                <div class="bg-white border-2 border-gray-100 p-4 rounded-xl flex justify-between items-center group">
                                    <div class="truncate pr-4">
                                        <p class="font-black text-sm text-anime-textMain truncate"><%= product.title %></p>
                                        <p class="text-[10px] font-bold text-gray-500 mt-1 uppercase tracking-wider">
                                            <%= product.category %> • $<%= product.price %> • <span class="text-anime-accent"><%= product.tier %></span>
                                        </p>
                                    </div>
                                    <div class="flex gap-2">
                                        <button type="button" 
                                            data-id="<%= product.id %>" data-title="<%= product.title %>" data-category="<%= product.category %>"
                                            data-price="<%= product.price %>" data-tier="<%= product.tier %>" data-platform="<%= product.platform %>"
                                            data-image="<%= product.image_url %>" data-desc="<%= product.description %>"
                                            onclick="openEditPostModal(this)"
                                            class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-blue-500 hover:text-white transition">
                                            Edit
                                        </button>
                                        <form action="/admin/delete-product" method="POST" class="inline" onsubmit="return confirm('Delete this post?');">
                                            <input type="hidden" name="id" value="<%= product.id %>">
                                            <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-sm font-bold text-gray-400 text-center py-4">No active posts.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="space-y-6 lg:row-span-2 lg:col-start-3 lg:row-start-1">
                <div class="bg-white rounded-3xl p-6 shadow-xl border-4 border-anime-skyLight relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-anime-accent to-anime-pink"></div>
                    <h2 class="text-xl font-black mb-4 flex items-center gap-2">
                        <span class="w-3 h-3 bg-red-500 rounded-full animate-pulse"></span> Active Orders
                    </h2>
                    <div class="space-y-4 max-h-[800px] overflow-y-auto pr-2">
                        <% if (orders && orders.length > 0) { %>
                            <% orders.forEach(order => { %>
                                <div class="bg-gray-50 p-4 rounded-xl border-2 border-gray-100 relative group">
                                    <div class="flex justify-between items-start mb-2">
                                        <span class="text-xs font-black bg-anime-textMain text-white px-2 py-0.5 rounded-md">#<%= order.order_id %></span>
                                        <form action="/admin/close-order" method="POST" class="inline">
                                            <input type="hidden" name="order_id" value="<%= order.order_id %>">
                                            <button type="submit" class="text-[10px] bg-red-100 text-red-600 font-black px-2 py-1 rounded-md hover:bg-red-500 hover:text-white transition">Close</button>
                                        </form>
                                    </div>
                                    <p class="text-xs font-bold text-anime-accent truncate mb-0.5">✉️ <%= order.email %></p>
                                    <% if (order.discord_username) { %>
                                        <p class="text-[10px] font-bold text-gray-400 truncate mb-2">🎮 <%= order.discord_username %></p>
                                    <% } else { %> <div class="mb-2"></div> <% } %>
                                    
                                    <div class="flex justify-between items-center mb-2">
                                        <p class="text-xs font-bold text-gray-500 truncate"><%= order.product_title %></p>
                                        <p class="text-sm font-black text-[#00b67a] ml-2">$<%= Number(order.product_price || 0).toFixed(2) %></p>
                                    </div>
                                    <div class="flex gap-2 mb-2">
                                        <span class="text-[10px] bg-gray-200 text-gray-700 font-black px-2 py-0.5 rounded-md"><%= order.tier %></span>
                                        <span class="text-[10px] bg-blue-100 text-blue-700 font-black px-2 py-0.5 rounded-md"><%= order.payment_method %></span>
                                    </div>
                                    <div class="bg-white border border-gray-200 p-2 rounded-lg text-center">
                                        <p class="text-[10px] font-black uppercase text-gray-400 mb-1">Status</p>
                                        <p class="text-xs font-black <%= order.status === 'Pending Payment' ? 'text-yellow-500' : 'text-green-500' %>"><%= order.status %></p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-sm font-bold text-gray-400 text-center py-6">No active orders right now.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-12 bg-[#1a1b26] rounded-3xl p-6 shadow-2xl border-4 border-indigo-900 relative overflow-hidden mb-10 text-white">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-black text-indigo-300">Admin Lounge 🎰</h2>
                <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mt-1 tracking-[0.2em]">Powered by Rainbet</p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <div class="lg:col-span-1">
                    <div class="bg-[#24283b] border-2 border-indigo-500/30 rounded-2xl p-5 hover:border-indigo-400 transition cursor-pointer select-none relative overflow-hidden group" ondblclick="openWalletPopup()">
                        <div class="absolute inset-0 bg-blue-500/10 group-hover:bg-blue-500/20 transition"></div>
                        <div class="relative z-10">
                            <div class="flex justify-between items-center mb-2">
                                <p class="text-xs font-black text-indigo-300 uppercase tracking-wider">Blue Wallet</p>
                                <div class="flex items-center gap-1">
                                    <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                                    <p class="text-[10px] text-gray-400 font-bold uppercase">Live SOL</p>
                                </div>
                            </div>
                            <h3 class="text-3xl font-black mb-1"><span id="solDisplay">0.0000</span> <span class="text-lg text-gray-400">SOL</span></h3>
                            <p class="text-sm font-bold text-green-400">≈ $<span id="usdDisplay">0.00</span> USD</p>
                            <p class="text-[10px] text-gray-500 font-bold mt-4">Double-click to manage virtual funds.</p>
                        </div>
                    </div>

                    <div class="bg-[#24283b] border-2 border-gray-700 rounded-2xl p-5 mt-4">
                        <label class="block text-xs font-black text-gray-400 uppercase tracking-wider mb-2">Place Bet (USD)</label>
                        <div class="flex gap-2">
                            <span class="bg-gray-800 text-gray-400 font-black px-4 py-3 rounded-xl border border-gray-700">$</span>
                            <input type="number" id="betAmountUsd" value="10" min="1" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 font-black text-white outline-none focus:border-indigo-500 transition">
                        </div>
                        <p class="text-[10px] text-gray-500 font-bold mt-2 text-right">≈ <span id="betAmountSol">0.00</span> SOL will be deducted</p>
                        
                        <div class="grid grid-cols-2 gap-2 mt-4">
                            <button onclick="startGame('blackjack')" class="bg-indigo-600 hover:bg-indigo-500 text-white font-black py-3 rounded-xl transition shadow-lg text-sm">Play Blackjack</button>
                            <button onclick="startGame('highlow')" class="bg-purple-600 hover:bg-purple-500 text-white font-black py-3 rounded-xl transition shadow-lg text-sm">Play High/Low</button>
                        </div>
                    </div>
                </div>

                <div class="lg:col-span-2 bg-[#24283b] border-2 border-gray-700 rounded-2xl p-6 flex flex-col justify-center min-h-[300px] relative">
                    
                    <div id="gameIdle" class="text-center">
                        <p class="text-5xl mb-4">🃏</p>
                        <h3 class="text-xl font-black text-gray-400">Select a game and place your bet to start.</h3>
                    </div>

                    <div id="gameBlackjack" class="hidden h-full flex flex-col justify-between">
                        <div class="mb-4">
                            <p class="text-xs font-black text-gray-400 uppercase tracking-wider mb-2">Dealer's Hand (<span id="bjDealerScore">?</span>)</p>
                            <div id="bjDealerCards" class="flex gap-2 flex-wrap min-h-[85px]"></div>
                        </div>
                        
                        <div id="bjResult" class="text-center font-black text-2xl my-4 py-2 rounded-xl hidden"></div>

                        <div class="mt-4">
                            <div class="flex justify-between items-end mb-2">
                                <p class="text-xs font-black text-indigo-300 uppercase tracking-wider">Your Hand (<span id="bjPlayerScore">0</span>)</p>
                                <div id="bjControls" class="flex gap-2">
                                    <button onclick="bjHit()" class="bg-blue-500 hover:bg-blue-400 text-white font-black px-4 py-1.5 rounded-lg text-xs transition">HIT</button>
                                    <button onclick="bjStand()" class="bg-red-500 hover:bg-red-400 text-white font-black px-4 py-1.5 rounded-lg text-xs transition">STAND</button>
                                </div>
                            </div>
                            <div id="bjPlayerCards" class="flex gap-2 flex-wrap min-h-[85px]"></div>
                        </div>
                    </div>

                    <div id="gameHighlow" class="hidden h-full flex flex-col items-center justify-center text-center">
                        <p class="text-xs font-black text-gray-400 uppercase tracking-wider mb-4">Will the next card be higher or lower?</p>
                        <div class="flex gap-8 items-center justify-center mb-8">
                            <div id="hlCurrentCard" class="playing-card flex items-center justify-center text-3xl font-black shadow-2xl scale-125">?</div>
                        </div>
                        <div id="hlResult" class="text-center font-black text-xl mb-6 hidden"></div>
                        <div id="hlControls" class="flex gap-4">
                            <button onclick="hlGuess('higher')" class="bg-green-600 hover:bg-green-500 text-white font-black px-6 py-3 rounded-xl transition shadow-lg w-32 flex flex-col items-center"><span class="text-xl">⬆</span> Higher</button>
                            <button onclick="hlGuess('lower')" class="bg-red-600 hover:bg-red-500 text-white font-black px-6 py-3 rounded-xl transition shadow-lg w-32 flex flex-col items-center"><span class="text-xl">⬇</span> Lower</button>
                        </div>
                        <button id="hlRestart" onclick="startGame('highlow')" class="hidden mt-4 bg-gray-700 hover:bg-gray-600 text-white font-black px-6 py-2 rounded-xl transition text-sm">Play Again</button>
                    </div>

                </div>
            </div>
        </div>

        <div id="walletModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm justify-center items-center z-50 p-4">
            <div class="bg-[#1a1b26] border-2 border-indigo-500 rounded-3xl w-full max-w-sm p-6 shadow-2xl text-white">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-xl font-black text-indigo-300">Blue Wallet Manager</h2>
                    <button onclick="closeWalletPopup()" class="text-gray-500 hover:text-white font-black">✕</button>
                </div>
                
                <div class="mb-4">
                    <label class="block text-xs font-black text-gray-400 uppercase tracking-wider mb-2">Modify Balance (SOL)</label>
                    <input type="number" id="walletModifyInput" step="0.1" placeholder="Enter SOL amount" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 font-black text-white outline-none focus:border-indigo-500">
                </div>
                
                <div class="flex gap-2">
                    <button onclick="modifyWallet('add')" class="w-1/2 bg-green-600 hover:bg-green-500 text-white font-black py-3 rounded-xl transition shadow-md">+ Add</button>
                    <button onclick="modifyWallet('remove')" class="w-1/2 bg-red-600 hover:bg-red-500 text-white font-black py-3 rounded-xl transition shadow-md">- Remove</button>
                </div>
            </div>
        </div>
        </div>

    <div id="createAnnModal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm flex justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white p-6 md:p-8 rounded-2xl w-full max-w-2xl shadow-2xl my-8 border-4 border-blue-400">
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-black text-2xl text-blue-700">📢 Post Blog Announcement</h2>
                <button onclick="document.getElementById('createAnnModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 bg-gray-100 p-2 rounded-full">×</button>
            </div>
            <form action="/admin/add-announcement" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Headline</label>
                    <input type="text" name="title" required placeholder="HUGE UPDATE: New Features..." class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Display in Category (or All)</label>
                    <select name="category" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm appearance-none">
                        <option value="All">All Pages (Global Announcement)</option>
                        <% categories.forEach(cat => { %> <option value="<%= cat.name %>"><%= cat.name %> Only</option> <% }) %>
                    </select>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Image 1 URL</label>
                        <input type="url" name="image1" placeholder="https://..." class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Image 2 URL (Optional)</label>
                        <input type="url" name="image2" placeholder="https://..." class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Blog Content (**bold** and #big# allowed)</label>
                    <textarea name="content" required rows="6" placeholder="Write your announcement here..." class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 resize-none text-sm"></textarea>
                </div>
                <div class="flex justify-end gap-2 mt-4 pt-4 border-t-2 border-dashed border-gray-100">
                    <button type="button" onclick="document.getElementById('createAnnModal').classList.add('hidden')" class="text-gray-500 font-bold px-4 py-2 hover:bg-gray-100 rounded-xl">Cancel</button>
                    <button type="submit" class="bg-blue-600 text-white font-black px-6 py-2 rounded-xl shadow-md hover:scale-105 transition">Publish Post</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editAnnModal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm flex justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white p-6 md:p-8 rounded-2xl w-full max-w-2xl shadow-2xl my-8 border-4 border-yellow-400">
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-black text-2xl text-yellow-700">✏️ Edit Announcement</h2>
                <button onclick="document.getElementById('editAnnModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 bg-gray-100 p-2 rounded-full">×</button>
            </div>
            <form action="/admin/edit-announcement" method="POST" class="space-y-4">
                <input type="hidden" name="id" id="editAnnId">
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Headline</label>
                    <input type="text" name="title" id="editAnnTitle" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-yellow-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Category</label>
                    <select name="category" id="editAnnCategory" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-yellow-500 text-sm appearance-none">
                        <option value="All">All Pages</option>
                        <% categories.forEach(cat => { %> <option value="<%= cat.name %>"><%= cat.name %> Only</option> <% }) %>
                    </select>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Image 1 URL</label>
                        <input type="url" name="image1" id="editAnnImg1" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-yellow-500 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Image 2 URL</label>
                        <input type="url" name="image2" id="editAnnImg2" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-yellow-500 text-sm">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Content</label>
                    <textarea name="content" id="editAnnContent" required rows="6" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-yellow-500 resize-none text-sm"></textarea>
                </div>
                <div class="flex justify-end gap-2 mt-4 pt-4 border-t-2 border-dashed border-gray-100">
                    <button type="button" onclick="document.getElementById('editAnnModal').classList.add('hidden')" class="text-gray-500 font-bold px-4 py-2 hover:bg-gray-100 rounded-xl">Cancel</button>
                    <button type="submit" class="bg-yellow-500 text-white font-black px-6 py-2 rounded-xl shadow-md hover:scale-105 transition">Save Changes</button>
                </div>
            </form>
        </div>
    </div>

    <div id="createPostModal" class="hidden fixed inset-0 bg-black/40 backdrop-blur-sm flex justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white p-6 md:p-8 rounded-2xl w-full max-w-2xl shadow-2xl my-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-black text-2xl text-anime-textMain">Create New Product ✨</h2>
