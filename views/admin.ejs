<!DOCTYPE html>
<html lang="en">
<head>
    <title>Admin - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
    <style>
        .stat-card { transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.2s; }
        .stat-card:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1); }
        .post-card, .order-card, .product-card { transition: all 0.2s ease; }
        .post-card:hover, .product-card:hover { border-color: #a855f7; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
        .modal { animation: modalPop 0.2s ease-out forwards; }
        @keyframes modalPop { from { opacity: 0; transform: scale(0.95) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
        .activity-item { transition: background-color 0.1s ease; }
        .activity-item:hover { background-color: #f8fafc; }
    </style>
</head>
<body class="p-4 md:p-8 bg-gray-50">
    <div class="max-w-7xl mx-auto relative z-10 mt-6">
        
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4 border-b-2 border-gray-200 pb-6">
            <div>
                <h1 class="text-3xl md:text-4xl font-black text-anime-textMain">ExamHub Admin 🛡️</h1>
                <p class="text-sm text-gray-500 font-bold mt-1">Manage content, orders & licenses</p>
            </div>
            <div class="flex flex-wrap gap-2">
                <button onclick="document.getElementById('createAnnModal').classList.remove('hidden')" class="bg-blue-600 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition flex items-center gap-2">📢 Announcement</button>
                <button onclick="document.getElementById('createPostModal').classList.remove('hidden')" class="bg-anime-accent text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition flex items-center gap-2">+ Product</button>
                <a href="/admin/whitelist" class="bg-blue-600 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition flex items-center gap-2">✅ Whitelist</a>
                <a href="/admin/casino" class="bg-[#00b67a] text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition flex items-center gap-2">🎰 Casino Lounge</a>
                <a href="/logout" class="bg-red-500 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:bg-red-600 transition">Logout</a>
            </div>
        </div>

        <!-- STATS DASHBOARD -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
            <div class="stat-card bg-white rounded-3xl p-5 shadow-sm border-2 border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black uppercase tracking-widest text-gray-500">TOTAL USERS</p>
                        <p class="text-4xl font-black text-gray-900 mt-1"><%= typeof userCount !== 'undefined' ? userCount : 0 %></p>
                    </div>
                    <div class="text-4xl opacity-80">👥</div>
                </div>
                <p class="text-[10px] text-gray-400 font-bold mt-3">Registered accounts</p>
            </div>

            <div class="stat-card bg-white rounded-3xl p-5 shadow-sm border-2 border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black uppercase tracking-widest text-gray-500">PRODUCTS</p>
                        <p class="text-4xl font-black text-gray-900 mt-1"><%= products ? products.length : 0 %></p>
                    </div>
                    <div class="text-4xl opacity-80">🛍️</div>
                </div>
                <p class="text-[10px] text-gray-400 font-bold mt-3">Active listings</p>
            </div>

            <div class="stat-card bg-white rounded-3xl p-5 shadow-sm border-2 border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black uppercase tracking-widest text-gray-500">BLOG POSTS</p>
                        <p class="text-4xl font-black text-gray-900 mt-1"><%= posts ? posts.length : 0 %></p>
                    </div>
                    <div class="text-4xl opacity-80">📝</div>
                </div>
                <p class="text-[10px] text-gray-400 font-bold mt-3">Published articles</p>
            </div>

            <div class="stat-card bg-white rounded-3xl p-5 shadow-sm border-2 border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black uppercase tracking-widest text-gray-500">ORDERS</p>
                        <p class="text-4xl font-black text-gray-900 mt-1"><%= orders ? orders.length : 0 %></p>
                    </div>
                    <div class="text-4xl opacity-80">📦</div>
                </div>
                <% let pendingCount = orders ? orders.filter(o => o.status !== 'Completed' && o.status !== 'Closed').length : 0; %>
                <span class="inline-block mt-1 px-2.5 py-0.5 rounded-full text-[10px] font-black bg-amber-100 text-amber-700"><%= pendingCount %> pending</span>
            </div>

            <div class="stat-card bg-white rounded-3xl p-5 shadow-sm border-2 border-gray-100">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="text-xs font-black uppercase tracking-widest text-gray-500">CATEGORIES</p>
                        <p class="text-4xl font-black text-gray-900 mt-1"><%= categories ? categories.length : 0 %></p>
                    </div>
                    <div class="text-4xl opacity-80">🗂️</div>
                </div>
                <p class="text-[10px] text-gray-400 font-bold mt-3">Organized sections</p>
            </div>
        </div>

        <!-- LATEST ACTIVITY -->
        <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100 mb-8">
            <div class="flex items-center justify-between mb-4 border-b-2 border-dashed border-gray-200 pb-3">
                <h2 class="text-xl font-black text-gray-800 flex items-center gap-2">⚡ Latest Activity</h2>
                <span class="text-xs font-bold text-gray-400">Recent posts & orders</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <p class="text-xs font-black uppercase tracking-widest text-purple-600 mb-2 px-1">RECENT POSTS</p>
                    <% if (posts && posts.length > 0) { posts.slice(0,4).forEach(post => { %>
                        <div class="activity-item flex items-center justify-between gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 text-sm">
                            <div class="flex-1 min-w-0">
                                <p class="font-black text-gray-800 truncate"><%= post.title %></p>
                                <p class="text-[10px] text-gray-400 font-bold"><%= new Date(post.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %></p>
                            </div>
                            <a href="/post/<%= post.id %>" target="_blank" class="text-purple-600 hover:text-purple-700 text-xs font-black">View →</a>
                        </div>
                    <% }) } else { %><p class="text-sm text-gray-400 font-bold px-3 py-2">No posts yet.</p><% } %>
                </div>

                <div>
                    <p class="text-xs font-black uppercase tracking-widest text-emerald-600 mb-2 px-1">RECENT ORDERS</p>
                    <% if (orders && orders.length > 0) { orders.slice(0,4).forEach(order => { %>
                        <div class="activity-item flex items-center justify-between gap-3 px-3 py-2.5 rounded-xl hover:bg-gray-50 text-sm">
                            <div class="flex-1 min-w-0">
                                <p class="font-black text-gray-800 truncate"><%= order.product_title || 'Unknown Product' %></p>
                                <div class="flex items-center gap-2 text-[10px]">
                                    <span class="font-bold text-gray-400"><%= new Date(order.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %></span>
                                    <span class="px-1.5 py-px rounded bg-gray-200 text-gray-600 font-black text-[9px]"><%= order.status %></span>
                                </div>
                            </div>
                            <span class="text-emerald-600 text-xs font-black">#<%= order.order_id %></span>
                        </div>
                    <% }) } else { %><p class="text-sm text-gray-400 font-bold px-3 py-2">No orders yet.</p><% } %>
                </div>
            </div>
        </div>

        <!-- MAIN GRIDS -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            
            <!-- Manage Blog Posts (with Edit) -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <div class="flex justify-between items-center mb-4 border-b-2 border-dashed border-gray-200 pb-2">
                    <div>
                        <h2 class="text-xl md:text-2xl font-black text-gray-800">Manage Blog Posts</h2>
                        <p class="text-xs text-gray-500 font-bold">Create, edit & optimize SEO content</p>
                    </div>
                    <button onclick="document.getElementById('createBlogPostModal').classList.remove('hidden')" class="bg-purple-600 text-white font-black px-5 py-2 rounded-xl text-sm hover:scale-105 transition flex items-center gap-2">+ Create Post</button>
                </div>
                
                <div class="flex flex-col gap-3 max-h-[380px] overflow-y-auto pr-2">
                    <% if (typeof posts !== 'undefined' && posts.length > 0) { %>
                        <% posts.forEach(post => { %>
                            <div class="post-card bg-gray-50 border-2 border-gray-100 p-4 rounded-2xl flex flex-col md:flex-row justify-between md:items-center gap-3 group">
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-2 mb-1">
                                        <h3 class="font-black text-gray-800 text-sm leading-tight"><%= post.title %></h3>
                                        <% if (post.created_at) { %>
                                            <span class="text-[10px] font-black px-2 py-0.5 rounded-full bg-purple-100 text-purple-700 whitespace-nowrap">
                                                <%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <p class="text-xs text-gray-500 font-bold">SEO: <%= post.seo_title || 'Not set' %></p>
                                    <% if (post.category_name) { %><span class="inline-block mt-1 text-[10px] px-2 py-px rounded bg-gray-200 text-gray-600 font-black"><%= post.category_name %></span><% } %>
                                </div>
                                
                                <div class="flex gap-2 opacity-80 group-hover:opacity-100 transition">
                                    <button onclick="openEditPostModal(this)"
                                            data-id="<%= post.id %>"
                                            data-title="<%= post.title ? post.title.replace(/"/g, '&quot;') : '' %>"
                                            data-content="<%= post.content ? post.content.replace(/"/g, '&quot;') : '' %>"
                                            data-category_name="<%= post.category_name || '' %>"
                                            data-product_id="<%= post.product_id || '' %>"
                                            data-seo_title="<%= post.seo_title || '' %>"
                                            data-seo_desc="<%= post.seo_desc || '' %>"
                                            data-seo_keywords="<%= post.seo_keywords || '' %>"
                                            data-og_image="<%= post.og_image || '' %>"
                                            data-canonical="<%= post.canonical_url || '' %>"
                                            class="bg-blue-100 hover:bg-blue-500 hover:text-white text-blue-600 px-4 py-1.5 rounded-xl text-xs font-black transition flex items-center gap-1">
                                        ✏️ Edit
                                    </button>
                                    
                                    <form action="/admin/delete-post" method="POST" onsubmit="return confirm('Delete this post permanently?');">
                                        <input type="hidden" name="id" value="<%= post.id %>">
                                        <button type="submit" class="bg-red-100 text-red-600 px-4 py-1.5 rounded-xl text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                    </form>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="text-center py-8"><p class="text-sm font-bold text-gray-400">No blog posts yet.</p></div>
                    <% } %>
                </div>
            </div>

            <!-- Manage Categories -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <div class="flex justify-between items-center mb-4 border-b-2 border-dashed border-gray-200 pb-2">
                    <h2 class="text-xl md:text-2xl font-black text-gray-800">Manage Categories</h2>
                    <button onclick="document.getElementById('createCatModal').classList.remove('hidden')" class="bg-gray-800 text-white font-black px-4 py-2 rounded-xl text-sm hover:scale-105 transition">+ Category</button>
                </div>
                <div class="flex flex-col gap-3 max-h-[380px] overflow-y-auto pr-2">
                    <% categories.forEach(cat => { %>
                        <div class="bg-gray-50 border-2 border-gray-100 p-4 rounded-xl flex justify-between items-center group">
                            <div>
                                <h3 class="font-black text-gray-800 text-sm"><%= cat.name %></h3>
                                <p class="text-xs text-gray-500 font-bold mt-1"><%= cat.seo_desc || 'No SEO desc' %></p>
                            </div>
                            <div class="flex gap-2 opacity-0 group-hover:opacity-100 transition">
                                <button onclick="openEditCatModal(this)" data-name="<%= cat.name %>" data-title="<%= cat.seo_title %>" data-desc="<%= cat.seo_desc %>" data-keywords="<%= cat.seo_keywords %>" data-ogimage="<%= cat.og_image %>" data-canonical="<%= cat.canonical_url %>" class="bg-blue-100 text-blue-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-blue-500 hover:text-white transition">Edit</button>
                                <form action="/admin/delete-category" method="POST" onsubmit="return confirm('Delete this category?');">
                                    <input type="hidden" name="category_name" value="<%= cat.name %>">
                                    <button type="submit" class="bg-red-100 text-red-600 px-3 py-1.5 rounded-lg text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <!-- Orders + Products Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mt-6">
            <!-- Active Orders Omitted for Brevity - Keeps Original Code -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <h2 class="text-xl md:text-2xl font-black text-gray-800 mb-4 border-b-2 border-dashed border-gray-200 pb-2">Active Orders</h2>
                <div class="flex flex-col gap-3 max-h-[420px] overflow-y-auto pr-2">
                    <% orders.forEach(order => { %>
                        <div class="order-card bg-gray-50 border-2 border-gray-100 p-4 rounded-2xl">
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <div class="flex items-center gap-2">
                                        <span class="text-xs font-bold text-gray-400">ID: <%= order.order_id %></span>
                                        <% if (order.created_at) { %><span class="text-[10px] font-black px-2 py-px rounded-full bg-gray-200 text-gray-600"><%= new Date(order.created_at).toLocaleDateString('en-US', {month:'short', day:'numeric'}) %></span><% } %>
                                    </div>
                                    <h3 class="font-black text-gray-800"><%= order.product_title || 'Unknown Product' %></h3>
                                </div>
                                <span class="text-[10px] font-black uppercase tracking-widest px-2.5 py-1 rounded-full bg-gray-200 text-gray-600"><%= order.status %></span>
                            </div>
                            <div class="text-xs font-bold text-gray-500 space-y-1 mb-3">
                                <p>Email: <span class="text-anime-accent"><%= order.email %></span></p>
                                <% if(order.discord_username) { %><p>Discord: <span class="text-anime-textMain"><%= order.discord_username %></span></p><% } %>
                                <p>Method: <%= order.payment_method %> (<%= order.tier %>)</p>
                                <% if(order.giftcard_code) { %><p class="text-red-500 break-all">Code: <%= order.giftcard_code %></p><% } %>
                            </div>
                            <div class="flex gap-2 border-t-2 border-gray-200 pt-3">
                                <button onclick="updateOrderStatus('<%= order.order_id %>', 'Completed')" class="flex-1 bg-green-100 text-green-600 py-2 rounded-xl text-xs font-black hover:bg-green-500 hover:text-white transition">Mark Complete</button>
                                <form action="/admin/close-order" method="POST" class="flex-1" onsubmit="return confirm('Close this order?');">
                                    <input type="hidden" name="order_id" value="<%= order.order_id %>">
                                    <button type="submit" class="w-full bg-red-100 text-red-600 py-2 rounded-xl text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>

            <!-- Active Products -->
            <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
                <div class="flex justify-between items-center mb-4 border-b-2 border-dashed border-gray-200 pb-2">
                    <h2 class="text-xl md:text-2xl font-black text-gray-800">Active Products</h2>
                    <button onclick="document.getElementById('createPostModal').classList.remove('hidden')" class="bg-anime-accent text-white font-black px-4 py-2 rounded-xl text-sm hover:scale-105 transition">+ Add Product</button>
                </div>
                
                <div class="flex flex-col gap-3 max-h-[420px] overflow-y-auto pr-2">
                    <% products.forEach(product => { %>
                        <div class="product-card bg-gray-50 border-2 border-gray-100 p-4 rounded-2xl flex flex-col md:flex-row justify-between md:items-center gap-3 group">
                            <div class="flex-1 min-w-0">
                                <h3 class="font-black text-gray-800 text-sm"><%= product.title %></h3>
                                <p class="text-xs text-gray-500 font-bold mt-1">$<%= product.price %> • <%= product.category %></p>
                                <% if (product.tier && product.tier !== 'Standard') { %>
                                    <span class="text-[10px] px-2 py-0.5 rounded-full bg-amber-100 text-amber-700 font-black"><%= product.tier %></span>
                                <% } %>
                                <% if (product.tags) { %>
                                    <p class="text-[10px] text-gray-400 mt-0.5 font-bold truncate">Tags: <%= product.tags %></p>
                                <% } %>
                            </div>
                            
                            <div class="flex gap-2 opacity-80 group-hover:opacity-100 transition md:opacity-100">
                                <button onclick="openEditProductModal(this)"
                                        data-id="<%= product.id %>"
                                        data-title="<%= product.title ? product.title.replace(/"/g, '&quot;') : '' %>"
                                        data-category="<%= product.category || '' %>"
                                        data-price="<%= product.price || '' %>"
                                        data-tier="<%= product.tier || 'Standard' %>"
                                        data-image_url="<%= product.image_url || '' %>"
                                        data-tags="<%= product.tags || '' %>"
                                        data-description="<%= product.description ? product.description.replace(/"/g, '&quot;') : '' %>"
                                        class="bg-blue-100 hover:bg-blue-500 hover:text-white text-blue-600 px-4 py-1.5 rounded-xl text-xs font-black transition flex items-center gap-1">
                                    ✏️ Edit
                                </button>
                                
                                <form action="/admin/delete-product" method="POST" onsubmit="return confirm('Delete this product permanently?');">
                                    <input type="hidden" name="id" value="<%= product.id %>">
                                    <button type="submit" class="bg-red-100 text-red-600 px-4 py-1.5 rounded-xl text-xs font-black hover:bg-red-500 hover:text-white transition">Delete</button>
                                </form>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>
    </div>

    <!-- CREATE BLOG POST MODAL (WITH JSON IMPORT TABS) -->
    <div id="createBlogPostModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex justify-center items-start z-50 p-4 pt-12 pb-20 overflow-y-auto">
        <div class="bg-white rounded-3xl w-full max-w-3xl overflow-hidden shadow-2xl shrink-0 modal">
            <div class="p-6 md:p-8">
                <div class="flex justify-between items-center mb-6 border-b-2 border-gray-100 pb-4">
                    <div>
                        <h2 class="text-2xl font-black text-gray-800">Create New Post</h2>
                        <p class="text-sm text-gray-500 font-bold">Write content • Link products • Optimize SEO</p>
                    </div>
                    <div class="flex items-center gap-2">
                        <button type="button" onclick="switchBlogTab('manual')" id="tabManualBtn" class="text-sm font-black bg-purple-100 text-purple-700 px-3 py-1.5 rounded-lg transition">Manual Entry</button>
                        <button type="button" onclick="switchBlogTab('json')" id="tabJsonBtn" class="text-sm font-black text-gray-500 hover:bg-gray-100 px-3 py-1.5 rounded-lg transition">JSON Import</button>
                        <button onclick="document.getElementById('createBlogPostModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 font-black text-3xl leading-none ml-2">&times;</button>
                    </div>
                </div>
                
                <!-- JSON IMPORT VIEW -->
                <div id="jsonImportView" class="hidden space-y-4">
                    <p class="text-sm text-gray-600 font-bold">Paste a JSON object to instantly map your post data. Body content supports Markdown format (e.g. <code>**bold**</code>, <code>## titles</code>).</p>
                    <textarea id="jsonImportInput" rows="14" class="w-full bg-gray-900 text-green-400 font-mono text-xs p-5 rounded-2xl outline-none border-2 border-transparent focus:border-purple-500 shadow-inner resize-y" placeholder='{
  "title": "My SEO Blog Post",
  "content": "## Main Topic\n\nThis is **bold** text and here is my content.",
  "seo_title": "My SEO Blog Post | Hub",
  "seo_desc": "Detailed explanation of the topic for search engines",
  "seo_keywords": "seo, blog, post",
  "canonical_url": "https://examhub.com/post/my-post",
  "og_image": "https://example.com/image.jpg"
}'></textarea>
                    <button type="button" onclick="processJsonImport()" class="w-full bg-gray-800 hover:bg-black text-white py-4 rounded-2xl font-black text-sm shadow-md transition flex items-center justify-center gap-2">
                        Parse & Auto-Fill Form
                    </button>
                </div>

                <!-- MANUAL ENTRY FORM (Default) -->
                <form id="manualEntryForm" action="/admin/add-post" method="POST" class="space-y-5">
                    <div>
                        <label class="block text-sm font-black mb-1.5 text-gray-600">Headline Title</label>
                        <input type="text" id="createPostInputTitle" name="title" required placeholder="e.g. How to Ace Your Final Exam with AI" class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-3.5 font-bold outline-none focus:border-purple-500 text-sm">
                    </div>

                    <div>
                        <label class="block text-sm font-black mb-1.5 text-gray-600">Article Content</label>
                        <p class="text-xs text-gray-400 mb-2 font-bold">Use <code class="bg-purple-100 text-purple-600 px-1.5 rounded">[product]</code> to embed a product. Supports Markdown <code class="bg-gray-200 px-1.5 rounded">**bold**</code> <code class="bg-gray-200 px-1.5 rounded">## header</code></p>
                        <textarea id="createPostInputContent" name="content" required rows="9" placeholder="Start writing your guide..." class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-5 py-4 font-bold outline-none focus:border-purple-500 text-sm resize-y"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pt-2">
                        <div class="relative dropdown-container">
                            <label class="block text-sm font-black mb-1.5 text-gray-600">Link Product (optional)</label>
                            <input type="hidden" name="product_id" id="selectedProductId">
                            <input type="text" id="productSearchInput" placeholder="Search products..." class="w-full bg-gray-50 border-2 border-gray-100 rounded-2xl px-4 py-3 font-bold outline-none focus:border-purple-500 text-sm" onfocus="document.getElementById('productDropdown').classList.remove('hidden')" onkeyup="filterDropdown('productSearchInput', 'productDropdown')">
                            <ul id="productDropdown" class="hidden absolute z-50 w-full bg-white border-2 border-gray-100 rounded-2xl mt-1 max-h-44 overflow-y-auto shadow-xl text-sm">
                                <li onclick="selectItem('selectedProductId', 'productSearchInput', 'productDropdown', '', 'None')" class="px-4 py-3 hover:bg-gray-100 cursor-pointer text-sm font-bold text-gray-500">None</li>
