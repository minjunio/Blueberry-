                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Product Title</label>
                            <input type="text" name="title" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Category</label>
                            <select name="category" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                                <% if (typeof categories !== 'undefined') { categories.forEach(cat => { %><option value="<%= cat.name %>"><%= cat.name %></option><% }) } %>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Price ($)</label>
                            <input type="number" step="0.01" name="price" required class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Tier Override</label>
                            <select name="tier" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                                <option value="Standard">Standard (Auto)</option>
                                <option value="Custom">Custom Method (BTC Only)</option>
                                <option value="Ultra">Ultra ($900+ Auto)</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Image URL</label>
                            <input type="url" name="image_url" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                        <div>
                            <label class="block text-sm font-black mb-1 text-gray-600">Tags (Comma separated)</label>
                            <input type="text" name="tags" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm">
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Description</label>
                        <textarea name="description" required rows="4" class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm resize-none"></textarea>
                    </div>
                    <button type="submit" class="w-full bg-anime-accent text-white py-4 rounded-xl font-black text-sm hover:scale-[1.02] transition shadow-md mt-4">Publish Product</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        function filterDropdown(inputId, dropdownId) {
            const filter = document.getElementById(inputId).value.toUpperCase();
            const ul = document.getElementById(dropdownId);
            if (!ul) return;
            const li = ul.getElementsByTagName("li");
            for (let i = 0; i < li.length; i++) {
                const txtValue = li[i].textContent || li[i].innerText;
                li[i].style.display = txtValue.toUpperCase().indexOf(filter) > -1 ? "" : "none";
            }
        }

        function selectItem(hiddenInputId, searchInputId, dropdownId, value, displayTitle) {
            const hidden = document.getElementById(hiddenInputId);
            const search = document.getElementById(searchInputId);
            const dropdown = document.getElementById(dropdownId);
            if (hidden) hidden.value = value;
            if (search) search.value = displayTitle;
            if (dropdown) dropdown.classList.add('hidden');
        }

        document.addEventListener('click', function(event) {
            if (!event.target.closest('.dropdown-container')) {
                document.querySelectorAll('#productDropdown, #categoryDropdown, #editProductDropdown, #editCategoryDropdown').forEach(d => d && d.classList.add('hidden'));
            }
        });

        function updateOrderStatus(orderId, status) {
            fetch(`/api/order/${orderId}/update`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            }).then(() => window.location.reload());
        }

        function openEditCatModal(element) {
            document.getElementById('editOriginalName').value = element.getAttribute('data-name');
            document.getElementById('editCatName').value = element.getAttribute('data-name');
            document.getElementById('editSeoTitle').value = element.getAttribute('data-title') || '';
            document.getElementById('editSeoDesc').value = element.getAttribute('data-desc') || '';
            document.getElementById('editSeoKeywords').value = element.getAttribute('data-keywords') || '';
            document.getElementById('editOgImage').value = element.getAttribute('data-ogimage') || '';
            document.getElementById('editCanonicalUrl').value = element.getAttribute('data-canonical') || '';
            document.getElementById('editCatModal').classList.remove('hidden');
        }

        function openEditPostModal(element) {
            const modal = document.getElementById('editPostModal');
            document.getElementById('editPostId').value = element.getAttribute('data-id');
            document.getElementById('editPostTitle').value = element.getAttribute('data-title') || '';
            document.getElementById('editPostContent').value = element.getAttribute('data-content') || '';
            
            const prodId = element.getAttribute('data-product_id') || '';
            document.getElementById('editSelectedProductId').value = prodId;
            document.getElementById('editProductSearchInput').value = prodId ? 'Linked Product' : '';
            
            const catName = element.getAttribute('data-category_name') || '';
            document.getElementById('editSelectedCategoryName').value = catName;
            document.getElementById('editCategorySearchInput').value = catName;
            
            document.getElementById('editSeoTitle').value = element.getAttribute('data-seo_title') || '';
            document.getElementById('editSeoDesc').value = element.getAttribute('data-seo_desc') || '';
            document.getElementById('editSeoKeywords').value = element.getAttribute('data-seo_keywords') || '';
            document.getElementById('editOgImage').value = element.getAttribute('data-og_image') || '';
            document.getElementById('editCanonicalUrl').value = element.getAttribute('data-canonical') || '';
            
            modal.classList.remove('hidden');
            setTimeout(() => { document.getElementById('editPostTitle').focus(); document.getElementById('editPostTitle').select(); }, 300);
        }

        function openEditProductModal(element) {
            const modal = document.getElementById('editProductModal');
            
            document.getElementById('editProductId').value = element.getAttribute('data-id');
            document.getElementById('editProductTitle').value = element.getAttribute('data-title') || '';
            document.getElementById('editProductPrice').value = element.getAttribute('data-price') || '';
            document.getElementById('editProductImage').value = element.getAttribute('data-image_url') || '';
            document.getElementById('editProductTags').value = element.getAttribute('data-tags') || '';
            document.getElementById('editProductDescription').value = element.getAttribute('data-description') || '';
            
            const tierSelect = document.getElementById('editProductTier');
            const tierValue = element.getAttribute('data-tier') || 'Standard';
            tierSelect.value = tierValue;
            
            const catSelect = document.getElementById('editProductCategory');
            const catValue = element.getAttribute('data-category') || '';
            if (catValue) {
                for (let i = 0; i < catSelect.options.length; i++) {
                    if (catSelect.options[i].value === catValue) {
                        catSelect.selectedIndex = i;
                        break;
                    }
                }
            }
            
            modal.classList.remove('hidden');
            
            setTimeout(() => {
                document.getElementById('editProductTitle').focus();
                document.getElementById('editProductTitle').select();
            }, 300);
        }

        // ========== CLEANED TEMPLATE GENERATOR ==========
        function generateBlogFromTemplate() {
            const productId = document.getElementById('selectedProductId').value;
            const productSearch = document.getElementById('productSearchInput').value;
            const templateCode = document.getElementById('templateCodeInput').value.trim();
            const contentTextarea = document.getElementById('blogContentTextarea');
            
            if (!productId || productId === '' || productSearch === 'None' || productSearch === '') {
                alert('⚠️ Please select a product from the dropdown first to use the template generator.');
                document.getElementById('productSearchInput').focus();
                document.getElementById('productSearchInput').classList.add('border-red-400');
                setTimeout(() => document.getElementById('productSearchInput').classList.remove('border-red-400'), 1400);
                return;
            }
            
            const productTitle = productSearch.replace(/\s*\(\\( [\d.]+\) \)/, '').trim();
            const priceMatch = productSearch.match(/\$([\d.]+)/);
            const productPrice = priceMatch ? priceMatch[1] : '49.00';
            
            const keywords = templateCode || 'undetectable, AI exam help, proctor bypass';
            const keywordList = keywords.split(',').map(k => k.trim()).filter(Boolean);
            
            const generatedContent = `## How ${productTitle} Helps You Pass Proctored Exams Undetected

