<!DOCTYPE html>
<html lang="en">
<head>
    <title>Admin Terminal - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
    <style>
        /* Professional Casino Theme */
        .casino-dark { background: #0f172a; color: #f8fafc; border-color: #10b981; }
        .casino-dark .casino-panel { background: #1e293b; border-color: #334155; }
        .casino-dark .casino-input { background: #0f172a; border-color: #334155; color: white; }
        .casino-dark .casino-btn { background: #334155; border-color: #475569; color: white; }
        .casino-dark .casino-btn:hover { background: #475569; }
        .casino-dark .casino-tab.active { border-bottom: 2px solid #10b981; color: #10b981; }
        .casino-dark .text-muted { color: #94a3b8; }

        .casino-light { background: #f8fafc; color: #0f172a; border-color: #10b981; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.1); }
        .casino-light .casino-panel { background: #ffffff; border-color: #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }
        .casino-light .casino-input { background: #f1f5f9; border-color: #cbd5e1; color: #0f172a; }
        .casino-light .casino-btn { background: #f1f5f9; border-color: #cbd5e1; color: #0f172a; }
        .casino-light .casino-btn:hover { background: #e2e8f0; }
        .casino-light .casino-tab.active { border-bottom: 2px solid #10b981; color: #059669; }
        .casino-light .text-muted { color: #64748b; }

        /* Smooth UI Elements */
        .casino-tab { padding: 0.75rem 1.25rem; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; transition: all 0.3s; white-space: nowrap; }
        .casino-tab:hover { opacity: 0.8; }
        
        /* CSS Playing Cards (No External Images) */
        .playing-card {
            width: 70px; height: 100px; background: white; border-radius: 6px; border: 1px solid #cbd5e1;
            display: flex; justify-content: center; align-items: center; font-weight: 900; font-size: 1.75rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.2); position: relative; flex-shrink: 0; cursor: default;
            color: #0f172a; transition: transform 0.2s;
        }
        .card-red { color: #ef4444 !important; }
        .card-black { color: #0f172a !important; }
        .card-suit-top { position: absolute; top: 4px; left: 6px; font-size: 0.85rem; }
        .card-suit-bottom { position: absolute; bottom: 4px; right: 6px; font-size: 0.85rem; transform: rotate(180deg); }
        .card-held { transform: translateY(-10px); border: 2px solid #10b981; box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.4); }
        .card-hidden { background: #1e293b; background-image: repeating-linear-gradient(45deg, #334155 25%, transparent 25%, transparent 75%, #334155 75%, #334155), repeating-linear-gradient(45deg, #334155 25%, #1e293b 25%, #1e293b 75%, #334155 75%, #334155); background-position: 0 0, 10px 10px; background-size: 20px 20px; border-color: #475569; }

        @media (max-width: 640px) {
            .playing-card { width: 50px; height: 75px; font-size: 1.25rem; }
            .card-suit-top, .card-suit-bottom { font-size: 0.65rem; top: 3px; left: 4px; right: 4px; bottom: 3px; }
            .card-held { transform: translateY(-5px); }
        }

        /* Animations */
        @keyframes dealIn { 0% { transform: translateY(-30px) scale(0.8) rotateY(90deg); opacity: 0; } 100% { transform: translateY(0) scale(1) rotateY(0deg); opacity: 1; } }
        .anim-deal { animation: dealIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
        @keyframes floatMoney { 0% { transform: translateY(0) scale(1); opacity: 1; } 100% { transform: translateY(-40px) scale(1.1); opacity: 0; } }
        .anim-money { animation: floatMoney 1.2s ease-out forwards; position: absolute; right: 10px; top: -10px; font-weight: 900; font-size: 1.1rem; pointer-events: none; z-index: 50; }
    </style>
</head>
<body class="p-4 md:p-8 bg-gray-50 antialiased">
    
    <div class="max-w-7xl mx-auto relative z-10 mt-6">
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4">
            <h1 class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight">System Admin</h1>
            <div class="flex flex-wrap gap-2">
                <button onclick="document.getElementById('createAnnModal').classList.remove('hidden')" class="bg-gray-900 text-white px-5 py-2 rounded-lg font-black shadow-sm text-sm hover:bg-gray-800 transition">Post Announcement</button>
                <button onclick="document.getElementById('createPostModal').classList.remove('hidden')" class="bg-blue-600 text-white px-5 py-2 rounded-lg font-black shadow-sm text-sm hover:bg-blue-500 transition">Create Product</button>
                <a href="/" class="bg-white px-5 py-2 rounded-lg font-black shadow-sm text-sm hover:bg-gray-50 transition border border-gray-200 text-gray-700">View Storefront</a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">
                    <div class="flex justify-between items-center mb-4 border-b border-gray-100 pb-3">
                        <h2 class="text-lg font-black text-gray-800 uppercase tracking-wider">Directories</h2>
                        <button onclick="document.getElementById('catModal').classList.remove('hidden')" class="bg-[#10b981] text-white font-black px-4 py-1.5 rounded-md text-xs transition hover:opacity-90">Add Directory</button>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <% categories.forEach(cat => { %>
                            <div class="bg-gray-50 border border-gray-200 px-3 py-1.5 rounded-md flex items-center gap-2 group cursor-pointer hover:border-gray-400 transition"
                                 data-name="<%= cat.name %>" data-title="<%= cat.seo_title || '' %>" data-desc="<%= cat.seo_desc || '' %>"
                                 data-keywords="<%= cat.seo_keywords || '' %>" data-ogimage="<%= cat.og_image || '' %>" data-canonical="<%= cat.canonical_url || '' %>"
                                 onclick="openEditCatModal(this)">
                                <span class="font-bold text-xs text-gray-700"><%= cat.name %></span>
                                <form action="/admin/delete-category" method="POST" class="inline m-0 p-0 ml-1" onsubmit="event.stopPropagation(); return confirm('Delete directory?');">
                                    <input type="hidden" name="category_name" value="<%= cat.name %>">
                                    <button type="submit" class="text-gray-400 hover:text-red-500 font-black">✕</button>
                                </form>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">
                    <h2 class="text-lg font-black text-gray-800 uppercase tracking-wider mb-4 border-b border-gray-100 pb-3">Communications</h2>
                    <div class="flex flex-col gap-3 max-h-[300px] overflow-y-auto pr-2">
                        <% if (announcements && announcements.length > 0) { %>
                            <% announcements.forEach(ann => { %>
                                <div class="bg-gray-50 border border-gray-200 p-4 rounded-xl flex justify-between items-center">
                                    <div class="truncate pr-4">
                                        <p class="font-black text-sm text-gray-900 truncate"><%= ann.title %></p>
                                        <p class="text-[10px] font-bold text-gray-500 mt-1 uppercase tracking-wider">Target: <%= ann.category %></p>
                                    </div>
                                    <div class="flex gap-2">
                                        <button type="button" 
                                            data-id="<%= ann.id %>" data-title="<%= ann.title %>" data-category="<%= ann.category %>"
                                            data-img1="<%= ann.image1 %>" data-img2="<%= ann.image2 %>" data-content="<%= ann.content %>"
                                            onclick="openEditAnnModal(this)"
                                            class="bg-gray-200 text-gray-700 px-3 py-1.5 rounded-md text-xs font-black hover:bg-gray-300 transition">Edit</button>
                                        <form action="/admin/delete-announcement" method="POST" class="inline" onsubmit="return confirm('Delete record?');">
                                            <input type="hidden" name="id" value="<%= ann.id %>">
                                            <button type="submit" class="bg-red-50 text-red-600 px-3 py-1.5 rounded-md text-xs font-black hover:bg-red-100 transition">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-xs font-bold text-gray-400 py-2">No communications found.</p>
                        <% } %>
                    </div>
                </div>

                <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-200">
                    <h2 class="text-lg font-black text-gray-800 uppercase tracking-wider mb-4 border-b border-gray-100 pb-3">Inventory</h2>
                    <div class="flex flex-col gap-3 max-h-[400px] overflow-y-auto pr-2">
                        <% if (products && products.length > 0) { %>
                            <% products.forEach(product => { %>
                                <div class="bg-gray-50 border border-gray-200 p-4 rounded-xl flex justify-between items-center">
                                    <div class="truncate pr-4">
                                        <p class="font-black text-sm text-gray-900 truncate"><%= product.title %></p>
                                        <p class="text-[10px] font-bold text-gray-500 mt-1 uppercase tracking-wider">
                                            <%= product.category %> | $<%= product.price %> | <%= product.tier %>
                                        </p>
                                    </div>
                                    <div class="flex gap-2">
                                        <button type="button" 
                                            data-id="<%= product.id %>" data-title="<%= product.title %>" data-category="<%= product.category %>"
                                            data-price="<%= product.price %>" data-tier="<%= product.tier %>" data-platform="<%= product.platform %>"
                                            data-image="<%= product.image_url %>" data-desc="<%= product.description %>"
                                            onclick="openEditPostModal(this)"
                                            class="bg-gray-200 text-gray-700 px-3 py-1.5 rounded-md text-xs font-black hover:bg-gray-300 transition">Edit</button>
                                        <form action="/admin/delete-product" method="POST" class="inline" onsubmit="return confirm('Delete record?');">
                                            <input type="hidden" name="id" value="<%= product.id %>">
                                            <button type="submit" class="bg-red-50 text-red-600 px-3 py-1.5 rounded-md text-xs font-black hover:bg-red-100 transition">Delete</button>
                                        </form>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-xs font-bold text-gray-400 py-2">No inventory found.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="space-y-6 lg:row-span-2 lg:col-start-3 lg:row-start-1">
                <div class="bg-gray-900 rounded-2xl p-6 shadow-xl border border-gray-800 text-white">
                    <h2 class="text-lg font-black mb-4 flex items-center gap-2 uppercase tracking-wider border-b border-gray-800 pb-3">
                        <span class="w-2 h-2 bg-[#10b981] rounded-full animate-pulse"></span> Network Orders
                    </h2>
                    <div class="space-y-3 max-h-[800px] overflow-y-auto pr-2">
                        <% if (orders && orders.length > 0) { %>
                            <% orders.forEach(order => { %>
                                <div class="bg-gray-800 p-4 rounded-xl border border-gray-700 relative">
                                    <div class="flex justify-between items-start mb-2">
                                        <span class="text-[10px] font-black bg-gray-700 text-gray-300 px-2 py-0.5 rounded uppercase">ID: <%= order.order_id %></span>
                                        <form action="/admin/close-order" method="POST" class="inline">
                                            <input type="hidden" name="order_id" value="<%= order.order_id %>">
                                            <button type="submit" class="text-[10px] text-gray-400 hover:text-white font-black transition">Close</button>
                                        </form>
                                    </div>
                                    <p class="text-xs font-bold text-gray-300 truncate mb-1">Client: <%= order.email %></p>
                                    
                                    <div class="flex justify-between items-center mb-3 mt-3">
                                        <p class="text-xs font-bold text-gray-400 truncate w-2/3"><%= order.product_title %></p>
                                        <p class="text-sm font-black text-[#10b981]">$<%= Number(order.product_price || 0).toFixed(2) %></p>
                                    </div>
                                    <div class="bg-gray-900 border border-gray-700 p-2 rounded-md text-center">
                                        <p class="text-[9px] font-black uppercase text-gray-500 mb-1">Status</p>
                                        <p class="text-xs font-black <%= order.status === 'Pending Payment' ? 'text-yellow-500' : 'text-[#10b981]' %>"><%= order.status %></p>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <p class="text-xs font-bold text-gray-500 text-center py-6">No active queries.</p>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <div id="casinoContainer" class="mt-12 rounded-3xl p-6 md:p-8 shadow-2xl border-2 transition-colors duration-300 casino-dark relative mb-10">
            
            <div class="absolute top-4 right-4 z-20 flex gap-3">
                <button onclick="toggleTheme()" class="text-muted hover:text-white transition focus:outline-none" title="Toggle Theme">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path></svg>
                </button>
            </div>

            <div class="mb-8">
                <div class="flex items-center gap-3 mb-1">
                    <svg viewBox="0 0 128 128" width="24" height="24" xmlns="http://www.w3.org/2000/svg"><path fill="#10b981" d="M21.5 98.4l15.9-27.4h74.5L96 98.4H21.5z"/><path fill="#34d399" d="M21.5 29.6l15.9 27.4h74.5L96 29.6H21.5z"/><path fill="#059669" d="M96 64H21.5l15.9 27.5H112L96 64z"/></svg>
                    <h2 class="text-2xl font-black uppercase tracking-tight">Admin Lounge</h2>
                </div>
                <div class="flex items-center gap-1">
                    <span class="text-[10px] font-bold text-[#10b981] uppercase tracking-[0.2em]">Secured by Rainbet API</span>
                    <span onclick="setRig()" class="cursor-default opacity-0 hover:opacity-100 text-[10px] text-[#10b981]">.</span>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
                <div class="lg:col-span-4 flex flex-col gap-4">
                    <div class="casino-panel border rounded-2xl p-5 cursor-pointer select-none relative overflow-hidden transition-all" ondblclick="openCustomModal('wallet')">
                        <div class="relative z-10">
                            <div class="flex justify-between items-center mb-3">
                                <p class="text-[10px] font-black text-[#10b981] uppercase tracking-widest">Financials</p>
                                <div class="flex items-center gap-1.5">
                                    <span class="w-1.5 h-1.5 bg-[#10b981] rounded-full animate-pulse"></span>
                                    <p class="text-[9px] text-muted font-bold uppercase tracking-wider">Live Oracle</p>
                                </div>
                            </div>
                            <div id="balanceAnimAnchor" class="relative">
                                <h3 class="text-3xl font-black mb-1 tracking-tight"><span id="solDisplay">5.0000</span> <span class="text-base text-muted font-bold">SOL</span></h3>
                            </div>
                            <p class="text-xs font-bold text-[#10b981]">≈ $<span id="usdDisplay">0.00</span> USD</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-2">
                        <button onclick="openCustomModal('history')" class="casino-panel casino-btn border font-black py-3 rounded-xl text-[10px] uppercase tracking-wider transition shadow-sm">History</button>
                        <button onclick="openCustomModal('withdraw')" class="bg-[#10b981] hover:bg-[#059669] text-white font-black py-3 rounded-xl text-[10px] uppercase tracking-wider transition shadow-sm">Withdraw</button>
                    </div>

                    <div class="casino-panel border rounded-2xl p-5 mt-2">
                        <label class="block text-[10px] font-black text-muted uppercase tracking-wider mb-3">Contract Size (USD)</label>
                        <div class="flex gap-2">
                            <span class="casino-input font-black px-4 py-3 rounded-xl border flex items-center justify-center text-sm">$</span>
                            <input type="number" id="betAmountUsd" value="10" min="1" class="w-full casino-input border rounded-xl px-4 py-3 font-black outline-none focus:border-[#10b981] transition text-sm">
                        </div>
                        <p class="text-[10px] text-muted font-bold mt-3 text-right">Debit ≈ <span id="betAmountSol">0.00</span> SOL</p>
                    </div>
                </div>

                <div class="lg:col-span-8 flex flex-col relative gap-0 casino-panel border rounded-2xl overflow-hidden">
                    
                    <div class="flex border-b border-gray-500/20 overflow-x-auto custom-scrollbar bg-black/10">
                        <button onclick="selectGame('blackjack', this)" class="casino-tab active">Blackjack</button>
                        <button onclick="selectGame('highlow', this)" class="casino-tab">High/Low</button>
                        <button onclick="selectGame('dragontiger', this)" class="casino-tab">Dragon Tiger</button>
                        <button onclick="selectGame('casinowar', this)" class="casino-tab">Casino War</button>
                        <button onclick="selectGame('baccarat', this)" class="casino-tab">Baccarat</button>
                        <button onclick="selectGame('videopoker', this)" class="casino-tab">Video Poker</button>
                    </div>

                    <div id="activeGameHeader" class="w-full flex justify-between items-center px-6 py-4 border-b border-gray-500/10">
                        <h3 id="activeGameTitle" class="text-sm font-black uppercase tracking-widest text-[#10b981]">Blackjack</h3>
                        <button onclick="showTutorial()" class="text-muted hover:text-white transition focus:outline-none" title="Rules">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        </button>
                    </div>

                    <div id="gameArea" class="flex-grow flex flex-col items-center justify-center p-6 min-h-[350px]">
                        </div>

                </div>
            </div>
        </div>

    </div>

    <div id="customUIModal" class="hidden fixed inset-0 z-50 bg-black/70 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
        <div class="casino-dark border border-[#10b981] p-6 md:p-8 rounded-2xl max-w-sm w-full shadow-2xl transform scale-95 transition-transform duration-300" id="customUIBox">
            <div class="flex justify-between items-center mb-4">
                <h3 id="uiModalTitle" class="text-sm font-black uppercase tracking-widest text-[#10b981]">Notification</h3>
                <button onclick="closeCustomModal()" class="text-gray-500 hover:text-white transition">✕</button>
            </div>
            <div id="uiModalContent" class="text-sm font-bold text-gray-300 mb-6 whitespace-pre-line leading-relaxed"></div>
            
            <div id="uiModalActions" class="flex gap-2"></div>
        </div>
    </div>

    <div id="createAnnModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white p-6 md:p-8 rounded-2xl w-full max-w-2xl shadow-2xl my-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-black text-2xl text-gray-900">Post Announcement</h2>
                <button onclick="document.getElementById('createAnnModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 bg-gray-100 p-2 rounded-full">✕</button>
            </div>
            <form action="/admin/add-announcement" method="POST" class="space-y-4">
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Headline</label>
                    <input type="text" name="title" required placeholder="New Update..." class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Display in Directory (or All)</label>
                    <select name="category" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm appearance-none">
                        <option value="All">All Pages (Global Announcement)</option>
                        <% categories.forEach(cat => { %> <option value="<%= cat.name %>"><%= cat.name %> Only</option> <% }) %>
                    </select>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Image 1 URL</label>
                        <input type="url" name="image1" placeholder="https://..." class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm">
                    </div>
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Image 2 URL (Optional)</label>
                        <input type="url" name="image2" placeholder="https://..." class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Content</label>
                    <textarea name="content" required rows="6" placeholder="Write your announcement here..." class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-blue-500 resize-none text-sm"></textarea>
                </div>
                <div class="flex justify-end gap-2 mt-4 pt-4 border-t border-gray-100">
                    <button type="button" onclick="document.getElementById('createAnnModal').classList.add('hidden')" class="text-gray-500 font-bold px-4 py-2 hover:bg-gray-100 rounded-lg">Cancel</button>
                    <button type="submit" class="bg-gray-900 text-white font-black px-6 py-2 rounded-lg shadow-sm hover:bg-black transition">Publish</button>
                </div>
            </form>
        </div>
    </div>

    <div id="editAnnModal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm flex justify-center items-center z-50 p-4 overflow-y-auto">
        <div class="bg-white p-6 md:p-8 rounded-2xl w-full max-w-2xl shadow-2xl my-8">
            <div class="flex justify-between items-center mb-6">
                <h2 class="font-black text-2xl text-gray-900">Edit Announcement</h2>
                <button onclick="document.getElementById('editAnnModal').classList.add('hidden')" class="text-gray-400 hover:text-gray-600 bg-gray-100 p-2 rounded-full">✕</button>
            </div>
            <form action="/admin/edit-announcement" method="POST" class="space-y-4">
                <input type="hidden" name="id" id="editAnnId">
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Headline</label>
                    <input type="text" name="title" id="editAnnTitle" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-gray-500 text-sm">
                </div>
                <div>
                    <label class="block text-sm font-black mb-1 text-gray-600">Directory</label>
                    <select name="category" id="editAnnCategory" required class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-gray-500 text-sm appearance-none">
                        <option value="All">All Pages</option>
                        <% categories.forEach(cat => { %> <option value="<%= cat.name %>"><%= cat.name %> Only</option> <% }) %>
                    </select>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-black mb-1 text-gray-600">Image 1 URL</label>
                        <input type="url" name="image1" id="editAnnImg1" class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-3 font-bold outline-none focus:border-gray-500 text-sm">
                    </div>
                    <div>
