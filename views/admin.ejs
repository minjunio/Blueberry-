            if (!seoDesc.value) seoDesc.value = `Complete guide to passing proctored exams with ${productTitle}. Real results, zero detection. Setup instructions included.`;
            if (!seoKeywords.value) seoKeywords.value = `${keywordList.join(', ')}, ${productTitle.toLowerCase().replace(/\s+/g, ' ')}, exam bypass tool`;
            
            const btns = document.querySelectorAll('.template-btn');
            if (btns.length) {
                const btn = btns[0];
                const oldHTML = btn.innerHTML;
                btn.innerHTML = '✅ Full Article Generated';
                btn.style.background = 'linear-gradient(135deg, #16a34a, #4ade80)';
                setTimeout(() => {
                    if (btn) {
                        btn.innerHTML = oldHTML;
                        btn.style.background = 'linear-gradient(135deg, #7c3aed, #a855f7)';
                    }
                }, 2100);
            }
            
            contentTextarea.scrollIntoView({ behavior: 'smooth', block: 'center' });
            contentTextarea.focus();
            contentTextarea.select();
        }

        // ========== JSON IMPORT FUNCTIONS ==========
        function showJsonImportBox() {
            const section = document.getElementById('jsonImportSection');
            if (section) {
                section.classList.remove('hidden');
                section.scrollIntoView({ behavior: 'smooth', block: 'center' });
                setTimeout(() => {
                    const ta = document.getElementById('jsonImportTextarea');
                    if (ta) ta.focus();
                }, 300);
            }
        }

        function hideJsonImportBox() {
            const section = document.getElementById('jsonImportSection');
            if (section) section.classList.add('hidden');
        }

        function loadExampleJson() {
            const textarea = document.getElementById('jsonImportTextarea');
            if (!textarea) return;

            const example = {
                "title": "How StealthAI v13 Helps You Pass Any Proctor Exam in 2026",
                "content": "## Introduction\n\n**Proctored exams** are becoming stricter every semester. Many students know the material but still struggle under pressure and constant monitoring.\n\n**StealthAI v13** gives you the edge you need. Built with advanced stealth technology and real-time multimodal AI, it helps you answer questions accurately while staying completely undetected.\n\n### Key Features\n- 100% undetectable on Honorlock, ProctorU, Respondus & more\n- Real-time AI question solving\n- Natural human-like cursor and typing behavior\n- Works on Windows, Mac, and Chromebook\n\n### How It Works\n1. Start your exam session\n2. The tool captures questions instantly\n3. AI returns correct answers in seconds\n4. Answers are entered using realistic human patterns\n\n**Pro Tip:** Use the smart paste and virtual clipboard to keep everything looking natural.\n\n### Real Results\nStudents report **94%+ pass rates** and zero detection across thousands of sessions.\n\n> \"I went from failing to top of my class. This changed everything for me.\" — Verified User\n\n### Getting Started\nPurchase your license, download the latest version, and join our Discord for live support.\n\nStop stressing over proctored exams. Take control of your success today.",
                "product_id": 42,
                "category_name": "Exam Tools",
                "seo_title": "StealthAI v13 Review 2026 — Best Undetectable Exam Bypass Tool",
                "seo_desc": "Learn how StealthAI v13 helps students pass proctored exams with zero detection. Full setup guide, features, and real results.",
                "seo_keywords": "stealthai, exam bypass, undetectable proctor, ai exam helper, honorlock bypass",
                "canonical_url": "",
                "og_image": "https://example.com/og-image.png"
            };

            textarea.value = JSON.stringify(example, null, 2);
        }

        function parseAndFillFromJson() {
            const textarea = document.getElementById('jsonImportTextarea');
            if (!textarea) return;

            let jsonData;
            try {
                jsonData = JSON.parse(textarea.value);
            } catch (e) {
                alert('❌ Invalid JSON. Please check your syntax and try again.\n\nError: ' + e.message);
                return;
            }

            if (jsonData.title) {
                const titleInput = document.querySelector('#createBlogForm input[name="title"]');
                if (titleInput) titleInput.value = jsonData.title;
            }

            if (jsonData.content) {
                const contentTa = document.getElementById('blogContentTextarea');
                if (contentTa) contentTa.value = jsonData.content;
            }

            if (jsonData.product_id) {
                const hiddenProd = document.getElementById('selectedProductId');
                const searchProd = document.getElementById('productSearchInput');
                if (hiddenProd) hiddenProd.value = jsonData.product_id;
                if (searchProd) searchProd.value = 'Product #' + jsonData.product_id + ' (from JSON)';
            }

            if (jsonData.category_name) {
                const hiddenCat = document.getElementById('selectedCategoryName');
                const searchCat = document.getElementById('categorySearchInput');
                if (hiddenCat) hiddenCat.value = jsonData.category_name;
                if (searchCat) searchCat.value = jsonData.category_name;
            }

            const seoFields = {
                'seo_title': 'seoTitleInput',
                'seo_desc': 'seoDescInput',
                'seo_keywords': 'seoKeywordsInput',
                'canonical_url': 'canonicalUrlInput',
                'og_image': 'ogImageInput'
            };

            Object.keys(seoFields).forEach(key => {
                if (jsonData[key]) {
                    const el = document.getElementById(seoFields[key]);
                    if (el) el.value = jsonData[key];
                }
            });

            alert('✅ JSON parsed successfully! All fields have been filled.\nYou can now review and publish the post.');
            hideJsonImportBox();

            const modalContent = document.querySelector('#createBlogPostModal .p-6');
            if (modalContent) modalContent.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
    </script>
</body>
</html>