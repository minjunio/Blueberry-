<!DOCTYPE html>
<html lang="en">
<head>
    <title>Secure Checkout - ExamHub</title>
    <%- include('partials/head') %>
</head>
<body class="antialiased flex items-center justify-center min-h-screen p-4 relative overflow-hidden bg-gray-50">
    <div class="cloud w-[400px] h-[400px] top-[-100px] left-[-100px] opacity-70 animate-float"></div>
    
    <div class="glass-card w-full max-w-xl p-6 md:p-8 relative z-10 shadow-2xl">
        
        <div class="flex justify-between items-center mb-6 pb-4 border-b-2 border-dashed border-gray-200">
            <div>
                <h1 class="text-2xl font-black text-anime-textMain">Secure Checkout</h1>
                <p class="text-sm font-bold text-gray-400">Order ID: <span class="text-anime-accent">#<%= order.order_id %></span></p>
            </div>
            <div class="px-3 py-1 bg-yellow-100 text-yellow-600 rounded-lg font-black text-xs uppercase tracking-wider animate-pulse">Awaiting Payment</div>
        </div>

        <div class="bg-gray-50 rounded-xl p-4 mb-6 border-2 border-gray-100">
            <h3 class="font-black text-gray-800"><%= order.product_title %></h3>
            <div class="flex gap-4 mt-2">
                <p class="text-xs font-bold text-gray-500">Tier: <span class="text-anime-accent"><%= order.tier %></span></p>
                <p class="text-xs font-bold text-gray-500">Method: <span class="text-anime-accent"><%= order.payment_method %></span></p>
            </div>
            <div class="mt-2 text-xs font-bold text-gray-400 truncate">Delivery to: <%= order.email %></div>
        </div>

        <% if (order.payment_method === 'Crypto') { %>
            <div class="bg-blue-50 border-2 border-blue-100 rounded-xl p-4 mb-6 relative">
                <div class="flex justify-between items-start mb-2">
                    <p class="text-xs font-black text-blue-600 uppercase">Need to buy Crypto?</p>
                    <button onclick="document.getElementById('cryptoTutorial').classList.remove('hidden')" class="text-[10px] bg-blue-600 text-white px-2 py-1 rounded shadow-sm font-black hover:scale-105 transition">📖 Learn How</button>
                </div>
                <p class="text-xs font-bold text-gray-600 mb-2">You can purchase crypto directly using a credit card / SSN via these trusted platforms:</p>
                <div class="flex gap-2">
                    <a href="https://www.moonpay.com/" target="_blank" class="bg-white text-blue-600 border border-blue-200 px-3 py-1.5 rounded-lg text-[11px] font-black hover:bg-blue-600 hover:text-white transition">MoonPay ↗</a>
                    <a href="https://www.bitpay.com/buy-crypto" target="_blank" class="bg-white text-blue-600 border border-blue-200 px-3 py-1.5 rounded-lg text-[11px] font-black hover:bg-blue-600 hover:text-white transition">BitPay ↗</a>
                </div>
            </div>

            <h3 class="font-black text-sm text-gray-500 uppercase tracking-wider mb-3">1. Select Currency to Send</h3>
            <div class="grid grid-cols-3 gap-2 mb-6">
                <button onclick="showCrypto('SOL', '7M27KDHbF1BtxEhghY6vWaXmbXyrsehSsWwxHtPYfSoJ')" class="crypto-btn bg-white border-2 border-gray-200 py-3 rounded-xl font-black text-gray-600 hover:border-anime-accent focus:border-anime-accent focus:bg-anime-skyLight transition">Solana (SOL)</button>
                <button onclick="showCrypto('BTC', '18MvG5FJ2a1CZLETt9bUpKPa33aLK9Qn5v')" class="crypto-btn bg-white border-2 border-gray-200 py-3 rounded-xl font-black text-gray-600 hover:border-anime-accent focus:border-anime-accent focus:bg-anime-skyLight transition">Bitcoin (BTC)</button>
                <button onclick="showCrypto('ETH', '0xD873A40dcA37dC2084E174007E30C71aC4463CD9')" class="crypto-btn bg-white border-2 border-gray-200 py-3 rounded-xl font-black text-gray-600 hover:border-anime-accent focus:border-anime-accent focus:bg-anime-skyLight transition">Ethereum (ETH)</button>
            </div>

            <div id="cryptoDetails" class="hidden flex-col items-center bg-gray-50 rounded-xl p-6 border-2 border-gray-100 mb-6">
                <img id="qrCode" src="" alt="QR Code" class="w-40 h-40 rounded-lg shadow-sm mb-4 border-4 border-white">
                <p class="text-xs font-black text-gray-400 uppercase tracking-wider mb-1">Send to this Address</p>
                <p id="cryptoAddress" class="font-bold text-sm text-anime-textMain break-all text-center bg-white px-4 py-2 rounded-lg border border-gray-200"></p>
            </div>

            <button onclick="confirmPayment('Crypto')" id="confirmBtn" class="w-full bg-[#00b67a] text-white font-black py-4 rounded-xl hover:scale-[1.02] transition shadow-md hidden">I have sent the Crypto ✓</button>

        <% } else { %>
            <% 
                let giftcardLink = "";
                if (order.tier === 'Standard') giftcardLink = "https://www.g2a.com/gift-me-crypto-gift-card-200-usd-giftmecrypto-key-global-i10000503347012";
                else if (order.tier === 'Pro') giftcardLink = "https://www.g2a.com/gift-me-crypto-gift-card-450-usd-giftmecrypto-key-global-i10000503347304";
                else if (order.tier === 'Premium') giftcardLink = "https://www.g2a.com/gift-me-crypto-gift-card-900-usd-giftmecrypto-key-global-i10000503347308";
            %>

            <div class="bg-[#ffebed] border-2 border-[#ffc2c8] rounded-xl p-5 mb-6 text-center">
                <p class="text-sm font-black text-[#e83e53] uppercase mb-2">Step 1: Purchase Giftcard</p>
                <p class="text-xs font-bold text-gray-600 mb-4">Click the link below to purchase the exact required giftcard for your tier.</p>
                <a href="<%= giftcardLink %>" target="_blank" class="inline-block bg-[#e83e53] text-white font-black px-6 py-3 rounded-xl shadow-sm hover:scale-105 transition">Buy G2A Giftcard ↗</a>
            </div>

            <div class="bg-gray-50 rounded-xl p-5 border-2 border-gray-100 mb-6">
                <p class="text-sm font-black text-gray-600 uppercase mb-3">Step 2: Submit Code</p>
                <input type="text" id="giftcardInput" placeholder="Enter the exact Giftcard Code here" class="w-full bg-white border-2 border-gray-200 rounded-xl px-4 py-3 font-bold outline-none focus:border-anime-accent text-sm mb-4">
                <button onclick="confirmPayment('Giftcard')" id="confirmBtn" class="w-full bg-[#00b67a] text-white font-black py-4 rounded-xl hover:scale-[1.02] transition shadow-md">Submit Code ✓</button>
            </div>
        <% } %>

        <div id="successMessage" class="hidden mt-6 bg-green-100 border-2 border-green-200 rounded-xl p-6 text-center">
            <h3 class="text-xl font-black text-green-700 mb-2">Successfully submitted and waiting for verification!</h3>
            <p class="text-sm font-bold text-green-600">Please leave this page open. Your order is now visible in our system. You will receive an email shortly with your delivery and tracking details.</p>
        </div>

    </div>

    <div id="cryptoTutorial" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex justify-center items-center p-4">
        <div class="bg-white w-full max-w-lg rounded-2xl p-6 md:p-8 shadow-2xl relative">
            <button onclick="document.getElementById('cryptoTutorial').classList.add('hidden')" class="absolute top-4 right-4 text-gray-400 hover:text-black font-black text-xl">×</button>
            
            <h2 class="text-2xl font-black text-anime-textMain mb-4">How to Buy & Send Crypto 💸</h2>
            
            <div class="space-y-4">
                <div class="bg-blue-50 p-4 rounded-xl border border-blue-100">
                    <h3 class="font-black text-blue-700 mb-1">Step 1: Buy Crypto</h3>
                    <p class="text-xs font-bold text-gray-600">Go to <a href="https://www.moonpay.com/" target="_blank" class="text-blue-500 underline">MoonPay</a> or <a href="https://www.bitpay.com/buy-crypto" target="_blank" class="text-blue-500 underline">BitPay</a>. Select the coin you want to buy (like Bitcoin or Solana). Enter the dollar amount you need for your Tier. You can pay using a credit card, Apple Pay, or bank transfer (SSN verification may be required).</p>
                </div>
                
                <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                    <h3 class="font-black text-gray-700 mb-1">Step 2: Copy the Address</h3>
                    <p class="text-xs font-bold text-gray-600">On this checkout page, click the button for the coin you just bought (e.g. Bitcoin). A long string of random letters and numbers will appear. <strong>Copy that exact address.</strong></p>
                </div>

                <div class="bg-green-50 p-4 rounded-xl border border-green-100">
                    <h3 class="font-black text-green-700 mb-1">Step 3: Paste and Send</h3>
                    <p class="text-xs font-bold text-gray-600">Go back to MoonPay/BitPay. It will ask "Where do you want to send your crypto?" <strong>Paste the address</strong> you copied into that box. Complete the transaction. Once done, click the green "I have sent the Crypto" button on this page!</p>
                </div>
            </div>
            
            <button onclick="document.getElementById('cryptoTutorial').classList.add('hidden')" class="w-full mt-6 bg-gray-800 text-white font-black py-3 rounded-xl hover:bg-black transition">Got it! Let's go.</button>
        </div>
    </div>

    <script>
        function showCrypto(type, address) {
            document.getElementById('cryptoDetails').classList.remove('hidden');
            document.getElementById('cryptoDetails').classList.add('flex');
            document.getElementById('confirmBtn').classList.remove('hidden');
            document.getElementById('cryptoAddress').innerText = address;
            document.getElementById('qrCode').src = `https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${address}`;
        }

        async function confirmPayment(type = 'Crypto') {
            const btn = document.getElementById('confirmBtn');
            const codeInput = document.getElementById('giftcardInput');
            let giftcardCode = null;

            if (type === 'Giftcard') {
                if (!codeInput.value) return alert("Please enter the giftcard code first.");
                giftcardCode = codeInput.value;
            }

            btn.innerText = 'Processing...';
            btn.disabled = true;

            // 1. Update DB live
            await fetch(`/api/order/<%= order.order_id %>/update`, {
                method: 'POST', headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ status: type === 'Giftcard' ? 'Code Submitted' : 'Crypto Sent', giftcard_code: giftcardCode })
            });

            // 2. Email Notification to Admin via Formsubmit with Email attached
            const formData = new FormData();
            formData.append('_subject', `New Payment Submitted - Order #<%= order.order_id %>`);
            formData.append('Order ID', '<%= order.order_id %>');
            formData.append('Email', '<%= order.email %>');
            formData.append('Discord User', '<%= order.discord_username || "Not Provided" %>');
            formData.append('Tier', '<%= order.tier %>');
            formData.append('Method', '<%= order.payment_method %>');
            if (giftcardCode) formData.append('Giftcard Code', giftcardCode);

            fetch('https://formsubmit.co/ajax/minjunnios@gmail.com', {
                method: 'POST', body: formData, headers: { 'Accept': 'application/json' }
            }).then(() => {
                if (type === 'Giftcard') codeInput.disabled = true;
                btn.classList.add('hidden');
                document.getElementById('successMessage').classList.remove('hidden');
            });
        }
    </script>
</body>
</html>
