<!DOCTYPE html>
<html lang="en">
<head>
  <title>Whitelist - ExamHub</title>
  <link rel="icon" type="image/png" href="/favicon.png">
  <%- include('partials/head') %>
</head>

<body class="p-4 md:p-8 bg-gray-50">
  <div class="max-w-7xl mx-auto relative z-10 mt-6">

    <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-4 border-b-2 border-gray-200 pb-6">
      <div>
        <h1 class="text-3xl md:text-4xl font-black text-anime-textMain">
          Machine Whitelist ✅
        </h1>
        <p class="text-sm font-bold text-gray-400 mt-2">
          Approve, edit, remove, import, and export verified machines.
        </p>
      </div>

      <div class="flex flex-wrap gap-2">
        <a href="/admin" class="bg-gray-800 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">
          ← Admin
        </a>

        <button type="button" id="downloadBtn" class="bg-green-600 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">
          Download JSON
        </button>

        <button type="button" id="uploadBtn" class="bg-yellow-500 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">
          Upload JSON
        </button>

        <button type="button" id="viewJsonBtn" class="bg-blue-600 text-white px-5 py-2 rounded-full font-black shadow-sm text-sm hover:scale-105 transition">
          View JSON
        </button>

        <input id="uploadFile" type="file" accept="application/json,.json" class="hidden">
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <div class="lg:col-span-2 bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
        <h2 class="text-xl md:text-2xl font-black text-gray-800 mb-4 border-b-2 border-dashed border-gray-200 pb-2">
          Add / Edit Key
        </h2>

        <form id="machineForm" class="space-y-4">
          <input type="hidden" id="editId">

          <div>
            <label for="keyName" class="block text-sm font-black mb-1 text-gray-600">
              Key Name
            </label>
            <input
              id="keyName"
              name="keyName"
              required
              autocomplete="off"
              class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm"
            >
          </div>

          <div>
            <label for="machineInput" class="block text-sm font-black mb-1 text-gray-600">
              Machine ID / Key
            </label>
            <input
              id="machineInput"
              name="machineInput"
              autocomplete="off"
              class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm"
            >
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
              <label for="hostname" class="block text-sm font-black mb-1 text-gray-600">
                Hostname
              </label>
              <input
                id="hostname"
                name="hostname"
                autocomplete="off"
                class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm"
              >
            </div>

            <div>
              <label for="status" class="block text-sm font-black mb-1 text-gray-600">
                Status
              </label>
              <select
                id="status"
                name="status"
                class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm"
              >
                <option value="active">active</option>
                <option value="pending">pending</option>
                <option value="blocked">blocked</option>
                <option value="expired">expired</option>
              </select>
            </div>
          </div>

          <div>
            <label for="expiresAt" class="block text-sm font-black mb-1 text-gray-600">
              Expire Date
            </label>
            <input
              id="expiresAt"
              name="expiresAt"
              type="datetime-local"
              class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm"
            >
          </div>

          <label class="flex items-center gap-2 text-sm font-black text-gray-600">
            <input id="forever" name="forever" type="checkbox" checked>
            Keep forever
          </label>

          <div>
            <label for="note" class="block text-sm font-black mb-1 text-gray-600">
              Note
            </label>
            <textarea
              id="note"
              name="note"
              rows="3"
              class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm resize-y"
            ></textarea>
          </div>

          <div class="flex flex-wrap gap-2">
            <button type="submit" class="bg-blue-600 text-white px-5 py-3 rounded-xl font-black shadow-sm text-sm hover:scale-105 transition">
              Save Key
            </button>

            <button type="button" id="clearBtn" class="bg-gray-800 text-white px-5 py-3 rounded-xl font-black shadow-sm text-sm hover:scale-105 transition">
              Clear
            </button>
          </div>
        </form>
      </div>

      <div class="space-y-4">
        <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
          <p class="text-sm font-black text-gray-400">Total Keys</p>
          <h3 id="totalMachines" class="text-4xl font-black text-gray-800 mt-2">0</h3>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
          <p class="text-sm font-black text-gray-400">Active</p>
          <h3 id="activeMachines" class="text-4xl font-black text-green-600 mt-2">0</h3>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
          <p class="text-sm font-black text-gray-400">Pending</p>
          <h3 id="pendingMachines" class="text-4xl font-black text-yellow-500 mt-2">0</h3>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
          <p class="text-sm font-black text-gray-400">Blocked / Expired</p>
          <h3 id="badMachines" class="text-4xl font-black text-red-500 mt-2">0</h3>
        </div>

        <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100">
          <label for="importMode" class="block text-sm font-black mb-1 text-gray-600">
            Upload Mode
          </label>
          <select
            id="importMode"
            class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm"
          >
            <option value="merge">Merge with current list</option>
            <option value="replace">Replace current list</option>
          </select>
        </div>
      </div>
    </div>

    <div class="bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100 mt-6">
      <h2 class="text-xl md:text-2xl font-black text-gray-800 mb-4 border-b-2 border-dashed border-gray-200 pb-2">
        Current Keys
      </h2>

      <input
        id="searchBox"
        autocomplete="off"
        class="w-full bg-gray-50 border-2 border-gray-100 rounded-xl px-4 py-3 font-bold outline-none focus:border-blue-500 text-sm mb-4"
      >

      <div class="overflow-x-auto">
        <table class="w-full min-w-[1050px]">
          <thead>
            <tr class="text-left text-xs uppercase tracking-widest text-gray-400 border-b-2 border-gray-100">
              <th class="p-3">Key</th>
              <th class="p-3">Status</th>
              <th class="p-3">Expiry</th>
              <th class="p-3">Last Seen</th>
              <th class="p-3">Location</th>
              <th class="p-3">Session Token</th>
              <th class="p-3">Actions</th>
            </tr>
          </thead>

          <tbody id="machinesTable">
            <tr>
              <td colspan="7" class="p-4 text-sm font-bold text-gray-400">
                Loading...
              </td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div id="jsonCard" class="hidden bg-white rounded-3xl p-6 shadow-sm border-2 border-gray-100 mt-6">
      <h2 class="text-xl md:text-2xl font-black text-gray-800 mb-4 border-b-2 border-dashed border-gray-200 pb-2">
        Stored JSON
      </h2>

      <pre id="jsonViewer" class="bg-gray-900 text-green-300 rounded-2xl p-4 text-xs overflow-x-auto max-h-[500px]">Loading...</pre>
    </div>

  </div>

  <script src="/js/admin-whitelist.js"></script>
</body>
</html>