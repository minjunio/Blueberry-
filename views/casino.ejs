            else { body.classList.add('hidden'); chev.style.transform = 'rotate(-90deg)'; }
        }

        function updateWalletUI() {
            let mainUsd = 0;
            let html = '';
            for (let coin in balances.main) {
                if (balances.main[coin] > 0) {
                    let valUsd = balances.main[coin] * prices[coin];
                    mainUsd += valUsd;
                    html += `
                        <div class="flex justify-between items-center bg-black/30 p-2.5 rounded-xl border border-gray-500/20 hover:bg-black/40 transition">
                            <div class="flex items-center gap-2">
                                ${cryptoIcons[coin]}
                                <span class="text-white font-black tracking-widest text-[11px]">${coin}</span> 
                            </div>
                            <div class="text-right">
                                <span class="text-white block font-bold text-xs">${balances.main[coin].toFixed(coin==='USDT'||coin==='XRP'||coin==='DOGE'?2:4)}</span>
