<!DOCTYPE html>
<html lang="en">
<head>
    <title>Rainbet API - ExamHub</title>
    <link rel="icon" type="image/png" href="/favicon.png">
    <%- include('partials/head') %>
    <style>
        /* Professional Protocol Theme */
        body { transition: background-color 0.3s, color 0.3s; }
        .casino-dark { background: #06090e; color: #f8fafc; }
        .casino-dark .casino-panel { background: #0d131f; border-color: #1f2937; box-shadow: 0 15px 35px rgba(0,0,0,0.6); }
        .casino-dark .casino-input { background: #06090e; border-color: #1f2937; color: white; }
        .casino-dark .casino-btn { background: #1f2937; border-color: #374151; color: white; }
        .casino-dark .casino-btn:hover { background: #374151; }
        .casino-dark .text-muted { color: #6b7280; }
        .casino-dark .win-glow { box-shadow: inset 0 0 40px rgba(0, 255, 170, 0.05), 0 0 20px rgba(0, 255, 170, 0.1); border-color: rgba(0, 255, 170, 0.3); }
        .casino-dark .lose-glow { box-shadow: inset 0 0 40px rgba(239, 68, 68, 0.05), 0 0 20px rgba(239, 68, 68, 0.1); border-color: rgba(239, 68, 68, 0.3); }

        /* Game Selector Grid */
        .game-card { border: 1px solid transparent; transition: all 0.2s; cursor: pointer; }
        .casino-dark .game-card { background: #151e32; border-color: #1f2937; }
        .game-card:hover { transform: translateY(-3px); }
        .game-card.active { border-color: #00ffaa; box-shadow: 0 0 15px rgba(0, 255, 170, 0.2); }

        /* High-Fidelity Cards */
        .playing-card {
            width: 70px; height: 105px; background: white; border-radius: 6px; border: 1px solid #cbd5e1;
            display: flex; justify-content: center; align-items: center; font-weight: 900; font-size: 1.8rem;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.3); position: relative; flex-shrink: 0; cursor: default;
            color: #111827; transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            font-family: "Times New Roman", Times, serif; 
        }
        .card-red { color: #ef4444 !important; }
        .card-suit-top { position: absolute; top: 4px; left: 5px; font-size: 0.8rem; line-height: 1; text-align: center; }
        .card-suit-bottom { position: absolute; bottom: 4px; right: 5px; font-size: 0.8rem; transform: rotate(180deg); line-height: 1; text-align: center; }
        .card-hidden { background: #1f2937; border-color: #374151; background-image: repeating-linear-gradient(45deg, #111827 25%, transparent 25%, transparent 75%, #111827 75%, #111827), repeating-linear-gradient(45deg, #111827 25%, #1f2937 25%, #1f2937 75%, #111827 75%, #111827); background-size: 16px 16px; }

        /* Arcade Games CSS */
        .mines-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; max-width: 300px; width: 100%; margin: 0 auto; }
        .mine-tile { aspect-ratio: 1; border-radius: 8px; cursor: pointer; transition: all 0.2s; display: flex; justify-content: center; align-items: center; background: #1f2937; border: 1px solid #374151; box-shadow: inset 0 -3px 0 rgba(0,0,0,0.3); }
        .mine-tile:hover:not(.revealed) { transform: scale(1.05); filter: brightness(1.2); }
        .mine-tile.revealed { box-shadow: none; transform: scale(0.95); cursor: default; }
        .mine-tile.safe { background: rgba(0, 255, 170, 0.1) !important; border-color: #00ffaa !important; }
        .mine-tile.bomb { background: rgba(239, 68, 68, 0.1) !important; border-color: #ef4444 !important; }

        .tower-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 8px; max-width: 250px; width: 100%; margin-left: auto; margin-right: auto; }
        .tower-tile { height: 40px; border-radius: 6px; transition: all 0.2s; display: flex; justify-content: center; align-items: center; opacity: 0.5; background: #1f2937; border: 1px solid #374151; }
        .tower-row.active .tower-tile { opacity: 1; cursor: pointer; }
        .tower-row.active .tower-tile:hover { filter: brightness(1.3); }
        .tower-tile.safe { background: #00ffaa !important; color: #000; border: none; }
        .tower-tile.bomb { background: #ef4444 !important; color: #fff; border: none; }

        .vault-tile { aspect-ratio: 1; border-radius: 12px; background: #1f2937; border: 2px solid #374151; display: flex; justify-content: center; align-items: center; cursor: pointer; transition: all 0.3s; }
        .vault-tile:hover:not(.opened) { border-color: #00ffaa; transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0, 255, 170, 0.1); }
        .vault-tile.opened { transform: scale(0.95); cursor: default; }
        .vault-tile.opened.win { background: rgba(0, 255, 170, 0.1); border-color: #00ffaa; }
        .vault-tile.opened.lose { background: rgba(239, 68, 68, 0.1); border-color: #ef4444; }

        /* Animations */
        @keyframes floatMoneyTable { 0% { transform: translate(-50%, 0) scale(0.5); opacity: 0; } 20% { transform: translate(-50%, -20px) scale(1.2); opacity: 1; } 100% { transform: translate(-50%, -100px) scale(1); opacity: 0; } }
        .anim-money-table { animation: floatMoneyTable 2.5s ease-out forwards; position: absolute; left: 50%; top: 40%; font-weight: 900; font-size: 2rem; pointer-events: none; z-index: 100; text-shadow: 0 4px 10px rgba(0,0,0,0.5); }
        
        .balance-flash-green { animation: flashGreen 1s ease-out; }
        .balance-flash-red { animation: flashRed 1s ease-out; }
        @keyframes flashGreen { 0% { color: #00ffaa; } 100% { color: inherit; } }
        @keyframes flashRed { 0% { color: #ef4444; } 100% { color: inherit; } }
        @keyframes fadeOutTable { 0% { opacity: 1; } 100% { opacity: 0; transform: scale(0.95); } }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
    </style>
</head>
<body id="casinoBody" class="p-3 md:p-6 casino-dark min-h-screen">
    
    <div class="max-w-[1400px] mx-auto relative z-10">
        
        <div class="flex flex-wrap justify-between items-center mb-6 gap-4">
