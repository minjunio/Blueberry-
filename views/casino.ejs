    <script>
        // --- UTILITIES & STATE ---
        const sleep = ms => new Promise(res => setTimeout(res, ms));
        
        // Persistent Data Logic
        let savedMain = JSON.parse(localStorage.getItem('rainbetMainWallet')) || { BTC: 0, ETH: 0, USDT: 0, SOL: 0, XRP: 0, DOGE: 0, LTC: 0 };
        let dbRainbetSol = parseFloat('<%= user ? user.sol_balance : 0 %>') || 0; // Pulls direct from DB so it NEVER resets
        
        let balances = {
            main: savedMain,
            rainbet: { SOL: dbRainbetSol } 
        };
        let prices = { BTC: 65000, ETH: 3500, USDT: 1, SOL: 150, XRP: 0.6, DOGE: 0.15, LTC: 80 };
        
        // Professional SVG Icons Dictionary
        const cryptoIcons = {
            BTC: `<svg viewBox="0 0 32 32" class="w-5 h-5"><circle cx="16" cy="16" r="16" fill="#F7931A"/><path d="M22 14.3c-.2-1.4-1.2-2.3-2.9-2.7l.6-2.4-1.5-.4-.6 2.3c-.4-.1-.8-.2-1.2-.3l.6-2.3-1.5-.4-.6 2.4c-.3-.1-.7-.2-1-.2L12.5 10l-.3 1.2s.8.2.8.2c.5.1.5.5.5.7l-1 3.9c.1 0 .2 0 .2.1-.1 0-.1-.1-.2-.1l-1.4 5.6c-.1.2-.3.3-.6.2 0 0-.8-.2-.8-.2l-.5 1.3 1.9.5c.4.1.8.2 1.1.3l-.6 2.5 1.5.4.6-2.4c.4.1.8.2 1.2.3l-.6 2.4 1.5.4.6-2.6c2.1.4 3.6.2 4.1-1.7.4-1.5-.1-2.4-1.1-2.9 1-.2 1.6-.9 1.8-2.1zM18.1 20c-.3 1.3-2.6.6-3.3.4l.9-3.6c.7.2 2.7.5 2.4 3.2zM18.8 14.8c-.3 1.1-2.1.6-2.6.4l.8-3.2c.6.1 2.1.4 1.8 2.8z" fill="#FFF"/></svg>`,
            ETH: `<svg viewBox="0 0 32 32" class="w-5 h-5"><circle cx="16" cy="16" r="16" fill="#627EEA"/><path d="M16 4l-6.8 11.3L16 19.3l6.8-4L16 4zM16 21l-6.8-4L16 28l6.8-11L16 21z" fill="#FFF" opacity="0.6"/><path d="M16 4L9.2 15.3 16 19.3V4zM16 21L9.2 17 16 28v-7z" fill="#FFF"/></svg>`,
            USDT: `<svg viewBox="0 0 32 32" class="w-5 h-5"><circle cx="16" cy="16" r="16" fill="#26A17B"/><path d="M17.5 10.7V8.5h4.6V6H9.9v2.5h4.6v2.2c-3.6.2-6.5 1.1-6.5 2.3 0 1.1 2.9 2 6.5 2.3v7.3h3V15.2c3.6-.2 6.5-1.1 6.5-2.3 0-1.2-2.9-2.1-6.5-2.3zm-1.5 3c-2.8 0-5.2-.6-5.2-1.4 0-.7 2.4-1.4 5.2-1.4s5.2.6 5.2 1.4c0 .8-2.4 1.4-5.2 1.4z" fill="#FFF"/></svg>`,
            SOL: `<svg viewBox="0 0 128 128" class="w-5 h-5"><path fill="#00FFA3" d="M21.5 98.4l15.9-27.4h74.5L96 98.4H21.5z"/><path fill="#03E1FF" d="M21.5 29.6l15.9 27.4h74.5L96 29.6H21.5z"/><path fill="#DC1FFF" d="M96 64H21.5l15.9 27.5H112L96 64z"/></svg>`,
            XRP: `<svg viewBox="0 0 32 32" class="w-5 h-5"><circle cx="16" cy="16" r="16" fill="#23292F"/><path d="M25.7 10.2l-2.4-2.4-7.3 7.3-7.3-7.3-2.4 2.4 7.3 7.3-7.3 7.3 2.4 2.4 7.3-7.3 7.3 7.3 2.4-2.4-7.3-7.3 7.3-7.3z" fill="#FFF"/></svg>`,
            DOGE: `<svg viewBox="0 0 32 32" class="w-5 h-5"><circle cx="16" cy="16" r="16" fill="#C2A633"/><path d="M11 9.5h3.5c4 0 6.5 2.5 6.5 6.5s-2.5 6.5-6.5 6.5H11V9.5zm3.5 10c2.5 0 4-1.5 4-3.5s-1.5-3.5-4-3.5h-1v7h1z" fill="#FFF"/></svg>`,
            LTC: `<svg viewBox="0 0 32 32" class="w-5 h-5"><circle cx="16" cy="16" r="16" fill="#BFBBBB"/><path d="M10.8 17.5l1.6-6.4 2.6-.6-1.3 5h3.4l-.8 3h-3.4l-1.3 5.4H19l-.8 3H7.5l2.2-8.8-2.1.5.8-3 2.2-.6z" fill="#FFF"/></svg>`
        };
        
        let currentBetSol = 0;
        let winRigPercentage = -1;
        let isGameActive = false;
        let resetTimeout;

        function saveMainWallet() { localStorage.setItem('rainbetMainWallet', JSON.stringify(balances.main)); }

        // --- LIVE ORACLE ---
        async function fetchPrices() {
            try {
                const res = await fetch('https://api.binance.com/api/v3/ticker/price');
                const data = await res.json();
                data.forEach(t => {
                    if(t.symbol === 'BTCUSDT') prices.BTC = parseFloat(t.price);
                    if(t.symbol === 'ETHUSDT') prices.ETH = parseFloat(t.price);
                    if(t.symbol === 'SOLUSDT') prices.SOL = parseFloat(t.price);
                    if(t.symbol === 'XRPUSDT') prices.XRP = parseFloat(t.price);
                    if(t.symbol === 'DOGEUSDT') prices.DOGE = parseFloat(t.price);
                    if(t.symbol === 'LTCUSDT') prices.LTC = parseFloat(t.price);
                });
                updateWalletUI();
            } catch (e) {}
        }
        setInterval(fetchPrices, 15000); fetchPrices();

        // --- WALLET UI ---
