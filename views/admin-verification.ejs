<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Verification Admin</title>

  <style>
    :root {
      --bg: #080b12;
      --panel: #111827;
      --panel2: #182235;
      --border: #263247;
      --text: #f8fafc;
      --muted: #94a3b8;
      --blue: #5865f2;
      --blue2: #4752c4;
      --red: #ef4444;
      --green: #22c55e;
      --yellow: #eab308;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      background: radial-gradient(circle at top, #172036 0%, #080b12 48%, #03050a 100%);
      color: var(--text);
      font-family: Arial, sans-serif;
    }

    .page {
      width: min(1350px, 100%);
      margin: auto;
      padding: 28px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 14px;
      margin-bottom: 20px;
    }

    h1 {
      margin: 0;
      font-size: 30px;
    }

    .sub {
      color: var(--muted);
      margin-top: 8px;
    }

    .top-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .card {
      background: rgba(17, 24, 39, 0.96);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,.25);
    }

    .grid {
      display: grid;
      grid-template-columns: 1.35fr .9fr;
      gap: 20px;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    label {
      display: block;
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 7px;
    }

    input,
    select,
    textarea {
      width: 100%;
      background: #080b12;
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 10px;
      padding: 11px;
      outline: none;
      margin-bottom: 14px;
    }

    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--blue);
    }

    textarea {
      min-height: 78px;
      resize: vertical;
    }

    button {
      border: 0;
      border-radius: 10px;
      padding: 11px 14px;
      font-weight: 800;
      color: white;
      background: var(--blue);
      cursor: pointer;
    }

    button:hover {
      background: var(--blue2);
    }

    button.gray {
      background: #334155;
    }

    button.red {
      background: var(--red);
    }

    button.green {
      background: var(--green);
    }

    button.yellow {
      background: var(--yellow);
      color: #111827;
    }

    .row {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .row input[type="checkbox"] {
      width: auto;
      margin: 0;
    }

    .stats {
      display: grid;
      gap: 12px;
    }

    .stat {
      background: var(--panel2);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
    }

    .stat-number {
      font-size: 28px;
      font-weight: 900;
    }

    .stat-label {
      color: var(--muted);
      margin-top: 4px;
      font-size: 13px;
    }

    .table-wrap {
      overflow-x: auto;
    }

    table {
      width: 100%;
      min-width: 1050px;
      border-collapse: collapse;
    }

    th,
    td {
      text-align: left;
      padding: 13px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
      font-size: 14px;
    }

    th {
      color: var(--muted);
      background: #0c111d;
    }

    code {
      background: #080b12;
      border: 1px solid var(--border);
      padding: 4px 7px;
      border-radius: 8px;
      word-break: break-all;
      display: inline-block;
      max-width: 330px;
    }

    .small {
      color: var(--muted);
      font-size: 12px;
      margin-top: 5px;
    }

    .status-active {
      color: #4ade80;
      font-weight: 900;
    }

    .status-pending {
      color: #facc15;
      font-weight: 900;
    }

    .status-blocked,
    .status-expired {
      color: #f87171;
      font-weight: 900;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .hidden {
      display: none;
    }

    pre {
      background: #05070c;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
      overflow: auto;
      max-height: 420px;
      color: #dbeafe;
    }

    @media (max-width: 900px) {
      .header,
      .grid,
      .form-grid {
        display: grid;
        grid-template-columns: 1fr;
      }

      .top-actions {
        justify-content: flex-start;
      }
    }
  </style>
</head>

<body>
  <div class="page">
    <div class="header">
      <div>
        <h1>Verification Admin</h1>
        <div class="sub">Add, edit, approve, remove, export, and import machine keys.</div>
      </div>

      <div class="top-actions">
        <button class="green" id="downloadBtn">Download JSON</button>
        <button class="yellow" id="uploadBtn">Upload JSON</button>
        <button class="gray" id="viewJsonBtn">View JSON</button>
        <input class="hidden" type="file" id="uploadFile" accept="application/json,.json" />
      </div>
    </div>

    <input type="hidden" id="adminKey" value="<%= adminKey %>" />

    <div class="grid">
      <div class="card">
        <h2>Add / Edit Key</h2>

        <form id="machineForm">
          <input type="hidden" id="editId" />

          <label>Key Name</label>
          <input id="keyName" placeholder="Example: Brandon, Customer 001, Main PC" required />

          <label>Machine ID / Key</label>
          <input id="machineInput" placeholder="Paste raw MachineGuid or already-hashed machineId" />

          <div class="small">
            If you paste a raw ID, the server hashes it. If you paste a 64-character SHA-256 hash, it stores it directly.
          </div>

          <br />

          <div class="form-grid">
            <div>
              <label>Dashboard Display Key</label>
              <input id="displayKey" placeholder="What you want to see in the list" />
            </div>

            <div>
              <label>Hostname</label>
              <input id="hostname" placeholder="Example: DESKTOP-123" />
            </div>
          </div>

          <div class="form-grid">
            <div>
              <label>Status</label>
              <select id="status">
                <option value="active">active</option>
                <option value="pending">pending</option>
                <option value="blocked">blocked</option>
                <option value="expired">expired</option>
              </select>
            </div>

            <div>
              <label>Expire Date</label>
              <input id="expiresAt" type="datetime-local" />
            </div>
          </div>

          <div class="row" style="margin-bottom: 14px;">
            <input id="forever" type="checkbox" checked />
            <label for="forever" style="margin:0;">Keep forever</label>
          </div>

          <label>Note</label>
          <textarea id="note" placeholder="Notes about this key"></textarea>

          <div class="row">
            <button type="submit">Save Key</button>
            <button type="button" class="gray" id="clearBtn">Clear</button>
          </div>
        </form>
      </div>

      <div>
        <div class="stats">
          <div class="stat">
            <div class="stat-number" id="totalMachines">0</div>
            <div class="stat-label">Total Keys</div>
          </div>

          <div class="stat">
            <div class="stat-number" id="activeMachines">0</div>
            <div class="stat-label">Active</div>
          </div>

          <div class="stat">
            <div class="stat-number" id="pendingMachines">0</div>
            <div class="stat-label">Pending Approval</div>
          </div>

          <div class="stat">
            <div class="stat-number" id="badMachines">0</div>
            <div class="stat-label">Blocked / Expired</div>
          </div>
        </div>

        <div class="card">
          <h3>Upload Mode</h3>
          <select id="importMode">
            <option value="merge">Merge with current list</option>
            <option value="replace">Replace current list</option>
          </select>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Current Keys</h2>

      <input id="searchBox" placeholder="Search key name, display key, hostname, note, status..." />

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Key</th>
              <th>Status</th>
              <th>Expiry</th>
              <th>Last Seen</th>
              <th>Location</th>
              <th>Session Token</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody id="machinesTable">
            <tr>
              <td colspan="7">Loading...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card hidden" id="jsonCard">
      <h2>Stored JSON</h2>
      <pre id="jsonViewer">Loading...</pre>
    </div>
  </div>

  <script src="/js/admin-verification.js"></script>
</body>
</html>