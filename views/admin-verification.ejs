<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>Verification Admin</title>

  <style>
    :root {
      --bg: #080b12;
      --panel: #111827;
      --panel-soft: #151e31;
      --panel-strong: #0c111d;
      --border: #263247;
      --text: #f8fafc;
      --muted: #94a3b8;
      --blue: #5865f2;
      --blue-hover: #4752c4;
      --red: #ef4444;
      --red-hover: #dc2626;
      --green: #22c55e;
      --green-hover: #16a34a;
      --yellow: #eab308;
      --yellow-hover: #ca8a04;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at top, #172036 0%, #080b12 48%, #03050a 100%);
      color: var(--text);
      font-family: Arial, sans-serif;
    }

    .page {
      width: min(1350px, 100%);
      margin: 0 auto;
      padding: 28px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 18px;
      margin-bottom: 20px;
    }

    h1,
    h2,
    h3 {
      margin-top: 0;
    }

    h1 {
      margin-bottom: 6px;
      font-size: 30px;
      letter-spacing: -0.5px;
    }

    h2 {
      font-size: 21px;
      margin-bottom: 18px;
    }

    h3 {
      font-size: 17px;
      margin-bottom: 14px;
    }

    .sub {
      color: var(--muted);
      font-size: 14px;
    }

    .top-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .card {
      background: rgba(17, 24, 39, 0.96);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
    }

    .grid {
      display: grid;
      grid-template-columns: 1.35fr 0.9fr;
      gap: 20px;
      align-items: start;
    }

    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    label {
      display: block;
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 7px;
    }

    input,
    select,
    textarea {
      width: 100%;
      background: #080b12;
      border: 1px solid var(--border);
      color: var(--text);
      border-radius: 10px;
      padding: 11px;
      outline: none;
      margin-bottom: 14px;
      font-size: 14px;
    }

    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--blue);
    }

    textarea {
      min-height: 78px;
      resize: vertical;
    }

    button {
      border: 0;
      border-radius: 10px;
      padding: 11px 14px;
      font-weight: 800;
      color: #ffffff;
      background: var(--blue);
      cursor: pointer;
      font-size: 14px;
      white-space: nowrap;
    }

    button:hover {
      background: var(--blue-hover);
    }

    button.gray {
      background: #334155;
    }

    button.gray:hover {
      background: #475569;
    }

    button.red {
      background: var(--red);
    }

    button.red:hover {
      background: var(--red-hover);
    }

    button.green {
      background: var(--green);
    }

    button.green:hover {
      background: var(--green-hover);
    }

    button.yellow {
      background: var(--yellow);
      color: #111827;
    }

    button.yellow:hover {
      background: var(--yellow-hover);
    }

    .row {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
    }

    .row input[type="checkbox"] {
      width: auto;
      margin: 0;
    }

    .checkbox-label {
      margin: 0;
      color: var(--text);
    }

    .small {
      color: var(--muted);
      font-size: 12px;
      margin-top: 5px;
      line-height: 1.4;
    }

    .stats {
      display: grid;
      gap: 12px;
    }

    .stat {
      background: var(--panel-soft);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
    }

    .stat-number {
      font-size: 28px;
      font-weight: 900;
      line-height: 1;
    }

    .stat-label {
      color: var(--muted);
      margin-top: 6px;
      font-size: 13px;
    }

    .table-tools {
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 14px;
    }

    .table-tools input {
      margin-bottom: 0;
    }

    .table-wrap {
      overflow-x: auto;
      border: 1px solid var(--border);
      border-radius: 14px;
    }

    table {
      width: 100%;
      min-width: 1050px;
      border-collapse: collapse;
      background: rgba(8, 11, 18, 0.45);
    }

    th,
    td {
      text-align: left;
      padding: 13px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
      font-size: 14px;
    }

    tr:last-child td {
      border-bottom: 0;
    }

    th {
      color: var(--muted);
      background: var(--panel-strong);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    code {
      background: #080b12;
      border: 1px solid var(--border);
      padding: 4px 7px;
      border-radius: 8px;
      word-break: break-all;
      display: inline-block;
      max-width: 330px;
      color: #dbeafe;
    }

    .status-active {
      color: #4ade80;
      font-weight: 900;
    }

    .status-pending {
      color: #facc15;
      font-weight: 900;
    }

    .status-blocked,
    .status-expired {
      color: #f87171;
      font-weight: 900;
    }

    .actions {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
    }

    .hidden {
      display: none;
    }

    pre {
      background: #05070c;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 16px;
      overflow: auto;
      max-height: 420px;
      color: #dbeafe;
      font-size: 13px;
      line-height: 1.45;
    }

    .import-card select {
      margin-bottom: 0;
    }

    @media (max-width: 900px) {
      .page {
        padding: 18px;
      }

      .header {
        display: grid;
        grid-template-columns: 1fr;
      }

      .top-actions {
        justify-content: flex-start;
      }

      .grid,
      .form-grid {
        grid-template-columns: 1fr;
      }

      table {
        min-width: 980px;
      }
    }
  </style>
</head>

<body>
  <div class="page">
    <div class="header">
      <div>
        <h1>Verification Admin</h1>
        <div class="sub">Add, approve, edit, remove, export, and import machine keys.</div>
      </div>

      <div class="top-actions">
        <button type="button" class="green" id="downloadBtn">Download JSON</button>
        <button type="button" class="yellow" id="uploadBtn">Upload JSON</button>
        <button type="button" class="gray" id="viewJsonBtn">View JSON</button>
        <input class="hidden" type="file" id="uploadFile" accept="application/json,.json" />
      </div>
    </div>

    <input type="hidden" id="adminKey" value="<%= adminKey %>" />

    <div class="grid">
      <div class="card">
        <h2>Add / Edit Key</h2>

        <form id="machineForm">
          <input type="hidden" id="editId" />

          <label for="keyName">Key Name</label>
          <input id="keyName" name="keyName" required autocomplete="off" />

          <label for="machineInput">Machine ID / Key</label>
          <input id="machineInput" name="machineInput" autocomplete="off" />

          <div class="form-grid">
            <div>
              <label for="hostname">Hostname</label>
              <input id="hostname" name="hostname" autocomplete="off" />
            </div>

            <div>
              <label for="status">Status</label>
              <select id="status" name="status">
                <option value="active">active</option>
                <option value="pending">pending</option>
                <option value="blocked">blocked</option>
                <option value="expired">expired</option>
              </select>
            </div>
          </div>

          <label for="expiresAt">Expire Date</label>
          <input id="expiresAt" name="expiresAt" type="datetime-local" />

          <div class="row" style="margin-bottom: 14px;">
            <input id="forever" name="forever" type="checkbox" checked />
            <label for="forever" class="checkbox-label">Keep forever</label>
          </div>

          <label for="note">Note</label>
          <textarea id="note" name="note"></textarea>

          <div class="row">
            <button type="submit">Save Key</button>
            <button type="button" class="gray" id="clearBtn">Clear</button>
          </div>
        </form>
      </div>

      <div>
        <div class="stats">
          <div class="stat">
            <div class="stat-number" id="totalMachines">0</div>
            <div class="stat-label">Total Keys</div>
          </div>

          <div class="stat">
            <div class="stat-number" id="activeMachines">0</div>
            <div class="stat-label">Active</div>
          </div>

          <div class="stat">
            <div class="stat-number" id="pendingMachines">0</div>
            <div class="stat-label">Pending Approval</div>
          </div>

          <div class="stat">
            <div class="stat-number" id="badMachines">0</div>
            <div class="stat-label">Blocked / Expired</div>
          </div>
        </div>

        <div class="card import-card">
          <h3>Upload Mode</h3>
          <select id="importMode">
            <option value="merge">Merge with current list</option>
            <option value="replace">Replace current list</option>
          </select>
        </div>
      </div>
    </div>

    <div class="card">
      <h2>Current Keys</h2>

      <div class="table-tools">
        <input id="searchBox" autocomplete="off" />
      </div>

      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Key</th>
              <th>Status</th>
              <th>Expiry</th>
              <th>Last Seen</th>
              <th>Location</th>
              <th>Session Token</th>
              <th>Actions</th>
            </tr>
          </thead>

          <tbody id="machinesTable">
            <tr>
              <td colspan="7">Loading...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <div class="card hidden" id="jsonCard">
      <h2>Stored JSON</h2>
      <pre id="jsonViewer">Loading...</pre>
    </div>
  </div>

  <script src="/js/admin-verification.js"></script>
</body>
</html>